---
interface Props {
  activePage?: string;
  hideBanner?: boolean;
}
const { activePage = '', hideBanner = false } = Astro.props;
---
<nav class:list={["nav-wrap", "fixed", "left-0", "right-0", "z-50", { "no-banner": hideBanner }]} style={hideBanner ? "top:0" : "top:40px"}>
  <div class="max-w-7xl mx-auto px-5 h-16 flex items-center justify-between gap-4">
    <a href="/" class="flex-shrink-0 focus-visible:outline-none">
      <img src="/Brand%20Assets/Happy Roof Logo.png" alt="Happy Roof" class="h-14 w-auto" />
    </a>
    <div class="hidden md:flex items-center gap-6">
      <a href="/" class:list={["nav-link", { active: activePage === "home" }]}>Home</a>
      <a href="/services" class:list={["nav-link", { active: activePage === "services" }]}>Services</a>
      <a href="/finance" class:list={["nav-link", { active: activePage === "finance" }]}>Financing</a>
      <a href="/referrals" class:list={["nav-link", { active: activePage === "referrals" }]}>Referrals</a>
      <a href="/about" class:list={["nav-link", { active: activePage === "about" }]}>About</a>
      <a href="/contact" class:list={["nav-link", { active: activePage === "contact" }]}>Contact</a>
    </div>
    <div class="flex items-center gap-3">
      <a href="tel:8135957663" class="hidden sm:block font-display font-bold text-brand-blue hover:text-brand-blueLight transition-colors call-tracking-number" style="font-size:1rem;letter-spacing:.02em;">(813) 595-7663</a>
      <a href="/contact" class="btn-p" style="font-size:.9rem;padding:.65rem 1.3rem;">Free Estimate</a>
      <button onclick="document.getElementById('mobile-menu').classList.toggle('open')" class="md:hidden flex flex-col gap-1.5 p-2 focus-visible:outline-none" aria-label="Menu">
        <span class="w-5 h-0.5 block" style="background:#1A1A1A"></span>
        <span class="w-5 h-0.5 block" style="background:#1A1A1A"></span>
        <span class="w-5 h-0.5 block" style="background:#1A1A1A"></span>
      </button>
    </div>
  </div>
  <!-- Mobile menu -->
  <div id="mobile-menu" class="md:hidden flex-col border-t border-brand-border px-5 pb-5 gap-1" style="background:#FFFFFF">
    <a href="/" class="nav-link py-3 border-b block" style="border-color:#E0E0E0">Home</a>
    <a href="/services" class="nav-link py-3 border-b block" style="border-color:#E0E0E0">Services</a>
    <a href="/finance" class="nav-link py-3 border-b block" style="border-color:#E0E0E0">Financing</a>
    <a href="/referrals" class="nav-link py-3 border-b block" style="border-color:#E0E0E0">Referrals</a>
    <a href="/about" class="nav-link py-3 border-b block" style="border-color:#E0E0E0">About</a>
    <a href="/contact" class="nav-link py-3 block">Contact</a>
  </div>
</nav>
