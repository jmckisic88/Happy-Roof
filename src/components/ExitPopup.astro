<!-- Exit-Intent Popup -->
<div id="exit-popup" style="display:none;position:fixed;inset:0;z-index:99999;background:rgba(0,0,0,.6);backdrop-filter:blur(4px);align-items:center;justify-content:center">
  <div style="background:#fff;border-radius:16px;max-width:440px;width:calc(100% - 2rem);padding:2.5rem;text-align:center;box-shadow:0 32px 64px rgba(0,0,0,.3);position:relative">
    <button onclick="document.getElementById('exit-popup').style.display='none'" style="position:absolute;top:12px;right:12px;background:none;border:none;font-size:1.5rem;color:#999;cursor:pointer;line-height:1">&times;</button>
    <h3 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.75rem;color:#1A1A1A;margin:0 0 .5rem;letter-spacing:-.01em">WAIT — DON'T LEAVE YET.</h3>
    <p style="font-family:'Nunito',sans-serif;color:#555;font-size:.95rem;line-height:1.6;margin:0 0 1.5rem">Get a <strong>free roof estimate</strong> with no obligation. We'll respond within 24 hours.</p>
    <div style="display:flex;flex-direction:column;gap:.75rem;margin-bottom:1rem">
      <a href="/contact" style="display:inline-block;background:#E6A817;color:#fff;font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.1rem;padding:.85rem 2rem;border-radius:10px;text-decoration:none;text-align:center">Get My Free Estimate</a>
      <a href="tel:8135957663" class="call-tracking-number" style="display:inline-block;background:#3B9FD9;color:#fff;font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1rem;padding:.75rem 2rem;border-radius:10px;text-decoration:none;text-align:center">Call (813) 595-7663</a>
    </div>
    <p style="font-size:.75rem;color:#999;margin:0">FL License #CCC1337380 · Licensed &amp; Insured</p>
  </div>
</div>
<script>
(function(){
  if(sessionStorage.getItem('hr_exit_shown'))return;
  if(window.innerWidth<768)return;
  document.addEventListener('mouseout',function(e){
    if(e.clientY<5&&!sessionStorage.getItem('hr_exit_shown')){
      document.getElementById('exit-popup').style.display='flex';
      sessionStorage.setItem('hr_exit_shown','1');
    }
  });
  document.getElementById('exit-popup').addEventListener('click',function(e){
    if(e.target===this)this.style.display='none';
  });
})();
</script>
