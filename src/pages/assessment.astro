---
import BaseLayout from '../layouts/BaseLayout.astro';

const schema = `{
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Happy Roof Assessment & Visualizer",
  "description": "Free roof assessment tool and AI-powered roof visualizer for Tampa Bay homeowners. See what your home looks like with a new roof.",
  "url": "https://happyroof.com/assessment",
  "applicationCategory": "HomeImprovement",
  "operatingSystem": "Web",
  "provider": {
    "@type": "RoofingContractor",
    "name": "Happy Roof LLC",
    "telephone": "+1-813-595-7663",
    "address": { "@type": "PostalAddress", "addressLocality": "Oldsmar", "addressRegion": "FL", "postalCode": "34677" }
  },
  "dateModified": "2026-04-17"
}`;
---

<BaseLayout
  title="Free Roof Assessment & Visualizer | Happy Roof"
  description="Take our free roof assessment to see if your roof needs attention. Then visualize your home with a brand new roof using our AI-powered tool. No contact info required."
  canonical="https://happyroof.com/assessment"
  ogTitle="Do You Need a New Roof? Free Assessment | Happy Roof"
  ogDescription="Take a 60-second roof assessment and see what your home looks like with a new roof. AI-powered visualizer, no contact info needed."
  activePage="assessment"
  schema={schema}
>

<style is:inline>
  /* Assessment styles */
  .assess-step { display: none }
  .assess-step.active { display: block }
  .assess-option { background: #FFFFFF; border: 2px solid #E0E0E0; border-radius: 14px; padding: 1.25rem; cursor: pointer; transition: border-color .2s, transform .2s cubic-bezier(.34,1.56,.64,1), box-shadow .2s; text-align: center }
  .assess-option:hover { border-color: rgba(230,168,23,.4); transform: translateY(-3px) }
  .assess-option.selected { border-color: #E6A817; background: rgba(230,168,23,.04); box-shadow: 0 0 0 3px rgba(230,168,23,.15) }
  .assess-option input { display: none }
  .assess-check { background: #FFFFFF; border: 2px solid #E0E0E0; border-radius: 12px; padding: 1rem 1.25rem; cursor: pointer; transition: border-color .2s; display: flex; align-items: center; gap: .75rem }
  .assess-check:hover { border-color: rgba(230,168,23,.4) }
  .assess-check.selected { border-color: #E6A817; background: rgba(230,168,23,.04) }
  .assess-check input { display: none }
  .assess-checkbox { width: 22px; height: 22px; border-radius: 6px; border: 2px solid #CCC; display: flex; align-items: center; justify-content: center; flex-shrink: 0; transition: background .15s, border-color .15s }
  .assess-check.selected .assess-checkbox { background: #E6A817; border-color: #E6A817 }
  .assess-progress { height: 4px; background: #E0E0E0; border-radius: 100px; overflow: hidden; margin-bottom: 2rem }
  .assess-progress-fill { height: 100%; background: #E6A817; border-radius: 100px; transition: width .4s cubic-bezier(.34,1.56,.64,1) }
  .assess-nav { display: flex; gap: .75rem; justify-content: flex-end; margin-top: 2rem }

  /* Result styles */
  .result-card { border-radius: 20px; padding: 2.5rem; text-align: center }
  .result-urgent { background: linear-gradient(135deg, rgba(220,38,38,.08), rgba(220,38,38,.03)); border: 2px solid rgba(220,38,38,.2) }
  .result-soon { background: linear-gradient(135deg, rgba(230,168,23,.08), rgba(230,168,23,.03)); border: 2px solid rgba(230,168,23,.2) }
  .result-maintain { background: linear-gradient(135deg, rgba(59,159,217,.08), rgba(59,159,217,.03)); border: 2px solid rgba(59,159,217,.2) }
  .result-good { background: linear-gradient(135deg, rgba(34,197,94,.08), rgba(34,197,94,.03)); border: 2px solid rgba(34,197,94,.2) }

  /* Visualizer styles */
  .viz-style-option { background: #FFFFFF; border: 2px solid #E0E0E0; border-radius: 12px; padding: 1rem; cursor: pointer; transition: border-color .2s, transform .15s; text-align: center }
  .viz-style-option:hover { border-color: rgba(230,168,23,.4); transform: translateY(-2px) }
  .viz-style-option.selected { border-color: #E6A817; box-shadow: 0 0 0 3px rgba(230,168,23,.15) }
  .viz-color-dot { width: 32px; height: 32px; border-radius: 50%; cursor: pointer; border: 3px solid transparent; transition: border-color .15s, transform .15s }
  .viz-color-dot:hover { transform: scale(1.15) }
  .viz-color-dot.selected { border-color: #E6A817; box-shadow: 0 0 0 3px rgba(230,168,23,.2) }
  .viz-loading { display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 300px }
  .viz-spinner { width: 40px; height: 40px; border: 3px solid #E0E0E0; border-top-color: #E6A817; border-radius: 50%; animation: spin .8s linear infinite }
  @keyframes spin { to { transform: rotate(360deg) } }

  /* Scrollable color row */
  .color-row { display: flex; gap: .5rem; flex-wrap: wrap; justify-content: center }

  @media (max-width: 767px) {
    .assess-option { padding: 1rem; font-size: .88rem }
    .result-card { padding: 1.5rem }
  }
</style>

<!-- ══════ HERO ══════ -->
<section class="relative overflow-hidden" style="background:#F5F5F5;padding:7rem 0 4rem">
  <div class="hero-photo-bg" style="background-image:url('/Brand%20Assets/Photos/4055F5E2-0A81-4BAC-A34D-586DC69AFF69_1_105_c.jpeg')"></div>
  <div class="hero-photo-overlay"></div>
  <div class="relative z-10 max-w-3xl mx-auto px-5 text-center">
    <p class="sl gp mb-4">Free Roof Assessment</p>
    <h1 class="font-display font-black tracking-tightest mb-5" style="font-family:'Barlow Condensed',sans-serif;font-size:clamp(2.5rem,6vw,4.5rem);line-height:.88;letter-spacing:-.01em;color:#1A1A1A">
      DOES YOUR ROOF<br/>NEED ATTENTION<span style="color:#E6A817">?</span>
    </h1>
    <p style="color:#555;font-size:1.05rem;line-height:1.75;max-width:520px;margin:0 auto 1rem">
      Answer a few quick questions to find out. Then see what your home looks like with a brand new roof using our AI-powered visualizer.
    </p>
    <p style="color:#888;font-size:.85rem;font-weight:600;letter-spacing:.04em">No contact information required.</p>
  </div>
</section>

<!-- Trust bar -->
<div style="background:#F7F7F7;border-top:1px solid #E0E0E0;border-bottom:1px solid #E0E0E0;padding:1rem 0">
  <div class="max-w-5xl mx-auto px-5">
    <div style="display:flex;flex-wrap:wrap;align-items:center;justify-content:center;gap:1.5rem 2.5rem">
      <div style="display:flex;align-items:center;gap:.4rem"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#E6A817" stroke-width="2"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg><span style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:.78rem;color:#1A1A1A;letter-spacing:.02em">5.0 STAR RATED</span></div>
      <div style="display:flex;align-items:center;gap:.4rem"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#3B9FD9" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg><span style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:.78rem;color:#1A1A1A;letter-spacing:.02em">60-SECOND QUIZ</span></div>
      <div style="display:flex;align-items:center;gap:.4rem"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#E6A817" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg><span style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:.78rem;color:#1A1A1A;letter-spacing:.02em">100% FREE</span></div>
      <div style="display:flex;align-items:center;gap:.4rem"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#3B9FD9" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg><span style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:.78rem;color:#1A1A1A;letter-spacing:.02em">NO CONTACT INFO NEEDED</span></div>
    </div>
  </div>
</div>

<!-- ══════ TAB NAVIGATION ══════ -->
<div style="background:#FFFFFF;border-bottom:2px solid #E0E0E0;padding:0">
  <div class="max-w-2xl mx-auto px-5" style="display:flex">
    <button id="tab-quiz" onclick="switchTab('quiz')" style="flex:1;padding:1rem;font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.05rem;letter-spacing:.04em;color:#E6A817;border:none;background:transparent;border-bottom:3px solid #E6A817;cursor:pointer;transition:color .15s">ROOF ASSESSMENT</button>
    <button id="tab-viz" onclick="switchTab('viz')" style="flex:1;padding:1rem;font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.05rem;letter-spacing:.04em;color:#888;border:none;background:transparent;border-bottom:3px solid transparent;cursor:pointer;transition:color .15s">ROOF VISUALIZER</button>
  </div>
</div>

<!-- ══════ ASSESSMENT QUIZ ══════ -->
<section id="quiz" class="py-16" style="background:#FFFFFF">
  <div class="max-w-2xl mx-auto px-5">
    <!-- Progress bar -->
    <div class="assess-progress"><div id="progress-fill" class="assess-progress-fill" style="width:0%"></div></div>

    <!-- Step 1: Roof Age -->
    <div id="step-1" class="assess-step active" data-step="1">
      <p class="sl gp mb-2">Question 1 of 7</p>
      <h2 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.5rem;color:#1A1A1A;margin-bottom:1.5rem">HOW OLD IS YOUR CURRENT ROOF?</h2>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:.75rem">
        <label class="assess-option" onclick="selectOption(this,1)"><input type="radio" name="q1" value="0-5" data-score="0"/><p style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.1rem">0-5 Years</p><p style="color:#888;font-size:.78rem;margin-top:.25rem">Relatively new</p></label>
        <label class="assess-option" onclick="selectOption(this,1)"><input type="radio" name="q1" value="5-10" data-score="1"/><p style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.1rem">5-10 Years</p><p style="color:#888;font-size:.78rem;margin-top:.25rem">Mid-life</p></label>
        <label class="assess-option" onclick="selectOption(this,1)"><input type="radio" name="q1" value="10-15" data-score="2"/><p style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.1rem">10-15 Years</p><p style="color:#888;font-size:.78rem;margin-top:.25rem">Aging</p></label>
        <label class="assess-option" onclick="selectOption(this,1)"><input type="radio" name="q1" value="15-20" data-score="3"/><p style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.1rem">15-20 Years</p><p style="color:#888;font-size:.78rem;margin-top:.25rem">Near end of life</p></label>
        <label class="assess-option" onclick="selectOption(this,1)"><input type="radio" name="q1" value="20+" data-score="4"/><p style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.1rem">20+ Years</p><p style="color:#888;font-size:.78rem;margin-top:.25rem">Past typical lifespan</p></label>
      </div>
    </div>

    <!-- Step 2: Current Material -->
    <div id="step-2" class="assess-step" data-step="2">
      <p class="sl gp mb-2">Question 2 of 7</p>
      <h2 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.5rem;color:#1A1A1A;margin-bottom:1.5rem">WHAT TYPE OF ROOF DO YOU HAVE?</h2>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:.75rem">
        <label class="assess-option" onclick="selectOption(this,2)"><input type="radio" name="q2" value="shingle" data-score="2"/><p style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.1rem">Shingle</p><p style="color:#888;font-size:.78rem;margin-top:.25rem">Most common</p></label>
        <label class="assess-option" onclick="selectOption(this,2)"><input type="radio" name="q2" value="metal" data-score="0"/><p style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.1rem">Metal</p><p style="color:#888;font-size:.78rem;margin-top:.25rem">Long-lasting</p></label>
        <label class="assess-option" onclick="selectOption(this,2)"><input type="radio" name="q2" value="tile" data-score="1"/><p style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.1rem">Tile</p><p style="color:#888;font-size:.78rem;margin-top:.25rem">Clay or concrete</p></label>
        <label class="assess-option" onclick="selectOption(this,2)"><input type="radio" name="q2" value="flat" data-score="2"/><p style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.1rem">Flat / TPO</p><p style="color:#888;font-size:.78rem;margin-top:.25rem">Low-slope</p></label>
        <label class="assess-option" onclick="selectOption(this,2)"><input type="radio" name="q2" value="unsure" data-score="1"/><p style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.1rem">Not Sure</p><p style="color:#888;font-size:.78rem;margin-top:.25rem">We can help</p></label>
      </div>
    </div>

    <!-- Step 3: Visible Issues (multi-select) -->
    <div id="step-3" class="assess-step" data-step="3">
      <p class="sl gp mb-2">Question 3 of 7</p>
      <h2 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.5rem;color:#1A1A1A;margin-bottom:.5rem">HAVE YOU NOTICED ANY OF THESE?</h2>
      <p style="color:#888;font-size:.85rem;margin-bottom:1.5rem">Select all that apply</p>
      <div style="display:grid;gap:.5rem">
        <div class="assess-check" onclick="toggleCheck(this)"><input type="checkbox" name="q3" value="leaks" data-score="4"/><span class="assess-checkbox"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#FFF" stroke-width="3" style="display:none"><path d="m5 12 5 5L20 7"/></svg></span><span style="font-size:.92rem;color:#1A1A1A">Active leaks or water stains on ceilings</span></div>
        <div class="assess-check" onclick="toggleCheck(this)"><input type="checkbox" name="q3" value="missing" data-score="3"/><span class="assess-checkbox"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#FFF" stroke-width="3" style="display:none"><path d="m5 12 5 5L20 7"/></svg></span><span style="font-size:.92rem;color:#1A1A1A">Missing, cracked, or curling shingles</span></div>
        <div class="assess-check" onclick="toggleCheck(this)"><input type="checkbox" name="q3" value="sagging" data-score="4"/><span class="assess-checkbox"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#FFF" stroke-width="3" style="display:none"><path d="m5 12 5 5L20 7"/></svg></span><span style="font-size:.92rem;color:#1A1A1A">Roof is sagging or looks uneven</span></div>
        <div class="assess-check" onclick="toggleCheck(this)"><input type="checkbox" name="q3" value="granules" data-score="2"/><span class="assess-checkbox"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#FFF" stroke-width="3" style="display:none"><path d="m5 12 5 5L20 7"/></svg></span><span style="font-size:.92rem;color:#1A1A1A">Granules in gutters or downspouts</span></div>
        <div class="assess-check" onclick="toggleCheck(this)"><input type="checkbox" name="q3" value="daylight" data-score="3"/><span class="assess-checkbox"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#FFF" stroke-width="3" style="display:none"><path d="m5 12 5 5L20 7"/></svg></span><span style="font-size:.92rem;color:#1A1A1A">Daylight visible through attic</span></div>
        <div class="assess-check" onclick="toggleCheck(this)"><input type="checkbox" name="q3" value="storm" data-score="3"/><span class="assess-checkbox"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#FFF" stroke-width="3" style="display:none"><path d="m5 12 5 5L20 7"/></svg></span><span style="font-size:.92rem;color:#1A1A1A">Recent storm damage (wind, hail, debris)</span></div>
        <div class="assess-check" onclick="toggleCheck(this)"><input type="checkbox" name="q3" value="mold" data-score="2"/><span class="assess-checkbox"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#FFF" stroke-width="3" style="display:none"><path d="m5 12 5 5L20 7"/></svg></span><span style="font-size:.92rem;color:#1A1A1A">Mold, moss, or algae growth</span></div>
        <div class="assess-check" onclick="toggleCheck(this)"><input type="checkbox" name="q3" value="none" data-score="0"/><span class="assess-checkbox"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#FFF" stroke-width="3" style="display:none"><path d="m5 12 5 5L20 7"/></svg></span><span style="font-size:.92rem;color:#1A1A1A">None of the above</span></div>
      </div>
    </div>

    <!-- Step 4: Goal -->
    <div id="step-4" class="assess-step" data-step="4">
      <p class="sl gp mb-2">Question 4 of 7</p>
      <h2 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.5rem;color:#1A1A1A;margin-bottom:1.5rem">WHAT'S YOUR PRIMARY GOAL?</h2>
      <div style="display:grid;gap:.5rem">
        <label class="assess-option" onclick="selectOption(this,4)" style="text-align:left;display:flex;align-items:center;gap:1rem;padding:1.25rem"><input type="radio" name="q4" value="replace" data-score="3"/><div><p style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.05rem">Replace an aging roof</p><p style="color:#888;font-size:.78rem;margin-top:.15rem">My roof is old and needs to go</p></div></label>
        <label class="assess-option" onclick="selectOption(this,4)" style="text-align:left;display:flex;align-items:center;gap:1rem;padding:1.25rem"><input type="radio" name="q4" value="upgrade" data-score="2"/><div><p style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.05rem">Upgrade to a better material</p><p style="color:#888;font-size:.78rem;margin-top:.15rem">Switch from shingle to metal or tile</p></div></label>
        <label class="assess-option" onclick="selectOption(this,4)" style="text-align:left;display:flex;align-items:center;gap:1rem;padding:1.25rem"><input type="radio" name="q4" value="damage" data-score="3"/><div><p style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.05rem">Fix storm or leak damage</p><p style="color:#888;font-size:.78rem;margin-top:.15rem">Something is wrong and needs repair</p></div></label>
        <label class="assess-option" onclick="selectOption(this,4)" style="text-align:left;display:flex;align-items:center;gap:1rem;padding:1.25rem"><input type="radio" name="q4" value="insurance" data-score="2"/><div><p style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.05rem">Lower my insurance premiums</p><p style="color:#888;font-size:.78rem;margin-top:.15rem">A new roof could save me money</p></div></label>
        <label class="assess-option" onclick="selectOption(this,4)" style="text-align:left;display:flex;align-items:center;gap:1rem;padding:1.25rem"><input type="radio" name="q4" value="explore" data-score="0"/><div><p style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.05rem">Just exploring options</p><p style="color:#888;font-size:.78rem;margin-top:.15rem">Curious about what's available</p></div></label>
      </div>
    </div>

    <!-- Step 5: Storm prep -->
    <div id="step-5" class="assess-step" data-step="5">
      <p class="sl gp mb-2">Question 5 of 7</p>
      <h2 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.5rem;color:#1A1A1A;margin-bottom:1.5rem">ARE YOU PREPARING FOR HURRICANE SEASON?</h2>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:.75rem">
        <label class="assess-option" onclick="selectOption(this,5)"><input type="radio" name="q5" value="yes-urgent" data-score="3"/><p style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.1rem">Yes, it's urgent</p><p style="color:#888;font-size:.78rem;margin-top:.25rem">I need to act before storm season</p></label>
        <label class="assess-option" onclick="selectOption(this,5)"><input type="radio" name="q5" value="yes-planning" data-score="1"/><p style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.1rem">Yes, planning ahead</p><p style="color:#888;font-size:.78rem;margin-top:.25rem">Want to be proactive</p></label>
        <label class="assess-option" onclick="selectOption(this,5)"><input type="radio" name="q5" value="no" data-score="0"/><p style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.1rem">Not specifically</p><p style="color:#888;font-size:.78rem;margin-top:.25rem">Other reasons</p></label>
      </div>
    </div>

    <!-- Step 6: Insurance -->
    <div id="step-6" class="assess-step" data-step="6">
      <p class="sl gp mb-2">Question 6 of 7</p>
      <h2 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.5rem;color:#1A1A1A;margin-bottom:1.5rem">IS YOUR INSURANCE COMPANY REQUESTING A NEW ROOF?</h2>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:.75rem">
        <label class="assess-option" onclick="selectOption(this,6)"><input type="radio" name="q6" value="yes-required" data-score="4"/><p style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.1rem">Yes, required</p><p style="color:#888;font-size:.78rem;margin-top:.25rem">They'll drop my policy without one</p></label>
        <label class="assess-option" onclick="selectOption(this,6)"><input type="radio" name="q6" value="yes-recommended" data-score="2"/><p style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.1rem">Yes, recommended</p><p style="color:#888;font-size:.78rem;margin-top:.25rem">They suggested it for better rates</p></label>
        <label class="assess-option" onclick="selectOption(this,6)"><input type="radio" name="q6" value="no" data-score="0"/><p style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.1rem">No</p><p style="color:#888;font-size:.78rem;margin-top:.25rem">Not an insurance issue</p></label>
      </div>
    </div>

    <!-- Step 7: Homeowner -->
    <div id="step-7" class="assess-step" data-step="7">
      <p class="sl gp mb-2">Question 7 of 7</p>
      <h2 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.5rem;color:#1A1A1A;margin-bottom:1.5rem">ARE YOU THE HOMEOWNER?</h2>
