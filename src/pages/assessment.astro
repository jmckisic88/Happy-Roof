<script is:inline>
// ── Assessment Quiz Logic ──
var currentStep = 1;
var totalSteps = 7;

function selectOption(el, step) {
  el.closest('.assess-step').querySelectorAll('.assess-option').forEach(function(o) { o.classList.remove('selected'); });
  el.classList.add('selected');
  el.querySelector('input').checked = true;
  document.getElementById('btn-next').style.opacity = '1';
  document.getElementById('btn-next').style.pointerEvents = 'auto';
  // Auto-advance after a short delay
  setTimeout(function() { nextStep(); }, 400);
}

function toggleCheck(el) {
  var input = el.querySelector('input');
  var svg = el.querySelector('svg');
  el.classList.toggle('selected');
  input.checked = !input.checked;
  svg.style.display = input.checked ? 'block' : 'none';
  // If "none" is selected, deselect others
  if (input.value === 'none' && input.checked) {
    el.closest('.assess-step').querySelectorAll('.assess-check').forEach(function(c) {
      if (c !== el) { c.classList.remove('selected'); c.querySelector('input').checked = false; c.querySelector('svg').style.display = 'none'; }
    });
  } else if (input.value !== 'none' && input.checked) {
    var noneCheck = el.closest('.assess-step').querySelector('input[value="none"]');
    if (noneCheck && noneCheck.checked) { noneCheck.checked = false; noneCheck.closest('.assess-check').classList.remove('selected'); noneCheck.closest('.assess-check').querySelector('svg').style.display = 'none'; }
  }
  // Enable next button if any checked
  var anyChecked = el.closest('.assess-step').querySelectorAll('input:checked').length > 0;
  document.getElementById('btn-next').style.opacity = anyChecked ? '1' : '.4';
  document.getElementById('btn-next').style.pointerEvents = anyChecked ? 'auto' : 'none';
}

function nextStep() {
  if (currentStep >= totalSteps) { showResults(); return; }
  document.getElementById('step-' + currentStep).classList.remove('active');
  currentStep++;
  document.getElementById('step-' + currentStep).classList.add('active');
  updateProgress();
  document.getElementById('btn-back').style.display = 'inline-block';
  // Reset next button state
  var stepEl = document.getElementById('step-' + currentStep);
  var hasSelection = stepEl.querySelector('input:checked');
  document.getElementById('btn-next').style.opacity = hasSelection ? '1' : '.4';
  document.getElementById('btn-next').style.pointerEvents = hasSelection ? 'auto' : 'none';
  document.getElementById('btn-next').textContent = currentStep === totalSteps ? 'See Results' : 'Next →';
  window.scrollTo({ top: document.getElementById('quiz').offsetTop - 100, behavior: 'smooth' });
}

function prevStep() {
  if (currentStep <= 1) return;
  document.getElementById('step-' + currentStep).classList.remove('active');
  currentStep--;
  document.getElementById('step-' + currentStep).classList.add('active');
  updateProgress();
  if (currentStep === 1) document.getElementById('btn-back').style.display = 'none';
  document.getElementById('btn-next').style.opacity = '1';
  document.getElementById('btn-next').style.pointerEvents = 'auto';
  document.getElementById('btn-next').textContent = 'Next →';
}

function updateProgress() {
  var pct = ((currentStep - 1) / totalSteps) * 100;
  document.getElementById('progress-fill').style.width = pct + '%';
}

function showResults() {
  // Calculate score
  var score = 0;
  document.querySelectorAll('#quiz input:checked').forEach(function(input) {
    score += parseInt(input.getAttribute('data-score') || '0');
  });

  var result;
  if (score >= 10) {
    result = { level: 'urgent', title: 'YOUR ROOF NEEDS IMMEDIATE ATTENTION', color: '#dc2626', icon: '⚠️', class: 'result-urgent', desc: 'Based on your answers, your roof is showing serious warning signs. We strongly recommend scheduling a professional inspection as soon as possible to prevent further damage to your home.', tip: 'Don\'t wait. Water damage from a failing roof can lead to mold, structural issues, and significantly higher repair costs.' };
  } else if (score >= 6) {
    result = { level: 'soon', title: 'REPLACEMENT RECOMMENDED SOON', color: '#E6A817', icon: '🔶', class: 'result-soon', desc: 'Your roof is aging and showing some signs of wear. While it may not be an emergency today, planning for a replacement in the near future will save you money and protect your home.', tip: 'Getting ahead of a roof replacement lets you choose materials and timing on your terms, rather than being forced into an emergency repair.' };
  } else if (score >= 3) {
    result = { level: 'maintain', title: 'INSPECTION RECOMMENDED', color: '#3B9FD9', icon: '🔍', class: 'result-maintain', desc: 'Your roof appears to be in decent shape, but a professional inspection can catch issues that aren\'t visible from the ground. A small repair now can prevent a costly replacement later.', tip: 'Annual inspections are the best way to extend your roof\'s lifespan. Most homeowners in Tampa Bay should inspect after every major storm.' };
  } else {
    result = { level: 'good', title: 'YOUR ROOF LOOKS GOOD', color: '#22c55e', icon: '✅', class: 'result-good', desc: 'Based on your answers, your roof appears to be in good condition. Keep up with regular maintenance and inspections to maximize its lifespan.', tip: 'Even healthy roofs benefit from an inspection every few years, especially in Florida\'s harsh climate. It\'s free with Happy Roof.' };
  }

  var html = '<div class="result-card ' + result.class + '">';
  html += '<p style="font-size:2.5rem;margin-bottom:.5rem">' + result.icon + '</p>';
  html += '<h2 style="font-family:\'Barlow Condensed\',sans-serif;font-weight:900;font-size:clamp(1.5rem,3vw,2rem);color:' + result.color + ';margin-bottom:1rem">' + result.title + '</h2>';
  html += '<p style="color:#555;font-size:.95rem;line-height:1.75;margin-bottom:1.5rem">' + result.desc + '</p>';
  html += '<div style="background:rgba(0,0,0,.04);border-radius:10px;padding:1rem 1.25rem;text-align:left"><p style="font-family:\'Barlow Condensed\',sans-serif;font-weight:700;font-size:.85rem;color:#888;letter-spacing:.08em;text-transform:uppercase;margin-bottom:.35rem">Pro Tip</p><p style="color:#555;font-size:.88rem;line-height:1.65">' + result.tip + '</p></div>';
  html += '</div>';

  document.getElementById('result-container').innerHTML = html;
  document.getElementById('quiz').style.display = 'none';
  document.getElementById('results-section').style.display = 'block';
  document.getElementById('progress-fill').style.width = '100%';
  window.scrollTo({ top: document.getElementById('results-section').offsetTop - 80, behavior: 'smooth' });
}

// ── Tab Switching ──
function switchTab(tab) {
  var quizTab = document.getElementById('tab-quiz');
  var vizTab = document.getElementById('tab-viz');
  var quizSection = document.getElementById('quiz');
  var resultsSection = document.getElementById('results-section');
  var vizSection = document.getElementById('visualizer-section');

  if (tab === 'quiz') {
    quizTab.style.color = '#E6A817';
    quizTab.style.borderBottom = '3px solid #E6A817';
    vizTab.style.color = '#888';
    vizTab.style.borderBottom = '3px solid transparent';
    quizSection.style.display = 'block';
    if (document.getElementById('result-container').innerHTML) resultsSection.style.display = 'block';
    vizSection.style.display = 'none';
  } else {
    vizTab.style.color = '#E6A817';
    vizTab.style.borderBottom = '3px solid #E6A817';
    quizTab.style.color = '#888';
    quizTab.style.borderBottom = '3px solid transparent';
    quizSection.style.display = 'none';
    resultsSection.style.display = 'none';
    vizSection.style.display = 'block';
    window.scrollTo({ top: vizSection.offsetTop - 100, behavior: 'smooth' });
  }
}

// ── Cost Estimate Logic ──
var costRates = {
  'architectural shingle': 470,
  'standing seam metal': 690,
  'metal shaker': 690,
  'barrel tile': 810,
  'flat concrete tile': 810,
  'metal tile': 690
};

function updateCostEstimate() {
  var sqft = parseInt(document.getElementById('viz-sqft').value);
  document.getElementById('viz-sqft-display').textContent = sqft.toLocaleString();
  var rate = costRates[selectedStyle] || 470;
  var squares = (sqft * 1.3) / 100;
  var base = rate * squares;
  var low = Math.round((base * 1.1) / 100) * 100;
  var high = Math.round((base * 1.75) / 100) * 100;
  document.getElementById('viz-cost-value').textContent = '$' + low.toLocaleString() + ' - $' + high.toLocaleString();

  var styleLabels = {
    'architectural shingle': 'Architectural Shingle',
    'standing seam metal': 'Standing Seam Metal',
    'metal shaker': 'Metal Shake',
    'barrel tile': 'Barrel Tile',
    'flat concrete tile': 'Flat Concrete Tile',
    'metal tile': 'Metal Tile'
  };
  document.getElementById('viz-cost-label').textContent = (styleLabels[selectedStyle] || 'Shingle') + ' | ~' + sqft.toLocaleString() + ' sq ft';
}

// ── Roof Visualizer Logic ──
var selectedStyle = 'architectural shingle';
var selectedColor = 'onyx black';
var streetViewLoaded = false;
var uploadedImageData = null;

function selectStyle(el, style) {
  document.querySelectorAll('.viz-style-option').forEach(function(o) { o.classList.remove('selected'); });
  el.classList.add('selected');
  selectedStyle = style;
  if (document.getElementById('viz-cost').style.display !== 'none') updateCostEstimate();
}

function selectColor(el, color) {
  document.querySelectorAll('.viz-color-dot').forEach(function(d) { d.classList.remove('selected'); });
  el.classList.add('selected');
  selectedColor = color;
}

function handleFileUpload(input) {
  var file = input.files[0];
  if (!file) return;
  if (file.size > 10 * 1024 * 1024) { alert('Image must be under 10MB'); return; }

  var reader = new FileReader();
  reader.onload = function(e) {
    uploadedImageData = e.target.result;
    document.getElementById('viz-original').src = uploadedImageData;
    document.getElementById('viz-source-label').textContent = 'Your uploaded photo';
    document.getElementById('viz-streetview').style.display = 'block';
    document.getElementById('viz-style-picker').style.display = 'block';
    document.getElementById('viz-upload-area').style.display = 'none';
    streetViewLoaded = true;
  };
  reader.readAsDataURL(file);
}

function loadStreetView() {
  var address = document.getElementById('viz-address').value.trim();
  if (!address) { alert('Please enter your address'); return; }

  uploadedImageData = null;
  var apiKey = 'AIzaSyB2dfmJRH3YQvnnezQLGD2gBwbf0aJLAbU';
  var imgUrl = 'https://maps.googleapis.com/maps/api/streetview?size=800x500&location=' + encodeURIComponent(address) + '&key=' + apiKey + '&fov=90&pitch=15';

  document.getElementById('viz-original').src = imgUrl;
  document.getElementById('viz-source-label').textContent = 'Your home from Google Street View';
  document.getElementById('viz-streetview').style.display = 'block';
  document.getElementById('viz-style-picker').style.display = 'block';
  document.getElementById('viz-upload-area').style.display = 'none';
  streetViewLoaded = true;
}

function getGenerationCount() {
  try {
    var data = JSON.parse(localStorage.getItem('hr_viz_gens') || '{}');
    var now = Date.now();
    // Reset if older than 24 hours
    if (data.timestamp && (now - data.timestamp) > 86400000) {
      localStorage.removeItem('hr_viz_gens');
      return 0;
    }
    return data.count || 0;
  } catch(e) { return 0; }
}

function incrementGenerationCount() {
  try {
    var data = JSON.parse(localStorage.getItem('hr_viz_gens') || '{}');
    data.count = (data.count || 0) + 1;
    if (!data.timestamp) data.timestamp = Date.now();
    localStorage.setItem('hr_viz_gens', JSON.stringify(data));
  } catch(e) {}
}

function generateVisualization() {
  if (!streetViewLoaded) { alert('Please find your home first'); return; }

  // Rate limit: 3 per 24 hours
  var genCount = getGenerationCount();
  if (genCount >= 3) {
    var msg = document.getElementById('viz-limit-msg');
    msg.textContent = 'You\'ve used all 3 visualizations for today. Come back tomorrow or call us at (813) 595-7663 for a free in-person consultation.';
    msg.style.display = 'block';
    return;
  }

  var address = document.getElementById('viz-address').value.trim();
  var btn = document.getElementById('viz-generate-btn');
  var remaining = 2 - genCount;

  // Show loading
  document.getElementById('viz-loading').style.display = 'flex';
  document.getElementById('viz-result').style.display = 'none';
  document.getElementById('viz-style-picker').style.display = 'none';
  btn.disabled = true;
  btn.textContent = 'Generating...';

  var payload = { roofStyle: selectedStyle, roofColor: selectedColor };
  if (uploadedImageData) {
    payload.uploadedImage = uploadedImageData;
  } else {
    payload.address = address;
  }

  fetch('/api/roof-visualizer', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(payload)
  })
  .then(function(r) { return r.json(); })
  .then(function(data) {
    document.getElementById('viz-loading').style.display = 'none';
    document.getElementById('viz-style-picker').style.display = 'block';
    btn.disabled = false;
    btn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="flex-shrink:0"><path d="M12 2v4m0 12v4M4.93 4.93l2.83 2.83m8.48 8.48l2.83 2.83M2 12h4m12 0h4M4.93 19.07l2.83-2.83m8.48-8.48l2.83-2.83"/></svg> Generate My New Roof';

    if (data.success) {
      incrementGenerationCount();
      var newCount = getGenerationCount();
      var remaining = 3 - newCount;
      document.getElementById('viz-before').src = data.originalImage;
      document.getElementById('viz-after').src = data.generatedImage;
      document.getElementById('viz-style-label').textContent = 'Showing: ' + data.style + (remaining > 0 ? ' (' + remaining + ' visualization' + (remaining === 1 ? '' : 's') + ' remaining today)' : '');
      document.getElementById('viz-result').style.display = 'block';
      updateCostEstimate();
      document.getElementById('viz-result').scrollIntoView({ behavior: 'smooth', block: 'start' });
      if (remaining <= 0) {
        document.getElementById('viz-generate-btn').style.display = 'none';
        var tryBtn = document.querySelector('#viz-result .btn-o');
        if (tryBtn) tryBtn.style.display = 'none';
      }
    } else {
      if (data.noStreetView) {
        document.getElementById('viz-upload-area').style.display = 'block';
        alert('No Street View image available for this address. Please upload a photo of your home instead.');
      } else {
        alert('We couldn\'t generate a visualization. ' + (data.error || 'Please try again.'));
      }
    }
  })
  .catch(function(err) {
    document.getElementById('viz-loading').style.display = 'none';
    document.getElementById('viz-style-picker').style.display = 'block';
    btn.disabled = false;
    btn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="flex-shrink:0"><path d="M12 2v4m0 12v4M4.93 4.93l2.83 2.83m8.48 8.48l2.83 2.83M2 12h4m12 0h4M4.93 19.07l2.83-2.83m8.48-8.48l2.83-2.83"/></svg> Generate My New Roof';
    alert('Something went wrong. Please try again or call us at (813) 595-7663.');
  });
}

function submitVisualizerLead(e) {
  e.preventDefault();
  var form = e.target;
  var name = form.viz_name.value;
  var phone = form.viz_phone.value;
  var email = form.viz_email ? form.viz_email.value : '';
  var address = document.getElementById('viz-address').value;

  var stPayload = {
    name: name, phone: phone, email: email, address: address,
    service: 'Roof Visualizer Lead',
    source: 'Website - Roof Assessment',
    page: '/assessment',
    notes: 'Roof style interest: ' + selectedColor + ' ' + selectedStyle
  };

  Promise.allSettled([
    fetch('/api/submit-lead', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(stPayload) }),
    fetch('https://formsubmit.co/ajax/info@happyroof.com', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
      body: JSON.stringify({
        _subject: 'Roof Visualizer Lead | ' + name,
        'Name': name, 'Phone': phone, 'Email': email || 'Not provided', 'Address': address,
        'Roof Style': selectedColor + ' ' + selectedStyle,
        'Source': 'Roof Assessment & Visualizer Page'
      })
    })
  ]).finally(function() {
    form.style.display = 'none';
    document.getElementById('viz-lead-success').style.display = 'block';
  });
}
</script>

<!-- Address autocomplete via Places API (server-side) -->
<script is:inline>
(function() {
  var input = document.getElementById('viz-address');
  if (!input) return;
  var dropdown = document.createElement('div');
  dropdown.id = 'address-dropdown';
  dropdown.style.cssText = 'position:absolute;left:0;right:60px;top:100%;background:#fff;border:1px solid #E0E0E0;border-top:none;border-radius:0 0 8px 8px;box-shadow:0 8px 24px -4px rgba(0,0,0,.12);z-index:100;display:none;max-height:250px;overflow-y:auto';
  input.parentElement.style.position = 'relative';
  input.parentElement.appendChild(dropdown);

  var debounce;
  input.addEventListener('input', function() {
    clearTimeout(debounce);
    var q = input.value.trim();
    if (q.length < 4) { dropdown.style.display = 'none'; return; }
    debounce = setTimeout(function() {
      fetch('/api/address-suggest?q=' + encodeURIComponent(q))
        .then(function(r) { return r.json(); })
        .then(function(data) {
          if (!data.suggestions || !data.suggestions.length) { dropdown.style.display = 'none'; return; }
          dropdown.innerHTML = '';
          data.suggestions.forEach(function(s) {
            var item = document.createElement('div');
            item.textContent = s;
            item.style.cssText = 'padding:.75rem 1rem;cursor:pointer;font-size:.9rem;color:#1A1A1A;border-bottom:1px solid #F0F0F0;transition:background .1s';
            item.onmouseenter = function() { this.style.background = 'rgba(230,168,23,.06)'; };
            item.onmouseleave = function() { this.style.background = 'transparent'; };
            item.onclick = function() {
              input.value = s;
              dropdown.style.display = 'none';
              loadStreetView();
            };
            dropdown.appendChild(item);
          });
          dropdown.style.display = 'block';
        })
        .catch(function() { dropdown.style.display = 'none'; });
    }, 300);
  });

  document.addEventListener('click', function(e) {
    if (!input.contains(e.target) && !dropdown.contains(e.target)) dropdown.style.display = 'none';
  });
})();
</script>

