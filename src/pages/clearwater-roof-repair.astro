---
import BaseLayout from '../layouts/BaseLayout.astro';

const schema = `[{
    "@context": "https://schema.org",
    "@type": ["LocalBusiness", "RoofingContractor"],
    "name": "Happy Roof LLC",
    "url": "https://happyroof.com",
    "telephone": "+1-813-595-7663",
    "email": "info@happyroof.com",
    "description": "Clearwater roof repair contractor. Emergency leak repair, storm damage, and general roofing repairs. FL License #CCC1337380.",
    "image": "/Brand%20Assets/Happy%20Roof%20Logo.jpeg",
    "logo": "/Brand%20Assets/Happy%20Roof%20Logo.jpeg",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "141 Stevens Ave #12",
      "addressLocality": "Oldsmar",
      "addressRegion": "FL",
      "postalCode": "34677",
      "addressCountry": "US"
    },
    "areaServed": {
      "@type": "City",
      "name": "Clearwater",
      "containedInPlace": { "@type": "State", "name": "Florida" }
    },
    "hasCredential": "Florida Roofing Contractor License #CCC1337380",
    "dateModified": "2026-04-10"
  },{
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How quickly can you respond to a roof emergency in Clearwater?",
        "acceptedAnswer": { "@type": "Answer", "text": "We provide same-day emergency tarping for active leaks throughout Clearwater and Pinellas County. Permanent repairs are typically scheduled within a few days depending on scope and weather." }
      },
      {
        "@type": "Question",
        "name": "When should I repair vs. replace my Clearwater roof?",
        "acceptedAnswer": { "@type": "Answer", "text": "If damage is localized and your roof is under 15 years old, repair is usually the smart choice. If your roof is 20+ years old with widespread damage or multiple prior repairs, replacement may be more cost-effective. We give you an honest recommendation either way." }
      },
      {
        "@type": "Question",
        "name": "Does insurance cover roof repairs in Clearwater?",
        "acceptedAnswer": { "@type": "Answer", "text": "Wind and storm damage are typically covered by Florida homeowners insurance. We provide detailed photo documentation and can coordinate with your insurance adjuster to help support your claim." }
      },
      {
        "@type": "Question",
        "name": "What does a typical roof repair cost in Clearwater?",
        "acceptedAnswer": { "@type": "Answer", "text": "Minor repairs (a few shingles, flashing reseal) cost $300-$1,500. More extensive repairs (multiple areas, tile work, decking) range from $1,500-$5,000+. We always provide a free assessment and written estimate first." }
      }
    ]
  }]`;
---

<BaseLayout
  title="Clearwater Roof Repair | Emergency Service | Happy Roof"
  description="Clearwater roof repair: emergency service by Happy Roof. Leak repair, storm damage, shingle & tile repair. FL License #CCC1337380. Call (813) 595-7663."
  canonical="https://happyroof.com/clearwater-roof-repair"
  schema={schema}
>

<style is:inline>
.check-dot{width:20px;height:20px;border-radius:50%;display:flex;align-items:center;justify-content:center;background:rgba(230,168,23,.1);flex-shrink:0;margin-top:.15rem}
    .step-num{width:48px;height:48px;border-radius:14px;display:flex;align-items:center;justify-content:center;background:rgba(230,168,23,.1);font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.25rem;color:#E6A817;flex-shrink:0}
</style>

<!-- HERO -->
<section class="pt-32 pb-20 relative overflow-hidden" style="background:#F5F5F5;border-bottom:1px solid #E5E5E5">
  <div class="hero-photo-bg" style="background-image:url('/Brand%20Assets/Photos/standing-seam-metal-roof-tampa.jpg')"></div>
