---
import LandingLayout from '../layouts/LandingLayout.astro';

---

<LandingLayout
  title="Careers at Happy Roof — Join Our Team in Tampa Bay"
  description="Join the Happy Roof team in Tampa Bay. We're hiring experienced roofers, sales reps, and crew members. Competitive pay, great culture, and growth opportunities."
  canonical="https://happyroof.com/recruit"
  noindex={true}
>

<style is:inline>
/* Buttons */
    /* Section label */
    /* Cards */
    /* Icon container */
    .ic{width:56px;height:56px;border-radius:14px;display:flex;align-items:center;justify-content:center;background:rgba(230,168,23,.1);flex-shrink:0;transition:background .2s,box-shadow .2s;box-shadow:0 0 0 1px rgba(230,168,23,.08)}
    /* Timeline */
    .tl-dot{width:18px;height:18px;border-radius:50%;border:3px solid #E6A817;background:#FFFFFF;flex-shrink:0;position:relative;z-index:2;transition:background .2s}
    .tl-dot.active{background:#E6A817}
    .tl-line{position:absolute;top:9px;left:0;right:0;height:3px;background:linear-gradient(90deg,#1A1A1A 0%,#E6A817 50%,#F0C040 100%);z-index:1}
    /* CTA section */
    /* Step card */
    .step-card{background:#FFFFFF;border:1px solid #E0E0E0;border-radius:16px;overflow:hidden;transition:transform .3s cubic-bezier(.34,1.56,.64,1),box-shadow .3s}
    .step-card:hover{transform:translateY(-4px);box-shadow:0 16px 48px -8px rgba(230,168,23,.12)}
    /* Footer */
    /* Animations */
    @keyframes fadeUp{from{opacity:0;transform:translateY(24px)}to{opacity:1;transform:translateY(0)}}
    .fade-up{animation:fadeUp .6s ease-out both}
    .fade-up-d1{animation-delay:.1s}
    .fade-up-d2{animation-delay:.2s}
    .fade-up-d3{animation-delay:.3s}
    .fade-up-d4{animation-delay:.4s}
    /* Responsive */
    @media(min-width:768px) and (max-width:1023px){
      .comp-grid{grid-template-columns:1fr 1fr !important}
      .day-grid{grid-template-columns:1fr 1fr !important}
      .growth-grid{grid-template-columns:1fr 1fr !important}
    }
</style>

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Careers at Happy Roof — Join Our Team in Tampa Bay</title>
  <meta name="robots" content="noindex, nofollow" />
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;600;700;800;900&family=Nunito:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            brand: {
              black: '#1A1A1A', dark: '#2A2A2A', card: '#F7F7F7',
              border: '#E0E0E0',
              yellow: '#E6A817', yellowLight: '#F0C040', yellowDim: 'rgba(230,168,23,0.12)',
              blue: '#3B9FD9',
              white: '#FFFFFF', muted: '#555555', muted2: '#888888',
            }
          },
          fontFamily: { display: ['Barlow Condensed','sans-serif'], body: ['Nunito','sans-serif'] },
        }
      }
    }
  </script>
  <style>
    *{box-sizing:border-box}
    body{background:#FFFFFF;color:#1A1A1A;font-family:'Nunito',sans-serif;margin:0}
    html{scroll-behavior:smooth}
    img{background:transparent}

    /* Buttons */
    .btn-p{background:#E6A817;color:#1A1A1A;border-radius:8px;font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1rem;letter-spacing:.02em;padding:.75rem 1.6rem;transition:background .18s,transform .2s cubic-bezier(.34,1.56,.64,1),box-shadow .18s;box-shadow:0 4px 20px -4px rgba(230,168,23,.42);display:inline-flex;align-items:center;gap:.45rem;text-decoration:none}
    .btn-p:hover{background:#F0C040;transform:translateY(-2px);box-shadow:0 8px 28px -4px rgba(230,168,23,.52)}
    .btn-p:active{transform:translateY(0)}
    .btn-p:focus-visible{outline:2px solid #F0C040;outline-offset:3px}

    .btn-t{background:#E6A817;color:#1A1A1A;border-radius:8px;font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.1rem;letter-spacing:.02em;padding:.9rem 2.2rem;transition:background .18s,transform .2s cubic-bezier(.34,1.56,.64,1),box-shadow .18s;box-shadow:0 4px 24px -4px rgba(230,168,23,.38);display:inline-flex;align-items:center;gap:.45rem;text-decoration:none}
    .btn-t:hover{background:#F0C040;transform:translateY(-2px);box-shadow:0 8px 32px -4px rgba(230,168,23,.48)}
    .btn-t:active{transform:translateY(0)}
    .btn-t:focus-visible{outline:2px solid #E6A817;outline-offset:3px}

    .btn-o{background:transparent;color:#1A1A1A;border:1.5px solid rgba(26,26,26,.2);border-radius:8px;font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.05rem;letter-spacing:.02em;padding:.85rem 1.8rem;transition:border-color .18s,background .18s,transform .2s cubic-bezier(.34,1.56,.64,1);display:inline-flex;align-items:center;gap:.45rem;text-decoration:none}
    .btn-o:hover{border-color:rgba(26,26,26,.4);background:rgba(230,168,23,.06);transform:translateY(-2px)}
    .btn-o:active{transform:translateY(0)}
    .btn-o:focus-visible{outline:2px solid #E6A817;outline-offset:3px}

    /* Section label */
    .sl{font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:.82rem;letter-spacing:.15em;text-transform:uppercase;color:#E6A817}

    /* Cards */
    .card{background:#FFFFFF;border:1px dashed #E0E0E0;border-radius:16px;transition:transform .3s cubic-bezier(.34,1.56,.64,1),border-color .2s,box-shadow .3s}
    .card:hover{transform:translateY(-6px);border-color:rgba(230,168,23,.4);box-shadow:0 20px 56px -12px rgba(230,168,23,.15),0 4px 16px -4px rgba(0,0,0,.06)}

    /* Icon container */
    .ic{width:56px;height:56px;border-radius:14px;display:flex;align-items:center;justify-content:center;background:rgba(230,168,23,.1);flex-shrink:0;transition:background .2s,box-shadow .2s;box-shadow:0 0 0 1px rgba(230,168,23,.08)}
    .card:hover .ic{background:rgba(230,168,23,.18);box-shadow:0 0 0 1px rgba(230,168,23,.3)}

    /* Timeline */
    .tl-dot{width:18px;height:18px;border-radius:50%;border:3px solid #E6A817;background:#FFFFFF;flex-shrink:0;position:relative;z-index:2;transition:background .2s}
    .tl-dot.active{background:#E6A817}
    .tl-line{position:absolute;top:9px;left:0;right:0;height:3px;background:linear-gradient(90deg,#1A1A1A 0%,#E6A817 50%,#F0C040 100%);z-index:1}

    /* CTA section */
    .cta-grad{background:radial-gradient(ellipse 60% 50% at 50% 80%,rgba(230,168,23,.1) 0%,rgba(26,26,26,.95) 40%,#1A1A1A 100%)}
    .cta-grad h2,.cta-grad p{color:#FFFFFF}

    /* Step card */
    .step-card{background:#FFFFFF;border:1px solid #E0E0E0;border-radius:16px;overflow:hidden;transition:transform .3s cubic-bezier(.34,1.56,.64,1),box-shadow .3s}
    .step-card:hover{transform:translateY(-4px);box-shadow:0 16px 48px -8px rgba(230,168,23,.12)}

    /* Footer */
    footer{background:#1A1A1A;border-top:1px solid #2A2A2A}

    /* Animations */
    @keyframes fadeUp{from{opacity:0;transform:translateY(24px)}to{opacity:1;transform:translateY(0)}}
    .fade-up{animation:fadeUp .6s ease-out both}
    .fade-up-d1{animation-delay:.1s}
    .fade-up-d2{animation-delay:.2s}
    .fade-up-d3{animation-delay:.3s}
    .fade-up-d4{animation-delay:.4s}

    /* Responsive */
    @media(max-width:767px){
      .hero-grid{grid-template-columns:1fr !important}
      .hero-img-wrap{height:280px !important;margin-top:1.5rem}
      .about-grid{grid-template-columns:1fr !important}
      .about-img{height:300px !important;order:-1}
      .timeline-row{flex-direction:column;gap:2rem;align-items:flex-start}
      .tl-line{display:none}
      .comp-grid{grid-template-columns:1fr !important}
      .day-grid{grid-template-columns:1fr !important}
      .career-steps{grid-template-columns:1fr !important}
      .growth-grid{grid-template-columns:1fr !important}
    }
    @media(min-width:768px) and (max-width:1023px){
      .comp-grid{grid-template-columns:1fr 1fr !important}
      .day-grid{grid-template-columns:1fr 1fr !important}
      .growth-grid{grid-template-columns:1fr 1fr !important}
    }
  </style>
</head>
<body>

<!-- ═══════════════ HERO ═══════════════ -->
<section class="relative overflow-hidden" style="background:#FFFFFF;border-bottom:1px solid #E0E0E0">
  <div class="max-w-7xl mx-auto px-6 py-20 md:py-28">
    <div class="hero-grid" style="display:grid;grid-template-columns:1fr 1fr;gap:3rem;align-items:center">
      <div class="fade-up">
        <div class="flex items-center gap-3 mb-6">
          <img src="Brand%20Assets/Happy%20Roof%20Logo.png" alt="Happy Roof" style="height:48px" />
        </div>
        <p class="sl mb-3">NOW HIRING IN TAMPA BAY</p>
        <h1 style="font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:clamp(2.4rem,5vw,3.6rem);line-height:1.05;letter-spacing:-.02em;color:#1A1A1A">
          Making Roofing Simple.<br/>Building Strong Careers.
        </h1>
        <p style="color:#555555;font-size:1.1rem;line-height:1.7;margin-top:1.25rem;max-width:520px">
          Happy Roof is a family-owned roofing company based in Oldsmar, Florida. We're growing fast and looking for driven people ready to earn, learn, and lead.
        </p>
        <div class="flex flex-wrap gap-3 mt-8">
          <a href="#about" class="btn-t">Learn More</a>
        </div>
        <p style="color:#888888;font-size:.8rem;margin-top:.75rem">Presented by Recruitomatic in partnership with Happy Roof</p>
      </div>
      <div class="hero-img-wrap fade-up fade-up-d2" style="height:420px;border-radius:20px;overflow:hidden;position:relative">
        <img src="Brand%20Assets/Photos/standing-seam-metal-roof-tampa.jpg" alt="Happy Roof project in Tampa Bay" style="width:100%;height:100%;object-fit:cover" />
        <div style="position:absolute;inset:0;background:linear-gradient(to top,rgba(26,26,26,.35) 0%,transparent 50%);border-radius:20px"></div>
        <div style="position:absolute;inset:0;background:rgba(230,168,23,.08);mix-blend-mode:multiply;border-radius:20px"></div>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════ STATS BAR ═══════════════ -->
<section style="background:linear-gradient(180deg,#F7F7F7 0%,#FFFFFF 100%);border-bottom:1px solid #E0E0E0">
  <div class="max-w-7xl mx-auto px-6 py-8">
    <div class="flex flex-wrap justify-center gap-8 md:gap-16 text-center">
      <div>
        <div style="font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:2.2rem;color:#E6A817">$1.5K–$2K</div>
        <div style="color:#555555;font-size:.85rem;font-weight:600">Weekly Earnings (Reps)</div>
      </div>
      <div>
        <div style="font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:2.2rem;color:#E6A817">$2,500+</div>
        <div style="color:#555555;font-size:.85rem;font-weight:600">Weekly (Managers)</div>
      </div>
      <div>
        <div style="font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:2.2rem;color:#E6A817">No Cap</div>
        <div style="color:#555555;font-size:.85rem;font-weight:600">On Earnings</div>
      </div>
      <div>
        <div style="font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:2.2rem;color:#E6A817">Tampa Bay</div>
        <div style="color:#555555;font-size:.85rem;font-weight:600">Top Roofing Market</div>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════ ABOUT US ═══════════════ -->
<section id="about" class="py-20 md:py-28" style="background:#FFFFFF">
  <div class="max-w-7xl mx-auto px-6">
    <div class="about-grid" style="display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:center">
      <div>
        <p class="sl mb-3">ABOUT US</p>
        <h2 style="font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:clamp(2rem,4vw,2.8rem);line-height:1.1;color:#1A1A1A">
          Built on One Mission — Make Roofing Simple
        </h2>
        <p style="color:#555555;font-size:1.05rem;line-height:1.7;margin-top:1.25rem">
          Happy Roof was built on one mission — make roofing simple, fast, and stress-free for homeowners. We specialize in free inspections, same-day quotes, and high-quality installations.
        </p>
        <p style="color:#555555;font-size:1.05rem;line-height:1.7;margin-top:1rem">
          We've built a strong reputation across the Tampa Bay area with exclusive programs like the $500 Heroes Discount — and this June, we're launching a foundation dedicated to providing free roof repairs and replacements for community members in need — name reveal coming soon. Growth, culture, and performance are at the core of everything we do.
        </p>
        <p style="color:#555555;font-size:1.05rem;line-height:1.7;margin-top:1rem">
          This is a company that values both its customers and its team.
        </p>
      </div>
      <div class="about-img" style="height:400px;border-radius:20px;overflow:hidden;position:relative">
        <img src="Brand%20Assets/Photos/architectural-shingle-roof-tampa-bay.jpg" alt="Roofing work in Tampa Bay" style="width:100%;height:100%;object-fit:cover" />
        <div style="position:absolute;inset:0;background:linear-gradient(to top,rgba(26,26,26,.3) 0%,transparent 50%);border-radius:20px"></div>
        <div style="position:absolute;inset:0;background:rgba(230,168,23,.06);mix-blend-mode:multiply;border-radius:20px"></div>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════ WHY WORK HERE ═══════════════ -->
<section class="py-20 md:py-28" style="background:#F7F7F7;border-top:1px solid #E0E0E0;border-bottom:1px solid #E0E0E0">
  <div class="max-w-7xl mx-auto px-6">
    <div class="text-center mb-14">
      <p class="sl mb-3">WHY HAPPY ROOF</p>
      <h2 style="font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:clamp(2rem,4vw,2.8rem);line-height:1.1;color:#1A1A1A">
        Why Work Here
      </h2>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      <!-- Growth -->
      <div class="card p-7">
        <div class="ic mb-4">
          <svg width="28" height="28" fill="none" stroke="#E6A817" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
        </div>
        <h3 style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.2rem;color:#1A1A1A;margin-bottom:.5rem">GROWTH</h3>
        <p style="color:#555555;font-size:.92rem;line-height:1.65">Clear path from rep to manager. Leadership opportunities based on performance.</p>
      </div>
      <!-- Earnings -->
      <div class="card p-7">
        <div class="ic mb-4">
          <svg width="28" height="28" fill="none" stroke="#E6A817" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>
        </div>
        <h3 style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.2rem;color:#1A1A1A;margin-bottom:.5rem">EARNINGS</h3>
        <p style="color:#555555;font-size:.92rem;line-height:1.65">High commission structure. Strong weekly earning potential with no cap.</p>
      </div>
      <!-- Support -->
      <div class="card p-7">
        <div class="ic mb-4">
          <svg width="28" height="28" fill="none" stroke="#E6A817" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>
        </div>
        <h3 style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.2rem;color:#1A1A1A;margin-bottom:.5rem">SUPPORT</h3>
        <p style="color:#555555;font-size:.92rem;line-height:1.65">Daily training and in-field coaching. Structured accountability programs included.</p>
      </div>
      <!-- Culture -->
      <div class="card p-7">
        <div class="ic mb-4">
          <svg width="28" height="28" fill="none" stroke="#E6A817" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>
        </div>
        <h3 style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.2rem;color:#1A1A1A;margin-bottom:.5rem">CULTURE</h3>
        <p style="color:#555555;font-size:.92rem;line-height:1.65">Team-focused environment. Fitness, mindset, and personal growth built in.</p>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════ INDUSTRY TIMELINE ═══════════════ -->
<section class="py-20 md:py-28" style="background:#FFFFFF">
  <div class="max-w-7xl mx-auto px-6">
    <div class="text-center mb-16">
      <p class="sl mb-3">THE INDUSTRY</p>
      <h2 style="font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:clamp(2rem,4vw,2.8rem);line-height:1.1;color:#1A1A1A">
        Industry Timeline
      </h2>
    </div>
    <div class="relative">
      <!-- Desktop timeline -->
      <div class="hidden md:block">
        <div class="relative" style="padding:0 2rem">
          <div class="tl-line" style="top:9px;left:2rem;right:2rem"></div>
          <div class="flex justify-between relative" style="z-index:2">
            <div class="flex flex-col items-center" style="width:16%">
              <div class="tl-dot active"></div>
              <div class="mt-4 text-center">
                <div style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.1rem;color:#1A1A1A">2010</div>
                <div style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:.75rem;letter-spacing:.1em;text-transform:uppercase;color:#E6A817;margin-top:.35rem">Market Expansion</div>
                <p style="color:#555555;font-size:.8rem;line-height:1.5;margin-top:.35rem">Increased homeownership drives demand for roofing.</p>
              </div>
            </div>
            <div class="flex flex-col items-center" style="width:16%">
              <div class="tl-dot active"></div>
              <div class="mt-4 text-center">
                <div style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.1rem;color:#1A1A1A">2015</div>
                <div style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:.75rem;letter-spacing:.1em;text-transform:uppercase;color:#E6A817;margin-top:.35rem">Storm Boom</div>
                <p style="color:#555555;font-size:.8rem;line-height:1.5;margin-top:.35rem">Insurance claims create massive opportunity in roofing sales.</p>
              </div>
            </div>
            <div class="flex flex-col items-center" style="width:16%">
              <div class="tl-dot active"></div>
              <div class="mt-4 text-center">
                <div style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.1rem;color:#1A1A1A">2018</div>
                <div style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:.75rem;letter-spacing:.1em;text-transform:uppercase;color:#E6A817;margin-top:.35rem">Tech in Roofing</div>
                <p style="color:#555555;font-size:.8rem;line-height:1.5;margin-top:.35rem">Faster estimates and inspections improve closing speed.</p>
              </div>
            </div>
            <div class="flex flex-col items-center" style="width:16%">
              <div class="tl-dot active"></div>
              <div class="mt-4 text-center">
                <div style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.1rem;color:#1A1A1A">2020</div>
                <div style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:.75rem;letter-spacing:.1em;text-transform:uppercase;color:#E6A817;margin-top:.35rem">Home Improvement</div>
                <p style="color:#555555;font-size:.8rem;line-height:1.5;margin-top:.35rem">Homeowners invest heavily in upgrades and repairs.</p>
              </div>
            </div>
            <div class="flex flex-col items-center" style="width:16%">
              <div class="tl-dot active"></div>
              <div class="mt-4 text-center">
                <div style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.1rem;color:#1A1A1A">2022</div>
                <div style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:.75rem;letter-spacing:.1em;text-transform:uppercase;color:#E6A817;margin-top:.35rem">Florida Growth</div>
                <p style="color:#555555;font-size:.8rem;line-height:1.5;margin-top:.35rem">Tampa Bay becomes a top roofing market in the U.S.</p>
              </div>
            </div>
            <div class="flex flex-col items-center" style="width:16%">
              <div class="tl-dot" style="background:#E6A817;border-color:#E6A817;width:22px;height:22px;margin-top:-2px"></div>
              <div class="mt-4 text-center">
                <div style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.1rem;color:#E6A817">Today</div>
                <div style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:.75rem;letter-spacing:.1em;text-transform:uppercase;color:#E6A817;margin-top:.35rem">Happy Roof Growth</div>
                <p style="color:#555555;font-size:.8rem;line-height:1.5;margin-top:.35rem">Rapid expansion with strong focus on sales team growth.</p>
              </div>
            </div>
          </div>
        </div>
