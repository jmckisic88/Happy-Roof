---
import BaseLayout from '../layouts/BaseLayout.astro';

const schema = `[{
    "@context": "https://schema.org",
    "@type": ["LocalBusiness", "RoofingContractor"],
    "name": "Happy Roof LLC",
    "url": "https://happyroof.com",
    "telephone": "+1-813-595-7663",
    "email": "info@happyroof.com",
    "description": "Clearwater roof replacement contractor. Shingle, metal, and tile roofing systems. Licensed and insured. FL License #CCC1337380.",
    "image": "/Brand%20Assets/Happy%20Roof%20Logo.jpeg",
    "logo": "/Brand%20Assets/Happy%20Roof%20Logo.jpeg",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "141 Stevens Ave #12",
      "addressLocality": "Oldsmar",
      "addressRegion": "FL",
      "postalCode": "34677",
      "addressCountry": "US"
    },
    "areaServed": {
      "@type": "City",
      "name": "Clearwater",
      "containedInPlace": { "@type": "State", "name": "Florida" }
    },
    "hasCredential": "Florida Roofing Contractor License #CCC1337380",
    "dateModified": "2026-04-25"
  },{
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How much does a roof replacement cost in Clearwater?",
        "acceptedAnswer": { "@type": "Answer", "text": "Clearwater roof replacement typically costs $8,500 to $27,000 depending on size, material, pitch, and structural condition. Beachfront properties may cost more due to corrosion-resistant material requirements. Call (813) 595-7663 for a free, personalized estimate." }
      },
      {
        "@type": "Question",
        "name": "What roofing material is best for homes near Clearwater Beach?",
        "acceptedAnswer": { "@type": "Answer", "text": "For properties on Clearwater Beach, Island Estates, and Sand Key, standing seam metal with a Kynar finish offers the best resistance to salt air corrosion. For mainland Clearwater homes, Owens Corning architectural shingles provide excellent wind resistance at a lower cost." }
      },
      {
        "@type": "Question",
        "name": "How long does a Clearwater roof replacement take?",
        "acceptedAnswer": { "@type": "Answer", "text": "Shingle roofs: 1-3 days. Metal roofs: 3-5 days. Tile roofs: 5-7 days. Clearwater's summer thunderstorms may cause minor scheduling adjustments, but we communicate proactively and plan around weather." }
      },
      {
        "@type": "Question",
        "name": "Does Happy Roof pull Clearwater permits?",
        "acceptedAnswer": { "@type": "Answer", "text": "Yes. We handle all permit applications with the City of Clearwater and Pinellas County, coordinate every required inspection, and ensure your new roof meets current Florida Building Code standards." }
      }
    ]
  }]`;
---

<BaseLayout
  title="Clearwater Roof Replacement | Free Estimates | Happy Roof"
  description="Clearwater roof replacement by Happy Roof. Shingle, metal & tile roofing with free estimates. Licensed and insured. FL License #CCC1337380. Call (813) 595-7663."
  canonical="https://happyroof.com/clearwater-roof-replacement"
  schema={schema}
>

<style is:inline>
.check-dot{width:20px;height:20px;border-radius:50%;display:flex;align-items:center;justify-content:center;background:rgba(230,168,23,.1);flex-shrink:0;margin-top:.15rem}
    .step-num{width:48px;height:48px;border-radius:14px;display:flex;align-items:center;justify-content:center;background:rgba(230,168,23,.1);font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.25rem;color:#E6A817;flex-shrink:0}
</style>

<!-- HERO -->
<section class="pt-32 pb-20 relative overflow-hidden" style="background:#F5F5F5;border-bottom:1px solid #E5E5E5">
  <div class="hero-photo-bg" style="background-image:url('/Brand%20Assets/Photos/architectural-shingle-roof-tampa-bay.jpg')"></div>
  <div class="hero-photo-overlay"></div>
  <div class="relative z-10 max-w-7xl mx-auto px-5 text-center">
    <p class="sl gp mb-4">Clearwater Roof Replacement</p>
