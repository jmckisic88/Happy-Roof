      <span class="scard px-4 py-3 text-center" style="font-size:.9rem;font-weight:600">Morningside</span>
      <span class="scard px-4 py-3 text-center" style="font-size:.9rem;font-weight:600">Drew Park</span>
      <span class="scard px-4 py-3 text-center" style="font-size:.9rem;font-weight:600">Clearwater East</span>
      <span class="scard px-4 py-3 text-center" style="font-size:.9rem;font-weight:600">Gulf Junction</span>
