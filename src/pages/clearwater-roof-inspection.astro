---
import BaseLayout from '../layouts/BaseLayout.astro';

const schema = `[{
    "@context": "https://schema.org",
    "@type": ["LocalBusiness", "RoofingContractor"],
    "name": "Happy Roof LLC",
    "url": "https://happyroof.com",
    "telephone": "+1-813-595-7663",
    "email": "info@happyroof.com",
    "description": "Free roof inspections in Clearwater FL. Comprehensive assessment of all roof types. FL License #CCC1337380.",
    "image": "/Brand%20Assets/Happy%20Roof%20Logo.jpeg",
    "logo": "/Brand%20Assets/Happy%20Roof%20Logo.jpeg",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "141 Stevens Ave #12",
      "addressLocality": "Oldsmar",
      "addressRegion": "FL",
      "postalCode": "34677",
      "addressCountry": "US"
    },
    "areaServed": {
      "@type": "City",
      "name": "Clearwater",
      "containedInPlace": { "@type": "State", "name": "Florida" }
    },
    "hasCredential": "Florida Roofing Contractor License #CCC1337380",
    "dateModified": "2026-04-10"
  },{
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Is the Clearwater roof inspection really free?",
        "acceptedAnswer": { "@type": "Answer", "text": "Absolutely. It is free with no strings attached. You are not obligated to purchase anything. We believe honest inspections build trust, and that is how we earn Clearwater homeowners' business when they do need roofing work." }
      },
      {
        "@type": "Question",
        "name": "How long does a roof inspection take in Clearwater?",
        "acceptedAnswer": { "@type": "Answer", "text": "Typically 45-60 minutes depending on roof size and complexity. Tile roofs and multi-story homes may take slightly longer. We are thorough rather than rushed." }
      },
      {
        "@type": "Question",
        "name": "What happens after the inspection if repairs are needed?",
        "acceptedAnswer": { "@type": "Answer", "text": "We present our findings with photos and provide a written estimate with options. You are free to get other quotes, think it over, or proceed. There is zero pressure from us." }
      },
      {
        "@type": "Question",
        "name": "How often should I have my Clearwater roof inspected?",
        "acceptedAnswer": { "@type": "Answer", "text": "We recommend annual inspections for roofs over 10 years old, and always after major storms. Pre-hurricane season (May-June) inspections are especially popular in Clearwater so homeowners can address vulnerabilities before the worst weather arrives." }
      }
    ]
  }]`;
---

<BaseLayout
  title="Free Roof Inspection Clearwater | Happy Roof"
  description="Free roof inspection in Clearwater FL by Happy Roof. Comprehensive assessment of shingle, metal & tile roofs. No obligation. FL License #CCC1337380. Call (813) 595-7663."
  canonical="https://happyroof.com/clearwater-roof-inspection"
  schema={schema}
>

<style is:inline>
.check-dot{width:20px;height:20px;border-radius:50%;display:flex;align-items:center;justify-content:center;background:rgba(230,168,23,.1);flex-shrink:0;margin-top:.15rem}
    .step-num{width:48px;height:48px;border-radius:14px;display:flex;align-items:center;justify-content:center;background:rgba(230,168,23,.1);font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.25rem;color:#E6A817;flex-shrink:0}
</style>

<!-- HERO -->
<section class="pt-32 pb-20 relative overflow-hidden" style="background:#F5F5F5;border-bottom:1px solid #E5E5E5">
  <div class="hero-photo-bg" style="background-image:url('/Brand%20Assets/Photos/commercial-tpo-roof-tampa.jpg')"></div>
  <div class="hero-photo-overlay"></div>
  <div class="relative z-10 max-w-7xl mx-auto px-5 text-center">
    <p class="sl gp mb-4">Clearwater Roof Inspection</p>
    <h1 class="font-display font-black tracking-tightest mb-5" style="font-family:'Barlow Condensed',sans-serif;font-size:clamp(2.5rem,5.5vw,4.5rem);line-height:.92;letter-spacing:-.01em;color:#1A1A1A">
      FREE ROOF INSPECTION<br/><span class="gt">CLEARWATER, FL</span>
    </h1>
    <p class="max-w-2xl mx-auto" style="color:#555555;font-size:1.05rem;line-height:1.75">
      Schedule a completely free roof inspection in Clearwater with Happy Roof. Our licensed team examines every component of your roofing system and delivers a detailed photo , no obligation, no sales pressure.
    </p>
    <div class="flex flex-wrap gap-3 justify-center mt-8">
      <a href="/contact" class="btn-t">Get a Free Estimate <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg></a>
      <a href="tel:8135957663" class="btn-o call-tracking-number">Call (813) 595-7663</a>
    </div>
  </div>
</section>

<!-- INFO STRIP -->
<div style="background:#FFFFFF;border-top:2px solid #E6A817;border-bottom:1px solid #E0E0E0;padding:.85rem 0">
  <div class="max-w-7xl mx-auto px-5">
    <div class="flex flex-wrap items-center justify-center gap-x-8 gap-y-2 font-display font-bold text-sm tracking-widest" style="color:#1A1A1A;text-transform:uppercase;font-family:'Barlow Condensed',sans-serif">
      <span>Clearwater, FL</span><span style="color:#E6A817">·</span><span>CCC1337380</span><span style="color:#E6A817">·</span><span>HappyRoof.com</span><span style="color:#E6A817">·</span><span style="color:#3B9FD9">(813) 595-7663</span>
    </div>
  </div>
</div>

<!-- WHY SECTION -->
<section class="py-20" style="background:#FFFFFF">
  <div class="max-w-7xl mx-auto px-5">
    <div class="grid lg:grid-cols-2 gap-14 items-start">
      <div>
        <p class="sl gt mb-3">Why Get a Free Inspection</p>
        <h2 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:clamp(2rem,4vw,3rem);line-height:.95;color:#1A1A1A;letter-spacing:-.01em;margin-bottom:1.5rem">WHY CLEARWATER HOMEOWNERS NEED REGULAR ROOF INSPECTIONS</h2>
        <p style="color:#555555;font-size:1rem;line-height:1.75;margin-bottom:1.5rem">Clearwater's roofing conditions are among the most demanding in Florida. The city receives over 50 inches of rain annually - most of it in sudden, intense downpours that test every seam, seal, and shingle on your roof. Add year-round UV exposure, salt air drifting inland from the Gulf of Mexico, and the annual threat of tropical storms, and it becomes clear why regular inspection is essential for Clearwater homeowners.</p>
        <p style="color:#555555;font-size:1rem;line-height:1.75;margin-bottom:1.5rem">Many Clearwater homes were built during the 1960s through 1980s construction boom. Neighborhoods like Countryside, Skycrest, and the areas surrounding Clearwater Mall are filled with homes whose roofs are now well past the 20-year mark. Even newer subdivisions in East Clearwater and near Clearwater High School have roofs that may be approaching their first major service interval. A professional inspection reveals issues that are invisible from the ground - deteriorated underlayment, rusting flashing, compromised pipe boots, and early-stage granule loss that signals shingle aging.</p>
        <p style="color:#555555;font-size:1rem;line-height:1.75;margin-bottom:1.5rem">Happy Roof's free inspection comes with absolutely no obligation. We check your roof, photograph our findings, and give you a clear report. No tricks, no pressure. If your roof is fine, we tell you. Visit our <a href="/clearwater-roofing" style="color:#3B9FD9;text-decoration:none;font-weight:600">Clearwater roofing page</a> to see all our services.</p>
      </div>
      <div class="space-y-4">
        <div class="scard p-6">
          <div class="check"><div class="check-dot"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#E6A817" stroke-width="3"><path d="M20 6L9 17l-5-5"/></svg></div><div><strong style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.05rem">Full 25-Point Inspection</strong><p style="color:#555555;font-size:.9rem;line-height:1.6;margin-top:.25rem">We check surface material, flashing, ridge caps, valleys, drip edge, gutters, soffit, fascia, ventilation, and attic conditions - nothing is skipped.</p></div></div>
        </div>
        <div class="scard p-6">
          <div class="check"><div class="check-dot"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#E6A817" stroke-width="3"><path d="M20 6L9 17l-5-5"/></svg></div><div><strong style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.05rem">Photo Documentation</strong><p style="color:#555555;font-size:.9rem;line-height:1.6;margin-top:.25rem">Every finding photographed in detail. You see exactly what we see, with no vague descriptions or guesswork.</p></div></div>
        </div>
        <div class="scard p-6">
          <div class="check"><div class="check-dot"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#E6A817" stroke-width="3"><path d="M20 6L9 17l-5-5"/></svg></div><div><strong style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.05rem">Written Report & Estimate</strong><p style="color:#555555;font-size:.9rem;line-height:1.6;margin-top:.25rem">Clear written report of all findings. If work is needed, you receive a transparent estimate with options and pricing.</p></div></div>
        </div>
        <div class="scard p-6">
          <div class="check"><div class="check-dot"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#E6A817" stroke-width="3"><path d="M20 6L9 17l-5-5"/></svg></div><div><strong style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.05rem">No Obligation - Period</strong><p style="color:#555555;font-size:.9rem;line-height:1.6;margin-top:.25rem">Our inspection is free. There is no catch, no required purchase, and no high-pressure follow-up calls.</p></div></div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- WHAT'S INCLUDED / COMMON REPAIRS / WHAT WE CHECK -->
<section class="py-20" style="background:#F7F7F7">
  <div class="max-w-7xl mx-auto px-5">
    <div class="text-center mb-14">
      <p class="sl gt mb-3">What We Check</p>
      <h2 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:clamp(2rem,4vw,3rem);line-height:.95;color:#1A1A1A;letter-spacing:-.01em">WHAT OUR CLEARWATER INSPECTION COVERS</h2>
