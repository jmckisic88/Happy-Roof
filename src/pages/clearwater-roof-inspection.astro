      <span class="scard px-4 py-3 text-center" style="font-size:.9rem;font-weight:600">Gulf Junction</span>
      <span class="scard px-4 py-3 text-center" style="font-size:.9rem;font-weight:600">North Greenwood</span>
      <span class="scard px-4 py-3 text-center" style="font-size:.9rem;font-weight:600">Stevenson Creek</span>
      <span class="scard px-4 py-3 text-center" style="font-size:.9rem;font-weight:600">Old Clearwater Bay</span>
    </div>
