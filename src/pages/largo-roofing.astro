---
import BaseLayout from '../layouts/BaseLayout.astro';

const schema = `[{
    "@context": "https://schema.org",
    "@type": ["LocalBusiness", "RoofingContractor"],
    "name": "Happy Roof LLC",
    "url": "https://happyroof.com",
    "telephone": "+1-813-595-7663",
    "email": "info@happyroof.com",
    "description": "Largo roofing contractor specializing in shingle, metal, and tile roof replacement and installation. Licensed and insured. FL License #CCC1337380.",
    "image": "/Brand%20Assets/Happy%20Roof%20Logo.jpeg",
    "logo": "/Brand%20Assets/Happy%20Roof%20Logo.jpeg",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "141 Stevens Ave #12",
      "addressLocality": "Oldsmar",
      "addressRegion": "FL",
      "postalCode": "34677",
      "addressCountry": "US"
    },
    "areaServed": {
      "@type": "City",
      "name": "Largo",
      "containedInPlace": {
        "@type": "State",
        "name": "Florida"
      }
    },
    "hasCredential": "Florida Roofing Contractor License #CCC1337380",
    "dateModified": "2026-04-20"
  },{
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How much does a roof replacement cost in Largo?",
        "acceptedAnswer": { "@type": "Answer", "text": "Roof replacement costs in Largo typically range from $8,000 to $25,000+ depending on your roof's size, pitch, material (shingles, metal, or tile), and any structural repairs needed. Homes near Largo Central Park and in the Belleair area may have different pricing due to roof size and architectural complexity. Happy Roof provides free, transparent estimates.  Call (813) 595-7663." }
      },
      {
        "@type": "Question",
        "name": "What roofing materials work best for Largo homes?",
        "acceptedAnswer": { "@type": "Answer", "text": "Largo's central Pinellas County location means homes face Florida's full range of weather challenges: intense UV, heavy summer rain, and hurricane-force winds. Owens Corning Duration HDZ architectural shingles rated for 130+ MPH winds are the most popular choice throughout Largo. Standing seam metal roofing reflects heat and lasts 40-60 years, making it ideal for energy-conscious homeowners. Tile roofs are common on larger homes in the Belleair and Seminole areas nearby." }
      },
      {
        "@type": "Question",
        "name": "Does Happy Roof handle permits for Largo roofing projects?",
        "acceptedAnswer": { "@type": "Answer", "text": "Yes. Happy Roof handles all permit applications with the City of Largo and Pinellas County building departments. We manage the entire permitting and inspection process so you never have to visit a government office or coordinate inspectors yourself. All work meets current Florida Building Code standards." }
      },
      {
        "@type": "Question",
        "name": "How long does a roof replacement take in Largo?",
        "acceptedAnswer": { "@type": "Answer", "text": "Most Largo shingle roof replacements are completed in 1 to 3 days. Metal roofs typically take 3 to 5 days, and tile roofs 5 to 7 days. Florida's summer afternoon storms can occasionally cause brief delays, but we plan around weather patterns and keep you informed at every stage of the project." }
      },
      {
        "@type": "Question",
        "name": "Is Happy Roof licensed to work in Largo?",
        "acceptedAnswer": { "@type": "Answer", "text": "Yes. Happy Roof LLC holds Florida Roofing Contractor License #CCC1337380, which authorizes roofing work throughout the entire state of Florida, including the City of Largo and all of Pinellas County. We carry full general liability and workers' compensation insurance." }
      }
    ]
  }]`;
---

<BaseLayout
  title="Largo Roofing Contractor | Licensed & Insured | Happy Roof"
  description="Largo roofing contractor. Happy Roof provides roof replacement, repair, and installation across Largo FL. Licensed and insured. FL License #CCC1337380. Free estimates: (813) 595-7663."
  canonical="https://happyroof.com/largo-roofing"
  ogTitle="Largo Roofing Contractor | Happy Roof"
  ogDescription="Licensed Largo roofer for replacements, repairs & storm damage. Free estimates.  Call (813) 595-7663."
  schema={schema}
>

<style is:inline>
.check-dot{width:20px;height:20px;border-radius:50%;display:flex;align-items:center;justify-content:center;background:rgba(230,168,23,.1);flex-shrink:0;margin-top:.15rem}
    .step-num{width:48px;height:48px;border-radius:14px;display:flex;align-items:center;justify-content:center;background:rgba(230,168,23,.1);font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.25rem;color:#E6A817;flex-shrink:0}
</style>

<!-- HERO -->
<section class="pt-32 pb-20 relative overflow-hidden" style="background:#F5F5F5;border-bottom:1px solid #E5E5E5">
  <div class="hero-photo-bg" style="background-image:url('/Brand%20Assets/Photos/architectural-shingle-roof-tampa-bay.jpg')"></div>
  <div class="hero-photo-overlay"></div>
  <div class="relative z-10 max-w-7xl mx-auto px-5 text-center">
    <p class="sl gp mb-4">Largo Roofing</p>
    <h1 class="font-display font-black tracking-tightest mb-5" style="font-family:'Barlow Condensed',sans-serif;font-size:clamp(2.5rem,5.5vw,4.5rem);line-height:.92;letter-spacing:-.01em;color:#1A1A1A">
      LARGO ROOFING CONTRACTOR<br/><span class="gt">LICENSED & INSURED</span>
    </h1>
    <p class="max-w-2xl mx-auto" style="color:#555555;font-size:1.05rem;line-height:1.75">
      Largo homeowners count on Happy Roof for professional roof replacement, repair, and installation. Centrally located in Pinellas County with easy access to Indian Rocks Beach, the Pinellas Trail, and neighboring Belleair and Seminole, Largo is home to thousands of families who need a roofing contractor they can trust. As a licensed and insured roofing contractor, we deliver high-performance roofing systems built to handle Florida's toughest conditions, backed by our up to 15-year workmanship warranty.
    </p>
    <div class="flex flex-wrap gap-3 justify-center mt-8">
      <a href="/contact" class="btn-t">Get a Free Estimate <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg></a>
      <a href="tel:8135957663" class="btn-o call-tracking-number">Call (813) 595-7663</a>
    </div>
  </div>
</section>

<!-- INFO STRIP -->
<div style="background:#FFFFFF;border-top:2px solid #E6A817;border-bottom:1px solid #E0E0E0;padding:.85rem 0">
  <div class="max-w-7xl mx-auto px-5">
    <div class="flex flex-wrap items-center justify-center gap-x-8 gap-y-2 font-display font-bold text-sm tracking-widest" style="color:#1A1A1A;text-transform:uppercase;font-family:'Barlow Condensed',sans-serif">
      <span>Largo, FL</span>
      <span style="color:#E6A817">·</span>
      <span>CCC1337380</span>
      <span style="color:#E6A817">·</span>
      <span>HappyRoof.com</span>
      <span style="color:#E6A817">·</span>
      <span style="color:#3B9FD9">(813) 595-7663</span>
    </div>
  </div>
</div>

<!-- WHY HAPPY ROOF IN LARGO -->
<section class="py-20" style="background:#FFFFFF">
  <div class="max-w-7xl mx-auto px-5">
    <div class="grid lg:grid-cols-2 gap-14 items-start">
      <div>
        <p class="sl gt mb-3">Why Happy Roof in Largo</p>
        <h2 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:clamp(2rem,4vw,3rem);line-height:.95;color:#1A1A1A;letter-spacing:-.01em;margin-bottom:1.5rem">WHY LARGO HOMEOWNERS CHOOSE HAPPY ROOF</h2>
        <p style="color:#555555;font-size:1rem;line-height:1.75;margin-bottom:1.5rem">
          Largo is the third-largest city in Pinellas County and one of the most established residential communities in the Tampa Bay area. With Largo Central Park serving as the city's green heart and the Pinellas Trail running right through town, this is a city built around families and long-term homeownership. The housing stock , and you will find everything from 1960s concrete block ranch homes to recently built developments, each with distinct roofing requirements based on age, construction type, and proximity to the Gulf coast.
        </p>
        <p style="color:#555555;font-size:1rem;line-height:1.75;margin-bottom:1.5rem">
          Largo's location in the center of the Pinellas peninsula means it catches weather from every direction. Tropical systems pushing in from the Gulf hit the nearby beaches at Indian Rocks Beach and Belleair first, but Largo is close enough to receive the full force of those winds and rain. Summer thunderstorms roll through nearly every afternoon from June through September. These conditions demand a roofing system , and a contractor who understands the local building codes and Pinellas County permitting process.
        </p>
        <p style="color:#555555;font-size:1rem;line-height:1.75;margin-bottom:1.5rem">
          Happy Roof holds Florida Roofing Contractor License #CCC1337380, carries full general liability and workers' compensation insurance, and pulls all required permits with the City of Largo and Pinellas County. Whether your home is near Largo Central Park, along the Seminole border, or in the neighborhoods adjacent to Belleair, we deliver the same standard of quality and back it with an up to 15-year workmanship warranty in writing.
        </p>
      </div>
      <div class="space-y-4">
        <div class="scard p-6">
          <div class="check"><div class="check-dot"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#E6A817" stroke-width="3"><path d="M20 6L9 17l-5-5"/></svg></div><div><strong style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.05rem">Up to 15-Year Workmanship Warranty</strong><p style="color:#555555;font-size:.9rem;line-height:1.6;margin-top:.25rem">Every Largo roof we install comes with a written up to 15-year workmanship warranty, no exceptions, no fine print.</p></div></div>
        </div>
        <div class="scard p-6">
          <div class="check"><div class="check-dot"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#E6A817" stroke-width="3"><path d="M20 6L9 17l-5-5"/></svg></div><div><strong style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.05rem">Pinellas County Permits Handled</strong><p style="color:#555555;font-size:.9rem;line-height:1.6;margin-top:.25rem">We pull all required permits with the City of Largo and Pinellas County and coordinate every inspection from start to finish.</p></div></div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- SERVICES IN LARGO -->
<section class="py-20" style="background:#F7F7F7">
  <div class="max-w-7xl mx-auto px-5">
    <div class="text-center mb-14">
      <p class="sl gt mb-3">Our Services</p>
      <h2 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:clamp(2rem,4vw,3rem);line-height:.95;color:#1A1A1A;letter-spacing:-.01em">ROOFING SERVICES WE OFFER IN LARGO</h2>
    </div>
    <div class="grid md:grid-cols-3 gap-8">
      <div class="scard p-8">
        <div style="width:52px;height:52px;border-radius:14px;display:flex;align-items:center;justify-content:center;background:rgba(230,168,23,.1);margin-bottom:1rem">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#E6A817" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/></svg>
        </div>
        <h3 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.35rem;color:#1A1A1A;margin-bottom:.75rem">Roof Replacement</h3>
        <p style="color:#555555;font-size:.95rem;line-height:1.7">
          Full tear-off and replacement using Owens Corning Duration HDZ shingles, standing seam metal panels, or concrete and clay tile. Many Largo homes were built in the 1960s through 1980s and benefit significantly from a complete roof system upgrade with modern underlayment, improved ridge ventilation, and current code-compliant flashing. We handle every permit and Pinellas County inspection. Most shingle roofs are completed in 1 to 3 days.
        </p>
      </div>
      <div class="scard p-8">
        <div style="width:52px;height:52px;border-radius:14px;display:flex;align-items:center;justify-content:center;background:rgba(230,168,23,.1);margin-bottom:1rem">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#E6A817" stroke-width="2"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
        </div>
        <h3 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.35rem;color:#1A1A1A;margin-bottom:.75rem">Roof Repair</h3>
        <p style="color:#555555;font-size:.95rem;line-height:1.7">
          From missing shingles and cracked tile to damaged flashing around plumbing boots and skylights, we diagnose and fix roofing issues across Largo. The city's older housing stock means many homes have aging roof systems where a targeted repair can extend the life of the roof significantly. We respond quickly after storms and give honest recommendations. If a repair will solve the problem, that is what we advise.
        </p>
      </div>
      <div class="scard p-8">
        <div style="width:52px;height:52px;border-radius:14px;display:flex;align-items:center;justify-content:center;background:rgba(230,168,23,.1);margin-bottom:1rem">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#E6A817" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
        </div>
        <h3 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.35rem;color:#1A1A1A;margin-bottom:.75rem">Storm Damage & Insurance</h3>
        <p style="color:#555555;font-size:.95rem;line-height:1.7">
          Largo's central Pinellas County position does not spare it from Florida's severe weather. When tropical storms and hurricanes strike, we provide thorough damage assessments, document everything for your insurance claim, and work directly with your adjuster. We handle all major insurance carriers in Florida and guide Largo homeowners through the entire claims process from initial inspection to final repairs.
        </p>
      </div>
    </div>
  </div>
</section>

<!-- OUR PROCESS -->
<section class="py-20" style="background:#FFFFFF">
  <div class="max-w-7xl mx-auto px-5">
    <div class="text-center mb-14">
      <p class="sl gt mb-3">How It Works</p>
      <h2 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:clamp(2rem,4vw,3rem);line-height:.95;color:#1A1A1A;letter-spacing:-.01em">OUR 4-STEP PROCESS</h2>
    </div>
    <div class="grid md:grid-cols-2 gap-6">
      <div class="scard p-8 flex gap-5">
        <div class="step-num">1</div>
        <div>
          <h3 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.2rem;color:#1A1A1A;margin-bottom:.5rem">Free Inspection & Estimate</h3>
          <p style="color:#555555;font-size:.95rem;line-height:1.7">We inspect your roof from top to bottom, checking decking, underlayment, flashing, ventilation, and overall condition. You receive a detailed written estimate with material options, timelines, and transparent pricing. No pressure, no hidden fees.</p>
        </div>
      </div>
      <div class="scard p-8 flex gap-5">
        <div class="step-num">2</div>
        <div>
          <h3 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.2rem;color:#1A1A1A;margin-bottom:.5rem">Material Selection & Permits</h3>
          <p style="color:#555555;font-size:.95rem;line-height:1.7">Choose your roofing material and color with our guidance. We pull all permits with the City of Largo or Pinellas County, order materials from the manufacturer, and schedule installation on a date that works for you.</p>
        </div>
      </div>
      <div class="scard p-8 flex gap-5">
        <div class="step-num">3</div>
        <div>
          <h3 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.2rem;color:#1A1A1A;margin-bottom:.5rem">Professional Installation</h3>
          <p style="color:#555555;font-size:.95rem;line-height:1.7">Our crew performs the full tear-off, inspects and repairs decking as needed, installs new underlayment and flashing, and lays your new roofing system to manufacturer specifications. We protect your landscaping, driveway, and property throughout the process.</p>
        </div>
      </div>
      <div class="scard p-8 flex gap-5">
        <div class="step-num">4</div>
        <div>
          <h3 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.2rem;color:#1A1A1A;margin-bottom:.5rem">Final Inspection & Warranty</h3>
          <p style="color:#555555;font-size:.95rem;line-height:1.7">We schedule the county inspection to verify code compliance. Once passed, you receive your warranty documentation, including our up to 15-year workmanship warranty and manufacturer material warranty. We follow up at 30 days and 1 year.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- SERVICE AREA -->
<section class="py-20" style="background:#F7F7F7">
  <div class="max-w-7xl mx-auto px-5">
    <div class="text-center mb-10">
      <p class="sl gt mb-3">Largo Service Area</p>
      <h2 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:clamp(2rem,4vw,3rem);line-height:.95;color:#1A1A1A;letter-spacing:-.01em;margin-bottom:1rem">NEIGHBORHOODS WE SERVE IN LARGO</h2>
      <p style="color:#555555;font-size:1rem;line-height:1.75;max-width:700px;margin:0 auto">Happy Roof provides roofing services throughout the greater Largo area and surrounding communities in central Pinellas County. From Largo Central Park to the beach communities, we have you covered.</p>
    </div>
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-3 max-w-4xl mx-auto">
      <span class="scard px-4 py-3 text-center" style="font-size:.9rem;font-weight:600">Largo Central Park</span>
      <span class="scard px-4 py-3 text-center" style="font-size:.9rem;font-weight:600">Belleair</span>
      <span class="scard px-4 py-3 text-center" style="font-size:.9rem;font-weight:600">Belleair Bluffs</span>
      <span class="scard px-4 py-3 text-center" style="font-size:.9rem;font-weight:600">Indian Rocks Beach</span>
      <span class="scard px-4 py-3 text-center" style="font-size:.9rem;font-weight:600">Seminole</span>
      <span class="scard px-4 py-3 text-center" style="font-size:.9rem;font-weight:600">Pinellas Trail</span>
      <span class="scard px-4 py-3 text-center" style="font-size:.9rem;font-weight:600">Clearwater</span>
      <span class="scard px-4 py-3 text-center" style="font-size:.9rem;font-weight:600">Pinellas Park</span>
      <span class="scard px-4 py-3 text-center" style="font-size:.9rem;font-weight:600">Bardmoor</span>
      <span class="scard px-4 py-3 text-center" style="font-size:.9rem;font-weight:600">Ridgecrest</span>
    </div>
  </div>
</section>

<!-- FAQ -->
<section class="py-20" style="background:#FFFFFF">
  <div class="max-w-3xl mx-auto px-5">
    <div class="text-center mb-12">
      <p class="sl gt mb-3">Common Questions</p>
      <h2 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:clamp(2rem,4vw,3rem);line-height:.95;color:#1A1A1A;letter-spacing:-.01em">LARGO ROOFING FAQ</h2>
    </div>

    <div class="faq-item">
      <button class="faq-btn" aria-expanded="false" onclick="this.setAttribute('aria-expanded',this.getAttribute('aria-expanded')==='true'?'false':'true');this.nextElementSibling.classList.toggle('open')">
        How much does a roof replacement cost in Largo?
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#1A1A1A" stroke-width="2.5"><path d="M6 9l6 6 6-6"/></svg>
      </button>
      <div class="faq-answer">
        <div class="faq-answer-inner">Roof replacement costs in Largo typically range from $8,000 to $25,000+ depending on your roof's size, pitch, material choice (shingles, metal, or tile), and whether structural repairs are needed. Many Largo homes built in the 1960s through 1980s may require decking repairs or ventilation upgrades as part of a full replacement. Happy Roof provides free, detailed estimates with no hidden fees - call <a href="tel:8135957663" class="call-tracking-number" style="color:#3B9FD9;text-decoration:none;font-weight:600">(813) 595-7663</a> for a personalized quote.</div>
      </div>
    </div>

    <div class="faq-item">
      <button class="faq-btn" aria-expanded="false" onclick="this.setAttribute('aria-expanded',this.getAttribute('aria-expanded')==='true'?'false':'true');this.nextElementSibling.classList.toggle('open')">
        What roofing materials work best for Largo homes?
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#1A1A1A" stroke-width="2.5"><path d="M6 9l6 6 6-6"/></svg>
      </button>
      <div class="faq-answer">
        <div class="faq-answer-inner">Largo's central Pinellas County location means homes face Florida's full range of weather challenges: intense UV, heavy summer rain, and hurricane-force winds. Owens Corning Duration HDZ architectural shingles rated for 130+ MPH winds are the most popular choice throughout Largo. Standing seam metal roofing reflects heat and lasts 40–60 years, making it ideal for energy-conscious homeowners near the Pinellas Trail corridor. Tile roofs are common on larger homes in the Belleair and Seminole areas nearby.</div>
      </div>
    </div>

    <div class="faq-item">
      <button class="faq-btn" aria-expanded="false" onclick="this.setAttribute('aria-expanded',this.getAttribute('aria-expanded')==='true'?'false':'true');this.nextElementSibling.classList.toggle('open')">
        Does Happy Roof handle permits for Largo roofing projects?
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#1A1A1A" stroke-width="2.5"><path d="M6 9l6 6 6-6"/></svg>
      </button>
      <div class="faq-answer">
        <div class="faq-answer-inner">Yes. Happy Roof handles all permit applications with the City of Largo and Pinellas County building departments. We manage the entire permitting and inspection process. You never have to visit a government office or coordinate with an inspector yourself. All work is performed to current Florida Building Code standards.</div>
      </div>
    </div>

    <div class="faq-item">
      <button class="faq-btn" aria-expanded="false" onclick="this.setAttribute('aria-expanded',this.getAttribute('aria-expanded')==='true'?'false':'true');this.nextElementSibling.classList.toggle('open')">
        How long does a roof replacement take in Largo?
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#1A1A1A" stroke-width="2.5"><path d="M6 9l6 6 6-6"/></svg>
      </button>
      <div class="faq-answer">
        <div class="faq-answer-inner">Most Largo shingle roof replacements are completed in 1 to 3 days. Metal roofs typically take 3 to 5 days, and tile roofs may require 5 to 7 days depending on complexity. Florida's summer afternoon thunderstorms can occasionally cause brief delays, but we plan around weather and keep you updated at every stage of the project.</div>
      </div>
    </div>

    <div class="faq-item">
      <button class="faq-btn" aria-expanded="false" onclick="this.setAttribute('aria-expanded',this.getAttribute('aria-expanded')==='true'?'false':'true');this.nextElementSibling.classList.toggle('open')">
        Is Happy Roof licensed to work in Largo?
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#1A1A1A" stroke-width="2.5"><path d="M6 9l6 6 6-6"/></svg>
      </button>
      <div class="faq-answer">
        <div class="faq-answer-inner">Yes. Happy Roof LLC holds Florida Roofing Contractor License #CCC1337380, which authorizes roofing work throughout the entire state of Florida - including the City of Largo and all of Pinellas County. We carry full general liability and workers' compensation insurance, and certificates are available upon request.</div>
      </div>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="cta-grad relative overflow-hidden py-20">
  <div class="relative z-10 max-w-3xl mx-auto px-5 text-center">
    <h2 class="font-display font-black tracking-tightest mb-4" style="font-family:'Barlow Condensed',sans-serif;font-size:clamp(2.5rem,5vw,4.5rem);line-height:.92;letter-spacing:-.01em">
