const schema = `[{"@context":"https://schema.org","@type":["LocalBusiness","RoofingContractor"],"name":"Happy Roof LLC","url":"https://happyroof.com","telephone":"+1-813-595-7663","email":"info@happyroof.com","description":"Hurricane season roof preparation in Tampa Bay. Pre-storm inspections and emergency repair services. FL License #CCC1337380.","image":"/Brand%20Assets/Happy%20Roof%20Logo.jpeg","logo":"/Brand%20Assets/Happy%20Roof%20Logo.jpeg","address":{"@type":"PostalAddress","streetAddress":"141 Stevens Ave #12","addressLocality":"Oldsmar","addressRegion":"FL","postalCode":"34677","addressCountry":"US"},"hasCredential":"Florida Roofing Contractor License #CCC1337380","dateModified":"2026-04-10"},{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[
    {"@type":"Question","name":"When does hurricane season start in Florida?","acceptedAnswer":{"@type":"Answer","text":"Atlantic hurricane season officially runs from June 1 through November 30. However, storms can form outside this window. We recommend scheduling your pre-hurricane roof inspection in April or May to ensure any repairs are completed before the season begins."}},
    {"@type":"Question","name":"What should I do to prepare my roof for a hurricane?","acceptedAnswer":{"@type":"Answer","text":"Schedule a professional roof inspection to identify and fix vulnerabilities. Ensure loose shingles are secured, flashing is sealed, gutters are clear, and any damaged areas are repaired. Trim overhanging tree branches, secure or remove rooftop items, and know your insurance policy details. Happy Roof offers free pre-hurricane season inspections."}},
    {"@type":"Question","name":"What should I do if my roof is damaged during a hurricane?","acceptedAnswer":{"@type":"Answer","text":"Stay safe and do not go on the roof. Document visible damage from the ground with photos. Call Happy Roof at (813) 595-7663 for emergency tarping to prevent further water damage. Contact your insurance company to report the damage. We help with documentation and claims support."}},
    {"@type":"Question","name":"Does Happy Roof offer emergency services during hurricanes?","acceptedAnswer":{"@type":"Answer","text":"Yes. We provide emergency tarping and temporary protection as quickly as conditions safely allow after a storm. We prioritize by severity and respond as fast as possible. Save our number — (813) 595-7663 — before hurricane season so you have it when you need it."}},
    {"@type":"Question","name":"How can I tell if my roof has hurricane damage?","acceptedAnswer":{"@type":"Answer","text":"Look for missing or displaced shingles/tiles, debris on the roof, damaged gutters or downspouts, water stains on ceilings or walls, daylight visible through the attic, or shingle granules in gutters. Some damage is not visible from the ground, so a professional inspection after any significant storm is strongly recommended."}},
    {"@type":"Question","name":"Will my insurance cover hurricane damage to my roof?","acceptedAnswer":{"@type":"Answer","text":"Most Florida homeowner's insurance policies cover wind damage from hurricanes. You may have a separate hurricane or wind deductible (typically 2-5% of your home's insured value). Happy Roof documents all damage to support your claim and can meet with your insurance adjuster. File your claim promptly — most policies have strict reporting deadlines."}}
