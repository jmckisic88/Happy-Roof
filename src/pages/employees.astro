---
import BaseLayout from '../layouts/BaseLayout.astro';

const schema = `{
    "@context": "https://schema.org",
    "@type": ["LocalBusiness", "RoofingContractor"],
    "name": "Happy Roof LLC",
    "url": "https://happyroof.com",
    "telephone": "+1-813-595-7663",
    "email": "info@happyroof.com",
    "description": "Tampa Bay's trusted roofing contractor specializing in roof replacement, repair, storm damage, inspections, and new construction. Licensed & insured — FL License #CCC1337380.",
    "image": "/Brand%20Assets/Happy%20Roof%20Logo.jpeg",
    "logo": "/Brand%20Assets/Happy%20Roof%20Logo.jpeg",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "141 Stevens Ave #12","addressLocality": "Oldsmar",
      "addressRegion": "FL","postalCode": "34677",
      "addressCountry": "US"
    },
    "geo": { "@type": "GeoCoordinates", "latitude": 28.0340, "longitude": -82.6651 },
    "priceRange": "$$",
    "openingHoursSpecification": [
      { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"], "opens": "07:00", "closes": "18:00" },
      { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Saturday"], "opens": "08:00", "closes": "14:00" }
    ],
    "areaServed": [
      { "@type": "City", "name": "Tampa" },
      { "@type": "City", "name": "St. Petersburg" },
      { "@type": "City", "name": "Clearwater" },
      { "@type": "City", "name": "Brandon" },
      { "@type": "City", "name": "Wesley Chapel" },
      { "@type": "City", "name": "Riverview" },
      { "@type": "City", "name": "Lutz" },
      { "@type": "City", "name": "Land O Lakes" },
      { "@type": "City", "name": "Odessa" },
      { "@type": "City", "name": "Temple Terrace" },
      { "@type": "City", "name": "New Tampa" },
      { "@type": "City", "name": "Carrollwood" },
      { "@type": "City", "name": "Oldsmar" },
      { "@type": "City", "name": "Palm Harbor" },
      { "@type": "City", "name": "Tarpon Springs" },
      { "@type": "City", "name": "Safety Harbor" },
      { "@type": "City", "name": "Dunedin" },
      { "@type": "City", "name": "Largo" },
      { "@type": "City", "name": "Seminole" },
      { "@type": "City", "name": "New Port Richey" },
      { "@type": "City", "name": "Trinity" },
      { "@type": "City", "name": "Valrico" },
      { "@type": "City", "name": "Plant City" },
      { "@type": "City", "name": "Seffner" },
      { "@type": "City", "name": "Town n Country" },
      { "@type": "City", "name": "Citrus Park" },
      { "@type": "City", "name": "Fish Hawk" },
      { "@type": "City", "name": "Apollo Beach" },
      { "@type": "City", "name": "Sun City Center" },
      { "@type": "AdministrativeArea", "name": "Hillsborough County" },
      { "@type": "AdministrativeArea", "name": "Pinellas County" },
      { "@type": "AdministrativeArea", "name": "Pasco County" }
    ],
    "sameAs": [
      "https://www.facebook.com/share/1E27RD4hjZ/",
      "https://www.instagram.com/happyroofflorida",
      "https://www.tiktok.com/@happyrooffl",
      "https://share.google/eM5h7LtohVsqVd0Nd"
    ],
    "hasOfferCatalog": {
      "@type": "OfferCatalog",
      "name": "Roofing Services",
      "itemListElement": [
        { "@type": "OfferCatalog", "name": "Roof Replacement", "description": "Complete residential and commercial roof replacement with asphalt shingles, metal, tile, or flat roof systems" },
        { "@type": "OfferCatalog", "name": "Roof Repair", "description": "Leak repair, shingle replacement, flashing repair, and emergency tarping" },
        { "@type": "OfferCatalog", "name": "Storm Damage Repair", "description": "Hurricane and storm damage roof repair with full insurance claim assistance" },
        { "@type": "OfferCatalog", "name": "Roof Inspection", "description": "Professional roof inspections for real estate, insurance, and maintenance" },
        { "@type": "OfferCatalog", "name": "Commercial Roofing", "description": "TPO, EPDM, modified bitumen, and metal roofing for commercial properties" },
        { "@type": "OfferCatalog", "name": "New Construction Roofing", "description": "Roofing systems for new residential and commercial construction" }
      ]
    },
    "dateModified": "2026-04-10",
    "hasCredential": "Florida Roofing Contractor License #CCC1337380",
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "5.0",
      "reviewCount": "3",
      "bestRating": "5",
      "worstRating": "1"
    }
  }`;
---

<BaseLayout
  title="Employee Resources | Happy Roof"
  description="Happy Roof employee onboarding resources, training materials and team tools for our Tampa Bay roofing crew."
  canonical="https://happyroof.com/employees"
  ogTitle="Employee Resources | Happy Roof Tampa Bay"
  ogDescription="Happy Roof employee onboarding and resources for our Tampa Bay roofing team."
  schema={schema}
>

<style is:inline>
/* Buttons */
    /* Tabs */
    .tab-btn{flex:1;padding:1rem 1.5rem;font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.15rem;letter-spacing:.04em;border-radius:12px;transition:all .2s;cursor:pointer;border:2px solid transparent;background:transparent;color:#555}
    .tab-btn.active-w2{background:#E6A817;color:#fff;border-color:#E6A817;box-shadow:0 4px 20px -4px rgba(230,168,23,.5)}
    .tab-btn.active-1099{background:#3B9FD9;color:#1A1A1A;border-color:#3B9FD9;box-shadow:0 4px 20px -4px rgba(59,159,217,.45)}
    .tab-btn:not(.active-w2):not(.active-1099):hover{color:#1A1A1A;border-color:#333}
    .tab-content{display:none}.tab-content.active{display:block}
    /* Cards */
    .doc-card{background:#F7F7F7;border:1px solid #252525;border-radius:14px;padding:1.1rem 1.25rem;display:flex;align-items:flex-start;gap:.875rem;transition:border-color .2s}
    .doc-card:hover{border-color:rgba(230,168,23,.3)}
    .doc-icon{width:38px;height:38px;border-radius:10px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
    .step-num{width:44px;height:44px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:1.2rem;flex-shrink:0}
    .policy.card{background:#FFFFFF;border:1px dashed #E0E0E0;border-radius:14px;padding:1.25rem;transition:border-color .2s,transform .2s cubic-bezier(.34,1.56,.64,1)}
    .policy-card:hover{border-color:rgba(230,168,23,.25);transform:translateY(-3px)}
    .check-row{display:flex;align-items:flex-start;gap:.65rem;padding:.55rem 0;border-bottom:1px solid #1A1A1A}
    .check-row:last-child{border-bottom:none}
    .check-dot{width:18px;height:18px;border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:.1rem}
    /* Business card strip */
    .bc-strip{background:#FFFFFF;border-top:1px solid #E0E0E0;border-bottom:1px solid #E0E0E0;position:relative;overflow:hidden;padding:2.5rem 0}
    .bc-info{display:flex;flex-wrap:wrap;justify-content:center;align-items:center;gap:1rem 2rem;font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.1rem;letter-spacing:.08em;color:#333}
    .bc-info span{color:#1A1A1A}
    .bc-info .sep{color:#E0E0E0}
    /* White section */
    .white-section{background:#F5F5F5;color:#1A1A1A}
    .white-section .sl{color:#666}
    /* Brand texture */
    /* Timeline */
    .tl-item{display:flex;gap:1.25rem;position:relative}
    .tl-item:not(:last-child)::before{content:'';position:absolute;left:21px;top:44px;bottom:-1rem;width:2px;background:linear-gradient(to bottom,rgba(230,168,23,.3),transparent)}
    .tl-dot{width:44px;height:44px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:1.1rem;flex-shrink:0;position:relative;z-index:1}
</style>

<!-- HERO (White section — business card light side) -->
<section class="white-section relative overflow-hidden pt-28 pb-16">
  <!-- Repeating text texture on white -->
  <div class="relative z-10 max-w-5xl mx-auto px-5 text-center">
    <!-- Logo prominent on white -->
    <div class="flex justify-center mb-8">
      <img src="/Brand%20Assets/Happy Roof Logo.png" alt="Happy Roof" style="height:56px;width:auto" class="hidden sm:block" />
    </div>
    <h1 class="font-display font-black tracking-tightest mb-5" style="font-family:'Barlow Condensed',sans-serif;font-size:clamp(2.8rem,6vw,5rem);line-height:.9;letter-spacing:-.01em;color:#1A1A1A">
      WELCOME TO<br/>HAPPY ROOF.
    </h1>
    <p style="color:#555555;font-size:1.05rem;line-height:1.75;max-width:560px;margin:0 auto 2rem">
      This page covers everything you need to know as a new member of the Happy Roof family — whether you're joining as a W2 employee or a 1099 contractor.
    </p>
    <!-- Type selector -->
    <div class="inline-flex gap-3 p-2 rounded-2xl mx-auto" style="background:#EBEBEB">
      <button id="tab-w2" class="tab-btn active-w2" onclick="switchTab('w2')">W2 Employee</button>
      <button id="tab-1099" class="tab-btn" onclick="switchTab('1099')">1099 Contractor</button>
    </div>
  </div>
</section>

<!-- ══════ SHARED ONBOARDING ══════ -->
<section class="py-14" style="background:#FFFFFF">
  <div class="max-w-5xl mx-auto px-5">
    <p class="sl gt mb-3">Both Types</p>
    <h2 class="font-display font-black tracking-tightest mb-10" style="font-family:'Barlow Condensed',sans-serif;font-size:clamp(2rem,4vw,3rem);line-height:.93;letter-spacing:-.01em">
      WHAT EVERYONE GETS<br/><span class="gp">ON DAY ONE.</span>
    </h2>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
      <div class="doc-card">
        <div class="doc-icon" style="background:rgba(0,0,0,.06)"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#3B9FD9" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg></div>
        <div><p class="font-medium text-brand-black text-sm">Team Introduction</p><p style="color:#888888;font-size:.8rem;margin-top:.15rem">Meet your crew, project manager, and office contacts on Day 1.</p></div>
      </div>
      <div class="doc-card">
        <div class="doc-icon" style="background:rgba(59,159,217,.1)"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#3B9FD9" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg></div>
        <div><p class="font-medium text-brand-black text-sm">Safety Orientation</p><p style="color:#888888;font-size:.8rem;margin-top:.15rem">OSHA fall protection, PPE requirements, and emergency procedures.</p></div>
      </div>
      <div class="doc-card">
        <div class="doc-icon" style="background:rgba(0,0,0,.06)"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#3B9FD9" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg></div>
        <div><p class="font-medium text-brand-black text-sm">Employee Handbook</p><p style="color:#888888;font-size:.8rem;margin-top:.15rem">Company policies, expectations, and code of conduct — read and sign.</p></div>
      </div>
      <div class="doc-card">
        <div class="doc-icon" style="background:rgba(59,159,217,.1)"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#3B9FD9" stroke-width="2"><rect x="5" y="2" width="14" height="20" rx="2"/><line x1="12" y1="18" x2="12" y2="18"/></svg></div>
        <div><p class="font-medium text-brand-black text-sm">Communication Setup</p><p style="color:#888888;font-size:.8rem;margin-top:.15rem">Contact list, scheduling system access, and preferred communication channels.</p></div>
      </div>
      <div class="doc-card">
        <div class="doc-icon" style="background:rgba(0,0,0,.06)"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#3B9FD9" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg></div>
        <div><p class="font-medium text-brand-black text-sm">Schedule &amp; Hours</p><p style="color:#888888;font-size:.8rem;margin-top:.15rem">Your typical shift, reporting location, and job site start times.</p></div>
      </div>
      <div class="doc-card">
        <div class="doc-icon" style="background:rgba(59,159,217,.1)"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#3B9FD9" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg></div>
        <div><p class="font-medium text-brand-black text-sm">Job Site Tour</p><p style="color:#888888;font-size:.8rem;margin-top:.15rem">Walkthrough of an active project — materials staging, safety zones, and workflow.</p></div>
      </div>
    </div>
  </div>
</section>

<!-- ══════ TABBED W2 / 1099 CONTENT ══════ -->
<section class="py-14" style="background:#F7F7F7;border-top:1px solid #E0E0E0">
  <div class="max-w-5xl mx-auto px-5">

    <!-- TAB TOGGLE (repeat for mobile UX) -->
    <div class="flex gap-3 p-2 rounded-2xl mb-12" style="background:#F7F7F7;max-width:480px">
      <button class="tab-btn active-w2" id="tab-w2b" onclick="switchTab('w2')">W2 Employee</button>
      <button class="tab-btn" id="tab-1099b" onclick="switchTab('1099')">1099 Contractor</button>
    </div>

    <!-- ═══ W2 CONTENT ═══ -->
    <div id="content-w2" class="tab-content active">

      <!-- Required Documents -->
      <div class="mb-14">
        <p class="sl gp mb-3">Required Documents</p>
        <h2 class="font-display font-black tracking-tightest mb-6" style="font-family:'Barlow Condensed',sans-serif;font-size:clamp(1.8rem,3.5vw,2.8rem);line-height:.93;letter-spacing:-.01em">W2 PAPERWORK CHECKLIST</h2>
        <p style="color:#555555;font-size:.92rem;line-height:1.7;margin-bottom:1.75rem">All documents must be submitted before your first day on a job site. Our office will guide you through anything unclear.</p>
        <div class="grid sm:grid-cols-2 gap-3">
          <div class="doc-card" style="border-color:rgba(230,168,23,.18)">
            <div class="doc-icon" style="background:rgba(0,0,0,.06)"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#3B9FD9" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg></div>
            <div><p class="font-medium text-brand-black text-sm">I-9 Form (Employment Eligibility)</p><p style="color:#888888;font-size:.78rem;margin-top:.12rem">Section 1 completed before Day 1. Bring original documents — List A, or B+C.</p></div>
          </div>
          <div class="doc-card" style="border-color:rgba(230,168,23,.18)">
            <div class="doc-icon" style="background:rgba(0,0,0,.06)"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#3B9FD9" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg></div>
            <div><p class="font-medium text-brand-black text-sm">W-4 (Federal Withholding)</p><p style="color:#888888;font-size:.78rem;margin-top:.12rem">Complete and submit to office before first payroll.</p></div>
          </div>
          <div class="doc-card" style="border-color:rgba(230,168,23,.18)">
            <div class="doc-icon" style="background:rgba(0,0,0,.06)"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#3B9FD9" stroke-width="2"><rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg></div>
            <div><p class="font-medium text-brand-black text-sm">Direct Deposit Authorization</p><p style="color:#888888;font-size:.78rem;margin-top:.12rem">Bank name, routing &amp; account numbers, plus a voided check or bank letter.</p></div>
          </div>
          <div class="doc-card" style="border-color:rgba(230,168,23,.18)">
            <div class="doc-icon" style="background:rgba(0,0,0,.06)"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#3B9FD9" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg></div>
            <div><p class="font-medium text-brand-black text-sm">Government-Issued Photo ID</p><p style="color:#888888;font-size:.78rem;margin-top:.12rem">Driver's license, state ID, or passport — current and unexpired.</p></div>
          </div>
          <div class="doc-card" style="border-color:rgba(230,168,23,.18)">
            <div class="doc-icon" style="background:rgba(0,0,0,.06)"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#3B9FD9" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg></div>
            <div><p class="font-medium text-brand-black text-sm">Social Security Card or Proof of SSN</p><p style="color:#888888;font-size:.78rem;margin-top:.12rem">Required for I-9 and payroll setup. Original document preferred.</p></div>
          </div>
          <div class="doc-card" style="border-color:rgba(230,168,23,.18)">
            <div class="doc-icon" style="background:rgba(0,0,0,.06)"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#3B9FD9" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.18 2 2 0 0 1 3.58 1h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 8.96a16 16 0 0 0 6.13 6.13l.82-.82a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg></div>
            <div><p class="font-medium text-brand-black text-sm">Emergency Contact Form</p><p style="color:#888888;font-size:.78rem;margin-top:.12rem">Name, relationship, and two contact numbers. Required for safety records.</p></div>
          </div>
          <div class="doc-card">
            <div class="doc-icon" style="background:rgba(230,168,23,.06)"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#666" stroke-width="2"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg></div>
            <div><p class="font-medium text-brand-black text-sm">Background Check Consent</p><p style="color:#888888;font-size:.78rem;margin-top:.12rem">Standard pre-employment screening. Results reviewed confidentially.</p></div>
          </div>
          <div class="doc-card">
            <div class="doc-icon" style="background:rgba(230,168,23,.06)"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#666" stroke-width="2"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg></div>
            <div><p class="font-medium text-brand-black text-sm">Drug Screening Consent</p><p style="color:#888888;font-size:.78rem;margin-top:.12rem">Pre-employment drug test required. Job-site safety is non-negotiable.</p></div>
          </div>
        </div>
      </div>

      <!-- Payroll & Benefits -->
      <div class="mb-14">
        <p class="sl gp mb-3">Compensation</p>
        <h2 class="font-display font-black tracking-tightest mb-6" style="font-family:'Barlow Condensed',sans-serif;font-size:clamp(1.8rem,3.5vw,2.8rem);line-height:.93;letter-spacing:-.01em">PAY &amp; BENEFITS</h2>
        <div class="grid sm:grid-cols-2 gap-5">
          <div class="policy-card" style="border-color:rgba(230,168,23,.15)">
            <div class="w-10 h-10 rounded-xl flex items-center justify-center mb-3" style="background:rgba(230,168,23,.1)"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#3B9FD9" stroke-width="2"><rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg></div>
            <h4 class="font-display font-bold text-brand-black mb-3" style="font-family:'Barlow Condensed',sans-serif;font-size:1.2rem">Payroll</h4>
            <div class="check-row"><div class="check-dot" style="background:rgba(230,168,23,.1)"><svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="#3B9FD9" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg></div><p style="color:#555555;font-size:.84rem">Bi-weekly pay schedule (every other Friday)</p></div>
            <div class="check-row"><div class="check-dot" style="background:rgba(230,168,23,.1)"><svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="#3B9FD9" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg></div><p style="color:#555555;font-size:.84rem">Direct deposit — set up in first week</p></div>
            <div class="check-row"><div class="check-dot" style="background:rgba(230,168,23,.1)"><svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="#3B9FD9" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg></div><p style="color:#555555;font-size:.84rem">Federal &amp; state taxes withheld automatically</p></div>
            <div class="check-row"><div class="check-dot" style="background:rgba(230,168,23,.1)"><svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="#3B9FD9" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg></div><p style="color:#555555;font-size:.84rem">W-2 issued each January</p></div>
            <div class="check-row"><div class="check-dot" style="background:rgba(230,168,23,.1)"><svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="#3B9FD9" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg></div><p style="color:#555555;font-size:.84rem">Overtime paid at 1.5× for hours over 40/week</p></div>
