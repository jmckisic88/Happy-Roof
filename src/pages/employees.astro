<script is:inline>
function switchTab(type) {
  document.getElementById('content-w2').classList.toggle('active', type === 'w2');
  document.getElementById('content-1099').classList.toggle('active', type === '1099');
  ['tab-w2','tab-w2b'].forEach(id => {
    const el = document.getElementById(id);
    if(el){ el.className = 'tab-btn ' + (type==='w2' ? 'active-w2' : ''); }
  });
  ['tab-1099','tab-1099b'].forEach(id => {
    const el = document.getElementById(id);
    if(el){ el.className = 'tab-btn ' + (type==='1099' ? 'active-1099' : ''); }
  });
}
function toggleFaq(el) {
  const isOpen = el.classList.contains('open');
  document.querySelectorAll('.faq-item').forEach(i => i.classList.remove('open'));
  if (!isOpen) el.classList.add('open');
}
</script>

