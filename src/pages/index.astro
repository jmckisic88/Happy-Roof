---

<BaseLayout
  title="Happy Roof — Tampa Bay Roofing Contractor | Licensed & Insured"
  description="Happy Roof is Tampa Bay's trusted roofing contractor. Licensed & insured for roof replacement, repair, storm damage, inspections, and new construction. Free estimates."
  canonical="https://happyroof.com/"
  ogTitle="Happy Roof — Tampa Bay's Trusted Roofing Contractor"
  ogDescription="Expert roof replacement, repair, storm damage & inspections in Tampa Bay. Licensed & insured. Free estimates — call (813) 595-7663."
  activePage="home"
  schema={schema}
>

<style is:inline>
/* ── Hero slideshow ── */
    /* ── Gradients ── */
    /* ── Nav ── */
    /* ── Buttons ── */
    /* ── Cards ── */
    /* ── Section label ── */
    /* ── Trust badge ── */
    /* ── Stats bar ── */
    /* ── Brand partner card ── */
    /* ── CTA gradient ── */
    /* ── Mobile nav toggle ── */
    /* ── Testimonial ── */
    /* ── Step card ── */
    /* ── Footer ── */
    /* ── Form ── */
        .hero-bg .btn-t{width:100%;justify-content:center;font-size:1rem !important;padding:.85rem 1.5rem !important}
        .hero-bg .badge{font-size:.7rem;padding:.3rem .6rem}
      }
</style>

<!-- ══════════════════════ HERO ══════════════════════ -->
<section class="hero-bg relative overflow-hidden pt-28 pb-20">
  <!-- Cycling roof photo background -->
  <div class="hero-slideshow" aria-hidden="true" style="background-image:url('/Brand%20Assets/Photos/architectural-shingle-roof-tampa-bay.jpg')">
    <div class="hero-slide active" style="background-image:url('/Brand%20Assets/Photos/architectural-shingle-roof-tampa-bay.jpg')"></div>
    <div class="hero-slide" style="background-image:url('/Brand%20Assets/Photos/4055F5E2-0A81-4BAC-A34D-586DC69AFF69_1_105_c.jpeg')"></div>
    <div class="hero-slide" style="background-image:url('/Brand%20Assets/Photos/commercial-tpo-roof-tampa.jpg')"></div>
    <div class="hero-overlay"></div>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-5 grid lg:grid-cols-2 gap-12 items-center">
    <div>
      <!-- Badges -->
      <div class="flex flex-wrap gap-2 mb-8">
        <span class="badge"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>Licensed &amp; Insured</span>
        <span class="badge"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>Tampa Bay Local</span>
        <span class="badge"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>Expert Team</span>
      </div>
      <!-- Headline -->
      <h1 class="font-display font-extrabold leading-none tracking-tight mb-5" style="font-size:clamp(2.8rem,5.5vw,4.6rem);line-height:.93;color:#1A1A1A;text-transform:uppercase;letter-spacing:-.01em">
        YOUR ROOF PROTECTS<br/>
        EVERYTHING.<br/>
        <span class="gt">WE PROTECT<br/>YOUR ROOF.</span>
      </h1>
      <p class="mb-8 max-w-lg" style="color:#555555;font-size:1.05rem;line-height:1.75">
        Get a straight answer, a fair price, and a crew that shows up on time. Every job backed by our 15-year workmanship warranty.
      </p>
      <div class="flex flex-wrap items-center gap-4 mb-10">
        <a href="tel:8135957663" class="btn-t call-tracking-number" style="font-size:1rem;padding:.75rem 1.5rem">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          CALL NOW — (813) 595-7663
        </a>
      </div>
      <p style="color:#888888;font-size:.75rem;letter-spacing:.07em">LICENSED &amp; INSURED &nbsp;·&nbsp; FL #CCC1337380</p>
    </div>

    <!-- Right: estimate form -->
    <div>
      <div style="background:#F7F7F7;border:1px solid #E0E0E0;border-radius:20px;padding:1.75rem 1.75rem 1.5rem;box-shadow:0 24px 64px -12px rgba(44,24,16,.08),0 8px 24px -8px rgba(44,24,16,.05)">
        <p class="font-display font-bold" style="font-family:'Barlow Condensed',sans-serif;font-size:1.4rem;color:#1A1A1A;letter-spacing:.01em;margin-bottom:.2rem">Get a Free Estimate</p>
        <p style="font-size:.82rem;color:#555555;margin-bottom:1.25rem">We typically respond within 1 business day.</p>
        <form id="hero-form" onsubmit="submitHeroForm(event)" novalidate>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mb-3">
            <div>
              <label class="flabel">Name <span style="color:#3B9FD9">*</span></label>
              <input type="text" name="name" class="finput" placeholder="Jane Smith" required />
            </div>
            <div>
              <label class="flabel">Phone <span style="color:#3B9FD9">*</span></label>
              <input type="tel" name="phone" class="finput" placeholder="(813) 555-0000" required />
            </div>
          </div>
          <div class="mb-3">
            <label class="flabel">Email</label>
            <input type="email" name="email" class="finput" placeholder="jane@example.com" />
          </div>
          <div class="mb-4">
            <label class="flabel">Promo Code</label>
            <div style="position:relative">
              <input type="text" name="promo_code" class="finput promo-input" placeholder="e.g. POSTCARD26" style="text-transform:uppercase;padding-right:2.5rem" />
              <span class="promo-status" style="position:absolute;right:.75rem;top:50%;transform:translateY(-50%);font-size:1rem;line-height:1;display:none"></span>
            </div>
            <p class="promo-msg" style="font-size:.75rem;margin-top:.35rem;line-height:1.4;display:none"></p>
          </div>
          <!-- SMS Consent -->
          <div class="mb-4">
            <p style="font-size:.8rem;font-weight:700;color:#1A1A1A;margin-bottom:.5rem">Do you agree to receive text messages from Happy Roof?</p>
            <div style="display:flex;gap:1.5rem;margin-bottom:.75rem">
              <label style="display:flex;align-items:center;gap:.4rem;cursor:pointer;font-size:.85rem;color:#1A1A1A;font-weight:600">
                <input type="radio" name="sms_consent" value="Yes" required style="width:16px;height:16px;accent-color:#3B9FD9;cursor:pointer" /> Yes
              </label>
              <label style="display:flex;align-items:center;gap:.4rem;cursor:pointer;font-size:.85rem;color:#1A1A1A;font-weight:600">
                <input type="radio" name="sms_consent" value="No" style="width:16px;height:16px;accent-color:#3B9FD9;cursor:pointer" /> No
              </label>
            </div>
            <div style="display:flex;align-items:flex-start;gap:.5rem;margin-bottom:.5rem">
              <input type="checkbox" id="privacy-consent-hero" name="privacy_consent" required style="width:16px;height:16px;min-width:16px;margin-top:.15rem;accent-color:#3B9FD9;cursor:pointer" />
              <label for="privacy-consent-hero" style="font-size:.72rem;color:#555555;line-height:1.55;cursor:pointer">I acknowledge and agree to receive SMS messages from Happy Roof. Message frequency varies. Message and data rates may apply. Reply STOP to opt out, HELP for help.</label>
            </div>
            <p style="font-size:.68rem;color:#888;line-height:1.5;margin:0">See our <a href="https://www.happyroof.com/privacy" style="color:#3B9FD9;text-decoration:underline" target="_blank">Privacy Policy</a> &amp; <a href="https://www.happyroof.com/terms" style="color:#3B9FD9;text-decoration:underline" target="_blank">Terms &amp; Conditions</a> for more details.</p>
          </div>
          <div id="hero-success" style="display:none;background:rgba(59,159,217,.08);border:1px solid rgba(59,159,217,.25);border-radius:10px;padding:.875rem 1rem;margin-bottom:1rem;text-align:center">
            <p style="color:#3B9FD9;font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.05rem">Request sent! We'll be in touch soon.</p>
          </div>
          <button type="submit" class="btn-t" style="width:100%;justify-content:center;font-size:1.05rem;padding:.9rem">
            Get My Free Estimate <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </button>
          <p style="text-align:center;font-size:.7rem;color:#888888;margin-top:.75rem;letter-spacing:.04em">NO OBLIGATION &nbsp;·&nbsp; LICENSED &amp; INSURED &nbsp;·&nbsp; #CCC1337380</p>
        </form>
      </div>
    </div>
  </div>

  <!-- Scroll hint -->
  <div class="relative z-10 flex justify-center pb-10">
    <div class="flex flex-col items-center gap-2" style="opacity:.3;color:#1A1A1A">
      <p style="font-size:.68rem;letter-spacing:.15em;font-weight:500;text-transform:uppercase">Scroll</p>
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg>
    </div>
  </div>
</section>

<!-- Trust Signals -->
<section style="background:#F7F7F7;border-top:1px solid #E0E0E0;border-bottom:1px solid #E0E0E0;padding:1.5rem 0">
  <div class="max-w-7xl mx-auto px-5">
