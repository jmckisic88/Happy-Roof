<script is:inline>
// ── Form submission config ──
function submitHeroForm(e) {
  e.preventDefault();
  const form = e.target;
  const req = form.querySelectorAll('[required]');
  let valid = true;
  req.forEach(el => { el.style.borderColor=''; if (!el.value.trim()) { el.style.borderColor='#EF4444'; valid=false; } });
  if (!valid) return;
  const btn = form.querySelector('button[type=submit]');
  btn.disabled = true; btn.textContent = 'Sending…';
  const formData = {
    _subject: 'New Estimate Request — Happy Roof Website',
    _source: 'homepage',
    _page: window.location.pathname,
    name: (form.querySelector('[name=name]')||{}).value||'',
    phone: (form.querySelector('[name=phone]')||{}).value||'',
    email: (form.querySelector('[name=email]')||{}).value||'',
    promo_code: (form.querySelector('[name=promo_code]')||{}).value||'',
    sms_consent: (form.querySelector('[name=sms_consent]:checked')||{}).value||'No',
    source: 'happy-roof-website'
  };
  var promoNote = formData.promo_code ? 'Promo Code: ' + formData.promo_code.toUpperCase() : '';
  // Send to BOTH ServiceTitan and email (belt + suspenders)
  const stPayload = { name: formData.name, phone: formData.phone, email: formData.email, notes: promoNote, source: 'Website - Homepage', page: window.location.pathname };
  Promise.allSettled([
    fetch('/api/submit-lead', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify(stPayload) }),
    fetch('https://formsubmit.co/ajax/info@happyroof.com', { method:'POST', headers:{'Content-Type':'application/json','Accept':'application/json'}, body:JSON.stringify(formData) })
  ]).finally(() => {
    document.getElementById('hero-success').style.display = 'block';
    form.querySelectorAll('input,select,textarea').forEach(el => el.disabled = true);
    btn.style.display = 'none';
  });
}

// ── Hero slideshow ──
// Container always has a background image so there's never a blank frame
(function(){
  const slides = document.querySelectorAll('.hero-slide');
  const container = document.querySelector('.hero-slideshow');
  if (slides.length < 2) return;
  let current = 0;
  setInterval(function(){
    slides[current].classList.remove('active');
    current = (current + 1) % slides.length;
    slides[current].classList.add('active');
    // Update container bg to current so it's always the fallback
    container.style.backgroundImage = slides[current].style.backgroundImage;
  }, 5000);
})();
</script>

