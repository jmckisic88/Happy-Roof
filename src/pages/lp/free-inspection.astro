<!-- HEADER -->
<header style="background:#FFFFFF;border-bottom:1px solid #E0E0E0;padding:.75rem 1.5rem">
  <div class="max-w-5xl mx-auto flex items-center justify-between">
    <img src="../Brand Assets/Happy Roof Logo.png" alt="Happy Roof" style="height:48px;width:auto" />
    <a href="tel:8135957663" class="call-tracking-number" style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.15rem;color:#3B9FD9;text-decoration:none;display:flex;align-items:center;gap:.4rem">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#3B9FD9" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
      (813) 595-7663
    </a>
  </div>
</header>

<!-- HERO + FORM -->
<section class="relative overflow-hidden" style="min-height:calc(100vh - 70px)">
  <div class="hero-photo-bg" style="background-image:url('../Brand Assets/Photos/tpo-roof-chimney-flashing-tampa.jpg')"></div>
  <div class="hero-photo-overlay"></div>
  <div class="relative z-10 max-w-5xl mx-auto px-5 py-12">
    <div class="grid lg:grid-cols-2 gap-10 items-start lp-grid" style="grid-template-columns:1fr 1fr">
      <!-- Left: Copy -->
      <div class="pt-4">
        <p class="sl gp mb-3">100% Free · No Obligation</p>
        <h1 style="font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:clamp(2.5rem,5vw,4rem);line-height:.92;letter-spacing:-.01em;color:#1A1A1A;margin-bottom:1.25rem">
          FREE ROOF<br/>INSPECTION<br/><span class="gt">TAMPA BAY.</span>
        </h1>
        <p style="color:#555555;font-size:1.05rem;line-height:1.75;margin-bottom:2rem;max-width:480px">
          Know your roof's condition before the next storm. Happy Roof's licensed inspectors check everything, for free.
        </p>

        <h3 style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.1rem;color:#1A1A1A;margin-bottom:1rem">WHAT'S INCLUDED:</h3>
        <div class="space-y-3 mb-8">
          <div class="flex gap-3 items-start">
            <div class="step-num">01</div>
            <div><strong style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:.95rem">Roofing Material Assessment</strong><p style="color:#555555;font-size:.82rem;margin-top:.1rem">Shingles, metal, tile - we check every surface for damage and wear.</p></div>
          </div>
          <div class="flex gap-3 items-start">
            <div class="step-num">02</div>
            <div><strong style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:.95rem">Flashing, Sealant &amp; Penetrations</strong><p style="color:#555555;font-size:.82rem;margin-top:.1rem">Vents, pipes, skylights - the #1 source of leaks.</p></div>
          </div>
          <div class="flex gap-3 items-start">
            <div class="step-num">03</div>
            <div><strong style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:.95rem">Gutters &amp; Drainage</strong><p style="color:#555555;font-size:.82rem;margin-top:.1rem">Proper flow prevents fascia rot and foundation damage.</p></div>
          </div>
          <div class="flex gap-3 items-start">
            <div class="step-num">04</div>
            <div><strong style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:.95rem">Attic &amp; Ventilation Check</strong><p style="color:#555555;font-size:.82rem;margin-top:.1rem">Heat buildup destroys shingles from below. We check airflow.</p></div>
          </div>
          <div class="flex gap-3 items-start">
            <div class="step-num">05</div>
            <div><strong style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:.95rem">Photo Report Delivered in 24h</strong><p style="color:#555555;font-size:.82rem;margin-top:.1rem">Detailed written report with photos, yours to keep, no strings attached.</p></div>
          </div>
        </div>
        <div style="background:rgba(59,159,217,.08);border:1px solid rgba(59,159,217,.2);border-radius:12px;padding:1rem 1.25rem;display:inline-block">
          <p style="font-size:.85rem;color:#555555;margin:0">Prefer to call?</p>
          <a href="tel:8135957663" class="call-tracking-number" style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.5rem;color:#3B9FD9;text-decoration:none">(813) 595-7663</a>
        </div>
      </div>
      <!-- Right: Form -->
      <div style="background:#FFFFFF;border:1px solid #E0E0E0;border-radius:16px;padding:2rem;box-shadow:0 8px 40px -8px rgba(0,0,0,.1)">
        <h2 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.5rem;color:#1A1A1A;margin-bottom:.5rem;text-align:center">SCHEDULE YOUR FREE INSPECTION</h2>
        <p style="color:#555555;font-size:.9rem;text-align:center;margin-bottom:1.5rem">Takes 30 seconds. We'll confirm your appointment within 24 hours.</p>
        <form id="lp-form" onsubmit="return submitForm(event)">
          <div style="display:flex;flex-direction:column;gap:.75rem">
            <input type="text" name="name" placeholder="Full Name" required />
            <input type="tel" name="phone" placeholder="Phone Number" required />
            <input type="email" name="email" placeholder="Email Address" required />
            <input type="text" name="address" placeholder="Property Address" required />
            <input type="text" name="_subject" value="LP: Free Roof Inspection Request" style="display:none" />
            <button type="submit" class="btn-t" style="margin-top:.5rem">Schedule My Free Inspection <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg></button>
          </div>
        </form>
        <div id="form-success" style="display:none;text-align:center;padding:2rem 0">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#E6A817" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M9 12l2 2 4-4"/></svg>
          <h3 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.3rem;margin-top:.75rem;color:#1A1A1A">You're All Set!</h3>
          <p style="color:#555555;font-size:.9rem;margin-top:.25rem">We'll confirm your inspection within 24 hours.</p>
        </div>
        <div style="display:flex;align-items:center;justify-content:center;gap:1rem;margin-top:1.25rem;flex-wrap:wrap">
          <span style="font-size:.7rem;color:#999999;display:flex;align-items:center;gap:.3rem"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#E6A817" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg>100% Free</span>
          <span style="font-size:.7rem;color:#999999;display:flex;align-items:center;gap:.3rem"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#E6A817" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg>No Obligation</span>
          <span style="font-size:.7rem;color:#999999;display:flex;align-items:center;gap:.3rem"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#E6A817" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg>FL #CCC1337380</span>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- STICKY MOBILE CTA -->

<script is:inline>
function submitForm(e){
  e.preventDefault();
  var form=e.target;
  var data=new FormData(form);
  var obj={};data.forEach(function(v,k){obj[k]=v});
  // ServiceTitan + FormSubmit fallback
  var stPayload = { name: obj.name||'', phone: obj.phone||'', email: obj.email||'', service: 'PPC Lead - Free Inspection', notes: obj.address||'', source: 'PPC - Free Inspection', page: '/lp/free-inspection' };
  fetch('/api/submit-lead', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify(stPayload) })
    .then(function(r){ return r.ok ? r.json() : Promise.reject(); })
    .catch(function(){ return fetch('https://formsubmit.co/ajax/info@happyroof.com', { method:'POST', headers:{'Content-Type':'application/json','Accept':'application/json'}, body:JSON.stringify(obj) }); })
    .finally(function(){
      form.style.display='none';
      document.getElementById('form-success').style.display='block';
    });
  return false;
}
</script>

