  <meta charset="UTF-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Free Roof Inspection Tampa Bay | Happy Roof</title>
  <meta name="robots" content="noindex, nofollow" />
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com" /><link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;600;700;800;900&family=Nunito:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    *{box-sizing:border-box}body{background:#FFFFFF;color:#1A1A1A;font-family:'Nunito',sans-serif;margin:0}html{scroll-behavior:smooth}
    .gp{color:#E6A817}.gt{color:#3B9FD9}
    .sl{font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:.82rem;letter-spacing:.2em;text-transform:uppercase}
    .btn-t{background:#E6A817;color:#1A1A1A;border-radius:8px;font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.05rem;letter-spacing:.04em;padding:.85rem 2rem;transition:background .18s,transform .2s cubic-bezier(.34,1.56,.64,1),box-shadow .18s;box-shadow:0 4px 24px -4px rgba(230,168,23,.48);display:inline-flex;align-items:center;justify-content:center;gap:.45rem;text-decoration:none;width:100%;cursor:pointer;border:none}
    .btn-t:hover{background:#F0C040;transform:translateY(-2px)}
    .btn-t:focus-visible{outline:2px solid #E6A817;outline-offset:3px}
    .btn-t:active{transform:translateY(0)}
    .check{display:flex;align-items:flex-start;gap:.6rem;margin-bottom:.85rem}
    .check-dot{width:20px;height:20px;border-radius:50%;display:flex;align-items:center;justify-content:center;background:rgba(230,168,23,.1);flex-shrink:0;margin-top:.15rem}
    .hero-photo-bg{position:absolute;inset:0;background-size:cover;background-position:center;z-index:0}
    .hero-photo-overlay{position:absolute;inset:0;background:linear-gradient(135deg,rgba(255,255,255,.82) 0%,rgba(255,255,255,.75) 40%,rgba(255,255,255,.65) 100%);z-index:1}
    .step-num{width:40px;height:40px;border-radius:12px;display:flex;align-items:center;justify-content:center;background:rgba(230,168,23,.1);font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.1rem;color:#E6A817;flex-shrink:0}
    input[type="text"],input[type="email"],input[type="tel"]{width:100%;padding:.75rem 1rem;border:1.5px solid #E0E0E0;border-radius:8px;font-family:'Nunito',sans-serif;font-size:.95rem;color:#1A1A1A;transition:border-color .18s;background:#FFFFFF}
    input:focus{outline:none;border-color:#E6A817;box-shadow:0 0 0 3px rgba(230,168,23,.15)}
    input::placeholder{color:#999999}
    @media(max-width:767px){.lp-grid{grid-template-columns:1fr !important}}
  </style>
<meta property="og:image" content="https://www.happyroof.com/Brand%20Assets/Happy%20Roof%20Logo_Alt.png">
