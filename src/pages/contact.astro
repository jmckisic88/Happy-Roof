<script is:inline>
function toggleFaq(el) {
  const isOpen = el.classList.contains('open');
  document.querySelectorAll('.faq-item').forEach(i => i.classList.remove('open'));
  if (!isOpen) el.classList.add('open');
}
function handleSubmit(e) {
  e.preventDefault();
  const form = e.target;
  const inputs = form.querySelectorAll('input,select,textarea');
  const data = { _subject: 'New Contact Form - Happy Roof Website' };
  inputs.forEach(el => { if (el.name) data[el.name] = el.type==='checkbox' ? (el.checked?'Yes':'No') : el.value; });
  const btn = form.querySelector('button[type=submit]');
  btn.disabled = true; btn.textContent = 'Sending…';
  // Send to BOTH ServiceTitan and email (belt + suspenders)
  var promoNote = data.promo_code ? 'Promo Code: ' + data.promo_code.toUpperCase() : '';
  const stPayload = { name: data.name||'', phone: data.phone||'', email: data.email||'', notes: promoNote, source: 'Website - Contact', page: window.location.pathname };
  Promise.allSettled([
    fetch('/api/submit-lead', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify(stPayload) }),
    fetch('https://formsubmit.co/ajax/info@happyroof.com', { method:'POST', headers:{'Content-Type':'application/json','Accept':'application/json'}, body:JSON.stringify(data) })
  ]).finally(() => {
    document.getElementById('success-msg').classList.remove('hidden');
    form.style.display = 'none';
  });
}
</script>

