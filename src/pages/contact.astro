---

<BaseLayout
  title="Contact Happy Roof | Free Estimates | (813) 595-7663"
  description="Get a free roofing estimate in Tampa Bay. Call (813) 595-7663 or submit our online form. We respond within 24 hours!"
  canonical="https://happyroof.com/contact"
  ogTitle="Free Roofing Estimate | Happy Roof Tampa Bay"
  ogDescription="Request your free roofing estimate in Tampa Bay. Call (813) 595-7663 or fill out our quick online form. We respond within 24 hours."
  activePage="contact"
  schema={schema}
>

<style is:inline>
/* Form */
    .fgroup{margin-bottom:1.1rem}
    /* Contact info card */
    .info.card{background:#FFFFFF;border:1px dashed #E0E0E0;border-radius:16px;padding:1.25rem 1.5rem;display:flex;align-items:flex-start;gap:.875rem;transition:border-color .2s}
    .info-card:hover{border-color:rgba(230,168,23,.25)}
    .info-icon{width:40px;height:40px;border-radius:10px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
    /* ── Hero photo bg ── */
</style>

<!-- HERO -->
<section class="pt-32 pb-16 relative overflow-hidden" style="background:#F5F5F5;border-bottom:1px solid #E5E5E5">
  <!-- Hero background photo -->
  <div class="hero-photo-bg" style="background-image:url('/Brand%20Assets/Photos/commercial-tpo-roof-tampa.jpg')"></div>
  <div class="hero-photo-overlay"></div>
  <div class="relative z-10 max-w-7xl mx-auto px-5 text-center">
    <p class="sl gp mb-4">Get in Touch</p>
    <h1 class="font-display font-black tracking-tightest mb-4" style="font-family:'Barlow Condensed',sans-serif;font-size:clamp(3rem,6vw,5rem);line-height:.92;letter-spacing:-.01em;color:#1A1A1A">
      LET'S TALK ROOFING.
    </h1>
    <p class="max-w-xl mx-auto" style="color:#555555;font-size:1.05rem;line-height:1.75">
      No call centers. No automated responses. Fill out the form or call us directly, and a real person from our team will get back to you within 24 hours.
    </p>
  </div>
</section>

<!-- Trust Signals -->
<section style="background:#F7F7F7;border-top:1px solid #E0E0E0;border-bottom:1px solid #E0E0E0;padding:1.5rem 0">
  <div class="max-w-7xl mx-auto px-5">
    <div style="display:flex;flex-wrap:wrap;align-items:center;justify-content:center;gap:2rem 3rem">
      <div style="display:flex;align-items:center;gap:.5rem"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#E6A817" stroke-width="2"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg><span style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:.85rem;color:#1A1A1A;letter-spacing:.02em">OWENS CORNING INSTALLER</span></div>
      <div style="display:flex;align-items:center;gap:.5rem"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#3B9FD9" stroke-width="2"><path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg><span style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:.85rem;color:#1A1A1A;letter-spacing:.02em">FL LICENSE #CCC1337380</span></div>
      <div style="display:flex;align-items:center;gap:.5rem"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#E6A817" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg><span style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:.85rem;color:#1A1A1A;letter-spacing:.02em">FULLY INSURED & BONDED</span></div>
      <div style="display:flex;align-items:center;gap:.5rem"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#3B9FD9" stroke-width="2"><path d="M12 2v4m0 12v4M4.93 4.93l2.83 2.83m8.48 8.48l2.83 2.83M2 12h4m12 0h4M4.93 19.07l2.83-2.83m8.48-8.48l2.83-2.83"/></svg><span style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:.85rem;color:#1A1A1A;letter-spacing:.02em">15-YEAR WARRANTY OPTION</span></div>
    </div>
  </div>
</section>


<!-- CONTACT INFO STRIP -->
<div style="background:#F7F7F7;border-top:1px solid #E0E0E0;border-bottom:1px solid #E0E0E0">
  <div class="max-w-7xl mx-auto px-5 py-5">
    <div class="flex flex-wrap justify-center gap-4">
      <a href="tel:8135957663" class="call-tracking-number flex items-center gap-3 px-5 py-3 rounded-xl transition-colors" style="background:#F7F7F7;border:1px solid #E0E0E0">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#3B9FD9" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.18 2 2 0 0 1 3.58 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.96a16 16 0 0 0 6.13 6.13l.82-.82a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        <div><p style="color:#555555;font-size:.68rem;letter-spacing:.1em">CALL OR TEXT</p><p class="font-display font-bold" style="font-family:'Barlow Condensed',sans-serif;color:#3B9FD9;font-size:1rem">(813) 595-7663</p></div>
      </a>
      <div class="flex items-center gap-3 px-5 py-3 rounded-xl" style="background:#F7F7F7;border:1px solid #E0E0E0">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#F0C040" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        <div><p style="color:#555555;font-size:.68rem;letter-spacing:.1em">HOURS</p><p class="font-display font-bold" style="font-family:'Barlow Condensed',sans-serif;color:#1A1A1A;font-size:1rem">Mon–Fri 9am–5pm</p></div>
      </div>
      <div class="flex items-center gap-3 px-5 py-3 rounded-xl" style="background:#F7F7F7;border:1px solid #E0E0E0">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#3B9FD9" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
        <div><p style="color:#555555;font-size:.68rem;letter-spacing:.1em">LOCATION</p><p class="font-display font-bold" style="font-family:'Barlow Condensed',sans-serif;color:#1A1A1A;font-size:1rem">Tampa Bay, FL</p></div>
      </div>
      <div class="flex items-center gap-3 px-5 py-3 rounded-xl" style="background:#F7F7F7;border:1px solid #E0E0E0">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#F0C040" stroke-width="2"><path d="M13 2 3 14h9l-1 8 10-12h-9l1-8z"/></svg>
        <div><p style="color:#555555;font-size:.68rem;letter-spacing:.1em">EMERGENCY</p><p class="font-display font-bold" style="font-family:'Barlow Condensed',sans-serif;color:#1A1A1A;font-size:1rem">48-hr Response</p></div>
      </div>
    </div>
  </div>
</div>

<!-- MAIN CONTENT -->
<section id="form" class="py-20" style="background:#FFFFFF">
  <div class="max-w-7xl mx-auto px-5">
    <div class="grid lg:grid-cols-5 gap-12">

      <!-- Form (3/5) -->
      <div class="lg:col-span-3">
        <div id="estimate-form" class="rounded-2xl p-8" style="background:#F7F7F7;border:1px solid #E0E0E0;box-shadow:0 24px 60px -12px rgba(0,0,0,.4);scroll-margin-top:75px">
          <h2 class="font-display font-black tracking-tightest mb-2" style="font-family:'Barlow Condensed',sans-serif;font-size:1.8rem;line-height:.95;letter-spacing:-.01em">GET A FREE ESTIMATE</h2>
          <p style="color:#888888;font-size:.85rem;margin-bottom:1.75rem">We typically respond within 1 business day.</p>

<form onsubmit="handleSubmit(event)">
            <div class="grid sm:grid-cols-2 gap-4 mb-0">
              <div class="fgroup">
                <label class="flabel">Name <span style="color:#3B9FD9">*</span></label>
                <input type="text" name="name" class="finput" placeholder="Jane Smith" required />
              </div>
              <div class="fgroup">
                <label class="flabel">Phone <span style="color:#3B9FD9">*</span></label>
                <input type="tel" name="phone" class="finput" placeholder="(813) 555-0000" required />
              </div>
            </div>
            <div class="fgroup">
              <label class="flabel">Email</label>
              <input type="email" name="email" class="finput" placeholder="jane@example.com" />
            </div>
            <div class="fgroup">
              <label class="flabel">Promo Code</label>
              <div style="position:relative">
                <input type="text" name="promo_code" class="finput promo-input" placeholder="e.g. POSTCARD26" style="text-transform:uppercase;padding-right:2.5rem" />
                <span class="promo-status" style="position:absolute;right:.75rem;top:50%;transform:translateY(-50%);font-size:1rem;line-height:1;display:none"></span>
              </div>
              <p class="promo-msg" style="font-size:.75rem;margin-top:.35rem;line-height:1.4;display:none"></p>
            </div>
            <!-- SMS Consent -->
            <div class="fgroup">
              <p style="font-size:.8rem;font-weight:700;color:#1A1A1A;margin-bottom:.5rem">Do you agree to receive text messages from Happy Roof?</p>
              <div style="display:flex;gap:1.5rem;margin-bottom:.75rem">
                <label style="display:flex;align-items:center;gap:.4rem;cursor:pointer;font-size:.85rem;color:#1A1A1A;font-weight:600">
                  <input type="radio" name="sms_consent" value="Yes" required style="width:16px;height:16px;accent-color:#3B9FD9;cursor:pointer" /> Yes
                </label>
                <label style="display:flex;align-items:center;gap:.4rem;cursor:pointer;font-size:.85rem;color:#1A1A1A;font-weight:600">
                  <input type="radio" name="sms_consent" value="No" style="width:16px;height:16px;accent-color:#3B9FD9;cursor:pointer" /> No
                </label>
              </div>
              <div style="display:flex;align-items:flex-start;gap:.5rem;margin-bottom:.5rem">
                <input type="checkbox" id="privacy-consent" name="privacy_consent" required style="width:16px;height:16px;min-width:16px;margin-top:.15rem;accent-color:#3B9FD9;cursor:pointer" />
                <label for="privacy-consent" style="font-size:.72rem;color:#555555;line-height:1.55;cursor:pointer">I acknowledge and agree to receive SMS messages from Happy Roof. Message frequency varies. Message and data rates may apply. Reply STOP to opt out, HELP for help.</label>
              </div>
              <p style="font-size:.68rem;color:#888;line-height:1.5;margin:0">See our <a href="https://www.happyroof.com/privacy" style="color:#3B9FD9;text-decoration:underline">Privacy Policy</a> &amp; <a href="https://www.happyroof.com/terms" style="color:#3B9FD9;text-decoration:underline">Terms &amp; Conditions</a> for more details.</p>
            </div>
            <button type="submit" class="btn-t w-full justify-center" style="font-size:1.1rem;padding:1rem">
              Get My Free Estimate
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </button>
          </form>

          <!-- Success message (hidden by default) -->
          <div id="success-msg" class="hidden mt-5 p-5 rounded-xl text-center" style="background:rgba(59,159,217,.08);border:1px solid rgba(59,159,217,.2)">
            <p style="font-size:1.5rem;margin-bottom:.5rem;color:#3B9FD9"><svg style="width:1em;height:1em;display:inline-block;vertical-align:-.1em" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg"><circle cx="10" cy="10" r="8.5" stroke="currentColor" stroke-width="1.5"/><circle cx="7" cy="7.5" r="1" fill="currentColor"/><circle cx="13" cy="7.5" r="1" fill="currentColor"/><path d="M6.5 12c1 3 6 3 7 0" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg></p>
            <p class="font-display font-bold text-brand-black" style="font-family:'Barlow Condensed',sans-serif;font-size:1.2rem">Request Sent!</p>
            <p style="color:#555555;font-size:.88rem;margin-top:.35rem">We'll be in touch within 24 hours, usually same day.</p>
          </div>
        </div>
      </div>

      <!-- Sidebar (2/5) -->
      <div class="lg:col-span-2 flex flex-col gap-6">

        <!-- Why contact us -->
        <div>
          <p class="sl gt mb-4">What to Expect</p>
          <div class="flex flex-col gap-4">
            <div class="flex items-start gap-3">
              <div class="w-8 h-8 rounded-full flex items-center justify-center font-display font-bold text-sm flex-shrink-0" style="font-family:'Barlow Condensed',sans-serif;background:rgba(0,0,0,.06);color:#F0C040;border:1px solid rgba(230,168,23,.2)">1</div>
              <div><p class="font-medium text-brand-black text-sm">We respond within 24 hours</p><p style="color:#888888;font-size:.83rem;margin-top:.2rem">Usually same day. A real team member, not an auto-reply.</p></div>
            </div>
            <div class="flex items-start gap-3">
              <div class="w-8 h-8 rounded-full flex items-center justify-center font-display font-bold text-sm flex-shrink-0" style="font-family:'Barlow Condensed',sans-serif;background:rgba(59,159,217,.1);color:#3B9FD9;border:1px solid rgba(59,159,217,.18)">2</div>
              <div><p class="font-medium text-brand-black text-sm">We schedule a free inspection</p><p style="color:#888888;font-size:.83rem;margin-top:.2rem">We come to you. No fee, no obligation, no pressure.</p></div>
            </div>
            <div class="flex items-start gap-3">
              <div class="w-8 h-8 rounded-full flex items-center justify-center font-display font-bold text-sm flex-shrink-0" style="font-family:'Barlow Condensed',sans-serif;background:rgba(0,0,0,.06);color:#F0C040;border:1px solid rgba(230,168,23,.2)">3</div>
              <div><p class="font-medium text-brand-black text-sm">We give you a clear written quote</p><p style="color:#888888;font-size:.83rem;margin-top:.2rem">Line-by-line breakdown. No hidden add-ons.</p></div>
            </div>
            <div class="flex items-start gap-3">
              <div class="w-8 h-8 rounded-full flex items-center justify-center font-display font-bold text-sm flex-shrink-0" style="font-family:'Barlow Condensed',sans-serif;background:rgba(59,159,217,.1);color:#3B9FD9;border:1px solid rgba(59,159,217,.18)">4</div>
              <div><p class="font-medium text-brand-black text-sm">You decide when you're ready</p><p style="color:#888888;font-size:.83rem;margin-top:.2rem">No upselling, no expiring offers, no follow-up pressure.</p></div>
            </div>
          </div>
        </div>

        <!-- Direct contact -->
        <div class="flex flex-col gap-3">
          <a href="tel:8135957663" class="call-tracking-number info-card" style="text-decoration:none">
            <div class="info-icon" style="background:rgba(59,159,217,.1)"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#3B9FD9" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.18 2 2 0 0 1 3.58 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.96a16 16 0 0 0 6.13 6.13l.82-.82a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg></div>
            <div><p style="color:#888888;font-size:.72rem;letter-spacing:.08em;text-transform:uppercase">Call or Text</p><p class="font-display font-bold" style="font-family:'Barlow Condensed',sans-serif;color:#3B9FD9;font-size:1.15rem">(813) 595-7663</p><p style="color:#888888;font-size:.78rem;margin-top:.1rem">Mon–Fri, 9am–5pm</p></div>
          </a>
          <a href="https://happyroof.com" class="info-card" style="text-decoration:none">
            <div class="info-icon" style="background:rgba(230,168,23,.1)"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#F0C040" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg></div>
            <div><p style="color:#888888;font-size:.72rem;letter-spacing:.08em;text-transform:uppercase">Website</p><p class="font-display font-bold" style="font-family:'Barlow Condensed',sans-serif;color:#F0C040;font-size:1.05rem">happyroof.com</p></div>
          </a>
          <div class="info-card">
            <div class="info-icon" style="background:rgba(230,168,23,.1)"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#F0C040" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg></div>
            <div><p style="color:#888888;font-size:.72rem;letter-spacing:.08em;text-transform:uppercase">Service Area</p><p class="font-display font-bold" style="font-family:'Barlow Condensed',sans-serif;color:#1A1A1A;font-size:1rem">Tampa Bay, FL</p><p style="color:#888888;font-size:.78rem;margin-top:.1rem">Hillsborough · Pinellas · Pasco</p></div>
          </div>
        </div>

        <!-- Urgent? -->
        <div class="rounded-xl p-5" style="background:rgba(239,68,68,.05);border:1px solid rgba(239,68,68,.15)">
