---
import BaseLayout from '../layouts/BaseLayout.astro';

const schema = `[{
    "@context": "https://schema.org",
    "@type": ["LocalBusiness", "RoofingContractor"],
    "name": "Happy Roof LLC",
    "url": "https://happyroof.com",
    "telephone": "+1-813-595-7663",
    "email": "info@happyroof.com",
    "description": "Largo roof replacement contractor. Shingle, metal, and tile roofing. Licensed and insured. FL License #CCC1337380.",
    "image": "/Brand%20Assets/Happy%20Roof%20Logo.jpeg",
    "logo": "/Brand%20Assets/Happy%20Roof%20Logo.jpeg",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "141 Stevens Ave #12",
      "addressLocality": "Oldsmar",
      "addressRegion": "FL",
      "postalCode": "34677",
      "addressCountry": "US"
    },
    "areaServed": {
      "@type": "City",
      "name": "Largo",
      "containedInPlace": { "@type": "State", "name": "Florida" }
    },
    "hasCredential": "Florida Roofing Contractor License #CCC1337380"
  },{
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How much does a roof replacement cost in Largo?",
        "acceptedAnswer": { "@type": "Answer", "text": "Largo roof replacement typically costs $8,000 to $25,000 depending on roof size, material (shingles, metal, or tile), pitch, and structural condition. Many Largo homes are single-story ranches with straightforward roof lines, which can help keep costs moderate. Call (813) 595-7663 for a free estimate." }
      },
      {
        "@type": "Question",
        "name": "What roofing material is best for Largo homes?",
        "acceptedAnswer": { "@type": "Answer", "text": "Owens Corning Duration HDZ architectural shingles are the most popular choice in Largo — they offer 130+ MPH wind rating, excellent durability, and competitive pricing. Standing seam metal is growing in popularity for its longevity and energy efficiency. Tile works well for homes with the right architectural style and structural support." }
      },
      {
        "@type": "Question",
        "name": "How long does a roof replacement take in Largo?",
        "acceptedAnswer": { "@type": "Answer", "text": "Shingle roofs: 1-3 days. Metal: 3-5 days. Tile: 5-7 days. Largo's summer thunderstorms may cause minor delays, but we schedule around weather and keep you informed." }
      },
      {
        "@type": "Question",
        "name": "Does Happy Roof handle City of Largo permits?",
        "acceptedAnswer": { "@type": "Answer", "text": "Yes. We manage all permitting with the City of Largo and Pinellas County building departments, including scheduling and attending all required inspections. Our FL License #CCC1337380 authorizes roofing work statewide." }
      }
    ]
  }]`;
---

<BaseLayout
  title="Largo Roof Replacement — Licensed & Insured | Happy Roof"
  description="Largo roof replacement by Happy Roof — licensed & insured Florida contractor. Shingle, metal & tile. 15-year warranty. FL License #CCC1337380. Free estimates: (813) 595-7663."
  canonical="https://happyroof.com/largo-roof-replacement"
  schema={schema}
>

<style is:inline>
.check-dot{width:20px;height:20px;border-radius:50%;display:flex;align-items:center;justify-content:center;background:rgba(230,168,23,.1);flex-shrink:0;margin-top:.15rem}
    .step-num{width:48px;height:48px;border-radius:14px;display:flex;align-items:center;justify-content:center;background:rgba(230,168,23,.1);font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.25rem;color:#E6A817;flex-shrink:0}
</style>

<!-- HERO -->
<section class="pt-32 pb-20 relative overflow-hidden" style="background:#F5F5F5;border-bottom:1px solid #E5E5E5">
  <div class="hero-photo-bg" style="background-image:url('/Brand%20Assets/Photos/standing-seam-metal-roof-tampa.jpg')"></div>
  <div class="hero-photo-overlay"></div>
  <div class="relative z-10 max-w-7xl mx-auto px-5 text-center">
    <p class="sl gp mb-4">Largo Roof Replacement</p>
    <h1 class="font-display font-black tracking-tightest mb-5" style="font-family:'Barlow Condensed',sans-serif;font-size:clamp(2.5rem,5.5vw,4.5rem);line-height:.92;letter-spacing:-.01em;color:#1A1A1A">
      LARGO ROOF REPLACEMENT<br/><span class="gt">LICENSED & INSURED</span>
    </h1>
    <p class="max-w-2xl mx-auto" style="color:#555555;font-size:1.05rem;line-height:1.75">
      Happy Roof provides full roof replacement in Largo, FL — the largest city in Pinellas County. From the established homes of Largo Central Park to the waterfront properties along the Intracoastal, we install shingle, metal, and tile roofing systems built for Florida's demanding climate.
    </p>
    <div class="flex flex-wrap gap-3 justify-center mt-8">
      <a href="/contact" class="btn-t">Get a Free Estimate <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg></a>
      <a href="tel:8135957663" class="btn-o call-tracking-number">Call (813) 595-7663</a>
    </div>
  </div>
</section>

<!-- INFO STRIP -->
<div style="background:#FFFFFF;border-top:2px solid #E6A817;border-bottom:1px solid #E0E0E0;padding:.85rem 0">
  <div class="max-w-7xl mx-auto px-5">
    <div class="flex flex-wrap items-center justify-center gap-x-8 gap-y-2 font-display font-bold text-sm tracking-widest" style="color:#1A1A1A;text-transform:uppercase;font-family:'Barlow Condensed',sans-serif">
      <span>Largo, FL</span><span style="color:#E6A817">·</span><span>CCC1337380</span><span style="color:#E6A817">·</span><span>HappyRoof.com</span><span style="color:#E6A817">·</span><span style="color:#3B9FD9">(813) 595-7663</span>
    </div>
  </div>
</div>

<!-- WHY SECTION -->
<section class="py-20" style="background:#FFFFFF">
  <div class="max-w-7xl mx-auto px-5">
    <div class="grid lg:grid-cols-2 gap-14 items-start">
      <div>
        <p class="sl gt mb-3">Why Replace Your Roof in Largo</p>
        <h2 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:clamp(2rem,4vw,3rem);line-height:.95;color:#1A1A1A;letter-spacing:-.01em;margin-bottom:1.5rem">WHY LARGO HOMEOWNERS CHOOSE A FULL ROOF REPLACEMENT</h2>
        <p style="color:#555555;font-size:1rem;line-height:1.75;margin-bottom:1.5rem">Largo is the largest city in Pinellas County, home to over 84,000 residents spread across a mix of post-war ranch homes, 1970s subdivisions, and newer planned communities. The city sits in the geographic center of the Pinellas peninsula, giving it exposure to Gulf storms from the west and Tampa Bay weather systems from the east. Largo's roofing challenges mirror much of Pinellas County — intense UV, heavy summer rain, and hurricane-season winds — but the city's older housing stock means a higher percentage of homes with roofs that have reached or exceeded their designed lifespan.</p>
        <p style="color:#555555;font-size:1rem;line-height:1.75;margin-bottom:1.5rem">Neighborhoods near Largo Central Park, along Indian Rocks Road, and south of Ulmerton Road contain thousands of concrete block homes from the 1960s and 1970s whose original or second-generation shingle roofs are now well past the 20-year mark. The communities around Largo High School and near the Pinellas Trail include a mix of older single-family homes and townhome complexes that share similar aging challenges. A full tear-off and replacement is the most thorough way to address widespread deterioration and bring these homes up to current Florida Building Code wind resistance standards.</p>
        <p style="color:#555555;font-size:1rem;line-height:1.75;margin-bottom:1.5rem">Happy Roof handles every step of roof replacement in Largo — from the initial free inspection through material selection, permitting with the City of Largo and Pinellas County, professional installation, and final inspection. We hold Florida License #CCC1337380 and provide a 15-year workmanship warranty on every job. Visit our <a href="/largo-roofing" style="color:#3B9FD9;text-decoration:none;font-weight:600">Largo roofing page</a> for all services.</p>
      </div>
      <div class="space-y-4">
        <div class="scard p-6">
          <div class="check"><div class="check-dot"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#E6A817" stroke-width="3"><path d="M20 6L9 17l-5-5"/></svg></div><div><strong style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.05rem">Architectural Shingles</strong><p style="color:#555555;font-size:.9rem;line-height:1.6;margin-top:.25rem">Owens Corning Duration HDZ rated for 130+ MPH winds. The go-to choice for Largo homeowners seeking durability, aesthetics, and value.</p></div></div>
        </div>
        <div class="scard p-6">
          <div class="check"><div class="check-dot"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#E6A817" stroke-width="3"><path d="M20 6L9 17l-5-5"/></svg></div><div><strong style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.05rem">Standing Seam Metal</strong><p style="color:#555555;font-size:.9rem;line-height:1.6;margin-top:.25rem">Heat-reflective, hurricane-rated, and built to last 40-60 years. Increasingly popular in Largo for both energy savings and storm resistance.</p></div></div>
        </div>
        <div class="scard p-6">
          <div class="check"><div class="check-dot"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#E6A817" stroke-width="3"><path d="M20 6L9 17l-5-5"/></svg></div><div><strong style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.05rem">Concrete & Clay Tile</strong><p style="color:#555555;font-size:.9rem;line-height:1.6;margin-top:.25rem">Extremely durable option with 50+ year lifespan. Well-suited for Largo homes with Mediterranean or Florida-style design.</p></div></div>
        </div>
        <div class="scard p-6">
          <div class="check"><div class="check-dot"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#E6A817" stroke-width="3"><path d="M20 6L9 17l-5-5"/></svg></div><div><strong style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.05rem">15-Year Workmanship Warranty</strong><p style="color:#555555;font-size:.9rem;line-height:1.6;margin-top:.25rem">Every Largo roof replacement includes our written 15-year workmanship warranty and the manufacturer's material warranty.</p></div></div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- WHAT'S INCLUDED / COMMON REPAIRS / WHAT WE CHECK -->
<section class="py-20" style="background:#F7F7F7">
  <div class="max-w-7xl mx-auto px-5">
    <div class="text-center mb-14">
      <p class="sl gt mb-3">What's Included</p>
      <h2 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:clamp(2rem,4vw,3rem);line-height:.95;color:#1A1A1A;letter-spacing:-.01em">EVERY LARGO ROOF REPLACEMENT INCLUDES</h2>
    </div>
    <div class="grid md:grid-cols-3 gap-8">
      <div class="scard p-8">
        <div style="width:52px;height:52px;border-radius:14px;display:flex;align-items:center;justify-content:center;background:rgba(230,168,23,.1);margin-bottom:1rem">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#E6A817" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        </div>
        <h3 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.35rem;color:#1A1A1A;margin-bottom:.75rem">Full Tear-Off & Decking Inspection</h3>
        <p style="color:#555555;font-size:.95rem;line-height:1.7">Complete removal of existing roofing, thorough decking inspection, and replacement of any damaged or rotted plywood before your new roof is installed.</p>
      </div>
      <div class="scard p-8">
        <div style="width:52px;height:52px;border-radius:14px;display:flex;align-items:center;justify-content:center;background:rgba(230,168,23,.1);margin-bottom:1rem">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#E6A817" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        </div>
        <h3 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.35rem;color:#1A1A1A;margin-bottom:.75rem">Premium Underlayment & Flashing</h3>
        <p style="color:#555555;font-size:.95rem;line-height:1.7">Peel-and-stick synthetic underlayment across the full deck, new flashing at all penetrations, valleys, and drip edges for complete waterproofing.</p>
      </div>
      <div class="scard p-8">
        <div style="width:52px;height:52px;border-radius:14px;display:flex;align-items:center;justify-content:center;background:rgba(230,168,23,.1);margin-bottom:1rem">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#E6A817" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        </div>
        <h3 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.35rem;color:#1A1A1A;margin-bottom:.75rem">Permits, Inspections & Cleanup</h3>
        <p style="color:#555555;font-size:.95rem;line-height:1.7">All City of Largo and Pinellas County permits handled, inspections coordinated, and post-installation cleanup including magnetic nail sweeps.</p>
      </div>
    </div>
  </div>
</section>

<!-- OUR PROCESS -->
<section class="py-20" style="background:#FFFFFF">
  <div class="max-w-7xl mx-auto px-5">
    <div class="text-center mb-14">
      <p class="sl gt mb-3">How It Works</p>
      <h2 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:clamp(2rem,4vw,3rem);line-height:.95;color:#1A1A1A;letter-spacing:-.01em">OUR 4-STEP REPLACEMENT PROCESS</h2>
    </div>
    <div class="grid md:grid-cols-2 gap-6">
      <div class="scard p-8 flex gap-5">
        <div class="step-num">1</div>
        <div>
          <h3 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.2rem;color:#1A1A1A;margin-bottom:.5rem">Free Roof Inspection</h3>
          <p style="color:#555555;font-size:.95rem;line-height:1.7">Detailed inspection of your Largo roof with a written estimate covering material options, timelines, and pricing.</p>
        </div>
      </div>
      <div class="scard p-8 flex gap-5">
        <div class="step-num">2</div>
        <div>
          <h3 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.2rem;color:#1A1A1A;margin-bottom:.5rem">Material Selection & Permits</h3>
          <p style="color:#555555;font-size:.95rem;line-height:1.7">Choose your roofing material with guidance from our team. We handle permits with the City of Largo and Pinellas County.</p>
        </div>
      </div>
      <div class="scard p-8 flex gap-5">
        <div class="step-num">3</div>
        <div>
          <h3 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.2rem;color:#1A1A1A;margin-bottom:.5rem">Professional Installation</h3>
          <p style="color:#555555;font-size:.95rem;line-height:1.7">Full tear-off, decking repair, underlayment, flashing, and new roofing system installed to manufacturer specifications.</p>
        </div>
      </div>
      <div class="scard p-8 flex gap-5">
        <div class="step-num">4</div>
        <div>
          <h3 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.2rem;color:#1A1A1A;margin-bottom:.5rem">Final Inspection & Warranty</h3>
          <p style="color:#555555;font-size:.95rem;line-height:1.7">County inspection to confirm code compliance. You receive your 15-year workmanship warranty and manufacturer warranty documentation.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- SERVICE AREA -->
<section class="py-20" style="background:#F7F7F7">
  <div class="max-w-7xl mx-auto px-5">
    <div class="text-center mb-10">
      <p class="sl gt mb-3">Largo Service Area</p>
      <h2 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:clamp(2rem,4vw,3rem);line-height:.95;color:#1A1A1A;letter-spacing:-.01em;margin-bottom:1rem">LARGO NEIGHBORHOODS & COMMUNITIES WE SERVE</h2>
      <p style="color:#555555;font-size:1rem;line-height:1.75;max-width:700px;margin:0 auto">Happy Roof provides roof replacement throughout Largo and all of Pinellas County.</p>
    </div>
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-3 max-w-4xl mx-auto">
      <span class="scard px-4 py-3 text-center" style="font-size:.9rem;font-weight:600">Largo Central Park</span>
      <span class="scard px-4 py-3 text-center" style="font-size:.9rem;font-weight:600">Indian Rocks Road</span>
      <span class="scard px-4 py-3 text-center" style="font-size:.9rem;font-weight:600">Ridgecrest</span>
      <span class="scard px-4 py-3 text-center" style="font-size:.9rem;font-weight:600">Belcher Road</span>
      <span class="scard px-4 py-3 text-center" style="font-size:.9rem;font-weight:600">Rosery Road</span>
      <span class="scard px-4 py-3 text-center" style="font-size:.9rem;font-weight:600">Largo Mall Area</span>
      <span class="scard px-4 py-3 text-center" style="font-size:.9rem;font-weight:600">Bardmoor</span>
      <span class="scard px-4 py-3 text-center" style="font-size:.9rem;font-weight:600">Imperial Point</span>
      <span class="scard px-4 py-3 text-center" style="font-size:.9rem;font-weight:600">Countryside North</span>
      <span class="scard px-4 py-3 text-center" style="font-size:.9rem;font-weight:600">Ulmerton Road</span>
      <span class="scard px-4 py-3 text-center" style="font-size:.9rem;font-weight:600">Pinellas Trail</span>
      <span class="scard px-4 py-3 text-center" style="font-size:.9rem;font-weight:600">Largo High Area</span>
      <span class="scard px-4 py-3 text-center" style="font-size:.9rem;font-weight:600">West Bay Drive</span>
      <span class="scard px-4 py-3 text-center" style="font-size:.9rem;font-weight:600">Clearwater-Largo Rd</span>
      <span class="scard px-4 py-3 text-center" style="font-size:.9rem;font-weight:600">Keene's Pointe</span>
    </div>
  </div>
</section>

<!-- FAQ -->
<section class="py-20" style="background:#FFFFFF">
  <div class="max-w-3xl mx-auto px-5">
    <div class="text-center mb-12">
      <p class="sl gt mb-3">Common Questions</p>
      <h2 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:clamp(2rem,4vw,3rem);line-height:.95;color:#1A1A1A;letter-spacing:-.01em">LARGO ROOF REPLACEMENT FAQ</h2>
    </div>
    <div class="faq-item">
      <button class="faq-btn" aria-expanded="false" onclick="this.setAttribute('aria-expanded',this.getAttribute('aria-expanded')==='true'?'false':'true');this.nextElementSibling.classList.toggle('open')">
        How much does a roof replacement cost in Largo?
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#1A1A1A" stroke-width="2.5"><path d="M6 9l6 6 6-6"/></svg>
      </button>
      <div class="faq-answer"><div class="faq-answer-inner">Largo roof replacement typically costs $8,000 to $25,000 depending on roof size, material (shingles, metal, or tile), pitch, and structural condition. Many Largo homes are single-story ranches with straightforward roof lines, which can help keep costs moderate. Call <a href="tel:8135957663" class="call-tracking-number" style="color:#3B9FD9;text-decoration:none;font-weight:600">(813) 595-7663</a> for a free estimate.</div></div>
    </div>
    <div class="faq-item">
      <button class="faq-btn" aria-expanded="false" onclick="this.setAttribute('aria-expanded',this.getAttribute('aria-expanded')==='true'?'false':'true');this.nextElementSibling.classList.toggle('open')">
        What roofing material is best for Largo homes?
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#1A1A1A" stroke-width="2.5"><path d="M6 9l6 6 6-6"/></svg>
      </button>
      <div class="faq-answer"><div class="faq-answer-inner">Owens Corning Duration HDZ architectural shingles are the most popular choice in Largo — they offer 130+ MPH wind rating, excellent durability, and competitive pricing. Standing seam metal is growing in popularity for its longevity and energy efficiency. Tile works well for homes with the right architectural style and structural support.</div></div>
    </div>
    <div class="faq-item">
      <button class="faq-btn" aria-expanded="false" onclick="this.setAttribute('aria-expanded',this.getAttribute('aria-expanded')==='true'?'false':'true');this.nextElementSibling.classList.toggle('open')">
        How long does a roof replacement take in Largo?
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#1A1A1A" stroke-width="2.5"><path d="M6 9l6 6 6-6"/></svg>
      </button>
      <div class="faq-answer"><div class="faq-answer-inner">Shingle roofs: 1-3 days. Metal: 3-5 days. Tile: 5-7 days. Largo's summer thunderstorms may cause minor delays, but we schedule around weather and keep you informed.</div></div>
    </div>
    <div class="faq-item">
      <button class="faq-btn" aria-expanded="false" onclick="this.setAttribute('aria-expanded',this.getAttribute('aria-expanded')==='true'?'false':'true');this.nextElementSibling.classList.toggle('open')">
        Does Happy Roof handle City of Largo permits?
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#1A1A1A" stroke-width="2.5"><path d="M6 9l6 6 6-6"/></svg>
      </button>
      <div class="faq-answer"><div class="faq-answer-inner">Yes. We manage all permitting with the City of Largo and Pinellas County building departments, including scheduling and attending all required inspections. Our FL License #CCC1337380 authorizes roofing work statewide.</div></div>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="cta-grad relative overflow-hidden py-20">
  <div class="relative z-10 max-w-3xl mx-auto px-5 text-center">
    <h2 class="font-display font-black tracking-tightest mb-4" style="font-family:'Barlow Condensed',sans-serif;font-size:clamp(2.5rem,5vw,4.5rem);line-height:.92;letter-spacing:-.01em">
      READY FOR A NEW ROOF<span style="color:#F0C040">?</span>
    </h2>
    <p style="color:rgba(255,248,240,.85);font-size:1rem;line-height:1.75;margin-bottom:2rem">Call us or request a free estimate online — we respond within 24 hours.</p>
    <div class="flex flex-wrap gap-3 justify-center">
      <a href="/contact" class="btn-t" style="font-size:1.15rem;padding:1rem 2.5rem">Get My Free Estimate <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg></a>
      <a href="tel:8135957663" class="btn-o call-tracking-number" style="font-size:1.05rem;padding:1rem 2.5rem">Call Now — No Obligation</a>
