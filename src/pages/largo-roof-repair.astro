---
import BaseLayout from '../layouts/BaseLayout.astro';

const schema = `[{
    "@context": "https://schema.org",
    "@type": ["LocalBusiness", "RoofingContractor"],
    "name": "Happy Roof LLC",
    "url": "https://happyroof.com",
    "telephone": "+1-813-595-7663",
    "email": "info@happyroof.com",
    "description": "Largo roof repair contractor. Emergency leak repair, storm damage, and general roofing repairs. FL License #CCC1337380.",
    "image": "/Brand%20Assets/Happy%20Roof%20Logo.jpeg",
    "logo": "/Brand%20Assets/Happy%20Roof%20Logo.jpeg",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "141 Stevens Ave #12",
      "addressLocality": "Oldsmar",
      "addressRegion": "FL",
      "postalCode": "34677",
      "addressCountry": "US"
    },
    "areaServed": {
      "@type": "City",
      "name": "Largo",
      "containedInPlace": { "@type": "State", "name": "Florida" }
    },
    "hasCredential": "Florida Roofing Contractor License #CCC1337380",
    "dateModified": "2026-04-10"
  },{
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How quickly can you respond to a roof emergency in Largo?",
        "acceptedAnswer": { "@type": "Answer", "text": "We provide same-day emergency tarping for active leaks throughout Largo and Pinellas County. Permanent repairs are typically scheduled within a few days depending on the scope of work and weather conditions." }
      },
      {
        "@type": "Question",
        "name": "When should I repair vs. replace my Largo roof?",
        "acceptedAnswer": { "@type": "Answer", "text": "If your Largo roof is under 15 years old and damage is localized, repair is usually the smart choice. If your roof is 20+ years old with widespread issues, replacement is often more cost-effective long-term. We provide honest guidance based on what we find during inspection." }
      },
      {
        "@type": "Question",
        "name": "Does insurance cover roof repairs in Largo?",
        "acceptedAnswer": { "@type": "Answer", "text": "Storm and wind damage repairs are typically covered by Florida homeowners insurance. We document all damage with detailed photos and can work with your insurance adjuster to support your claim." }
      },
      {
        "@type": "Question",
        "name": "How much does a roof repair cost in Largo?",
        "acceptedAnswer": { "@type": "Answer", "text": "Minor repairs (shingle replacement, flashing reseal) cost $300-$1,500. Larger repairs involving multiple areas or decking work range from $1,500-$5,000+. Free inspection and written estimate always provided first." }
      }
    ]
  }]`;
---

<BaseLayout
  title="Largo Roof Repair | Emergency Leak Repair | Happy Roof"
  description="Largo roof repair: emergency leak repair by Happy Roof. Storm damage, missing shingles, flashing repair & more. FL License #CCC1337380. Call (813) 595-7663."
  canonical="https://happyroof.com/largo-roof-repair"
  schema={schema}
>

<style is:inline>
.check-dot{width:20px;height:20px;border-radius:50%;display:flex;align-items:center;justify-content:center;background:rgba(230,168,23,.1);flex-shrink:0;margin-top:.15rem}
    .step-num{width:48px;height:48px;border-radius:14px;display:flex;align-items:center;justify-content:center;background:rgba(230,168,23,.1);font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.25rem;color:#E6A817;flex-shrink:0}
</style>

<!-- HERO -->
<section class="pt-32 pb-20 relative overflow-hidden" style="background:#F5F5F5;border-bottom:1px solid #E5E5E5">
  <div class="hero-photo-bg" style="background-image:url('/Brand%20Assets/Photos/commercial-tpo-roof-tampa.jpg')"></div>
  <div class="hero-photo-overlay"></div>
  <div class="relative z-10 max-w-7xl mx-auto px-5 text-center">
    <p class="sl gp mb-4">Largo Roof Repair</p>
