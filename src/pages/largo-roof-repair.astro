          <h3 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.2rem;color:#1A1A1A;margin-bottom:.5rem">Transparent Quote</h3>
          <p style="color:#555555;font-size:.95rem;line-height:1.7">Written estimate with itemized costs. No surprise charges and no pressure to do more than what is necessary.</p>
        </div>
      </div>
      <div class="scard p-8 flex gap-5">
        <div class="step-num">3</div>
        <div>
          <h3 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.2rem;color:#1A1A1A;margin-bottom:.5rem">Expert Repair</h3>
          <p style="color:#555555;font-size:.95rem;line-height:1.7">Quality materials matched to your existing roof, installed by experienced crews. Complete property protection throughout.</p>
        </div>
      </div>
      <div class="scard p-8 flex gap-5">
        <div class="step-num">4</div>
        <div>
          <h3 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.2rem;color:#1A1A1A;margin-bottom:.5rem">Follow-Up & Warranty</h3>
          <p style="color:#555555;font-size:.95rem;line-height:1.7">We follow up to verify the repair is performing well. All work backed by our workmanship warranty.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- SERVICE AREA -->
<section class="py-20" style="background:#F7F7F7">
  <div class="max-w-7xl mx-auto px-5">
    <div class="text-center mb-10">
      <p class="sl gt mb-3">Largo Service Area</p>
      <h2 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:clamp(2rem,4vw,3rem);line-height:.95;color:#1A1A1A;letter-spacing:-.01em;margin-bottom:1rem">LARGO NEIGHBORHOODS WE SERVE</h2>
      <p style="color:#555555;font-size:1rem;line-height:1.75;max-width:700px;margin:0 auto">Happy Roof provides roof repair throughout Largo and Pinellas County.</p>
