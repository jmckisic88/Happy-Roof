<script is:inline src="https://cdn.sheetjs.com/xlsx-0.20.3/package/dist/xlsx.full.min.js"></script>
<script is:inline>
(function() {
  /* ── Password Gate ── */
  const PASS = 'HAPPY';
  const lockScreen = document.getElementById('lock-screen');
  const appContent = document.getElementById('app-content');
  const pwForm = document.getElementById('pw-form');
  const pwInput = document.getElementById('pw-input');
  const pwError = document.getElementById('pw-error');

  // Check if already authenticated this session
  if (sessionStorage.getItem('hr-comm-auth') === '1') {
    lockScreen.style.display = 'none';
    appContent.classList.remove('hidden');
  }

  pwForm.addEventListener('submit', function(e) {
    e.preventDefault();
    if (pwInput.value.trim() === PASS) {
      sessionStorage.setItem('hr-comm-auth', '1');
      lockScreen.style.opacity = '1';
      lockScreen.style.transition = 'opacity .3s ease';
      lockScreen.style.opacity = '0';
      setTimeout(function() {
        lockScreen.style.display = 'none';
        appContent.classList.remove('hidden');
      }, 300);
    } else {
      pwError.classList.remove('hidden');
      pwInput.value = '';
      pwInput.focus();
      pwInput.style.borderColor = '#e53e3e';
      setTimeout(function() { pwInput.style.borderColor = ''; }, 1500);
    }
  });

  /* ── Data stores ── */
  let role = 'rep'; // 'rep' | 'mgr'
  let jobs = [];
  let recruitSales = [];

  /* ── Commission tiers ── */
  const REP_TIERS = [
    { max: 20000,  total: 1000,  upfront: 700,   backend: 300  },
    { max: 30000,  total: 1500,  upfront: 1070,  backend: 430  },
    { max: 45000,  total: 2250,  upfront: 1575,  backend: 675  },
    { max: 60000,  total: 3000,  upfront: 2100,  backend: 900  },
    { max: 75000,  total: 3750,  upfront: 2625,  backend: 1125 },
    { max: 90000,  total: 4500,  upfront: 3150,  backend: 1350 },
    { max: Infinity, total: 5000, upfront: 3500, backend: 1500 },
  ];

  const MGR_TIERS = [
    { max: 10000,  total: 500,   upfront: 350,   backend: 150  },
    { max: 15000,  total: 1000,  upfront: 700,   backend: 300  },
    { max: 20000,  total: 1500,  upfront: 1050,  backend: 450  },
    { max: 25000,  total: 2000,  upfront: 1400,  backend: 600  },
    { max: 30000,  total: 2500,  upfront: 1750,  backend: 750  },
    { max: 40000,  total: 3500,  upfront: 2450,  backend: 1050 },
    { max: 50000,  total: 4500,  upfront: 3150,  backend: 1350 },
    { max: 60000,  total: 5500,  upfront: 3850,  backend: 1650 },
    { max: 70000,  total: 6500,  upfront: 4550,  backend: 1950 },
    { max: 80000,  total: 7500,  upfront: 5250,  backend: 1575 },
    { max: 90000,  total: 8500,  upfront: 5950,  backend: 2550 },
    { max: 100000, total: 9500,  upfront: 6650,  backend: 2850 },
    { max: Infinity, total: 10500, upfront: 7350, backend: 3150 },
  ];

  const REP_BACKEND_MULT = [
    { max: 5,  mult: 1    },
    { max: 10, mult: 1.25 },
    { max: 15, mult: 1.5  },
    { max: 20, mult: 1.75 },
    { max: 25, mult: 2    },
    { max: Infinity, mult: 2.25 },
  ];

  const MGR_BACKEND_MULT = [
    { max: 6,  mult: 1,    teamPct: 0.005  },
    { max: 11, mult: 1.25, teamPct: 0.0075 },
    { max: 14, mult: 1.5,  teamPct: 0.0125 },
    { max: 17, mult: 1.75, teamPct: 0.015  },
    { max: 20, mult: 2,    teamPct: 0.0175 },
    { max: Infinity, mult: 2.25, teamPct: 0.02 },
  ];

  const GP_BONUS = [
    { max: 15, pct: -0.02 },
    { max: 20, pct: -0.01 },
    { max: 25, pct: 0     },
    { max: 30, pct: 0.005 },
    { max: 35, pct: 0.01  },
    { max: 40, pct: 0.015 },
    { max: Infinity, pct: 0.02 },
  ];

  /* ── Helpers ── */
  const $ = s => document.querySelector(s);
  const $$ = s => document.querySelectorAll(s);
  const fmt = n => {
    const neg = n < 0;
    const s = '$' + Math.abs(n).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    return neg ? '-' + s : s;
  };
  const fmtInt = n => '$' + n.toLocaleString('en-US');

  function getTiers() { return role === 'mgr' ? MGR_TIERS : REP_TIERS; }
  function getMultTable() { return role === 'mgr' ? MGR_BACKEND_MULT : REP_BACKEND_MULT; }

  function lookupComm(price) {
    const tiers = getTiers();
    for (const t of tiers) { if (price < t.max) return t; }
    return tiers[tiers.length - 1];
  }

  function lookupGPBonus(gpPct) {
    for (const t of GP_BONUS) { if (gpPct < t.max) return t.pct; }
    return GP_BONUS[GP_BONUS.length - 1].pct;
  }

  function lookupMultiplier(jobCount) {
    const table = getMultTable();
    for (const t of table) { if (jobCount <= t.max) return t; }
    return table[table.length - 1];
  }

  /* ── Fiscal year options ── */
  function initFiscalYear() {
    const sel = $('#fiscal-year');
    const now = new Date();
    // FY2025 = Nov 2024 – Oct 2025 (named by the year it ends)
    const currentCalYear = now.getFullYear();
    const m = now.getMonth(); // 0-indexed
    // If Nov or Dec, we're in the FY that ends next calendar year; else ends this year
    const currentFY = m >= 10 ? currentCalYear + 1 : currentCalYear;
    for (let y = currentFY + 1; y >= currentFY - 2; y--) {
      const opt = document.createElement('option');
      opt.value = y;
      opt.textContent = 'FY' + y + ' (Nov ' + (y - 1) + ' – Oct ' + y + ')';
      if (y === currentFY) opt.selected = true;
      sel.appendChild(opt);
    }
    // Auto-select current quarter
    const qtrSel = $('#fiscal-quarter');
    if (m === 10 || m === 11 || m === 0) qtrSel.value = 'Q1';
    else if (m >= 1 && m <= 3) qtrSel.value = 'Q2';
    else if (m >= 4 && m <= 6) qtrSel.value = 'Q3';
    else qtrSel.value = 'Q4';
  }

  /* ── Role toggle ── */
  function setRole(r) {
    role = r;
    $('#btn-rep').classList.toggle('active', r === 'rep');
    $('#btn-mgr').classList.toggle('active', r === 'mgr');
    // Show/hide sections
    $('#upgrades-section').classList.toggle('hidden', r === 'mgr');
    $('#recruiting-section').classList.toggle('hidden', r === 'mgr');
    $('#team-section').classList.toggle('hidden', r === 'rep');
    $('#prev-qtr-wrap').classList.toggle('hidden', r === 'mgr');
    $('#upgrade-line').style.display = r === 'rep' ? '' : 'none';
    $('#recruit-line').style.display = r === 'rep' ? '' : 'none';
    $('#team-line').style.display = r === 'mgr' ? '' : 'none';
    recalc();
  }

  /* ── Job rows ── */
  function addJob(price, gp) {
    jobs.push({ price: price || 0, gp: gp || 25 });
    renderJobs();
  }

  function removeJob(i) {
    jobs.splice(i, 1);
    renderJobs();
  }

  function renderJobs() {
    const tbody = $('#job-body');
    tbody.innerHTML = '';
    jobs.forEach((job, i) => {
      const comm = lookupComm(job.price);
      const gpBonusPct = lookupGPBonus(job.gp);
      const gpBonus = gpBonusPct * job.price;
      const tr = document.createElement('tr');
      tr.className = 'job-row';
      tr.innerHTML = `
        <td class="text-[#888] font-600">${i + 1}</td>
        <td><input type="number" class="calc-input" data-idx="${i}" data-field="price" value="${job.price}" min="0" step="100" placeholder="$0" /></td>
        <td><input type="number" class="calc-input" data-idx="${i}" data-field="gp" value="${job.gp}" min="0" max="100" step="1" placeholder="%" /></td>
        <td class="text-right font-600">${fmtInt(comm.total)}</td>
        <td class="text-right">${fmtInt(comm.upfront)}</td>
        <td class="text-right">${fmtInt(comm.backend)}</td>
        <td class="text-right ${gpBonusPct < 0 ? 'gp-neg' : gpBonusPct > 0 ? 'gp-pos' : ''}">${(gpBonusPct * 100).toFixed(1)}%</td>
        <td class="text-right font-600 ${gpBonus < 0 ? 'gp-neg' : gpBonus > 0 ? 'gp-pos' : ''}">${fmt(gpBonus)}</td>
        <td><button class="del-btn" data-idx="${i}" title="Remove job">✕</button></td>
      `;
      tbody.appendChild(tr);
    });

    // Attach listeners
    tbody.querySelectorAll('input').forEach(inp => {
      inp.addEventListener('input', function() {
        const idx = +this.dataset.idx;
        const field = this.dataset.field;
        jobs[idx][field] = parseFloat(this.value) || 0;
        recalc();
        // Update this row's computed cells without full re-render
        updateRowDisplay(idx);
      });
    });
    tbody.querySelectorAll('.del-btn').forEach(btn => {
      btn.addEventListener('click', function() { removeJob(+this.dataset.idx); });
    });

    recalc();
  }

  function updateRowDisplay(idx) {
    const rows = $$('#job-body .job-row');
    if (!rows[idx]) return;
    const job = jobs[idx];
    const comm = lookupComm(job.price);
    const gpBonusPct = lookupGPBonus(job.gp);
    const gpBonus = gpBonusPct * job.price;
    const cells = rows[idx].querySelectorAll('td');
    cells[3].textContent = fmtInt(comm.total);
    cells[4].textContent = fmtInt(comm.upfront);
    cells[5].textContent = fmtInt(comm.backend);
    cells[6].textContent = (gpBonusPct * 100).toFixed(1) + '%';
    cells[6].className = 'text-right ' + (gpBonusPct < 0 ? 'gp-neg' : gpBonusPct > 0 ? 'gp-pos' : '');
    cells[7].textContent = fmt(gpBonus);
    cells[7].className = 'text-right font-600 ' + (gpBonus < 0 ? 'gp-neg' : gpBonus > 0 ? 'gp-pos' : '');
  }

  /* ── Recruit rows ── */
  function addRecruit() {
    recruitSales.push(0);
    renderRecruits();
  }

  function renderRecruits() {
    const wrap = $('#recruit-rows');
    wrap.innerHTML = '';
    recruitSales.forEach((val, i) => {
      const div = document.createElement('div');
      div.className = 'flex items-center gap-3';
      div.innerHTML = `
        <span class="text-sm font-600 text-[#888] w-24">Recruit ${i + 1}</span>
        <input type="number" class="calc-input flex-1" data-ridx="${i}" value="${val}" min="0" step="1000" placeholder="Total Qtr Sales $" />
        <span class="text-sm font-600 text-[#3B9FD9] w-20 text-right" id="rec-earn-${i}">${fmt(val * 0.005)}</span>
        <button class="del-btn" data-ridx="${i}">✕</button>
      `;
      wrap.appendChild(div);
    });
    wrap.querySelectorAll('input').forEach(inp => {
      inp.addEventListener('input', function() {
        recruitSales[+this.dataset.ridx] = parseFloat(this.value) || 0;
        const earn = document.getElementById('rec-earn-' + this.dataset.ridx);
        if (earn) earn.textContent = fmt(recruitSales[+this.dataset.ridx] * 0.005);
        recalc();
      });
    });
    wrap.querySelectorAll('.del-btn').forEach(btn => {
      btn.addEventListener('click', function() {
        recruitSales.splice(+this.dataset.ridx, 1);
        renderRecruits();
        recalc();
      });
    });
  }

  /* ── Main recalc ── */
  function recalc() {
    const numJobs = jobs.length;
    const carryover = role === 'rep' ? parseInt($('#prev-qtr-jobs').value) || 0 : 0;
    const effectiveJobs = numJobs + carryover;

    let totalSales = 0, totalComm = 0, totalUpfront = 0, totalBackend = 0, totalGPBonus = 0;

    jobs.forEach(job => {
      const comm = lookupComm(job.price);
      const gpBonusPct = lookupGPBonus(job.gp);
      const gpBonus = gpBonusPct * job.price;
      totalSales += job.price;
      totalComm += comm.total;
      totalUpfront += comm.upfront;
      totalBackend += comm.backend;
      totalGPBonus += gpBonus;
    });

    // Footer totals
    $('#total-jobs').textContent = numJobs;
    $('#total-sales').textContent = fmtInt(Math.round(totalSales));
    $('#total-comm').textContent = fmtInt(Math.round(totalComm));
    $('#total-upfront').textContent = fmtInt(Math.round(totalUpfront));
    $('#total-backend').textContent = fmtInt(Math.round(totalBackend));
    $('#total-gp-bonus').textContent = fmt(totalGPBonus);

    // Multiplier (based on effective jobs for rep, actual jobs for manager)
    const multEntry = lookupMultiplier(role === 'rep' ? effectiveJobs : numJobs);
    const mult = multEntry.mult;

    // Backend calculation: (backend + gpBonus) × multiplier
    const backendPlusGP = totalBackend + totalGPBonus;
    const backendMultiplied = backendPlusGP * mult;

    // Upgrades + deposit bonus (rep only)
    let upgradeTotal = 0;
    let depositBonus = 0;
    if (role === 'rep') {
      const warranties = parseInt($('#warranties').value) || 0;
      const atticBreeze = parseInt($('#attic-breeze').value) || 0;
      const depMid = parseInt($('#deposits-mid').value) || 0;
      const depHigh = parseInt($('#deposits-high').value) || 0;
      upgradeTotal = (warranties * 100) + (atticBreeze * 150);
      depositBonus = (depMid * 25) + (depHigh * 50);
    }

    // Recruiting override (rep only)
    let recruitTotal = 0;
    if (role === 'rep') {
      recruitSales.forEach(s => { recruitTotal += s * 0.005; });
    }

    // Team override (manager only)
    let teamOverride = 0;
    if (role === 'mgr') {
      const teamSales = parseFloat($('#team-sales').value) || 0;
      const teamPct = multEntry.teamPct || 0.005;
      teamOverride = teamSales * teamPct;
      $('#team-override-pct').textContent = (teamPct * 100).toFixed(2) + '%';
      $('#team-override-amt').textContent = fmt(teamOverride);
    }

    // Grand total
    const grandTotal = totalUpfront + backendMultiplied + upgradeTotal + depositBonus + recruitTotal + teamOverride;

    // Summary
    $('#sum-jobs').textContent = numJobs;
    $('#sum-effective-jobs').textContent = role === 'rep' ? effectiveJobs : numJobs;
    $('#sum-multiplier').textContent = mult + 'x';
    $('#sum-upfront').textContent = fmt(totalUpfront);
    $('#sum-backend-base').textContent = fmt(totalBackend);
    $('#sum-gp-bonus').textContent = fmt(totalGPBonus);
    $('#sum-backend-mult').textContent = fmt(backendMultiplied);
    var multBonusAmt = backendMultiplied - totalBackend - totalGPBonus;
    $('#sum-mult-bonus').textContent = fmt(multBonusAmt);
    $('#sum-upgrades').textContent = fmt(upgradeTotal + depositBonus);
    $('#sum-recruit').textContent = fmt(recruitTotal);
    $('#sum-team').textContent = fmt(teamOverride);
    $('#sum-total').textContent = fmt(grandTotal);
    $('#sum-monthly').textContent = fmt(grandTotal / 3);
    $('#sum-weekly').textContent = fmt(grandTotal / 13);

    // Avg commission %
    const avgPct = totalSales > 0 ? (grandTotal / totalSales * 100) : 0;
    $('#sum-avg-pct').textContent = avgPct.toFixed(1) + '%';
  }

  /* ── Scenario Builder ── */
  function randomBetween(min, max) {
    return Math.floor(Math.random() * (max - min + 1)) + min;
  }

  function randomPrice() {
    // Realistic roof job prices: weighted toward $15k-$45k range
    var ranges = [
      { min: 8000, max: 19999, weight: 15 },
      { min: 20000, max: 29999, weight: 30 },
      { min: 30000, max: 44999, weight: 30 },
      { min: 45000, max: 59999, weight: 15 },
      { min: 60000, max: 89999, weight: 8 },
      { min: 90000, max: 120000, weight: 2 },
    ];
    var total = ranges.reduce(function(s, r) { return s + r.weight; }, 0);
    var roll = Math.random() * total;
    var acc = 0;
    for (var i = 0; i < ranges.length; i++) {
      acc += ranges[i].weight;
      if (roll < acc) {
        return Math.round(randomBetween(ranges[i].min, ranges[i].max) / 500) * 500;
      }
    }
    return 25000;
  }

  function randomGP() {
    // Realistic GP: mostly 20-35%, occasionally outside
    var base = 18 + Math.random() * 22; // 18-40
    // Bias toward center (22-32)
    base = base * 0.7 + 27 * 0.3;
    return Math.round(base);
  }

  function randomizeScenario() {
    var numJobs = randomBetween(3, 18);
    jobs = [];
    for (var i = 0; i < numJobs; i++) {
      jobs.push({ price: randomPrice(), gp: randomGP() });
    }
    renderJobs();

    if (role === 'rep') {
      // Random upgrades
      $('#warranties').value = randomBetween(0, Math.ceil(numJobs * 0.6));
      $('#attic-breeze').value = randomBetween(0, Math.ceil(numJobs * 0.3));
      $('#deposits-mid').value = randomBetween(0, Math.ceil(numJobs * 0.4));
      $('#deposits-high').value = randomBetween(0, Math.ceil(numJobs * 0.2));

      // Random recruits (0-3)
      var numRecruits = randomBetween(0, 3);
      recruitSales = [];
      for (var r = 0; r < numRecruits; r++) {
        recruitSales.push(randomBetween(20000, 200000));
      }
      renderRecruits();

      // Random carryover
      $('#prev-qtr-jobs').value = String(randomBetween(0, 5));
    } else {
      // Manager: random team sales
      $('#team-sales').value = randomBetween(100000, 800000);
    }

    recalc();

    // Sync sliders to match the generated data
    var avgPrice = 0;
    var avgGM = 0;
    jobs.forEach(function(j) { avgPrice += j.price; avgGM += j.gp; });
    avgPrice = Math.round(avgPrice / jobs.length / 1000) * 1000;
    avgGM = Math.round(avgGM / jobs.length);

    $('#deals-slider').value = numJobs;
    $('#price-slider').value = Math.min(120000, Math.max(5000, avgPrice));
    $('#gp-slider').value = Math.min(50, Math.max(10, avgGM));
    updateAllSliderDisplays();

    showToast('Generated random scenario - ' + numJobs + ' jobs');
  }

  function sliderGP() {
    var base = parseInt($('#gp-slider').value) || 27;
    var jitter = randomBetween(-3, 3);
    return Math.max(5, Math.min(55, base + jitter));
  }

  // Compute estimated earnings from the 3 sliders (without generating jobs)
  function computeSliderEarnings() {
    var numDeals = parseInt($('#deals-slider').value) || 6;
    var avgPrice = parseInt($('#price-slider').value) || 30000;
    var avgGP = parseInt($('#gp-slider').value) || 27;

    var totalUpfront = 0, totalBackend = 0, totalGPBonus = 0;
    for (var i = 0; i < numDeals; i++) {
      var comm = lookupComm(avgPrice);
      var gpBonusPct = lookupGPBonus(avgGP);
      totalUpfront += comm.upfront;
      totalBackend += comm.backend;
      totalGPBonus += gpBonusPct * avgPrice;
    }

    var carryover = role === 'rep' ? (parseInt($('#prev-qtr-jobs').value) || 0) : 0;
    var effectiveJobs = numDeals + carryover;
    var multEntry = lookupMultiplier(role === 'rep' ? effectiveJobs : numDeals);
    var backendMultiplied = (totalBackend + totalGPBonus) * multEntry.mult;

    return totalUpfront + backendMultiplied;
  }

  function generateFromSlider() {
    var numDeals = parseInt($('#deals-slider').value) || 6;
    var avgPrice = parseInt($('#price-slider').value) || 30000;
    var targetGP = parseInt($('#gp-slider').value) || 27;

    jobs = [];
    for (var i = 0; i < numDeals; i++) {
      // Vary price ±15% and GM ±3 around the slider values
      var priceFactor = 0.85 + Math.random() * 0.30;
      var price = Math.round((avgPrice * priceFactor) / 500) * 500;
      jobs.push({ price: price, gp: sliderGP() });
    }

    // Add modest upgrades/recruits for rep
    if (role === 'rep') {
      var nj = jobs.length;
      $('#warranties').value = randomBetween(0, Math.ceil(nj * 0.3));
      $('#attic-breeze').value = randomBetween(0, Math.ceil(nj * 0.2));
      $('#deposits-mid').value = randomBetween(0, Math.ceil(nj * 0.3));
      $('#deposits-high').value = randomBetween(0, Math.ceil(nj * 0.15));
      recruitSales = [];
      if (nj > 5 && Math.random() > 0.5) {
        recruitSales.push(randomBetween(30000, 150000));
      }
      renderRecruits();
    } else {
      $('#team-sales').value = randomBetween(80000, 400000);
    }

    renderJobs();
    recalc();
    showToast('Generated ' + numDeals + ' deals - avg ' + fmtInt(avgPrice) + ' at ' + targetGP + '% GM');
  }

  function clearAll() {
    jobs = [];
    recruitSales = [];
    renderJobs();
    renderRecruits();
    $('#warranties').value = 0;
    $('#attic-breeze').value = 0;
    $('#deposits-mid').value = 0;
    $('#deposits-high').value = 0;
    $('#team-sales').value = 0;
    $('#prev-qtr-jobs').value = '0';
    recalc();
  }

  // Slider display updates - all 3 sliders update the computed earnings
  function updateSliderFill(slider, min, max) {
    var val = parseFloat(slider.value);
    var pct = ((val - min) / (max - min)) * 100;
    slider.style.background = 'linear-gradient(to right, #E6A817 0%, #E6A817 ' + pct + '%, #333 ' + pct + '%, #333 100%)';
  }

  function updateGPSliderFill() {
    var val = parseInt($('#gp-slider').value);
    var pct = ((val - 10) / (50 - 10)) * 100;
    var slider = $('#gp-slider');
    var color;
    if (val < 20) color = '#e53e3e';
    else if (val < 35) color = '#E6A817';
    else color = '#38a169';
    slider.style.background = 'linear-gradient(to right, ' + color + ' 0%, ' + color + ' ' + pct + '%, #333 ' + pct + '%, #333 100%)';
  }

  function updateAllSliderDisplays() {
    // Deals
    var deals = parseInt($('#deals-slider').value);
    $('#deals-slider-value').textContent = deals;
    updateSliderFill($('#deals-slider'), 1, 30);

    // Price
    var price = parseInt($('#price-slider').value);
    $('#price-slider-value').textContent = '$' + price.toLocaleString('en-US');
    updateSliderFill($('#price-slider'), 5000, 120000);

    // GM
    var gp = parseInt($('#gp-slider').value);
    $('#gp-slider-value').textContent = gp + '%';
    updateGPSliderFill();

    // Computed earnings
    var est = computeSliderEarnings();
    $('#slider-value').textContent = '$' + Math.round(est).toLocaleString('en-US');
  }

  /* ── Excel Template Download ── */
  function downloadTemplate() {
    var wb = XLSX.utils.book_new();

    // Tab 1: Jobs
    var jobsData = [
      ['Date', 'Address', 'Selling Price', 'Gross Margin %'],
      ['3/15/2026', '123 Main St, Tampa FL', 25000, 27],
      ['3/18/2026', '456 Oak Ave, Clearwater FL', 35000, 30],
      ['3/22/2026', '789 Palm Dr, St Pete FL', 42000, 25],
    ];
    var wsJobs = XLSX.utils.aoa_to_sheet(jobsData);
    wsJobs['!cols'] = [{ wch: 12 }, { wch: 32 }, { wch: 14 }, { wch: 16 }];
    XLSX.utils.book_append_sheet(wb, wsJobs, 'Jobs');

    // Tab 2: Upgrades & Bonuses (Rep only)
    var upgradesData = [
      ['Warranties Sold', 'Attic Breeze Vents Sold', 'Jobs w/ $5k–$10k Deposit', 'Jobs w/ $10k+ Deposit'],
      [0, 0, 0, 0],
    ];
    var wsUpgrades = XLSX.utils.aoa_to_sheet(upgradesData);
    wsUpgrades['!cols'] = [{ wch: 18 }, { wch: 24 }, { wch: 26 }, { wch: 22 }];
    XLSX.utils.book_append_sheet(wb, wsUpgrades, 'Upgrades & Bonuses');

    // Tab 3: Recruiting Override (Rep only)
    var recruitData = [
      ['Recruit Name', 'Total Sales'],
      ['Jane Doe', 50000],
      ['Mike Smith', 75000],
    ];
    var wsRecruit = XLSX.utils.aoa_to_sheet(recruitData);
    wsRecruit['!cols'] = [{ wch: 20 }, { wch: 14 }];
    XLSX.utils.book_append_sheet(wb, wsRecruit, 'Recruiting Override');

    // Tab 4: Team Override (Manager only)
    var teamData = [
      ['Rep Name', 'Total Sales'],
      ['Rep A', 80000],
      ['Rep B', 120000],
    ];
    var wsTeam = XLSX.utils.aoa_to_sheet(teamData);
    wsTeam['!cols'] = [{ wch: 20 }, { wch: 14 }];
    XLSX.utils.book_append_sheet(wb, wsTeam, 'Team Override');

    XLSX.writeFile(wb, 'commission-template.xlsx');
  }

  /* ── Excel Import ── */
  function importFile(file) {
    var reader = new FileReader();
    reader.onload = function(e) {
      var data = new Uint8Array(e.target.result);
      var wb = XLSX.read(data, { type: 'array' });

      var importedJobs = [];
      var importedRecruits = [];
      var importedTeamSales = [];
      var upgrades = {};

      // Parse Jobs tab
      var jobsSheet = wb.Sheets['Jobs'] || wb.Sheets[wb.SheetNames[0]];
      if (jobsSheet) {
        var jobRows = XLSX.utils.sheet_to_json(jobsSheet, { defval: '' });
        jobRows.forEach(function(row) {
          var price = parseFloat(row['Selling Price']) || 0;
          var gp = parseFloat(row['Gross Margin %']) || 25;
          if (price > 0) {
            importedJobs.push({ price: price, gp: gp });
          }
        });
      }

      // Parse Upgrades & Bonuses tab
      var upgradesSheet = wb.Sheets['Upgrades & Bonuses'];
      if (upgradesSheet) {
        var upRows = XLSX.utils.sheet_to_json(upgradesSheet, { defval: 0 });
        if (upRows.length > 0) {
          var r = upRows[0];
          upgrades.warranties = parseInt(r['Warranties Sold']) || 0;
          upgrades.atticBreeze = parseInt(r['Attic Breeze Vents Sold']) || 0;
          upgrades.depositsMid = parseInt(r['Jobs w/ $5k–$10k Deposit'] || r['Jobs w/ $5k-$10k Deposit']) || 0;
          upgrades.depositsHigh = parseInt(r['Jobs w/ $10k+ Deposit']) || 0;
        }
      }

      // Parse Recruiting Override tab
      var recruitSheet = wb.Sheets['Recruiting Override'];
      if (recruitSheet) {
        var recRows = XLSX.utils.sheet_to_json(recruitSheet, { defval: '' });
        recRows.forEach(function(row) {
          var sales = parseFloat(row['Total Sales']) || 0;
          if (sales > 0) {
            importedRecruits.push(sales);
          }
        });
      }

      // Parse Team Override tab
      var teamSheet = wb.Sheets['Team Override'];
      if (teamSheet) {
        var teamRows = XLSX.utils.sheet_to_json(teamSheet, { defval: '' });
        teamRows.forEach(function(row) {
          var sales = parseFloat(row['Total Sales']) || 0;
          if (sales > 0) {
            importedTeamSales.push(sales);
          }
        });
      }

      // Determine role from which tabs have data
      var hasTeamData = importedTeamSales.length > 0;
      var hasRepData = importedRecruits.length > 0 || upgrades.warranties > 0 || upgrades.atticBreeze > 0 || upgrades.depositsMid > 0 || upgrades.depositsHigh > 0;

      if (hasTeamData && !hasRepData) {
        setRole('mgr');
      } else {
        setRole('rep');
      }

      // Apply upgrades
      $('#warranties').value = upgrades.warranties || 0;
      $('#attic-breeze').value = upgrades.atticBreeze || 0;
      $('#deposits-mid').value = upgrades.depositsMid || 0;
      $('#deposits-high').value = upgrades.depositsHigh || 0;

      // Apply team sales (sum all reps for manager)
      if (hasTeamData) {
        var totalTeam = 0;
        importedTeamSales.forEach(function(s) { totalTeam += s; });
        $('#team-sales').value = totalTeam;
      }

      // Load jobs
      jobs = importedJobs;
      renderJobs();

      // Load recruits
      recruitSales = importedRecruits;
      renderRecruits();

      recalc();

      // Build toast message
      var parts = [importedJobs.length + ' job' + (importedJobs.length !== 1 ? 's' : '')];
      if (importedRecruits.length > 0) parts.push(importedRecruits.length + ' recruit' + (importedRecruits.length !== 1 ? 's' : ''));
      if (hasTeamData) parts.push(importedTeamSales.length + ' team rep' + (importedTeamSales.length !== 1 ? 's' : ''));
      showToast('Imported ' + parts.join(', '));
    };
    reader.readAsArrayBuffer(file);
  }

  function showToast(msg) {
    var existing = document.getElementById('import-toast');
    if (existing) existing.remove();
    var toast = document.createElement('div');
    toast.id = 'import-toast';
    toast.textContent = msg;
    toast.style.cssText = 'position:fixed;bottom:2rem;left:50%;transform:translateX(-50%);background:#1A1A1A;color:#E6A817;font-family:Barlow Condensed,sans-serif;font-weight:700;padding:.75rem 1.5rem;border-radius:10px;font-size:.95rem;z-index:9999;box-shadow:0 8px 30px -8px rgba(0,0,0,.3);opacity:0;transition:opacity .3s ease;';
    document.body.appendChild(toast);
    requestAnimationFrame(function() { toast.style.opacity = '1'; });
    setTimeout(function() {
      toast.style.opacity = '0';
      setTimeout(function() { toast.remove(); }, 300);
    }, 3000);
  }

  /* ── Init ── */
  initFiscalYear();

  $('#btn-rep').addEventListener('click', () => setRole('rep'));
  $('#btn-mgr').addEventListener('click', () => setRole('mgr'));
  $('#add-job').addEventListener('click', () => addJob(25000, 27));
  $('#add-recruit').addEventListener('click', () => { addRecruit(); recalc(); });

  // Scenario builder
  $('#btn-randomize').addEventListener('click', randomizeScenario);
  $('#btn-generate').addEventListener('click', generateFromSlider);
  $('#btn-clear-all').addEventListener('click', clearAll);
  $('#deals-slider').addEventListener('input', updateAllSliderDisplays);
  $('#price-slider').addEventListener('input', updateAllSliderDisplays);
  $('#gp-slider').addEventListener('input', updateAllSliderDisplays);
  // Initialize the computed earnings display
  updateAllSliderDisplays();

  // Import / Template buttons
  $('#btn-template').addEventListener('click', downloadTemplate);
  $('#btn-import').addEventListener('click', function() { $('#xlsx-file-input').click(); });
  $('#xlsx-file-input').addEventListener('change', function() {
    if (this.files.length > 0) {
      importFile(this.files[0]);
      this.value = '';
    }
  });

  // Recalc on any change
  ['#prev-qtr-jobs', '#warranties', '#attic-breeze', '#deposits-mid', '#deposits-high', '#team-sales'].forEach(sel => {
    const el = $(sel);
    if (el) el.addEventListener('input', recalc);
  });

  // Start with one sample job
  addJob(25000, 27);
})();
</script>
</LandingLayout>
