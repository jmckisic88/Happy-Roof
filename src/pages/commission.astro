---
import LandingLayout from '../layouts/LandingLayout.astro';
---
<LandingLayout
  title="Commission Calculator | Happy Roof"
  description="Internal commission calculator for Happy Roof sales reps and managers."
  canonical="https://happyroof.com/commission"
  noindex={true}
>

<!-- ═══ Password Gate ═══ -->
<div id="lock-screen" class="fixed inset-0 z-50 bg-[#1A1A1A] flex items-center justify-center">
  <div class="text-center px-6 w-full max-w-sm">
    <div class="w-16 h-16 mx-auto mb-6 rounded-2xl bg-[#2A2A2A] flex items-center justify-center">
      <svg width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="#E6A817" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
    </div>
    <h1 class="font-['Barlow_Condensed'] text-2xl font-800 text-white mb-2">Commission Calculator</h1>
    <p class="text-sm text-[#888] mb-6">Enter your access code to continue.</p>
    <form id="pw-form" class="space-y-3" autocomplete="off">
      <input
        id="pw-input"
        type="password"
        placeholder="Access Code"
        autofocus
        class="w-full bg-[#2A2A2A] border border-[#333] rounded-lg px-4 py-3 text-white text-center text-lg font-['Barlow_Condensed'] font-700 tracking-widest placeholder:text-[#555] focus:outline-none focus:border-[#E6A817] focus:ring-2 focus:ring-[rgba(230,168,23,.25)] transition-all duration-200"
      />
      <button type="submit" class="w-full bg-[#E6A817] text-[#1A1A1A] font-['Barlow_Condensed'] font-700 text-lg rounded-lg py-3 transition-all duration-200 hover:bg-[#F0C040] active:translate-y-0 focus-visible:outline-2 focus-visible:outline-[#F0C040] focus-visible:outline-offset-3" style="box-shadow: 0 4px 20px -4px rgba(230,168,23,.42);">
        Unlock
      </button>
      <p id="pw-error" class="text-sm text-red-400 hidden">Incorrect code. Try again.</p>
    </form>
  </div>
</div>

<section id="app-content" class="pt-12 pb-12 bg-white hidden" style="padding-top: 3rem !important;">
  <div class="max-w-5xl mx-auto px-5">

    <!-- Header -->
    <div class="text-center mb-10">
      <span class="sl text-[#E6A817] block mb-2">Internal Tool</span>
      <h1 class="font-['Barlow_Condensed'] text-4xl md:text-5xl font-800 tracking-tight text-[#1A1A1A] mb-3">Commission Calculator</h1>
      <p class="text-[#555] text-lg max-w-2xl mx-auto">Model quarterly scenarios in real time. Fiscal year starts <strong>Nov 1</strong>.</p>
    </div>

    <!-- Role Toggle + Import/Export -->
    <div class="flex flex-col items-center gap-4 mb-8">
      <div class="flex justify-center gap-3">
        <button id="btn-rep" class="role-btn active font-['Barlow_Condensed'] font-700 text-lg px-6 py-2.5 rounded-lg transition-all duration-200">Sales Rep</button>
        <button id="btn-mgr" class="role-btn font-['Barlow_Condensed'] font-700 text-lg px-6 py-2.5 rounded-lg transition-all duration-200">Manager</button>
      </div>
      <div class="flex gap-3">
        <button id="btn-import" class="flex items-center gap-2 text-sm font-600 px-4 py-2 rounded-lg border border-[#E0E0E0] bg-white text-[#555] hover:border-[#E6A817] hover:text-[#1A1A1A] focus-visible:outline-2 focus-visible:outline-[#E6A817] focus-visible:outline-offset-3 transition-all duration-200" style="box-shadow: 0 1px 4px rgba(0,0,0,.06);">
          <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
          Import Data
        </button>
        <button id="btn-template" class="flex items-center gap-2 text-sm font-600 px-4 py-2 rounded-lg border border-[#E0E0E0] bg-white text-[#555] hover:border-[#E6A817] hover:text-[#1A1A1A] focus-visible:outline-2 focus-visible:outline-[#E6A817] focus-visible:outline-offset-3 transition-all duration-200" style="box-shadow: 0 1px 4px rgba(0,0,0,.06);">
          <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          Download Template
        </button>
      </div>
      <input type="file" id="xlsx-file-input" accept=".xlsx,.xls,.csv" class="hidden" />
    </div>

    <!-- Quarter Selector -->
    <div class="flex flex-wrap justify-center items-center gap-4 mb-8">
      <div>
        <label class="block text-xs font-600 text-[#888] mb-1 uppercase tracking-wider">Fiscal Year</label>
        <select id="fiscal-year" class="calc-input w-32"></select>
      </div>
      <div>
        <label class="block text-xs font-600 text-[#888] mb-1 uppercase tracking-wider">Quarter</label>
        <select id="fiscal-quarter" class="calc-input w-44">
          <option value="Q1">Q1 (Nov – Jan)</option>
          <option value="Q2">Q2 (Feb – Apr)</option>
          <option value="Q3">Q3 (May – Jul)</option>
          <option value="Q4">Q4 (Aug – Oct)</option>
        </select>
      </div>
      <div id="prev-qtr-wrap">
        <label class="block text-xs font-600 text-[#888] mb-1 uppercase tracking-wider">Prev Qtr Jobs (Carryover)</label>
        <select id="prev-qtr-jobs" class="calc-input w-36">
          <option value="0">0–5 (start at 0)</option>
          <option value="1">6–10 (start at 1)</option>
          <option value="2">11–15 (start at 2)</option>
          <option value="3">16–20 (start at 3)</option>
          <option value="4">21–25 (start at 4)</option>
          <option value="5">25+ (start at 5)</option>
        </select>
      </div>
    </div>

    <!-- ═══════════════════════════════════════════ -->
    <!--  RANDOMIZE (standalone)                       -->
    <!-- ═══════════════════════════════════════════ -->
    <div class="flex justify-center mb-6">
      <button id="btn-randomize" class="flex items-center gap-2.5 font-700 font-['Barlow_Condensed'] text-lg px-7 py-3 rounded-xl bg-white text-[#1A1A1A] border-2 border-[#E0E0E0] hover:border-[#E6A817] hover:shadow-lg active:scale-95 focus-visible:outline-2 focus-visible:outline-[#E6A817] focus-visible:outline-offset-3 transition-all duration-200" style="box-shadow: 0 2px 8px rgba(0,0,0,.06);">
        <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="#E6A817" stroke-width="2.5"><path d="M3 3l4 4m0-4l-4 4"/><path d="M21 21l-4-4m4 4l-4-4"/><path d="M3 21c4-8 8-8 18-18"/><path d="M21 3c-4 8-8 8-18 18"/></svg>
        Randomize Scenario
      </button>
    </div>

    <!-- ═══════════════════════════════════════════ -->
    <!--  SCENARIO BUILDER                             -->
    <!-- ═══════════════════════════════════════════ -->
    <div class="bg-gradient-to-br from-[#1A1A1A] to-[#2A2A2A] rounded-2xl p-5 md:p-7 mb-8 text-white">
      <div class="mb-5">
        <h2 class="font-['Barlow_Condensed'] text-xl font-700">Scenario Builder</h2>
        <p class="text-sm text-[#888] mt-1">Adjust the sliders to model a scenario. Estimated earnings update in real time.</p>
      </div>

      <!-- Sliders Grid -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-5">

        <!-- Number of Deals -->
        <div>
          <div class="flex items-center justify-between mb-2">
            <label class="text-xs font-600 text-[#888] uppercase tracking-wider">Number of Deals</label>
            <span id="deals-slider-value" class="font-['Barlow_Condensed'] text-2xl font-800 text-[#E6A817]">6</span>
          </div>
          <input type="range" id="deals-slider" min="1" max="30" step="1" value="6"
            class="scenario-slider w-full h-2 rounded-full appearance-none cursor-pointer"
            style="background: linear-gradient(to right, #E6A817 0%, #E6A817 17.2%, #333 17.2%, #333 100%);" />
          <div class="flex justify-between text-xs text-[#555] mt-1">
            <span>1</span>
            <span>10</span>
            <span>20</span>
            <span>30</span>
          </div>
        </div>

        <!-- Avg Sales Price -->
        <div>
          <div class="flex items-center justify-between mb-2">
            <label class="text-xs font-600 text-[#888] uppercase tracking-wider">Avg Sales Price</label>
            <span id="price-slider-value" class="font-['Barlow_Condensed'] text-2xl font-800 text-[#E6A817]">$30,000</span>
          </div>
          <input type="range" id="price-slider" min="5000" max="120000" step="1000" value="30000"
            class="scenario-slider w-full h-2 rounded-full appearance-none cursor-pointer"
            style="background: linear-gradient(to right, #E6A817 0%, #E6A817 12.8%, #333 12.8%, #333 100%);" />
          <div class="flex justify-between text-xs text-[#555] mt-1">
            <span>$5k</span>
            <span>$30k</span>
            <span>$60k</span>
            <span>$90k</span>
            <span>$120k</span>
          </div>
        </div>

        <!-- Avg Gross Margin % -->
        <div>
          <div class="flex items-center justify-between mb-2">
            <label class="text-xs font-600 text-[#888] uppercase tracking-wider">Avg Gross Margin %</label>
            <span id="gp-slider-value" class="font-['Barlow_Condensed'] text-2xl font-800 text-[#E6A817]">27%</span>
          </div>
          <input type="range" id="gp-slider" min="10" max="50" step="1" value="27"
            class="scenario-slider w-full h-2 rounded-full appearance-none cursor-pointer"
            style="background: linear-gradient(to right, #e53e3e 0%, #E6A817 25%, #38a169 62.5%, #38a169 100%);" />
          <div class="flex justify-between text-xs mt-1">
            <span class="text-[#e53e3e]">10%</span>
            <span class="text-[#888]">20%</span>
            <span class="text-[#888]">30%</span>
            <span class="text-[#38a169]">40%</span>
            <span class="text-[#38a169]">50%</span>
          </div>
        </div>
      </div>

      <!-- Estimated Earnings (computed) -->
      <div class="mt-6 bg-[#2A2A2A] rounded-xl p-4 flex items-center justify-between">
        <span class="text-sm text-[#888] font-600 uppercase tracking-wider">Est. Quarterly Earnings</span>
        <span id="slider-value" class="font-['Barlow_Condensed'] text-3xl font-900 text-[#E6A817]">$0</span>
      </div>

      <div class="flex gap-3 mt-5">
        <button id="btn-generate" class="flex-1 text-sm font-700 font-['Barlow_Condensed'] py-2.5 rounded-lg border border-[#E6A817] text-[#E6A817] hover:bg-[#E6A817] hover:text-[#1A1A1A] focus-visible:outline-2 focus-visible:outline-[#F0C040] focus-visible:outline-offset-3 transition-all duration-200">
          Generate from Sliders
        </button>
        <button id="btn-clear-all" class="text-sm font-600 px-5 py-2.5 rounded-lg border border-[#444] text-[#888] hover:border-[#e53e3e] hover:text-[#e53e3e] focus-visible:outline-2 focus-visible:outline-[#e53e3e] focus-visible:outline-offset-3 transition-all duration-200">
          Clear All
        </button>
      </div>
    </div>

    <!-- ═══════════════════════════════════════════ -->
    <!--  JOB TABLE                                  -->
    <!-- ═══════════════════════════════════════════ -->
    <div class="bg-[#F7F7F7] border border-[#E0E0E0] rounded-2xl p-5 md:p-7 mb-8">
      <div class="flex items-center justify-between mb-5">
        <h2 class="font-['Barlow_Condensed'] text-xl font-700 text-[#1A1A1A]">Personal Sales</h2>
        <button id="add-job" class="btn-p text-sm !py-2 !px-4">+ Add Job</button>
      </div>

      <div class="overflow-x-auto">
        <table class="w-full text-sm" id="job-table">
          <thead>
            <tr class="text-left text-[#888] text-xs uppercase tracking-wider font-600 border-b border-[#E0E0E0]">
              <th class="pb-3 pr-2 w-8">#</th>
              <th class="pb-3 pr-2">Selling Price</th>
              <th class="pb-3 pr-2">Gross Margin %</th>
              <th class="pb-3 pr-2 text-right">Total Comm</th>
              <th class="pb-3 pr-2 text-right">Upfront (70%)</th>
              <th class="pb-3 pr-2 text-right">Backend (30%)</th>
              <th class="pb-3 pr-2 text-right">GM Bonus %</th>
              <th class="pb-3 text-right">GM Bonus $</th>
              <th class="pb-3 w-8"></th>
            </tr>
          </thead>
          <tbody id="job-body"></tbody>
          <tfoot>
            <tr class="font-700 text-[#1A1A1A] border-t-2 border-[#E6A817]">
              <td class="pt-4" id="total-jobs">0</td>
              <td class="pt-4" id="total-sales">$0</td>
              <td class="pt-4"></td>
              <td class="pt-4 text-right" id="total-comm">$0</td>
              <td class="pt-4 text-right" id="total-upfront">$0</td>
              <td class="pt-4 text-right" id="total-backend">$0</td>
              <td class="pt-4 text-right"></td>
              <td class="pt-4 text-right" id="total-gp-bonus">$0</td>
              <td></td>
            </tr>
          </tfoot>
        </table>
      </div>
    </div>

    <!-- ═══════════════════════════════════════════ -->
    <!--  UPGRADES + DEPOSIT (Rep only)              -->
    <!-- ═══════════════════════════════════════════ -->
    <div id="upgrades-section" class="bg-[#F7F7F7] border border-[#E0E0E0] rounded-2xl p-5 md:p-7 mb-8">
      <h2 class="font-['Barlow_Condensed'] text-xl font-700 text-[#1A1A1A] mb-5">Upgrades &amp; Bonuses</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-5">
        <div>
          <label class="block text-xs font-600 text-[#888] mb-1 uppercase tracking-wider">Warranties Sold</label>
          <input type="number" id="warranties" min="0" value="0" class="calc-input w-full" />
          <p class="text-xs text-[#888] mt-1">$100 each</p>
        </div>
        <div>
          <label class="block text-xs font-600 text-[#888] mb-1 uppercase tracking-wider">Attic Breeze Vents Sold</label>
          <input type="number" id="attic-breeze" min="0" value="0" class="calc-input w-full" />
          <p class="text-xs text-[#888] mt-1">$150 each</p>
        </div>
        <div>
          <label class="block text-xs font-600 text-[#888] mb-1 uppercase tracking-wider">Jobs w/ $5k–$10k Deposit</label>
          <input type="number" id="deposits-mid" min="0" value="0" class="calc-input w-full" />
          <p class="text-xs text-[#888] mt-1">$25 bonus each</p>
        </div>
        <div>
          <label class="block text-xs font-600 text-[#888] mb-1 uppercase tracking-wider">Jobs w/ $10k+ Deposit</label>
          <input type="number" id="deposits-high" min="0" value="0" class="calc-input w-full" />
          <p class="text-xs text-[#888] mt-1">$50 bonus each</p>
        </div>
      </div>
    </div>

    <!-- ═══════════════════════════════════════════ -->
    <!--  TEAM SALES OVERRIDE (Manager only)         -->
    <!-- ═══════════════════════════════════════════ -->
    <div id="team-section" class="bg-[#F7F7F7] border border-[#E0E0E0] rounded-2xl p-5 md:p-7 mb-8 hidden">
      <h2 class="font-['Barlow_Condensed'] text-xl font-700 text-[#1A1A1A] mb-5">Team Sales Override</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        <div>
          <label class="block text-xs font-600 text-[#888] mb-1 uppercase tracking-wider">Total Team (Downline) Sales $</label>
          <input type="number" id="team-sales" min="0" value="0" class="calc-input w-full" placeholder="$0" />
        </div>
        <div class="flex flex-col justify-end">
          <p class="text-sm text-[#555]">Override %: <strong id="team-override-pct">0.5%</strong></p>
          <p class="text-sm text-[#555]">Override Earned: <strong id="team-override-amt" class="text-[#E6A817]">$0</strong></p>
        </div>
      </div>
    </div>

    <!-- ═══════════════════════════════════════════ -->
    <!--  RECRUITING OVERRIDE (Rep only)             -->
    <!-- ═══════════════════════════════════════════ -->
    <div id="recruiting-section" class="bg-[#F7F7F7] border border-[#E0E0E0] rounded-2xl p-5 md:p-7 mb-8">
      <h2 class="font-['Barlow_Condensed'] text-xl font-700 text-[#1A1A1A] mb-5">Recruiting Override</h2>
      <p class="text-sm text-[#555] mb-4">0.5% override on each direct recruit's total quarterly sales.</p>
      <div id="recruit-rows" class="space-y-3"></div>
      <button id="add-recruit" class="mt-4 text-sm font-600 text-[#3B9FD9] hover:text-[#1A1A1A] transition-colors duration-200">+ Add Recruit</button>
    </div>

    <!-- ═══════════════════════════════════════════ -->
    <!--  SUMMARY DASHBOARD                          -->
    <!-- ═══════════════════════════════════════════ -->
    <div class="bg-[#1A1A1A] rounded-2xl p-6 md:p-8 text-white">
      <h2 class="font-['Barlow_Condensed'] text-2xl font-700 mb-6">Quarterly Summary</h2>

      <!-- Backend Multiplier Row -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
        <div class="bg-[#2A2A2A] rounded-xl p-4">
          <p class="text-xs text-[#888] uppercase tracking-wider mb-1">Jobs This Qtr</p>
          <p class="text-2xl font-['Barlow_Condensed'] font-800" id="sum-jobs">0</p>
        </div>
        <div class="bg-[#2A2A2A] rounded-xl p-4">
          <p class="text-xs text-[#888] uppercase tracking-wider mb-1">Backend Multiplier</p>
          <p class="text-2xl font-['Barlow_Condensed'] font-800 text-[#E6A817]" id="sum-multiplier">1x</p>
        </div>
        <div class="bg-[#2A2A2A] rounded-xl p-4">
          <p class="text-xs text-[#888] uppercase tracking-wider mb-1">Effective Jobs (w/ Carryover)</p>
          <p class="text-2xl font-['Barlow_Condensed'] font-800" id="sum-effective-jobs">0</p>
        </div>
        <div class="bg-[#2A2A2A] rounded-xl p-4">
          <p class="text-xs text-[#888] uppercase tracking-wider mb-1">Avg Commission %</p>
          <p class="text-2xl font-['Barlow_Condensed'] font-800" id="sum-avg-pct">0%</p>
        </div>
      </div>

      <!-- Breakdown -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
        <div class="space-y-3">
          <!-- Upfront Commission -->
          <div class="flex justify-between text-sm"><span class="text-[#888]">Upfront Commission</span><span id="sum-upfront" class="font-600">$0</span></div>

          <!-- Backend Commission -->
          <div class="flex justify-between text-sm border-t border-[#333] pt-3 mt-1"><span class="text-[#888]">Backend Commission</span><span id="sum-backend-mult" class="font-600">$0</span></div>
          <div class="pl-4 space-y-1.5">
            <div class="flex justify-between text-xs"><span class="text-[#666]">Base Backend</span><span id="sum-backend-base" class="text-[#888]">$0</span></div>
            <div class="flex justify-between text-xs"><span class="text-[#666]">GM Bonus</span><span id="sum-gp-bonus" class="text-[#888]">$0</span></div>
            <div class="flex justify-between text-xs"><span class="text-[#666]">Multiplier Bonus</span><span id="sum-mult-bonus" class="text-[#888]">$0</span></div>
          </div>

          <!-- Upgrades -->
          <div class="flex justify-between text-sm border-t border-[#333] pt-3 mt-1" id="upgrade-line"><span class="text-[#888]">Upgrades + Deposit Bonus</span><span id="sum-upgrades" class="font-600">$0</span></div>

          <!-- Recruiting -->
          <div class="flex justify-between text-sm border-t border-[#333] pt-3 mt-1" id="recruit-line"><span class="text-[#888]">Recruiting Override</span><span id="sum-recruit" class="font-600">$0</span></div>

          <!-- Team (manager) -->
          <div class="flex justify-between text-sm border-t border-[#333] pt-3 mt-1" id="team-line" style="display:none"><span class="text-[#888]">Team Sales Override</span><span id="sum-team" class="font-600">$0</span></div>
        </div>

        <div class="flex flex-col items-center justify-center bg-[#2A2A2A] rounded-xl p-6">
          <p class="text-xs text-[#888] uppercase tracking-wider mb-2">Total Quarterly Earnings</p>
          <p class="text-5xl font-['Barlow_Condensed'] font-900 text-[#E6A817]" id="sum-total">$0</p>
          <div class="flex gap-6 mt-4 text-sm text-[#888]">
            <div class="text-center"><p class="font-600 text-white" id="sum-monthly">$0</p><p>/ month</p></div>
            <div class="text-center"><p class="font-600 text-white" id="sum-weekly">$0</p><p>/ week</p></div>
          </div>
        </div>
      </div>
    </div>

    <!-- Reference Tables Toggle -->
    <details class="mt-8 mb-12">
      <summary class="font-['Barlow_Condensed'] font-700 text-lg cursor-pointer text-[#555] hover:text-[#1A1A1A] transition-colors duration-200">View Commission Tables &amp; Reference</summary>
      <div class="mt-5 grid grid-cols-1 md:grid-cols-2 gap-6">

        <!-- Rep Commission Grid -->
        <div id="ref-rep" class="bg-[#F7F7F7] border border-[#E0E0E0] rounded-xl p-5">
          <h3 class="font-['Barlow_Condensed'] font-700 text-base mb-3">Sales Rep - Base Commission</h3>
          <table class="w-full text-xs">
            <thead><tr class="text-[#888] border-b border-[#E0E0E0]"><th class="pb-2 text-left">Selling Price</th><th class="pb-2 text-right">Total</th><th class="pb-2 text-right">Upfront</th><th class="pb-2 text-right">Backend</th></tr></thead>
            <tbody>
              <tr><td>&lt; $20k</td><td class="text-right">$1,000</td><td class="text-right">$700</td><td class="text-right">$300</td></tr>
              <tr><td>$20k–$30k</td><td class="text-right">$1,500</td><td class="text-right">$1,070</td><td class="text-right">$430</td></tr>
              <tr><td>$30k–$45k</td><td class="text-right">$2,250</td><td class="text-right">$1,575</td><td class="text-right">$675</td></tr>
              <tr><td>$45k–$60k</td><td class="text-right">$3,000</td><td class="text-right">$2,100</td><td class="text-right">$900</td></tr>
              <tr><td>$60k–$75k</td><td class="text-right">$3,750</td><td class="text-right">$2,625</td><td class="text-right">$1,125</td></tr>
