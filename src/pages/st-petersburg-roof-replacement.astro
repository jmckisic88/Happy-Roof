      <span class="scard px-4 py-3 text-center" style="font-size:.9rem;font-weight:600">Crescent Lake</span>
      <span class="scard px-4 py-3 text-center" style="font-size:.9rem;font-weight:600">Historic Uptown</span>
      <span class="scard px-4 py-3 text-center" style="font-size:.9rem;font-weight:600">Coquina Key</span>
      <span class="scard px-4 py-3 text-center" style="font-size:.9rem;font-weight:600">Riviera Bay</span>
      <span class="scard px-4 py-3 text-center" style="font-size:.9rem;font-weight:600">Lakewood Estates</span>
      <span class="scard px-4 py-3 text-center" style="font-size:.9rem;font-weight:600">Tyrone</span>
      <span class="scard px-4 py-3 text-center" style="font-size:.9rem;font-weight:600">Pasadena</span>
      <span class="scard px-4 py-3 text-center" style="font-size:.9rem;font-weight:600">Downtown St. Pete</span>
    </div>
