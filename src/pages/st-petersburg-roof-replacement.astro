---
import BaseLayout from '../layouts/BaseLayout.astro';

const schema = `[{
    "@context": "https://schema.org",
    "@type": ["LocalBusiness", "RoofingContractor"],
    "name": "Happy Roof LLC",
    "url": "https://happyroof.com",
    "telephone": "+1-813-595-7663",
    "email": "info@happyroof.com",
    "description": "St. Petersburg roof replacement contractor. Shingle, metal, and tile roofing. Licensed and insured. FL License #CCC1337380.",
    "image": "/Brand%20Assets/Happy%20Roof%20Logo.jpeg",
    "logo": "/Brand%20Assets/Happy%20Roof%20Logo.jpeg",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "141 Stevens Ave #12",
      "addressLocality": "Oldsmar",
      "addressRegion": "FL",
      "postalCode": "34677",
      "addressCountry": "US"
    },
    "areaServed": {
      "@type": "City",
      "name": "St. Petersburg",
      "containedInPlace": { "@type": "State", "name": "Florida" }
    },
    "hasCredential": "Florida Roofing Contractor License #CCC1337380",
    "dateModified": "2026-04-25"
  },{
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How much does a roof replacement cost in St. Petersburg?",
        "acceptedAnswer": { "@type": "Answer", "text": "Roof replacement in St. Petersburg typically ranges from $8,500 to $28,000 depending on roof size, material (shingles, metal, or tile), pitch complexity, and whether structural repairs are needed. Older homes in neighborhoods like Old Northeast and Kenwood sometimes require additional decking work. Call (813) 595-7663 for a free estimate." }
      },
      {
        "@type": "Question",
        "name": "What materials hold up best in St. Petersburg's coastal climate?",
        "acceptedAnswer": { "@type": "Answer", "text": "Standing seam metal with Kynar finish is the top performer against salt air corrosion along the St. Pete waterfront. Owens Corning Duration HDZ shingles offer excellent wind resistance at a lower price point. Concrete tile is extremely durable and suits the architectural character of many St. Petersburg neighborhoods." }
      },
      {
        "@type": "Question",
        "name": "How long does a roof replacement take in St. Petersburg?",
        "acceptedAnswer": { "@type": "Answer", "text": "Shingle roofs typically take 1-3 days, metal roofs 3-5 days, and tile roofs 5-7 days. St. Pete's afternoon sea breeze thunderstorms during summer can cause brief delays, but we schedule around weather and communicate proactively." }
      },
      {
        "@type": "Question",
        "name": "Does Happy Roof handle St. Petersburg and Pinellas County permits?",
        "acceptedAnswer": { "@type": "Answer", "text": "Yes. We manage the entire permit process with the City of St. Petersburg and Pinellas County building departments, including all required inspections. Our Florida License #CCC1337380 authorizes roofing work statewide." }
      }
    ]
  }]`;
---

<BaseLayout
  title="St. Petersburg Roof Replacement | Happy Roof"
  description="St. Petersburg roof replacement by Happy Roof. Shingle, metal & tile options. Licensed and insured. 15-year warranty option. FL License #CCC1337380. Free estimates: (813) 595-7663."
  canonical="https://happyroof.com/st-petersburg-roof-replacement"
  schema={schema}
>

<style is:inline>
.check-dot{width:20px;height:20px;border-radius:50%;display:flex;align-items:center;justify-content:center;background:rgba(230,168,23,.1);flex-shrink:0;margin-top:.15rem}
    .step-num{width:48px;height:48px;border-radius:14px;display:flex;align-items:center;justify-content:center;background:rgba(230,168,23,.1);font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.25rem;color:#E6A817;flex-shrink:0}
</style>

<!-- HERO -->
<section class="pt-32 pb-20 relative overflow-hidden" style="background:#F5F5F5;border-bottom:1px solid #E5E5E5">
  <div class="hero-photo-bg" style="background-image:url('/Brand%20Assets/Photos/standing-seam-metal-roof-tampa.jpg')"></div>
  <div class="hero-photo-overlay"></div>
  <div class="relative z-10 max-w-7xl mx-auto px-5 text-center">
    <p class="sl gp mb-4">St. Petersburg Roof Replacement</p>
    <h1 class="font-display font-black tracking-tightest mb-5" style="font-family:'Barlow Condensed',sans-serif;font-size:clamp(2.5rem,5.5vw,4.5rem);line-height:.92;letter-spacing:-.01em;color:#1A1A1A">
      ST. PETERSBURG<br/>ROOF REPLACEMENT<br/><span class="gt">TRUSTED LOCAL CONTRACTOR</span>
    </h1>
    <p class="max-w-2xl mx-auto" style="color:#555555;font-size:1.05rem;line-height:1.75">
      Happy Roof provides complete roof replacement in St. Petersburg, FL. From the Craftsman bungalows of Historic Kenwood to the waterfront condos along the downtown marina, we install shingle, metal, and tile roofing systems engineered for Pinellas County's coastal climate.
    </p>
    <div class="flex flex-wrap gap-3 justify-center mt-8">
      <a href="/contact" class="btn-t">Get a Free Estimate <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg></a>
      <a href="tel:8135957663" class="btn-o call-tracking-number">Call (813) 595-7663</a>
    </div>
  </div>
</section>

<!-- INFO STRIP -->
<div style="background:#FFFFFF;border-top:2px solid #E6A817;border-bottom:1px solid #E0E0E0;padding:.85rem 0">
  <div class="max-w-7xl mx-auto px-5">
    <div class="flex flex-wrap items-center justify-center gap-x-8 gap-y-2 font-display font-bold text-sm tracking-widest" style="color:#1A1A1A;text-transform:uppercase;font-family:'Barlow Condensed',sans-serif">
      <span>St. Petersburg, FL</span><span style="color:#E6A817">·</span><span>CCC1337380</span><span style="color:#E6A817">·</span><span>HappyRoof.com</span><span style="color:#E6A817">·</span><span style="color:#3B9FD9">(813) 595-7663</span>
    </div>
  </div>
</div>

<!-- WHY SECTION -->
<section class="py-20" style="background:#FFFFFF">
  <div class="max-w-7xl mx-auto px-5">
    <div class="grid lg:grid-cols-2 gap-14 items-start">
      <div>
        <p class="sl gt mb-3">Why Replace Your Roof in St. Petersburg</p>
        <h2 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:clamp(2rem,4vw,3rem);line-height:.95;color:#1A1A1A;letter-spacing:-.01em;margin-bottom:1.5rem">WHY ST. PETERSBURG HOMEOWNERS CHOOSE A FULL ROOF REPLACEMENT</h2>
        <p style="color:#555555;font-size:1rem;line-height:1.75;margin-bottom:1.5rem">St. Petersburg occupies a narrow peninsula between Tampa Bay and the Gulf of Mexico, giving it a microclimate distinct from mainland Tampa. Salt-laden gulf breezes accelerate corrosion on metal components, afternoon sea breezes pull moisture inland, and the city's proximity to open water amplifies storm surge risk during hurricanes. Roofs in waterfront neighborhoods like Shore Acres, Snell Isle, and Old Northeast endure constant salt air exposure that degrades roofing materials faster than homes just 20 miles inland.</p>
        <p style="color:#555555;font-size:1rem;line-height:1.75;margin-bottom:1.5rem">Many St. Petersburg homes were built during the city's mid-century boom - the 1950s and 1960s - and their original or second-generation roofs have reached the end of their service life. Neighborhoods like Jungle Terrace, Disston Heights, and Euclid-St. Paul are filled with concrete block homes whose aging shingle roofs show widespread granule loss, curling edges, and compromised underlayment. A full tear-off and replacement is the most reliable way to restore weatherproofing and protect these homes for another 25 to 50 years.</p>
        <p style="color:#555555;font-size:1rem;line-height:1.75;margin-bottom:1.5rem">Happy Roof handles every aspect of roof replacement in St. Petersburg - from pulling permits with the City of St. Petersburg and Pinellas County to coordinating inspections and final cleanup. We hold Florida License #CCC1337380 and carry full insurance. Visit our <a href="/st-petersburg-roofing" style="color:#3B9FD9;text-decoration:none;font-weight:600">St. Petersburg roofing page</a> for an overview of all services we offer in the area.</p>
      </div>
      <div class="space-y-4">
        <div class="scard p-6">
          <div class="check"><div class="check-dot"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#E6A817" stroke-width="3"><path d="M20 6L9 17l-5-5"/></svg></div><div><strong style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.05rem">Architectural Shingles</strong><p style="color:#555555;font-size:.9rem;line-height:1.6;margin-top:.25rem">Owens Corning Duration HDZ shingles rated for 130+ MPH winds. The most popular and cost-effective choice for St. Petersburg homes, available in a wide range of colors.</p></div></div>
        </div>
        <div class="scard p-6">
          <div class="check"><div class="check-dot"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#E6A817" stroke-width="3"><path d="M20 6L9 17l-5-5"/></svg></div><div><strong style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.05rem">Standing Seam Metal</strong><p style="color:#555555;font-size:.9rem;line-height:1.6;margin-top:.25rem">Corrosion-resistant panels ideal for St. Pete's salt air environment. Reflects solar heat, lasts 40-60 years, and withstands hurricane-force winds.</p></div></div>
        </div>
        <div class="scard p-6">
          <div class="check"><div class="check-dot"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#E6A817" stroke-width="3"><path d="M20 6L9 17l-5-5"/></svg></div><div><strong style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.05rem">Concrete & Clay Tile</strong><p style="color:#555555;font-size:.9rem;line-height:1.6;margin-top:.25rem">Perfect for the Mediterranean Revival and Spanish Colonial homes found throughout Old Northeast, Snell Isle, and the Historic Uptown neighborhood.</p></div></div>
        </div>
        <div class="scard p-6">
          <div class="check"><div class="check-dot"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#E6A817" stroke-width="3"><path d="M20 6L9 17l-5-5"/></svg></div><div><strong style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.05rem">Up to 15-Year Workmanship Warranty</strong><p style="color:#555555;font-size:.9rem;line-height:1.6;margin-top:.25rem">Every St. Petersburg roof replacement includes our written up to 15-year workmanship warranty plus the manufacturer's material warranty.</p></div></div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- WHAT'S INCLUDED / COMMON REPAIRS / WHAT WE CHECK -->
<section class="py-20" style="background:#F7F7F7">
