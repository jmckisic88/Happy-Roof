---
import BaseLayout from '../layouts/BaseLayout.astro';

const schema = `[{
    "@context": "https://schema.org",
    "@type": ["LocalBusiness", "RoofingContractor"],
    "name": "Happy Roof LLC",
    "url": "https://happyroof.com",
    "telephone": "+1-813-595-7663",
    "email": "info@happyroof.com",
    "description": "Tampa Bay roof repair contractor offering emergency leak repair, storm damage repair, shingle replacement, and flashing repair. FL License #CCC1337380.",
    "image": "/Brand%20Assets/Happy%20Roof%20Logo.jpeg",
    "logo": "/Brand%20Assets/Happy%20Roof%20Logo.jpeg",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "141 Stevens Ave #12","addressLocality": "Oldsmar",
      "addressRegion": "FL","postalCode": "34677","addressCountry": "US"
    },
    "hasCredential": "Florida Roofing Contractor License #CCC1337380",
    "dateModified": "2026-04-20"
  },{
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How quickly can Happy Roof respond to an emergency roof repair?",
        "acceptedAnswer": { "@type": "Answer", "text": "Happy Roof offers a 48-hour emergency response for roof repairs in Tampa Bay. If your roof is actively leaking or has sustained storm damage, call (813) 595-7663 immediately. We can typically have a crew on-site within 24 to 48 hours to tarp, patch, or stabilize your roof and prevent further interior damage." }
      },
      {
        "@type": "Question",
        "name": "Does Happy Roof help with roof insurance claims?",
        "acceptedAnswer": { "@type": "Answer", "text": "Yes. Happy Roof provides full insurance claim assistance for storm damage and other covered roof repairs. We document all damage with photos and detailed reports, meet with your insurance adjuster on-site, and help ensure your claim is processed fairly. We work with all major Florida homeowners insurance carriers." }
      },
      {
        "@type": "Question",
        "name": "How do I know if my roof needs a repair or a full replacement?",
        "acceptedAnswer": { "@type": "Answer", "text": "Generally, if the damage is isolated to a small area (missing shingles, a single leak point, damaged flashing around one penetration), a repair is the most cost-effective solution. If your roof is over 15-20 years old, has widespread damage, multiple leak points, or significant decking deterioration, a full replacement is usually the better long-term investment. Happy Roof provides honest assessments. We will never recommend a replacement when a repair will do." }
      },
      {
        "@type": "Question",
        "name": "Does Happy Roof offer a warranty on roof repairs?",
        "acceptedAnswer": { "@type": "Answer", "text": "Yes. Happy Roof provides an up to 15-year workmanship warranty on qualifying roof repairs,. in writing. Not all repairs qualify (for example, a temporary emergency tarp is not warrantied the same as a permanent shingle or flashing repair), but we will always be upfront about what is covered before work begins." }
      },
      {
        "@type": "Question",
        "name": "How much does a roof repair cost in Tampa Bay?",
        "acceptedAnswer": { "@type": "Answer", "text": "Roof repair costs in Tampa Bay vary widely depending on the type and extent of damage. Minor repairs like replacing a few shingles or sealing a small leak typically range from $300 to $800. More extensive repairs, such as replacing damaged flashing, fixing multiple leak points, or repairing storm damage, can range from $1,000 to $3,500+. Happy Roof provides free inspections and written estimates with no hidden fees. Call (813) 595-7663." }
      }
    ]
  },{
    "@context": "https://schema.org",
    "@type": "Service",
    "serviceType": "Roof Repair",
    "provider": { "@type": "RoofingContractor", "name": "Happy Roof LLC", "telephone": "+1-813-595-7663", "url": "https://happyroof.com" },
    "areaServed": { "@type": "State", "name": "Florida" },
    "description": "Professional roof repair services in Tampa Bay including emergency leak repair, storm damage repair, shingle replacement, flashing repair, and insurance claim assistance. 48-hour emergency response. 15-year warranty option on qualifying repairs."
  },{"@context":"https://schema.org","@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"Home","item":"https://happyroof.com/"},{"@type":"ListItem","position":2,"name":"Services","item":"https://happyroof.com/services"},{"@type":"ListItem","position":3,"name":"Roof Repair","item":"https://happyroof.com/roof-repair"}]}]`;
---

<BaseLayout
  title="Roof Repair Tampa Bay | Fast Emergency Service | Happy Roof"
  description="Fast roof repairs in Tampa Bay. Emergency leaks, storm damage, shingle &amp; flashing repair. 48hr response. Licensed FL #CCC1337380."
  canonical="https://happyroof.com/roof-repair"
  ogTitle="Roof Repair Tampa Bay | Emergency Leak & Storm Damage | Happy Roof"
  ogDescription="Fast, honest roof repairs in Tampa Bay. 48hr emergency response. Leak detection, shingle replacement, storm damage. 15-year warranty option on qualifying repairs."
  schema={schema}
>

<style is:inline>
.check-dot{width:20px;height:20px;border-radius:50%;display:flex;align-items:center;justify-content:center;background:rgba(230,168,23,.1);flex-shrink:0;margin-top:.15rem}
    .step-num{width:48px;height:48px;border-radius:14px;display:flex;align-items:center;justify-content:center;background:rgba(230,168,23,.1);font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.25rem;color:#E6A817;flex-shrink:0}
</style>

<!-- PAGE HERO -->
<section class="pt-32 pb-20 relative overflow-hidden" style="background:#F5F5F5;border-bottom:1px solid #E5E5E5">
  <div class="hero-photo-bg" style="background-image:url('/Brand%20Assets/Photos/architectural-shingle-roof-tampa-bay.jpg')"></div>
  <div class="hero-photo-overlay"></div>
  <div class="relative z-10 max-w-7xl mx-auto px-5 text-center">
    <p class="sl gp mb-4">Roof Repair</p>
    <h1 class="font-display font-black tracking-tightest mb-5" style="font-family:'Barlow Condensed',sans-serif;font-size:clamp(3rem,6vw,5rem);line-height:.92;letter-spacing:-.01em;color:#1A1A1A">
      FAST, HONEST<br/><span class="gt">ROOF REPAIRS.</span>
    </h1>
    <p class="max-w-2xl mx-auto" style="color:#555555;font-size:1.05rem;line-height:1.75">
      When your roof is leaking, damaged, or compromised, you need a contractor who shows up fast, gives you an honest assessment, and does the job right. Happy Roof provides professional roof repairs across Tampa Bay with a 48-hour emergency response, backed by our up to 15-year workmanship warranty on qualifying repairs.
    </p>
    <p class="max-w-2xl mx-auto mt-4" style="color:#777;font-size:.88rem;line-height:1.75">
      Roof repair in Tampa Bay typically costs between $350 and $1,500 depending on the extent of damage. Happy Roof (FL License #CCC1337380) offers emergency tarping within 48 hours, leak detection, shingle and flashing replacement, soffit and fascia repair, and full storm damage restoration with insurance claim assistance. Serving Tampa, Clearwater, St. Petersburg, and surrounding areas. Free inspections.  Call (813) 595-7663.
    </p>
  </div>
</section>

<!-- INFO STRIP -->
<div style="background:#FFFFFF;border-top:2px solid #E6A817;border-bottom:1px solid #E0E0E0;padding:.85rem 0">
  <div class="max-w-7xl mx-auto px-5">
    <div class="flex flex-wrap items-center justify-center gap-x-8 gap-y-2 font-display font-bold text-sm tracking-widest" style="color:#1A1A1A;text-transform:uppercase;font-family:'Barlow Condensed',sans-serif">
      <span>48hr Emergency Response</span>
      <span style="color:#E6A817">&middot;</span>
      <span>CCC1337380</span>
      <span style="color:#E6A817">&middot;</span>
      <span>Insurance Claim Help</span>
      <span style="color:#E6A817">&middot;</span>
      <span style="color:#3B9FD9">(813) 595-7663</span>
    </div>
  </div>
</div>

<!-- EMERGENCY REPAIRS -->
<section class="py-20" style="background:#FFFFFF">
  <div class="max-w-7xl mx-auto px-5">
    <div class="grid lg:grid-cols-2 gap-14 items-start">
      <div>
        <p class="sl gt mb-3">Emergency Service</p>
        <h2 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:clamp(2rem,4vw,3rem);line-height:.95;color:#1A1A1A;letter-spacing:-.01em;margin-bottom:1.5rem">EMERGENCY ROOF REPAIRS - 48-HOUR RESPONSE</h2>
        <p style="color:#555555;font-size:1rem;line-height:1.75;margin-bottom:1.5rem">
          A damaged roof does not wait for business hours, and neither do we. When a storm tears off shingles, a tree limb punctures your decking, or you discover water pouring through your ceiling at 2 a.m., Happy Roof is ready to respond. Our emergency repair service is designed to stabilize your roof quickly and prevent further damage to your home's interior, structure, and belongings.
        </p>
        <p style="color:#555555;font-size:1rem;line-height:1.75;margin-bottom:1.5rem">
          We provide emergency tarping, temporary patching, and board-up services within 48 hours of your call, often faster. Once the immediate threat is contained, we perform a thorough inspection to determine the full scope of damage and provide a written estimate for permanent repair. If the damage is insurance-related, we document everything your adjuster needs and walk you through the claims process step by step.
        </p>
        <p style="color:#555555;font-size:1rem;line-height:1.75">
          Do not wait for water damage to spread. Call <a href="tel:8135957663" class="call-tracking-number" style="color:#3B9FD9;text-decoration:none;font-weight:600">(813) 595-7663</a> now - we answer 7 days a week.
        </p>
      </div>
      <div class="space-y-4">
        <div class="scard p-6">
          <div class="check"><div class="check-dot"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#E6A817" stroke-width="3"><path d="M20 6L9 17l-5-5"/></svg></div><div><strong style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.05rem">Emergency Tarping</strong><p style="color:#555555;font-size:.9rem;line-height:1.6;margin-top:.25rem">Heavy-duty tarps secured to prevent further water intrusion. We use proper anchoring methods that protect your roof while keeping your home dry.</p></div></div>
        </div>
        <div class="scard p-6">
          <div class="check"><div class="check-dot"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#E6A817" stroke-width="3"><path d="M20 6L9 17l-5-5"/></svg></div><div><strong style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.05rem">Temporary Patching</strong><p style="color:#555555;font-size:.9rem;line-height:1.6;margin-top:.25rem">Quick patches for punctures, holes, and exposed decking. Stops active leaks while you decide on permanent repair options.</p></div></div>
        </div>
        <div class="scard p-6">
          <div class="check"><div class="check-dot"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#E6A817" stroke-width="3"><path d="M20 6L9 17l-5-5"/></svg></div><div><strong style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.05rem">Insurance Documentation</strong><p style="color:#555555;font-size:.9rem;line-height:1.6;margin-top:.25rem">We photograph all damage, provide detailed reports, and meet with your adjuster on-site to support your claim.</p></div></div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- LEAK DETECTION -->
<section class="py-20" style="background:#F7F7F7">
  <div class="max-w-7xl mx-auto px-5">
    <div class="text-center mb-14">
      <p class="sl gt mb-3">Leak Detection</p>
      <h2 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:clamp(2rem,4vw,3rem);line-height:.95;color:#1A1A1A;letter-spacing:-.01em;margin-bottom:1rem">PROFESSIONAL LEAK DETECTION &amp; DIAGNOSIS</h2>
      <p style="color:#555555;font-size:1rem;line-height:1.75;max-width:700px;margin:0 auto">
        Not all roof leaks are obvious. Water can travel along rafters, trusses, and sheathing before emerging as a ceiling stain far from the actual entry point. That is why accurate leak detection requires experience, training, and a systematic approach, not guesswork.
      </p>
    </div>
    <div class="grid md:grid-cols-3 gap-8">
      <div class="scard p-8">
        <div style="width:52px;height:52px;border-radius:14px;display:flex;align-items:center;justify-content:center;background:rgba(230,168,23,.1);margin-bottom:1rem">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#E6A817" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
        </div>
        <h3 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.35rem;color:#1A1A1A;margin-bottom:.75rem">Visual Roof Inspection</h3>
        <p style="color:#555555;font-size:.95rem;line-height:1.7">
          We start with a comprehensive visual inspection of your entire roof surface, checking for missing, cracked, or curling shingles, damaged flashing, compromised sealant, and signs of wear around penetrations like vents, pipes, and skylights. We also inspect your attic from the inside, looking for daylight penetration, moisture stains, and mold growth.
        </p>
      </div>
      <div class="scard p-8">
        <div style="width:52px;height:52px;border-radius:14px;display:flex;align-items:center;justify-content:center;background:rgba(230,168,23,.1);margin-bottom:1rem">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#E6A817" stroke-width="2"><path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z"/></svg>
        </div>
        <h3 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.35rem;color:#1A1A1A;margin-bottom:.75rem">Water Testing</h3>
        <p style="color:#555555;font-size:.95rem;line-height:1.7">
          For leaks that are difficult to pinpoint visually, we use controlled water testing to isolate the entry point. By systematically wetting specific areas of the roof while monitoring the interior, we can identify exactly where water is penetrating, even when the stain on your ceiling is several feet from the actual source.
        </p>
      </div>
      <div class="scard p-8">
        <div style="width:52px;height:52px;border-radius:14px;display:flex;align-items:center;justify-content:center;background:rgba(230,168,23,.1);margin-bottom:1rem">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#E6A817" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
        </div>
        <h3 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.35rem;color:#1A1A1A;margin-bottom:.75rem">Detailed Repair Report</h3>
        <p style="color:#555555;font-size:.95rem;line-height:1.7">
          After diagnosis, you receive a detailed written report with photos documenting the damage, the identified leak source(s), and our recommended repair plan with pricing. If the damage is covered by insurance, this report serves as supporting documentation for your claim. No surprises, no guesswork.
        </p>
      </div>
    </div>
  </div>
</section>

<!-- SHINGLE REPLACEMENT & FLASHING REPAIR -->
<section class="py-20" style="background:#FFFFFF">
  <div class="max-w-7xl mx-auto px-5">
    <div class="grid lg:grid-cols-2 gap-14 items-start">
      <div>
        <p class="sl gt mb-3">Shingle Repair</p>
        <h2 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:clamp(2rem,4vw,3rem);line-height:.95;color:#1A1A1A;letter-spacing:-.01em;margin-bottom:1.5rem">SHINGLE REPLACEMENT &amp; REPAIR</h2>
        <p style="color:#555555;font-size:1rem;line-height:1.75;margin-bottom:1.5rem">
          Missing, cracked, curling, or wind-lifted shingles leave your roof deck exposed to water, UV damage, and further deterioration. Even a few compromised shingles can lead to leaks, mold growth, and structural damage if left unaddressed. Happy Roof replaces damaged shingles with matching materials, restoring your roof's protection and appearance without the cost of a full replacement.
        </p>
        <p style="color:#555555;font-size:1rem;line-height:1.75;margin-bottom:1.5rem">
          We carry a wide inventory of Owens Corning, and other major-brand shingles to ensure a close color and profile match with your existing roof. If your shingles are discontinued or heavily weathered, we will let you know upfront and discuss options - including partial re-roofing of the affected slope for a uniform appearance.
        </p>
        <p style="color:#555555;font-size:1rem;line-height:1.75">
          All shingle repairs include inspection of the underlying felt or synthetic underlayment and decking. If we find rot, delamination, or moisture damage beneath the shingles, we address it before installing new material, because patching over a bad substrate just delays the problem.
        </p>
      </div>
      <div>
        <p class="sl gt mb-3">Flashing Repair</p>
        <h2 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:clamp(2rem,4vw,3rem);line-height:.95;color:#1A1A1A;letter-spacing:-.01em;margin-bottom:1.5rem">FLASHING REPAIR &amp; REPLACEMENT</h2>
        <p style="color:#555555;font-size:1rem;line-height:1.75;margin-bottom:1.5rem">
          Roof flashing, the metal strips that seal joints, valleys, chimneys, vents, skylights, and wall-to-roof transitions, is one of the most critical components of your roofing system. When flashing corrodes, lifts, or separates, it creates a direct path for water into your home. In fact, damaged or improperly installed flashing is the number one cause of roof leaks in Tampa Bay.
        </p>
        <p style="color:#555555;font-size:1rem;line-height:1.75;margin-bottom:1.5rem">
          Happy Roof repairs and replaces all types of roof flashing, including step flashing, counter flashing, valley flashing, drip edge, pipe boots, and chimney flashing. We use corrosion-resistant aluminum and galvanized steel, never cheap galvanized tin that rusts in Florida's humidity.
        </p>
        <p style="color:#555555;font-size:1rem;line-height:1.75">
          Every flashing repair we perform is sealed with high-quality roofing sealant and mechanically fastened to code. We do not use roof cement as a substitute for proper flashing installation, a common shortcut that leads to callbacks and repeat leaks.
        </p>
      </div>
    </div>
  </div>
</section>

<!-- STORM DAMAGE -->
<section class="py-20" style="background:#F7F7F7">
  <div class="max-w-7xl mx-auto px-5">
    <div class="text-center mb-14">
      <p class="sl gt mb-3">Storm Damage</p>
      <h2 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:clamp(2rem,4vw,3rem);line-height:.95;color:#1A1A1A;letter-spacing:-.01em;margin-bottom:1rem">STORM DAMAGE REPAIRS &amp; INSURANCE ASSISTANCE</h2>
      <p style="color:#555555;font-size:1rem;line-height:1.75;max-width:700px;margin:0 auto">
        Tampa Bay homeowners know that hurricanes, tropical storms, and severe thunderstorms can cause significant roof damage in minutes. High winds lift and tear shingles, hail cracks tiles, and flying debris can puncture even the strongest roofing systems. After a storm, fast action is critical, both to protect your home and to preserve your insurance claim.
      </p>
    </div>
    <div class="grid md:grid-cols-2 gap-6">
      <div class="scard p-8">
        <div class="check"><div class="check-dot"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#E6A817" stroke-width="3"><path d="M20 6L9 17l-5-5"/></svg></div><div><strong style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.05rem">Wind Damage Repair</strong><p style="color:#555555;font-size:.9rem;line-height:1.6;margin-top:.25rem">High winds can lift shingles, peel back flashing, and expose your roof deck to water. We replace blown-off shingles, re-secure lifted material, and repair any underlying damage to the deck and underlayment.</p></div></div>
      </div>
      <div class="scard p-8">
        <div class="check"><div class="check-dot"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#E6A817" stroke-width="3"><path d="M20 6L9 17l-5-5"/></svg></div><div><strong style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.05rem">Hail &amp; Impact Damage</strong><p style="color:#555555;font-size:.9rem;line-height:1.6;margin-top:.25rem">Hail can crack tiles, bruise shingles, and dent metal panels - often causing damage that is not visible from the ground. Our trained inspectors identify all hail impact points and document them for your insurance claim.</p></div></div>
      </div>
      <div class="scard p-8">
        <div class="check"><div class="check-dot"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#E6A817" stroke-width="3"><path d="M20 6L9 17l-5-5"/></svg></div><div><strong style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.05rem">Debris &amp; Tree Damage</strong><p style="color:#555555;font-size:.9rem;line-height:1.6;margin-top:.25rem">Fallen branches and airborne debris can puncture your roof and cause structural damage. We safely remove debris, assess structural integrity, and make permanent repairs to decking, underlayment, and surface materials.</p></div></div>
      </div>
      <div class="scard p-8">
        <div class="check"><div class="check-dot"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#E6A817" stroke-width="3"><path d="M20 6L9 17l-5-5"/></svg></div><div><strong style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.05rem">Insurance Claim Assistance</strong><p style="color:#555555;font-size:.9rem;line-height:1.6;margin-top:.25rem">We document all storm damage with photos and detailed reports, meet with your adjuster on-site, and help ensure your claim is processed accurately. We work with all major Florida insurance carriers and never pressure you into unnecessary work.</p></div></div>
      </div>
    </div>
  </div>
</section>

<!-- REPAIR VS REPLACE -->
<section class="py-20" style="background:#FFFFFF">
  <div class="max-w-7xl mx-auto px-5">
    <div class="text-center mb-14">
      <p class="sl gt mb-3">Decision Guide</p>
      <h2 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:clamp(2rem,4vw,3rem);line-height:.95;color:#1A1A1A;letter-spacing:-.01em;margin-bottom:1rem">WHEN TO REPAIR VS. WHEN TO REPLACE</h2>
      <p style="color:#555555;font-size:1rem;line-height:1.75;max-width:700px;margin:0 auto">
        Not every roof problem requires a full replacement. But sometimes a repair is just a band-aid on a bigger issue. Here is how to tell the difference, and Happy Roof will always give you an honest recommendation.
      </p>
    </div>
    <div class="grid md:grid-cols-2 gap-8">
      <div class="scard p-8">
        <h3 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.35rem;color:#1A1A1A;margin-bottom:1rem">
          <span style="color:#3B9FD9">REPAIR</span> Makes Sense When...
        </h3>
        <ul style="color:#555555;font-size:.95rem;line-height:1.7;list-style:none;padding:0;margin:0">
          <li style="margin-bottom:.75rem;padding-left:1.5rem;position:relative"><span style="position:absolute;left:0;color:#E6A817;font-weight:700">+</span> Damage is isolated to one area or a few shingles</li>
          <li style="margin-bottom:.75rem;padding-left:1.5rem;position:relative"><span style="position:absolute;left:0;color:#E6A817;font-weight:700">+</span> Your roof is less than 15 years old</li>
          <li style="margin-bottom:.75rem;padding-left:1.5rem;position:relative"><span style="position:absolute;left:0;color:#E6A817;font-weight:700">+</span> There is a single, identifiable leak point</li>
          <li style="margin-bottom:.75rem;padding-left:1.5rem;position:relative"><span style="position:absolute;left:0;color:#E6A817;font-weight:700">+</span> Flashing around one penetration has failed</li>
          <li style="padding-left:1.5rem;position:relative"><span style="position:absolute;left:0;color:#E6A817;font-weight:700">+</span> The decking underneath is still solid</li>
        </ul>
      </div>
      <div class="scard p-8">
        <h3 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.35rem;color:#1A1A1A;margin-bottom:1rem">
          <span style="color:#3B9FD9">REPLACE</span> Makes Sense When...
        </h3>
        <ul style="color:#555555;font-size:.95rem;line-height:1.7;list-style:none;padding:0;margin:0">
          <li style="margin-bottom:.75rem;padding-left:1.5rem;position:relative"><span style="position:absolute;left:0;color:#3B9FD9;font-weight:700">+</span> Your roof is 20+ years old with widespread wear</li>
