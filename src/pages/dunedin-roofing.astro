---
import BaseLayout from '../layouts/BaseLayout.astro';

const schema = `[{"@context":"https://schema.org","@type":["LocalBusiness","RoofingContractor"],"name":"Happy Roof LLC","url":"https://happyroof.com","telephone":"+1-813-595-7663","email":"info@happyroof.com","description":"Dunedin roofing contractor specializing in shingle, metal, and tile roof replacement. Licensed and insured. FL License #CCC1337380.","image":"/Brand%20Assets/Happy%20Roof%20Logo.jpeg","logo":"/Brand%20Assets/Happy%20Roof%20Logo.jpeg","address":{"@type":"PostalAddress","streetAddress":"141 Stevens Ave #12","addressLocality":"Oldsmar","addressRegion":"FL","postalCode":"34677","addressCountry":"US"},"areaServed":{"@type":"City","name":"Dunedin","containedInPlace":{"@type":"State","name":"Florida"}},"hasCredential":"Florida Roofing Contractor License #CCC1337380","dateModified":"2026-04-10"},{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[
    {"@type":"Question","name":"How much does a roof replacement cost in Dunedin?","acceptedAnswer":{"@type":"Answer","text":"A typical roof replacement in Dunedin ranges from $8,000 to $24,000+ depending on roof size, pitch, material, and structural condition. Dunedin's mix of older bungalows near downtown and newer construction in outlying areas means pricing can vary significantly. Happy Roof provides free, no-obligation estimates - call (813) 595-7663."}},
    {"@type":"Question","name":"What roofing material works best for homes in Dunedin?","acceptedAnswer":{"@type":"Answer","text":"Dunedin's proximity to the Gulf of Mexico and St. Joseph Sound means salt air, intense UV, and strong storm winds. Architectural shingles with 130+ MPH ratings are the most popular choice. Metal roofing is excellent for Dunedin's climate - it reflects heat and resists salt-air corrosion. Tile is popular on homes with a classic Florida or Mediterranean style. We install all three."}},
    {"@type":"Question","name":"Does Happy Roof handle City of Dunedin permits?","acceptedAnswer":{"@type":"Answer","text":"Yes. We handle all permit applications and inspections with the City of Dunedin and Pinellas County building departments. You never have to visit a government office or coordinate with inspectors - we manage the entire process."}},
    {"@type":"Question","name":"How long does a Dunedin roof replacement take?","acceptedAnswer":{"@type":"Answer","text":"Most Dunedin shingle roof replacements are completed in 1 to 3 days. Metal roofs take 3 to 5 days, and tile roofs 5 to 7 days. We work around weather and keep you informed at every step. Full cleanup and debris removal is included."}},
    {"@type":"Question","name":"Is Happy Roof licensed to work in Dunedin?","acceptedAnswer":{"@type":"Answer","text":"Yes. Happy Roof LLC holds Florida Roofing Contractor License #CCC1337380, authorizing roofing work throughout Florida including Dunedin and all of Pinellas County. We carry full general liability and workers' compensation insurance."}}
  ]}]`;
---

<BaseLayout
  title="Dunedin Roofing Contractor - Licensed & Insured | Happy Roof"
  description="Dunedin roofing contractor - Happy Roof provides roof replacement, repair, and installation in Dunedin FL. Licensed and insured. FL License #CCC1337380. Free estimates: (813) 595-7663."
  canonical="https://happyroof.com/dunedin-roofing"
  ogTitle="Dunedin Roofing Contractor | Happy Roof"
  ogDescription="Licensed Dunedin roofer for replacements, repairs & storm damage. Free estimates - call (813) 595-7663."
  schema={schema}
>

<style is:inline>
.step-num{width:48px;height:48px;border-radius:14px;display:flex;align-items:center;justify-content:center;background:rgba(230,168,23,.1);font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.25rem;color:#E6A817;flex-shrink:0}
</style>

<section class="pt-32 pb-20 relative overflow-hidden" style="background:#F5F5F5;border-bottom:1px solid #E5E5E5">
  <div class="hero-photo-bg" style="background-image:url('/Brand%20Assets/Photos/standing-seam-metal-roof-tampa.jpg')"></div>
  <div class="hero-photo-overlay"></div>
  <div class="relative z-10 max-w-7xl mx-auto px-5 text-center">
    <p class="sl gp mb-4">Dunedin Roofing</p>
    <h1 class="font-display font-black tracking-tightest mb-5" style="font-family:'Barlow Condensed',sans-serif;font-size:clamp(2.5rem,5.5vw,4.5rem);line-height:.92;letter-spacing:-.01em;color:#1A1A1A">DUNEDIN ROOFING CONTRACTOR<br/><span class="gt">LICENSED & INSURED</span></h1>
    <p class="max-w-2xl mx-auto" style="color:#555555;font-size:1.05rem;line-height:1.75">Dunedin homeowners trust Happy Roof for quality roof replacement, repair, and installation. As a licensed and insured roofing contractor, we build roofing systems designed to protect this charming Gulf-side community from Florida's toughest weather - backed by our 15-year workmanship warranty.</p>
    <div class="flex flex-wrap gap-3 justify-center mt-8"><a href="/contact" class="btn-t">Get a Free Estimate <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg></a><a href="tel:8135957663" class="btn-o call-tracking-number">Call (813) 595-7663</a></div>
  </div>
</section>

<div style="background:#FFFFFF;border-top:2px solid #E6A817;border-bottom:1px solid #E0E0E0;padding:.85rem 0"><div class="max-w-7xl mx-auto px-5"><div class="flex flex-wrap items-center justify-center gap-x-8 gap-y-2 font-display font-bold text-sm tracking-widest" style="color:#1A1A1A;text-transform:uppercase;font-family:'Barlow Condensed',sans-serif"><span>Dunedin, FL</span><span style="color:#E6A817">·</span><span>CCC1337380</span><span style="color:#E6A817">·</span><span>HappyRoof.com</span><span style="color:#E6A817">·</span><span style="color:#3B9FD9">(813) 595-7663</span></div></div></div>

<section class="py-20" style="background:#FFFFFF">
  <div class="max-w-7xl mx-auto px-5">
    <div class="grid lg:grid-cols-2 gap-14 items-start">
      <div>
        <p class="sl gt mb-3">Why Happy Roof in Dunedin</p>
        <h2 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:clamp(2rem,4vw,3rem);line-height:.95;color:#1A1A1A;letter-spacing:-.01em;margin-bottom:1.5rem">WHY DUNEDIN HOMEOWNERS CHOOSE HAPPY ROOF</h2>
        <p style="color:#555555;font-size:1rem;line-height:1.75;margin-bottom:1.5rem">
          Dunedin is one of the most charming coastal cities in Pinellas County - known for its Scottish heritage, walkable downtown along Main Street, the Pinellas Trail, and the gateway to Caladesi Island and Honeymoon Island state parks. The city's housing stock ranges from 1920s-era bungalows in the historic downtown district to newer construction in planned communities south of Curlew Road. Many of these older homes have roofs with unique pitch angles and architectural details that require experienced craftsmanship to re-roof properly, while newer homes in communities like The Woodlands and Stirling Chase need roofs that can handle the next 25 to 50 years of Florida weather.
        </p>
        <p style="color:#555555;font-size:1rem;line-height:1.75;margin-bottom:1.5rem">
          Happy Roof serves Dunedin from our Oldsmar headquarters - just a short drive east on Tampa Road. We know the City of Dunedin's building department requirements, understand the coastal wind zones that affect homes along the Intracoastal, and have experience working on every style of roof in town. We hold Florida License #CCC1337380, carry full insurance, and provide a 15-year written workmanship warranty on every installation.
        </p>
      </div>
      <div class="space-y-4">
        <div class="scard p-6"><div class="check"><div class="check-dot"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#E6A817" stroke-width="3"><path d="M20 6L9 17l-5-5"/></svg></div><div><strong style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.05rem">Owens Corning Installer</strong><p style="color:#555555;font-size:.9rem;line-height:1.6;margin-top:.25rem">We install premium Owens Corning roofing systems with manufacturer warranties on all products.</p></div></div></div>
        <div class="scard p-6"><div class="check"><div class="check-dot"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#E6A817" stroke-width="3"><path d="M20 6L9 17l-5-5"/></svg></div><div><strong style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.05rem">15-Year Workmanship Warranty</strong><p style="color:#555555;font-size:.9rem;line-height:1.6;margin-top:.25rem">Written 15-year workmanship warranty on every Dunedin roof installation - no exceptions.</p></div></div></div>
        <div class="scard p-6"><div class="check"><div class="check-dot"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#E6A817" stroke-width="3"><path d="M20 6L9 17l-5-5"/></svg></div><div><strong style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.05rem">City of Dunedin Permits Handled</strong><p style="color:#555555;font-size:.9rem;line-height:1.6;margin-top:.25rem">We manage all permits and inspections with the City of Dunedin building department - start to finish.</p></div></div></div>
      </div>
    </div>
  </div>
</section>

<section class="py-20" style="background:#F7F7F7">
  <div class="max-w-7xl mx-auto px-5">
    <div class="text-center mb-14"><p class="sl gt mb-3">Our Services</p><h2 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:clamp(2rem,4vw,3rem);line-height:.95;color:#1A1A1A;letter-spacing:-.01em">ROOFING SERVICES WE OFFER IN DUNEDIN</h2></div>
    <div class="grid md:grid-cols-3 gap-8">
      <div class="scard p-8"><div style="width:52px;height:52px;border-radius:14px;display:flex;align-items:center;justify-content:center;background:rgba(230,168,23,.1);margin-bottom:1rem"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#E6A817" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/></svg></div><h3 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.35rem;color:#1A1A1A;margin-bottom:.75rem">Roof Replacement</h3><p style="color:#555555;font-size:.95rem;line-height:1.7">Full tear-off and replacement with Owens Corning Duration HDZ shingles, Gulf Coast Supply standing seam metal, or concrete tile. We handle decking, underlayment, flashing, ventilation, and all City of Dunedin inspections. Historic downtown homes receive special attention to preserve architectural character.</p></div>
      <div class="scard p-8"><div style="width:52px;height:52px;border-radius:14px;display:flex;align-items:center;justify-content:center;background:rgba(230,168,23,.1);margin-bottom:1rem"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#E6A817" stroke-width="2"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg></div><h3 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.35rem;color:#1A1A1A;margin-bottom:.75rem">Roof Repair</h3><p style="color:#555555;font-size:.95rem;line-height:1.7">Leak repair, shingle replacement, tile restoration, and flashing work for Dunedin homes. We provide honest assessments - if a repair solves the problem, that is what we recommend. Many older Dunedin homes have specific issues we have seen and resolved many times.</p></div>
      <div class="scard p-8"><div style="width:52px;height:52px;border-radius:14px;display:flex;align-items:center;justify-content:center;background:rgba(230,168,23,.1);margin-bottom:1rem"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#E6A817" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg></div><h3 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.35rem;color:#1A1A1A;margin-bottom:.75rem">Storm Damage & Insurance</h3><p style="color:#555555;font-size:.95rem;line-height:1.7">Dunedin's waterfront exposure puts it in the direct path of tropical storms. We provide thorough post-storm damage assessments, document everything for your insurance claim, and coordinate with your adjuster for a smooth resolution.</p></div>
    </div>
  </div>
</section>

<section class="py-20" style="background:#FFFFFF">
  <div class="max-w-7xl mx-auto px-5">
    <div class="text-center mb-14"><p class="sl gt mb-3">How It Works</p><h2 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:clamp(2rem,4vw,3rem);line-height:.95;color:#1A1A1A;letter-spacing:-.01em">OUR 4-STEP PROCESS</h2></div>
    <div class="grid md:grid-cols-2 gap-6">
      <div class="scard p-8 flex gap-5"><div class="step-num">1</div><div><h3 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.2rem;color:#1A1A1A;margin-bottom:.5rem">Free Inspection & Estimate</h3><p style="color:#555555;font-size:.95rem;line-height:1.7">Thorough roof inspection covering decking, underlayment, flashing, and ventilation. Detailed written estimate with material options, timelines, and transparent pricing.</p></div></div>
      <div class="scard p-8 flex gap-5"><div class="step-num">2</div><div><h3 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.2rem;color:#1A1A1A;margin-bottom:.5rem">Material Selection & Permits</h3><p style="color:#555555;font-size:.95rem;line-height:1.7">Choose your material and color. We pull all City of Dunedin permits, order materials, and schedule your preferred start date.</p></div></div>
      <div class="scard p-8 flex gap-5"><div class="step-num">3</div><div><h3 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.2rem;color:#1A1A1A;margin-bottom:.5rem">Professional Installation</h3><p style="color:#555555;font-size:.95rem;line-height:1.7">Full tear-off, decking inspection and repair, new underlayment and flashing, and roofing system installed to manufacturer specifications. Property protection throughout.</p></div></div>
      <div class="scard p-8 flex gap-5"><div class="step-num">4</div><div><h3 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.2rem;color:#1A1A1A;margin-bottom:.5rem">Final Inspection & Warranty</h3><p style="color:#555555;font-size:.95rem;line-height:1.7">City inspection for code compliance, warranty documentation delivery, and follow-up at 30 days and 1 year to ensure your satisfaction.</p></div></div>
    </div>
  </div>
</section>

<section class="py-20" style="background:#F7F7F7">
  <div class="max-w-7xl mx-auto px-5">
    <div class="text-center mb-10"><p class="sl gt mb-3">Dunedin Service Area</p><h2 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:clamp(2rem,4vw,3rem);line-height:.95;color:#1A1A1A;letter-spacing:-.01em;margin-bottom:1rem">NEIGHBORHOODS WE SERVE IN & AROUND DUNEDIN</h2><p style="color:#555555;font-size:1rem;line-height:1.75;max-width:700px;margin:0 auto">Happy Roof serves all of Dunedin and the surrounding northern Pinellas County communities.</p></div>
