      "@type": "AggregateRating",
      "ratingValue": "5.0",
      "reviewCount": "2",
      "bestRating": "5",
      "worstRating": "1"
    }
  },{
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How much does a roof replacement cost in Tampa Bay?",
        "acceptedAnswer": { "@type": "Answer", "text": "A typical residential roof replacement in Tampa Bay ranges from $8,000 to $25,000+ depending on roof size, material (asphalt shingles, metal, tile), slope complexity, and whether structural repairs are needed. Happy Roof provides free, itemized estimates with no hidden fees. Call (813) 595-7663 for a quote." }
      },
      {
        "@type": "Question",
        "name": "How long does a roof replacement take in Florida?",
        "acceptedAnswer": { "@type": "Answer", "text": "Most residential roof replacements in Tampa Bay take 1 to 3 days depending on size, material, and weather. Metal and tile roofs may take 3 to 5 days. Happy Roof pulls all permits and schedules inspections so homeowners don't have to coordinate anything." }
      },
      {
        "@type": "Question",
        "name": "Does Happy Roof help with insurance claims for storm damage?",
        "acceptedAnswer": { "@type": "Answer", "text": "Yes. Happy Roof assists Tampa Bay homeowners with the full insurance claim process for storm damage — from the initial roof inspection and damage documentation to working directly with your adjuster. We do not charge for the initial storm damage inspection." }
      },
      {
        "@type": "Question",
        "name": "What roofing materials does Happy Roof install?",
        "acceptedAnswer": { "@type": "Answer", "text": "Happy Roof installs Owens Corning Duration HDZ and UHDZ shingles, Owens Corning Duration and Oakridge shingles, standing seam and corrugated metal roofing, Verea clay and concrete tiles, and flat roof systems including TPO, EPDM, and modified bitumen. All materials come with manufacturer warranties." }
      },
      {
        "@type": "Question",
        "name": "What areas does Happy Roof serve in Tampa Bay?",
        "acceptedAnswer": { "@type": "Answer", "text": "Happy Roof serves all of Hillsborough, Pinellas, and Pasco counties including Tampa, St. Petersburg, Clearwater, Brandon, Riverview, Wesley Chapel, Lutz, Land O' Lakes, Odessa, Temple Terrace, Oldsmar, Palm Harbor, Tarpon Springs, Safety Harbor, Dunedin, Largo, Seminole, New Port Richey, Trinity, and surrounding communities." }
      },
      {
        "@type": "Question",
        "name": "Is Happy Roof licensed and insured?",
        "acceptedAnswer": { "@type": "Answer", "text": "Yes. Happy Roof LLC holds Florida Roofing Contractor License #CCC1337380 and carries full general liability and workers' compensation insurance. Certificate of insurance is available on request." }
      },
      {
        "@type": "Question",
        "name": "Does Happy Roof offer financing for roof replacement?",
        "acceptedAnswer": { "@type": "Answer", "text": "Yes. Happy Roof offers flexible financing options for roof replacements and repairs in Tampa Bay. Plans include low monthly payments and promotional 0% APR periods. Visit happyroof.com/finance.html or call (813) 595-7663 for details." }
      },
      {
        "@type": "Question",
        "name": "What warranty does Happy Roof offer?",
        "acceptedAnswer": { "@type": "Answer", "text": "Happy Roof provides a 15-year workmanship warranty on all shingle, metal, and tile roof installations, and a 10-year workmanship warranty on flat roof installations — in writing, every time. This is in addition to manufacturer material warranties from Owens Corning, and other brands." }
      }
    ]
  },[
    {
      "@context": "https://schema.org",
      "@type": "Service",
      "serviceType": "Roof Replacement",
      "provider": { "@type": "RoofingContractor", "name": "Happy Roof LLC", "telephone": "+1-813-595-7663", "url": "https://happyroof.com" },
      "areaServed": { "@type": "State", "name": "Florida" },
      "description": "Complete residential and commercial roof replacement in Tampa Bay. Full tear-off, permit pulling, and installation of asphalt shingles, metal, tile, or flat roof systems. 15-year workmanship warranty included.",
      "offers": { "@type": "Offer", "availability": "https://schema.org/InStock", "priceSpecification": { "@type": "PriceSpecification", "priceCurrency": "USD" } }
    },
    {
      "@context": "https://schema.org",
      "@type": "Service",
      "serviceType": "Roof Repair",
      "provider": { "@type": "RoofingContractor", "name": "Happy Roof LLC", "telephone": "+1-813-595-7663", "url": "https://happyroof.com" },
      "areaServed": { "@type": "State", "name": "Florida" },
      "description": "Expert roof leak repair, shingle and tile replacement, flashing repair, and emergency tarping for Tampa Bay homes and businesses. 48-hour emergency response available."
    },
    {
      "@context": "https://schema.org",
      "@type": "Service",
      "serviceType": "Storm Damage Roof Repair",
      "provider": { "@type": "RoofingContractor", "name": "Happy Roof LLC", "telephone": "+1-813-595-7663", "url": "https://happyroof.com" },
      "areaServed": { "@type": "State", "name": "Florida" },
      "description": "Hurricane and storm damage roof repair in Tampa Bay. Free storm damage inspections, full insurance claim assistance, emergency tarping, and permanent repair or replacement."
    },
    {
      "@context": "https://schema.org",
      "@type": "Service",
      "serviceType": "Roof Inspection",
      "provider": { "@type": "RoofingContractor", "name": "Happy Roof LLC", "telephone": "+1-813-595-7663", "url": "https://happyroof.com" },
      "areaServed": { "@type": "State", "name": "Florida" },
      "description": "Professional roof inspections in Tampa Bay for real estate transactions, insurance renewals, and preventive maintenance. Written reports with photos provided."
    },
    {
      "@context": "https://schema.org",
      "@type": "Service",
      "serviceType": "Commercial Roofing",
      "provider": { "@type": "RoofingContractor", "name": "Happy Roof LLC", "telephone": "+1-813-595-7663", "url": "https://happyroof.com" },
      "areaServed": { "@type": "State", "name": "Florida" },
      "description": "Commercial roofing services in Tampa Bay including TPO, EPDM, modified bitumen, built-up roofing, and standing seam metal. Phased scheduling to minimize business disruption."
    }
  ],{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "What roofing services does Happy Roof offer in Tampa Bay?", "acceptedAnswer": { "@type": "Answer", "text": "Happy Roof offers residential roof replacement, commercial roofing, roof repairs, roof inspections, storm damage and insurance claim assistance, new construction roofing, and gutter services throughout Tampa Bay, FL." } },
    { "@type": "Question", "name": "Do you do emergency roof repairs in Tampa Bay?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Happy Roof provides emergency roof repair services in Tampa Bay, FL. Call (813) 595-7663 for urgent assistance with storm damage, active leaks, or structural concerns." } },
    { "@type": "Question", "name": "Does Happy Roof do commercial roofing in Tampa?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Happy Roof handles commercial roofing projects throughout Tampa Bay including flat roofs, low-slope systems, and membrane roofing for businesses, HOAs, and property managers." } },
    { "@type": "Question", "name": "How do I know if I need a roof replacement or just a repair?", "acceptedAnswer": { "@type": "Answer", "text": "Happy Roof offers free roof inspections in Tampa Bay to determine whether a repair or full replacement is the right call. Signs you may need replacement include age (15–25+ years), widespread granule loss, multiple leak areas, or major storm damage." } }
  ]
},{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "What roofing services does Happy Roof offer in Tampa Bay?", "acceptedAnswer": { "@type": "Answer", "text": "Happy Roof offers residential roof replacement, commercial roofing, roof repairs, roof inspections, storm damage and insurance claim assistance, new construction roofing, and gutter services throughout Tampa Bay, FL." } },
    { "@type": "Question", "name": "Do you do emergency roof repairs in Tampa Bay?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Happy Roof provides emergency roof repair services in Tampa Bay, FL. Call (813) 595-7663 for urgent assistance with storm damage, active leaks, or structural concerns." } },
    { "@type": "Question", "name": "Does Happy Roof do commercial roofing in Tampa?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Happy Roof handles commercial roofing projects throughout Tampa Bay including flat roofs, low-slope systems, and membrane roofing for businesses, HOAs, and property managers." } },
    { "@type": "Question", "name": "How do I know if I need a roof replacement or just a repair?", "acceptedAnswer": { "@type": "Answer", "text": "Happy Roof offers free roof inspections in Tampa Bay to determine whether a repair or full replacement is the right call. Signs you may need replacement include age (15–25+ years), widespread granule loss, multiple leak areas, or major storm damage." } }
  ]
}]`;
---

<BaseLayout
  title="Roofing Services Tampa Bay — Residential & Commercial | Happy Roof"
  description="Residential & commercial roofing in Tampa Bay — replacements, repairs, storm damage & inspections. Licensed & insured. Get your free estimate today!"
  canonical="https://happyroof.com/services"
  ogTitle="Roofing Services Tampa Bay | Happy Roof"
  ogDescription="Residential & commercial roofing in Tampa Bay. Replacements, repairs, storm damage, inspections & new construction. Free estimates!"
  activePage="services"
  schema={schema}
>

<style is:inline>
.sci{width:52px;height:52px;border-radius:14px;display:flex;align-items:center;justify-content:center;background:rgba(230,168,23,.1);flex-shrink:0}
    .check-dot{width:20px;height:20px;border-radius:50%;display:flex;align-items:center;justify-content:center;background:rgba(230,168,23,.1);flex-shrink:0;margin-top:.15rem}
    /* ── Hero photo bg ── */
</style>

<!-- PAGE HERO -->
<section class="pt-32 pb-20 relative overflow-hidden" style="background:#F5F5F5;border-bottom:1px solid #E5E5E5">
  <!-- Hero background photo -->
  <div class="hero-photo-bg" style="background-image:url('/Brand%20Assets/Photos/architectural-shingle-roof-tampa-bay.jpg')"></div>
  <div class="hero-photo-overlay"></div>
  <div class="relative z-10 max-w-7xl mx-auto px-5 text-center">
    <p class="sl gp mb-4">What We Offer</p>
    <h1 class="font-display font-black tracking-tightest mb-5" style="font-family:'Barlow Condensed',sans-serif;font-size:clamp(3rem,6vw,5rem);line-height:.92;letter-spacing:-.01em;color:#1A1A1A">
      ROOFING SERVICES<br/><span class="gt">BUILT FOR FLORIDA.</span>
    </h1>
    <p class="max-w-2xl mx-auto" style="color:#555555;font-size:1.05rem;line-height:1.75">
      From a single shingle to a full commercial system — if it's on a roof in Tampa Bay, Happy Roof handles it. All work is overseen by our licensed team and backed by our 15-year workmanship warranty.
    </p>
  </div>
</section>

<!-- Trust Signals -->
<section style="background:#F7F7F7;border-top:1px solid #E0E0E0;border-bottom:1px solid #E0E0E0;padding:1.5rem 0">
  <div class="max-w-7xl mx-auto px-5">
    <div style="display:flex;flex-wrap:wrap;align-items:center;justify-content:center;gap:2rem 3rem">
      <div style="display:flex;align-items:center;gap:.5rem"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#E6A817" stroke-width="2"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg><span style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:.85rem;color:#1A1A1A;letter-spacing:.02em">OWENS CORNING INSTALLER</span></div>
      <div style="display:flex;align-items:center;gap:.5rem"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#3B9FD9" stroke-width="2"><path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg><span style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:.85rem;color:#1A1A1A;letter-spacing:.02em">FL LICENSE #CCC1337380</span></div>
      <div style="display:flex;align-items:center;gap:.5rem"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#E6A817" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg><span style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:.85rem;color:#1A1A1A;letter-spacing:.02em">FULLY INSURED & BONDED</span></div>
      <div style="display:flex;align-items:center;gap:.5rem"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#3B9FD9" stroke-width="2"><path d="M12 2v4m0 12v4M4.93 4.93l2.83 2.83m8.48 8.48l2.83 2.83M2 12h4m12 0h4M4.93 19.07l2.83-2.83m8.48-8.48l2.83-2.83"/></svg><span style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:.85rem;color:#1A1A1A;letter-spacing:.02em">15-YEAR WARRANTY OPTION</span></div>
    </div>
  </div>
</section>


<!-- INFO STRIP -->
<div style="background:#FFFFFF;border-top:2px solid #E6A817;border-bottom:1px solid #E0E0E0;padding:.85rem 0">
  <div class="max-w-7xl mx-auto px-5">
    <div class="flex flex-wrap items-center justify-center gap-x-8 gap-y-2 font-display font-bold text-sm tracking-widest" style="color:#1A1A1A;text-transform:uppercase;font-family:'Barlow Condensed',sans-serif">
      <span>Tampa Bay, FL</span>
      <span style="color:#E6A817">·</span>
      <span>CCC1337380</span>
      <span style="color:#E6A817">·</span>
      <span>HappyRoof.com</span>
      <span style="color:#E6A817">·</span>
      <span style="color:#3B9FD9">(813) 595-7663</span>
    </div>
  </div>
</div>

<!-- ══ RESIDENTIAL ══ -->
<section id="residential" class="py-20" style="background:#FFFFFF">
  <div class="max-w-7xl mx-auto px-5">
    <div class="scard">
      <div class="grid lg:grid-cols-2">
        <div class="p-10 lg:p-14 flex flex-col gap-6">
          <div class="flex items-center gap-4">
            <div class="sci"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#F0C040" stroke-width="2"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg></div>
            <span class="sl gp">Residential</span>
          </div>
          <h2 class="font-display font-black tracking-tightest" style="font-family:'Barlow Condensed',sans-serif;font-size:clamp(2rem,3.5vw,3rem);line-height:.95;letter-spacing:-.01em">RESIDENTIAL ROOFING</h2>
          <p style="color:#555555;line-height:1.75">Your home deserves the best. We install premium asphalt shingles, clay and concrete tiles, and metal roofing systems designed to handle Florida's heat, humidity, and hurricane season — all backed by manufacturer warranties and Happy Roof's 15-year workmanship guarantee (10yr flat roof).</p>
          <div>
            <div class="check"><div class="check-dot"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#F0C040" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg></div><p style="color:#555555;font-size:.9rem;line-height:1.5"><strong style="color:#1A1A1A">Full roof replacements</strong> — complete tear-off and installation with permit pulling included</p></div>
            <div class="check"><div class="check-dot"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#F0C040" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg></div><p style="color:#555555;font-size:.9rem;line-height:1.5"><strong style="color:#1A1A1A">Re-roofing over existing</strong> — where code allows, a cost-effective upgrade option</p></div>
            <div class="check"><div class="check-dot"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#F0C040" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg></div><p style="color:#555555;font-size:.9rem;line-height:1.5"><strong style="color:#1A1A1A">Material selection guidance</strong> — shingles, tile, metal, and more; we help you choose</p></div>
            <div class="check"><div class="check-dot"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#F0C040" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg></div><p style="color:#555555;font-size:.9rem;line-height:1.5"><strong style="color:#1A1A1A">FL Building Code compliant</strong> — licensed crew, permits pulled, inspections passed</p></div>
          </div>
          <div><a href="/contact" class="btn-t">Schedule Free Inspection <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg></a></div>
        </div>
        <div class="relative hidden lg:block" style="min-height:400px">
          <img src="/Brand%20Assets/Photos/4055F5E2-0A81-4BAC-A34D-586DC69AFF69_1_105_c.jpeg" alt="Residential architectural shingle roof installation in Tampa Bay" class="w-full h-full object-cover" />
          <div class="absolute inset-0" style="background:linear-gradient(to right,rgba(20,20,20,.8) 0%,transparent 40%)"></div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ══ COMMERCIAL ══ -->
<section id="commercial" class="py-8" style="background:#FFFFFF">
  <div class="max-w-7xl mx-auto px-5">
    <div class="scard" style="border-color:rgba(59,159,217,.15)">
      <div class="grid lg:grid-cols-2">
        <div class="relative hidden lg:block" style="min-height:400px">
          <img src="/Brand%20Assets/Photos/roof-replacement-project-tampa-bay.jpg" alt="Commercial TPO flat roof installation" class="w-full h-full object-cover" style="object-position:center top" />
          <div class="absolute inset-0" style="background:linear-gradient(to left,rgba(20,20,20,.8) 0%,transparent 40%)"></div>
        </div>
        <div class="p-10 lg:p-14 flex flex-col gap-6">
          <div class="flex items-center gap-4">
            <div class="sci" style="background:rgba(59,159,217,.1)"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#3B9FD9" stroke-width="2"><path d="M6 2h12l4 4v16H2V6z"/><path d="M9 22V12h6v10"/></svg></div>
            <span class="sl gt">Commercial</span>
          </div>
          <h2 class="font-display font-black tracking-tightest" style="font-family:'Barlow Condensed',sans-serif;font-size:clamp(2rem,3.5vw,3rem);line-height:.95;letter-spacing:-.01em">COMMERCIAL ROOFING</h2>
          <p style="color:#555555;line-height:1.75">We understand that business downtime costs money. Our commercial crews work efficiently on flat, low-slope, and steep-slope systems — coordinating around your schedule to minimize disruption.</p>
          <div>
