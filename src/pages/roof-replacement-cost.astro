---
import BaseLayout from '../layouts/BaseLayout.astro';

const schema = `[{
    "@context": "https://schema.org",
    "@type": ["LocalBusiness", "RoofingContractor"],
    "name": "Happy Roof LLC",
    "url": "https://happyroof.com",
    "telephone": "+1-813-595-7663",
    "email": "info@happyroof.com",
    "description": "Tampa Bay roofing contractor providing transparent roof replacement pricing. Licensed and insured. FL License #CCC1337380.",
    "image": "/Brand%20Assets/Happy%20Roof%20Logo.jpeg",
    "logo": "/Brand%20Assets/Happy%20Roof%20Logo.jpeg",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "141 Stevens Ave #12","addressLocality": "Oldsmar",
      "addressRegion": "FL","postalCode": "34677","addressCountry": "US"
    },
    "hasCredential": "Florida Roofing Contractor License #CCC1337380",
    "dateModified": "2026-04-20"
  },{
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "dateModified": "2026-04-20",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How much does it cost to replace a roof in Tampa?",
        "acceptedAnswer": { "@type": "Answer", "text": "A typical roof replacement in Tampa Bay costs between $8,000 and $25,000 for a single-family home in 2026. The final price depends on roof size (square footage), material choice (shingles, metal, or tile), pitch complexity, number of layers to remove, and whether deck repairs are needed. Happy Roof provides free, no-obligation estimates — call (813) 595-7663." }
      },
      {
        "@type": "Question",
        "name": "Is a new roof tax deductible in Florida?",
        "acceptedAnswer": { "@type": "Answer", "text": "A new roof on your primary residence is generally not tax deductible as a standard expense. However, if the roof replacement is part of an insurance claim due to storm damage, the out-of-pocket costs may be deductible as a casualty loss in certain situations. Additionally, energy-efficient roofing materials (like metal or cool-roof-rated shingles) may qualify for federal energy tax credits. Consult a tax professional for advice specific to your situation." }
      },
      {
        "@type": "Question",
        "name": "How long does a roof replacement take?",
        "acceptedAnswer": { "@type": "Answer", "text": "Most shingle roof replacements in Tampa Bay take 1 to 3 days. Metal roofs typically take 3 to 5 days, and tile roofs may take 5 to 7 days depending on complexity and weather conditions. Happy Roof handles all permits, inspections, and cleanup so you don't have to coordinate anything." }
      },
      {
        "@type": "Question",
        "name": "Does insurance cover roof replacement?",
        "acceptedAnswer": { "@type": "Answer", "text": "Homeowners insurance typically covers roof replacement if the damage was caused by a covered peril such as a hurricane, hailstorm, or fallen tree. Normal wear and tear and age-related deterioration are generally not covered. Happy Roof works with all major insurance carriers and can assist with the claims process, including documentation and adjuster meetings. Call (813) 595-7663 to discuss your situation." }
      },
      {
        "@type": "Question",
        "name": "Can I finance my roof replacement?",
        "acceptedAnswer": { "@type": "Answer", "text": "Yes. Happy Roof offers flexible financing through Enhancify with options including 0% APR for qualified buyers and low monthly payment plans. You can apply online in minutes with no impact to your credit score for prequalification. Visit happyroof.com/finance or call (813) 595-7663 to learn more." }
      }
    ]
  },{"@context":"https://schema.org","@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"Home","item":"https://happyroof.com/"},{"@type":"ListItem","position":2,"name":"Roof Replacement Cost","item":"https://happyroof.com/roof-replacement-cost"}]}]`;
---

<BaseLayout
  title="Roof Replacement Cost in Tampa Bay | 2026 Price Guide | Happy Roof"
  description="How much does a roof replacement cost in Tampa Bay? Typical range: $8,000 to $25,000+ depending on size and material. Free estimates from Happy Roof."
  canonical="https://happyroof.com/roof-replacement-cost"
  ogTitle="Roof Replacement Cost in Tampa Bay | 2026 Price Guide"
  ogDescription="How much does a roof replacement cost in Tampa Bay? Typical range: $8,000 to $25,000+ depending on size and material. Free estimates from Happy Roof."
  schema={schema}
>

<style is:inline>
.cost-card{background:#FFFFFF;border:1px solid #E0E0E0;border-radius:16px;padding:2rem;transition:transform .2s cubic-bezier(.22,1,.36,1),box-shadow .2s cubic-bezier(.22,1,.36,1)}
.cost-card:hover{transform:translateY(-2px);box-shadow:0 8px 24px rgba(230,168,23,.08)}
.cost-card .popular-badge{display:inline-block;background:rgba(230,168,23,.1);color:#E6A817;font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:.75rem;letter-spacing:.1em;text-transform:uppercase;padding:.25rem .75rem;border-radius:999px;margin-bottom:.75rem}
.factor-item{display:flex;gap:1rem;align-items:flex-start}
.factor-dot{width:20px;height:20px;border-radius:50%;display:flex;align-items:center;justify-content:center;background:rgba(230,168,23,.1);flex-shrink:0;margin-top:.15rem}
.breakdown-item{display:flex;gap:1rem;align-items:flex-start;padding:1rem 0;border-bottom:1px solid #F0F0F0}
.breakdown-item:last-child{border-bottom:none}
.save-card{background:#FFFFFF;border:1px solid #E0E0E0;border-radius:16px;padding:1.5rem;transition:transform .2s cubic-bezier(.22,1,.36,1),box-shadow .2s cubic-bezier(.22,1,.36,1)}
.save-card:hover{transform:translateY(-2px);box-shadow:0 8px 24px rgba(59,159,217,.06)}
</style>

<!-- HERO -->
<section class="relative overflow-hidden" style="padding:8rem 0 5rem;background:#FFFFFF">
  <div class="hero-photo-bg" style="background-image:url('/Brand%20Assets/Photos/architectural-shingle-roof-tampa-bay.jpg')"></div>
  <div class="hero-photo-overlay"></div>
  <div class="relative z-10 max-w-7xl mx-auto px-5 text-center">
    <p class="sl gp mb-4">2026 Price Guide</p>
    <h1 class="font-display font-black tracking-tightest mb-5" style="font-family:'Barlow Condensed',sans-serif;font-size:clamp(3rem,6vw,5rem);line-height:.92;letter-spacing:-.01em;color:#1A1A1A">
      ROOF REPLACEMENT COST<br/><span class="gt">IN TAMPA BAY</span>
    </h1>
    <p style="color:#1A1A1A;font-size:1.1rem;line-height:1.75;font-weight:600;max-width:700px;margin:0 auto 1rem">
      A roof replacement in Tampa Bay costs between <strong>$8,000 and $25,000</strong> for a typical single-family home in 2026. The final price depends on roof size, material choice, pitch complexity, and deck condition.
    </p>
    <p class="max-w-2xl mx-auto" style="color:#555555;font-size:1.05rem;line-height:1.75">
      This guide breaks down the real costs Tampa Bay homeowners are paying right now, what drives the price up or down, and how to get the best value on your roof replacement. Happy Roof provides free, no-obligation estimates with transparent pricing — call <a href="tel:8135957663" class="call-tracking-number" style="color:#3B9FD9;text-decoration:none;font-weight:600">(813) 595-7663</a>.
    </p>
  </div>
</section>

<!-- INFO STRIP -->
<div style="background:#FFFFFF;border-top:2px solid #E6A817;border-bottom:1px solid #E0E0E0;padding:.85rem 0">
  <div class="max-w-7xl mx-auto px-5">
    <div class="flex flex-wrap items-center justify-center gap-x-8 gap-y-2 font-display font-bold text-sm tracking-widest" style="color:#1A1A1A;text-transform:uppercase;font-family:'Barlow Condensed',sans-serif">
      <span>Tampa Bay, FL</span>
      <span style="color:#E6A817">·</span>
      <span>CCC1337380</span>
      <span style="color:#E6A817">·</span>
      <span>HappyRoof.com</span>
      <span style="color:#E6A817">·</span>
      <span style="color:#3B9FD9">(813) 595-7663</span>
    </div>
  </div>
</div>

<!-- COST BY MATERIAL -->
<section class="py-20" style="background:#F7F7F7">
  <div class="max-w-7xl mx-auto px-5">
    <div class="text-center mb-14">
      <p class="sl gt mb-3">Cost by Material</p>
      <h2 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:clamp(2rem,4vw,3rem);line-height:.95;color:#1A1A1A;letter-spacing:-.01em">WHAT DOES EACH ROOFING MATERIAL COST?</h2>
      <p style="color:#555555;font-size:1rem;line-height:1.75;max-width:650px;margin:.75rem auto 0">Estimates below are for a typical 2,000 sq ft Tampa Bay home including tear-off, materials, labor, permits, and cleanup.</p>
    </div>
    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">

      <!-- Shingle -->
      <div class="cost-card">
        <span class="popular-badge">Most Popular</span>
        <div style="width:48px;height:48px;border-radius:14px;display:flex;align-items:center;justify-content:center;background:rgba(230,168,23,.1);margin-bottom:1rem">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#E6A817" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/></svg>
        </div>
        <h3 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.25rem;color:#1A1A1A;margin-bottom:.5rem">Asphalt Shingles</h3>
        <p style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.75rem;color:#E6A817;margin-bottom:.5rem">$8,000 – $16,000</p>
        <p style="color:#555555;font-size:.9rem;line-height:1.65">Best value for most homeowners. Architectural shingles from Owens Corning and GAF with 130+ MPH wind ratings and 25–30 year lifespans.</p>
        <a href="/residential-roofing" style="display:inline-block;margin-top:1rem;font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:.85rem;color:#3B9FD9;letter-spacing:.08em;text-transform:uppercase;text-decoration:none">Learn More →</a>
      </div>

      <!-- Metal -->
      <div class="cost-card">
        <div style="width:48px;height:48px;border-radius:14px;display:flex;align-items:center;justify-content:center;background:rgba(230,168,23,.1);margin-bottom:1rem;margin-top:2rem">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#E6A817" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M3 15h18M9 3v18M15 3v18"/></svg>
        </div>
        <h3 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.25rem;color:#1A1A1A;margin-bottom:.5rem">Metal (Standing Seam)</h3>
        <p style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.75rem;color:#E6A817;margin-bottom:.5rem">$15,000 – $30,000</p>
        <p style="color:#555555;font-size:.9rem;line-height:1.65">Premium durability with 40–60 year lifespans. Reflects solar heat, reducing cooling costs up to 25%. May qualify for insurance discounts.</p>
        <a href="/residential-roofing" style="display:inline-block;margin-top:1rem;font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:.85rem;color:#3B9FD9;letter-spacing:.08em;text-transform:uppercase;text-decoration:none">Learn More →</a>
      </div>

      <!-- Tile -->
      <div class="cost-card">
        <div style="width:48px;height:48px;border-radius:14px;display:flex;align-items:center;justify-content:center;background:rgba(230,168,23,.1);margin-bottom:1rem;margin-top:2rem">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#E6A817" stroke-width="2"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
        </div>
        <h3 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.25rem;color:#1A1A1A;margin-bottom:.5rem">Tile (Barrel / Flat)</h3>
        <p style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.75rem;color:#E6A817;margin-bottom:.5rem">$18,000 – $35,000</p>
        <p style="color:#555555;font-size:.9rem;line-height:1.65">Classic Florida aesthetic with 50+ year lifespans. Concrete and clay tile options. Fire-resistant and naturally energy-efficient.</p>
        <a href="/residential-roofing" style="display:inline-block;margin-top:1rem;font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:.85rem;color:#3B9FD9;letter-spacing:.08em;text-transform:uppercase;text-decoration:none">Learn More →</a>
      </div>

      <!-- Flat/TPO -->
      <div class="cost-card">
        <div style="width:48px;height:48px;border-radius:14px;display:flex;align-items:center;justify-content:center;background:rgba(230,168,23,.1);margin-bottom:1rem;margin-top:2rem">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#E6A817" stroke-width="2"><rect x="2" y="6" width="20" height="12" rx="2"/><path d="M2 10h20"/></svg>
        </div>
        <h3 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.25rem;color:#1A1A1A;margin-bottom:.5rem">Flat / TPO</h3>
        <p style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.75rem;color:#E6A817;margin-bottom:.5rem">$12,000 – $25,000</p>
        <p style="color:#555555;font-size:.9rem;line-height:1.65">Ideal for flat or low-slope roof sections. TPO and modified bitumen systems provide excellent waterproofing and energy efficiency.</p>
        <a href="/services" style="display:inline-block;margin-top:1rem;font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:.85rem;color:#3B9FD9;letter-spacing:.08em;text-transform:uppercase;text-decoration:none">Learn More →</a>
      </div>

    </div>
  </div>
</section>

<!-- WHAT AFFECTS THE COST -->
<section class="py-20" style="background:#FFFFFF">
  <div class="max-w-7xl mx-auto px-5">
    <div class="grid lg:grid-cols-2 gap-14 items-start">
      <div>
        <p class="sl gt mb-3">Pricing Factors</p>
        <h2 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:clamp(2rem,4vw,3rem);line-height:.95;color:#1A1A1A;letter-spacing:-.01em;margin-bottom:1.5rem">WHAT AFFECTS YOUR ROOF REPLACEMENT COST?</h2>
        <p style="color:#555555;font-size:1rem;line-height:1.75;margin-bottom:1.5rem">
          No two roofs are the same, and pricing varies based on several factors specific to your home. Here are the key variables that affect the total cost of a roof replacement in Tampa Bay. A free inspection from Happy Roof will give you an accurate, itemized estimate for your specific situation.
        </p>
        <p style="color:#555555;font-size:1rem;line-height:1.75">
          Want a quick ballpark before scheduling an inspection? Try our <a href="/roof-cost-calculator" style="color:#3B9FD9;text-decoration:none;font-weight:600">Roof Cost Calculator</a> for an instant estimate based on your home's details.
        </p>
      </div>
      <div class="space-y-5">
        <div class="factor-item">
          <div class="factor-dot"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#E6A817" stroke-width="3"><path d="M20 6L9 17l-5-5"/></svg></div>
          <div><strong style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.05rem">Roof Size (Square Footage)</strong><p style="color:#555555;font-size:.9rem;line-height:1.6;margin-top:.25rem">The total area of your roof is the biggest factor. Larger homes require more materials and labor. Roofing is measured in "squares" (100 sq ft each) — a typical Tampa Bay home is 20–30 squares.</p></div>
        </div>
        <div class="factor-item">
          <div class="factor-dot"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#E6A817" stroke-width="3"><path d="M20 6L9 17l-5-5"/></svg></div>
          <div><strong style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.05rem">Pitch & Slope</strong><p style="color:#555555;font-size:.9rem;line-height:1.6;margin-top:.25rem">Steeper roofs require more safety equipment, take longer to install, and use more material. A 7/12 pitch or higher will increase costs compared to a standard 4/12 or 5/12 pitch.</p></div>
        </div>
        <div class="factor-item">
          <div class="factor-dot"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#E6A817" stroke-width="3"><path d="M20 6L9 17l-5-5"/></svg></div>
          <div><strong style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.05rem">Material Selection</strong><p style="color:#555555;font-size:.9rem;line-height:1.6;margin-top:.25rem">Asphalt shingles are the most affordable option. Metal costs roughly 2x shingles, and tile can be 2.5x or more. Higher-end materials offer longer lifespans and potential insurance savings. Read our detailed <a href="/blog/choosing-right-roof-type-florida" style="color:#3B9FD9;text-decoration:none;font-weight:600">guide to choosing the right roof type for Florida</a> to compare all options.</p></div>
        </div>
        <div class="factor-item">
          <div class="factor-dot"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#E6A817" stroke-width="3"><path d="M20 6L9 17l-5-5"/></svg></div>
          <div><strong style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.05rem">Layers to Remove</strong><p style="color:#555555;font-size:.9rem;line-height:1.6;margin-top:.25rem">If your existing roof has multiple layers of shingles, tear-off costs increase. Florida code requires a full tear-off down to the deck for most re-roofing projects.</p></div>
        </div>
        <div class="factor-item">
          <div class="factor-dot"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#E6A817" stroke-width="3"><path d="M20 6L9 17l-5-5"/></svg></div>
          <div><strong style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.05rem">Deck Repairs</strong><p style="color:#555555;font-size:.9rem;line-height:1.6;margin-top:.25rem">Rotted or damaged decking (plywood/OSB) must be replaced before installing the new roof. Deck repair costs depend on how much wood needs replacement — we won't know until tear-off.</p></div>
        </div>
        <div class="factor-item">
          <div class="factor-dot"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#E6A817" stroke-width="3"><path d="M20 6L9 17l-5-5"/></svg></div>
          <div><strong style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.05rem">Permits & Code Requirements</strong><p style="color:#555555;font-size:.9rem;line-height:1.6;margin-top:.25rem">All roof replacements in Tampa Bay require a building permit and final inspection. Permit costs vary by county. Happy Roof handles all permitting for you.</p></div>
        </div>
        <div class="factor-item">
          <div class="factor-dot"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#E6A817" stroke-width="3"><path d="M20 6L9 17l-5-5"/></svg></div>
          <div><strong style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.05rem">Complexity (Valleys, Dormers, Skylights)</strong><p style="color:#555555;font-size:.9rem;line-height:1.6;margin-top:.25rem">Roofs with multiple valleys, dormers, skylights, chimneys, or pipe penetrations require more flashing and detail work, which adds to the total cost.</p></div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- COST BREAKDOWN -->
<section class="py-20" style="background:#F7F7F7">
  <div class="max-w-3xl mx-auto px-5">
    <div class="text-center mb-12">
      <p class="sl gt mb-3">What's Included</p>
      <h2 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:clamp(2rem,4vw,3rem);line-height:.95;color:#1A1A1A;letter-spacing:-.01em">YOUR ROOF REPLACEMENT COST BREAKDOWN</h2>
      <p style="color:#555555;font-size:1rem;line-height:1.75;max-width:600px;margin:.75rem auto 0">Every Happy Roof estimate is fully itemized. Here's what's included in the price — no hidden fees, no surprises.</p>
    </div>
    <div class="scard p-8">
      <div class="breakdown-item">
        <div class="factor-dot" style="margin-top:.25rem"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#E6A817" stroke-width="3"><path d="M20 6L9 17l-5-5"/></svg></div>
        <div>
          <strong style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.05rem">Roofing Materials</strong>
          <p style="color:#555555;font-size:.9rem;line-height:1.6;margin-top:.15rem">Shingles, metal panels, or tile; underlayment (synthetic felt); drip edge; flashing; ridge caps; starter strips; pipe boots; and all fasteners.</p>
        </div>
      </div>
      <div class="breakdown-item">
        <div class="factor-dot" style="margin-top:.25rem"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#E6A817" stroke-width="3"><path d="M20 6L9 17l-5-5"/></svg></div>
        <div>
          <strong style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.05rem">Labor</strong>
          <p style="color:#555555;font-size:.9rem;line-height:1.6;margin-top:.15rem">Full tear-off of existing roof, deck inspection, installation of new roofing system by licensed, insured crews. Project managed by a licensed foreman on-site every day.</p>
        </div>
      </div>
      <div class="breakdown-item">
        <div class="factor-dot" style="margin-top:.25rem"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#E6A817" stroke-width="3"><path d="M20 6L9 17l-5-5"/></svg></div>
        <div>
          <strong style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.05rem">Permits & Inspections</strong>
          <p style="color:#555555;font-size:.9rem;line-height:1.6;margin-top:.15rem">We pull all required building permits and schedule the county final inspection. Permit fees are included in your estimate.</p>
        </div>
      </div>
      <div class="breakdown-item">
        <div class="factor-dot" style="margin-top:.25rem"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#E6A817" stroke-width="3"><path d="M20 6L9 17l-5-5"/></svg></div>
        <div>
          <strong style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.05rem">Dump Fees & Debris Removal</strong>
          <p style="color:#555555;font-size:.9rem;line-height:1.6;margin-top:.15rem">All old roofing material is hauled away and properly disposed of. Dumpster rental and disposal fees are included — you won't see a separate charge.</p>
        </div>
      </div>
      <div class="breakdown-item">
        <div class="factor-dot" style="margin-top:.25rem"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#E6A817" stroke-width="3"><path d="M20 6L9 17l-5-5"/></svg></div>
        <div>
          <strong style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.05rem">Job-Site Cleanup</strong>
          <p style="color:#555555;font-size:.9rem;line-height:1.6;margin-top:.15rem">Magnetic nail sweep of your yard and driveway, debris removal, and property protection throughout the project. We leave your property cleaner than we found it.</p>
        </div>
      </div>
      <div class="breakdown-item">
        <div class="factor-dot" style="margin-top:.25rem"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#E6A817" stroke-width="3"><path d="M20 6L9 17l-5-5"/></svg></div>
        <div>
          <strong style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.05rem">Warranty Documentation</strong>
          <p style="color:#555555;font-size:.9rem;line-height:1.6;margin-top:.15rem">Up to 15-year workmanship warranty from Happy Roof plus manufacturer material warranties, all provided in writing upon completion.</p>
