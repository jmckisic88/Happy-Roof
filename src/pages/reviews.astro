  schema={schema}
>

<style is:inline>
.review-card{background:#FFFFFF;border:1px solid #E0E0E0;border-radius:20px;padding:2rem;transition:border-color .25s,transform .3s cubic-bezier(.34,1.56,.64,1)}
    .review-card:hover{border-color:rgba(245,184,0,.3);transform:translateY(-4px)}
    .star{color:#F5B800}
    /* Hero photo bg */
</style>

<section class="relative overflow-hidden" style="padding:8rem 0 5rem;background:#FFFFFF">
  <div class="hero-photo-bg" style="background-image:url('/Brand%20Assets/Photos/architectural-shingle-roof-tampa-bay.jpg')"></div>
  <div class="hero-photo-overlay"></div>
  <div class="relative z-10 max-w-5xl mx-auto px-5 text-center">
    <p class="sl mb-4" style="color:#888888">Customer Reviews</p>
    <h1 class="font-display font-black tracking-tightest mb-5" style="font-family:'Barlow Condensed',sans-serif;font-size:clamp(3rem,7vw,5.5rem);line-height:.88;letter-spacing:-.01em;color:#1A1A1A">
      WHAT OUR CUSTOMERS<br/><span style="color:#F5B800">SAY.</span>
    </h1>
    <p style="color:#555555;font-size:1.1rem;line-height:1.75;max-width:560px;margin:0 auto 2.5rem">
      Real reviews from real Tampa Bay homeowners. No fake testimonials, no inflated numbers, just honest feedback from people we've served.
    </p>
    <div class="flex flex-wrap gap-3 justify-center">
      <a href="https://g.page/r/CZIUzU-T0dUKEBM/review" target="_blank" rel="noopener" class="btn-p" style="font-size:1.1rem;padding:.9rem 2rem">Leave Us a Review</a>
      <a href="/contact" class="btn-o" style="font-size:1rem;padding:.85rem 1.8rem">Get a Free Estimate</a>
    </div>
  </div>
</section>

