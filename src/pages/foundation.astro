---
import BaseLayout from '../layouts/BaseLayout.astro';

---

<BaseLayout
  title="Happy Roof Foundation — Community Giving | Coming June 2026"
  description="Happy Roof is launching a community giving program in June 2026. Something big is coming for Tampa Bay families in need. Stay tuned."
  canonical="https://happyroof.com/foundation"
  ogTitle="Something Big Is Coming | Happy Roof Tampa Bay"
  ogDescription="Happy Roof is launching a community giving program in June 2026. Stay tuned."
>

<style is:inline>
.gh{background:linear-gradient(135deg,#F87171 0%,#E8415A 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
    @keyframes pulse-glow{0%,100%{box-shadow:0 0 40px -10px rgba(232,65,90,.3)}50%{box-shadow:0 0 60px -5px rgba(232,65,90,.5)}}
    @keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-8px)}}
    /* ── Hero photo bg ── */
</style>

<!-- HERO — COMING SOON -->
<section style="min-height:100vh;display:flex;align-items:center;justify-content:center;position:relative;overflow:hidden;background:radial-gradient(ellipse 60% 50% at 50% 40%,rgba(232,65,90,.06) 0%,transparent 70%),#FFFFFF">
  <!-- Hero background photo -->
  <div class="hero-photo-bg" style="background-image:url('/Brand%20Assets/Photos/commercial-tpo-roof-tampa.jpg')"></div>
  <div class="hero-photo-overlay"></div>
  <!-- Subtle animated background -->
  <div style="position:absolute;inset:0;overflow:hidden;pointer-events:none">
    <div style="position:absolute;width:600px;height:600px;border-radius:50%;background:radial-gradient(circle,rgba(232,65,90,.04) 0%,transparent 70%);top:20%;left:50%;transform:translateX(-50%);animation:pulse-glow 4s ease-in-out infinite"></div>
  </div>

  <div class="relative z-10 max-w-3xl mx-auto px-5 text-center" style="padding:8rem 0 6rem">
    <!-- Animated heart icon -->
    <div class="flex justify-center mb-8" style="animation:float 3s ease-in-out infinite">
      <div style="width:100px;height:100px;background:#fff;border:2px solid rgba(232,65,90,.2);box-shadow:0 12px 40px -8px rgba(232,65,90,.15);border-radius:24px;display:flex;align-items:center;justify-content:center;animation:pulse-glow 4s ease-in-out infinite">
        <svg width="52" height="52" viewBox="0 0 44 44" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M22 8 L36 20 L34 20 L34 34 L10 34 L10 20 L8 20 Z" stroke="#E8415A" stroke-width="1.5" stroke-linejoin="round" fill="none" opacity=".4"/>
          <path d="M22 30 C22 30 14 24.5 14 19.5 C14 16.5 16.2 14.5 18.5 14.5 C20 14.5 21.2 15.3 22 16.5 C22.8 15.3 24 14.5 25.5 14.5 C27.8 14.5 30 16.5 30 19.5 C30 24.5 22 30 22 30Z" fill="#E8415A"/>
        </svg>
      </div>
    </div>

    <p class="sl mb-4" style="color:#E8415A">A Happy Roof Initiative</p>

    <h1 style="font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:clamp(2.8rem,7vw,5.5rem);line-height:.9;letter-spacing:-.01em;margin-bottom:1.5rem">
      SOMETHING<br/>
      <span class="gh">BIGGER THAN</span><br/>
      ROOFING.
    </h1>

    <p style="color:#555555;font-size:1.15rem;line-height:1.8;max-width:520px;margin:0 auto 1.5rem">
      We believe a safe roof shouldn't be a luxury. This June, we're launching a program that puts our skills where they're needed most — in the hands of Tampa Bay families who need it.
    </p>

    <p style="color:#888888;font-size:.95rem;line-height:1.7;max-width:460px;margin:0 auto 2.5rem">
      Free roofs. No strings. Real impact.<br/>
      <span style="color:#E8415A;font-weight:600">The name drops June 2026.</span>
    </p>

    <!-- Countdown-style date callout -->
    <div style="display:inline-flex;align-items:center;gap:1rem;background:#fff;border:1.5px solid rgba(232,65,90,.18);box-shadow:0 4px 20px -6px rgba(0,0,0,.06);border-radius:16px;padding:1.25rem 2.5rem;margin-bottom:2.5rem">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#E8415A" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
      <div style="text-align:left">
        <p style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.3rem;color:#1A1A1A;line-height:1;letter-spacing:-.01em">June 2026</p>
        <p style="color:#555555;font-size:.78rem;margin-top:.15rem">Official launch &amp; name reveal</p>
      </div>
    </div>

    <div class="flex flex-wrap gap-3 justify-center">
      <a href="/contact" class="btn-p" style="font-size:1rem;padding:.85rem 2rem">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
        Get Notified
      </a>
    </div>

    <p style="color:#888888;font-size:.8rem;margin-top:3rem;line-height:1.6">
      A community initiative by <a href="/" style="color:#555555;text-decoration:none" onmouseover="this.style.color='#E6A817'" onmouseout="this.style.color='#555555'">Happy Roof LLC</a> · Tampa Bay, FL
    </p>
  </div>
</section>

<!-- FOOTER -->

</BaseLayout>