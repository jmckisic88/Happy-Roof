    </div>

    <!-- Tier quick reference table -->
    <div class="rounded-2xl overflow-hidden" style="background:#F7F7F7;border:1px solid #E0E0E0">
      <div class="p-5" style="border-bottom:1px solid #E0E0E0">
        <h3 class="font-display font-bold text-brand-black" style="font-family:'Barlow Condensed',sans-serif;font-size:1.3rem">Quick Reference — All Tiers</h3>
      </div>
      <div class="overflow-x-auto">
        <table style="width:100%;border-collapse:collapse">
          <thead>
            <tr style="border-bottom:1px solid #E0E0E0">
              <th style="padding:.75rem 1.25rem;text-align:left;color:#555555;font-size:.75rem;letter-spacing:.1em;text-transform:uppercase;font-weight:600">Tier</th>
              <th style="padding:.75rem 1.25rem;text-align:left;color:#555555;font-size:.75rem;letter-spacing:.1em;text-transform:uppercase;font-weight:600">Trigger</th>
