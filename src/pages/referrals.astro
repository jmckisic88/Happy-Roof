---

<BaseLayout
  title="Referral Program — Earn Up to $1,000 | Happy Roof"
  description="Refer friends to Happy Roof and earn cash rewards. Submit your referral online in minutes and get paid when they close!"
  canonical="https://happyroof.com/referrals"
  ogTitle="Happy Roof Referral Program | Earn Cash in Tampa Bay"
  ogDescription="Refer a neighbor to Happy Roof and earn cash. Tampa Bay's best roofing referral program — submit online in minutes."
  activePage="referrals"
  schema={schema}
>

<style is:inline>
/* Tier cards */
    .tier-card{border-radius:20px;transition:transform .3s cubic-bezier(.34,1.56,.64,1),box-shadow .3s;cursor:default;position:relative;overflow:hidden}
    .tier-card:hover{transform:translateY(-6px)}
    .tier-amount{font-family:'Barlow Condensed',sans-serif;font-weight:900;line-height:1;letter-spacing:-.01em}
    /* Brand texture */
    /* White section */
    .white-section{background:#F5F5F5;color:#1A1A1A}
    /* How it works step */
    .how.step{background:#FFFFFF;border:1px solid #E0E0E0;border-radius:18px;padding:1.75rem;transition:border-color .2s,transform .3s cubic-bezier(.34,1.56,.64,1)}
    .how-step:hover{border-color:rgba(230,168,23,.3);transform:translateY(-4px)}
    /* FAQ */
    /* Form */
    /* Animated payout ring */
    .payout-ring{width:100px;height:100px;border-radius:50%;display:flex;flex-direction:column;align-items:center;justify-content:center;flex-shrink:0}
    /* ── Hero photo bg ── */
</style>

<!-- ══════ HERO (Business card style — bright white) ══════ -->
<section class="white-section relative overflow-hidden pt-28 pb-20">
  <!-- Hero background photo -->
  <div class="hero-photo-bg" style="background-image:url('/Brand%20Assets/Photos/4055F5E2-0A81-4BAC-A34D-586DC69AFF69_1_105_c.jpeg')"></div>
  <div class="hero-photo-overlay"></div>
  <div class="relative z-10 max-w-5xl mx-auto px-5 text-center">
    <div class="flex justify-center mb-8">
      <img src="/Brand%20Assets/Happy Roof Logo.png" alt="Happy Roof" style="height:56px;width:auto" class="hidden sm:block" />
    </div>
    <p class="sl mb-4" style="color:#888888">Referral Program</p>
    <h1 class="font-display font-black tracking-tightest mb-5" style="font-family:'Barlow Condensed',sans-serif;font-size:clamp(3rem,7vw,5.5rem);line-height:.88;letter-spacing:-.01em;color:#1A1A1A">
      REFER &amp; EARN<br/><span style="color:#E6A817">UP TO $1,000.</span>
    </h1>
    <p style="color:#555555;font-size:1.1rem;line-height:1.75;max-width:560px;margin:0 auto 2.5rem">
      Know someone who needs a roof? Send them our way — and we'll send cash your way. It's that simple. No caps, no expiration, no fine print.
    </p>
    <div class="flex flex-wrap gap-3 justify-center">
      <a href="#refer-form" class="btn-p" style="font-size:1.1rem;padding:.9rem 2rem">Submit a Referral</a>
      <a href="#tiers" class="btn-o" style="color:#1A1A1A;border-color:rgba(0,0,0,.2);font-size:1rem;padding:.85rem 1.75rem">See Payout Tiers</a>
    </div>
  </div>
</section>

<!-- Trust Signals -->
<section style="background:#F7F7F7;border-top:1px solid #E0E0E0;border-bottom:1px solid #E0E0E0;padding:1.5rem 0">
  <div class="max-w-7xl mx-auto px-5">
    <div style="display:flex;flex-wrap:wrap;align-items:center;justify-content:center;gap:2rem 3rem">
      <div style="display:flex;align-items:center;gap:.5rem"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#E6A817" stroke-width="2"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg><span style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:.85rem;color:#1A1A1A;letter-spacing:.02em">OWENS CORNING PREFERRED</span></div>
      <div style="display:flex;align-items:center;gap:.5rem"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#3B9FD9" stroke-width="2"><path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg><span style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:.85rem;color:#1A1A1A;letter-spacing:.02em">FL LICENSE #CCC1337380</span></div>
      <div style="display:flex;align-items:center;gap:.5rem"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#E6A817" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg><span style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:.85rem;color:#1A1A1A;letter-spacing:.02em">FULLY INSURED & BONDED</span></div>
      <div style="display:flex;align-items:center;gap:.5rem"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#3B9FD9" stroke-width="2"><path d="M12 2v4m0 12v4M4.93 4.93l2.83 2.83m8.48 8.48l2.83 2.83M2 12h4m12 0h4M4.93 19.07l2.83-2.83m8.48-8.48l2.83-2.83"/></svg><span style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:.85rem;color:#1A1A1A;letter-spacing:.02em">15-YEAR WARRANTY</span></div>
    </div>
  </div>
</section>


<!-- ══════ QUICK STATS ══════ -->
<div style="background:#FFFFFF;border-bottom:1px solid #E0E0E0">
  <div class="max-w-5xl mx-auto px-5">
    <div class="flex flex-wrap justify-center divide-x" style="divide-color:#E0E0E0">
      <div class="flex flex-col items-center py-6 px-8 flex-1 min-w-[140px]">
        <p class="font-display font-black" style="font-family:'Barlow Condensed',sans-serif;font-size:2.5rem;line-height:1;letter-spacing:-.01em;color:#1A1A1A">$50</p>
        <p style="color:#888888;font-size:.8rem;margin-top:.25rem">Per Estimate</p>
      </div>
      <div class="flex flex-col items-center py-6 px-8 flex-1 min-w-[140px]">
        <p class="font-display font-black" style="font-family:'Barlow Condensed',sans-serif;font-size:2.5rem;line-height:1;letter-spacing:-.01em;color:#1A1A1A">$1,000</p>
        <p style="color:#888888;font-size:.8rem;margin-top:.25rem">Max Payout</p>
      </div>
      <div class="flex flex-col items-center py-6 px-8 flex-1 min-w-[140px]">
        <p class="font-display font-black" style="font-family:'Barlow Condensed',sans-serif;font-size:2.5rem;line-height:1;letter-spacing:-.01em;color:#1A1A1A">0</p>
        <p style="color:#888888;font-size:.8rem;margin-top:.25rem">Referral Cap</p>
      </div>
      <div class="flex flex-col items-center py-6 px-8 flex-1 min-w-[140px]">
        <p class="font-display font-black" style="font-family:'Barlow Condensed',sans-serif;font-size:2.5rem;line-height:1;letter-spacing:-.01em;color:#1A1A1A">Fast</p>
        <p style="color:#888888;font-size:.8rem;margin-top:.25rem">Payment Turnaround</p>
      </div>
    </div>
  </div>
</div>

<!-- ══════ PAYOUT TIERS ══════ -->
<section id="tiers" class="py-24" style="background:#FFFFFF">
  <div class="max-w-5xl mx-auto px-5">
    <div class="text-center mb-14">
      <p class="sl gp mb-3">The Payouts</p>
      <h2 class="font-display font-black tracking-tightest mb-4" style="font-family:'Barlow Condensed',sans-serif;font-size:clamp(2.5rem,5vw,4rem);line-height:.9;letter-spacing:-.01em">
        THE MORE THEY SPEND,<br/><span class="gt">THE MORE YOU EARN.</span>
      </h2>
      <p style="color:#555555;max-width:520px;margin:0 auto;font-size:.95rem;line-height:1.75">
        Payouts are based on the closed contract value. Every referral counts — even if the job is small.
      </p>
    </div>

    <!-- 5 Tier cards -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5 mb-6">

      <!-- Tier 1: Estimate -->
      <div class="tier-card p-6 flex flex-col gap-4" style="background:#F7F7F7;border:2px solid #E0E0E0;box-shadow:0 4px 16px -4px rgba(0,0,0,.06)">
        <div class="flex items-center gap-4">
          <div class="payout-ring" style="background:rgba(0,0,0,.06);border:2px solid rgba(230,168,23,.2)">
            <p class="tier-amount" style="font-size:1.8rem;color:#1A1A1A">$50</p>
          </div>
          <div>
            <p style="color:#555555;font-size:.72rem;font-weight:600;letter-spacing:.12em;text-transform:uppercase">Tier 1</p>
            <p class="font-display font-bold text-brand-black" style="font-family:'Barlow Condensed',sans-serif;font-size:1.3rem;line-height:1.1">Estimate Booked</p>
          </div>
        </div>
        <p style="color:#555555;font-size:.87rem;line-height:1.65">Your referral schedules and completes a free estimate with Happy Roof. You earn <strong>$50</strong> — no matter if they proceed or not.</p>
        <div class="mt-auto pt-3" style="border-top:1px solid #E0E0E0">
          <p style="color:#888888;font-size:.75rem"><span style="color:#888888">✓</span> &nbsp;Paid within 5 business days of the estimate appointment</p>
        </div>
      </div>

      <!-- Tier 2: Any Repair -->
      <div class="tier-card p-6 flex flex-col gap-4" style="background:#F7F7F7;border:2px solid rgba(59,159,217,.2);box-shadow:0 8px 32px -8px rgba(59,159,217,.15)">
        <div class="flex items-center gap-4">
          <div class="payout-ring" style="background:rgba(59,159,217,.1);border:2px solid rgba(59,159,217,.25)">
            <p class="tier-amount" style="font-size:1.8rem;color:#1A1A1A">$125</p>
          </div>
          <div>
            <p style="color:#555555;font-size:.72rem;font-weight:600;letter-spacing:.12em;text-transform:uppercase">Tier 2</p>
            <p class="font-display font-bold text-brand-black" style="font-family:'Barlow Condensed',sans-serif;font-size:1.3rem;line-height:1.1">Any Repair Closed</p>
          </div>
        </div>
        <p style="color:#555555;font-size:.87rem;line-height:1.65">Your referral closes any repair job with Happy Roof. You earn <strong style="color:#3B9FD9">$125</strong> — a great return on a quick recommendation.</p>
        <div class="mt-auto pt-3" style="border-top:1px solid #E0E0E0">
          <p style="color:#888888;font-size:.75rem"><span style="color:#888888">✓</span> &nbsp;Paid upon job completion and final payment received</p>
        </div>
      </div>

      <!-- Tier 3: Up to $12,500 — PURPLE -->
      <div class="tier-card p-6 flex flex-col gap-4" style="background:#F7F7F7;border:2px solid rgba(230,168,23,.2);box-shadow:0 8px 32px -8px rgba(230,168,23,.15)">
        <div class="flex items-center gap-4">
          <div class="payout-ring" style="background:rgba(0,0,0,.06);border:2px solid rgba(230,168,23,.25)">
            <p class="tier-amount" style="font-size:1.8rem;color:#1A1A1A">$250</p>
          </div>
          <div>
            <p style="color:#555555;font-size:.72rem;font-weight:600;letter-spacing:.12em;text-transform:uppercase">Tier 3 · Replacement</p>
            <p class="font-display font-bold text-brand-black" style="font-family:'Barlow Condensed',sans-serif;font-size:1.3rem;line-height:1.1">Replacement — Up to $12,500</p>
          </div>
        </div>
        <p style="color:#555555;font-size:.87rem;line-height:1.65">Your referral closes a roof replacement valued up to $12,500. You earn <strong>$250</strong> in referral cash.</p>
        <div class="mt-auto pt-3" style="border-top:1px solid #E0E0E0">
          <p style="color:#888888;font-size:.75rem"><span style="color:#888888">✓</span> &nbsp;Paid upon job completion and final payment received</p>
        </div>
      </div>

      <!-- Tier 4: Up to $25,000 — TEAL + POPULAR -->
      <div class="tier-card p-6 flex flex-col gap-4" style="background:#FFFFFF;border:2px solid rgba(59,159,217,.3);box-shadow:0 4px 16px -4px rgba(0,0,0,.06)">
        <div class="absolute top-3 right-3">
          <span style="background:#FFFFFF;color:#1A1A1A;font-size:.68rem;font-weight:700;letter-spacing:.06em;padding:.25rem .65rem;border-radius:100px;font-family:'Barlow Condensed',sans-serif">POPULAR</span>
        </div>
        <div class="flex items-center gap-4">
          <div class="payout-ring" style="background:rgba(59,159,217,.15);border:2px solid rgba(59,159,217,.35)">
            <p class="tier-amount" style="font-size:1.8rem;color:#1A1A1A">$500</p>
          </div>
          <div>
            <p style="color:#555555;font-size:.72rem;font-weight:600;letter-spacing:.12em;text-transform:uppercase">Tier 4 · Replacement</p>
            <p class="font-display font-bold text-brand-black" style="font-family:'Barlow Condensed',sans-serif;font-size:1.3rem;line-height:1.1">Replacement — Up to $25,000</p>
          </div>
        </div>
        <p style="color:#777;font-size:.87rem;line-height:1.65">Your referral closes a roof replacement valued up to $25,000. You earn <strong style="color:#3B9FD9">$500</strong> — a solid return for one conversation.</p>
        <div class="mt-auto pt-3" style="border-top:1px solid rgba(59,159,217,.15)">
          <p style="color:#555555;font-size:.75rem"><span style="color:#888888">✓</span> &nbsp;Paid upon job completion and final payment received</p>
        </div>
      </div>

      <!-- Tier 5: Up to $40,000 — PURPLE -->
      <div class="tier-card p-6 flex flex-col gap-4" style="background:#F7F7F7;border:2px solid rgba(230,168,23,.2);box-shadow:0 8px 32px -8px rgba(230,168,23,.15)">
        <div class="flex items-center gap-4">
          <div class="payout-ring" style="background:rgba(0,0,0,.06);border:2px solid rgba(230,168,23,.25)">
            <p class="tier-amount" style="font-size:1.8rem;color:#1A1A1A">$750</p>
          </div>
          <div>
            <p style="color:#555555;font-size:.72rem;font-weight:600;letter-spacing:.12em;text-transform:uppercase">Tier 5 · Replacement</p>
            <p class="font-display font-bold text-brand-black" style="font-family:'Barlow Condensed',sans-serif;font-size:1.3rem;line-height:1.1">Replacement — Up to $40,000</p>
          </div>
        </div>
        <p style="color:#555555;font-size:.87rem;line-height:1.65">A larger residential or small commercial roof replacement closes at up to $40,000. That's <strong>$750</strong> heading straight to you.</p>
        <div class="mt-auto pt-3" style="border-top:1px solid #E0E0E0">
          <p style="color:#888888;font-size:.75rem"><span style="color:#888888">✓</span> &nbsp;Paid upon job completion and final payment received</p>
        </div>
      </div>

      <!-- Tier 5: $40,000+ -->
