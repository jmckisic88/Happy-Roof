---
import BaseLayout from '../layouts/BaseLayout.astro';

const schema = `[{
    "@context": "https://schema.org",
    "@type": ["LocalBusiness", "RoofingContractor"],
    "name": "Happy Roof LLC",
    "url": "https://happyroof.com",
    "telephone": "+1-813-595-7663",
    "email": "info@happyroof.com",
    "description": "Tampa Bay's trusted roofing contractor specializing in roof replacement, repair, storm damage, inspections, and new construction. Licensed & insured — FL License #CCC1337380.",
    "image": "/Brand%20Assets/Happy%20Roof%20Logo.jpeg",
    "logo": "/Brand%20Assets/Happy%20Roof%20Logo.jpeg",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "141 Stevens Ave #12","addressLocality": "Oldsmar",
      "addressRegion": "FL","postalCode": "34677",
      "addressCountry": "US"
    },
    "geo": { "@type": "GeoCoordinates", "latitude": 28.0340, "longitude": -82.6651 },
    "priceRange": "$$",
    "openingHoursSpecification": [
      { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"], "opens": "07:00", "closes": "18:00" },
      { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Saturday"], "opens": "08:00", "closes": "14:00" }
    ],
    "areaServed": [
      { "@type": "City", "name": "Tampa" },
      { "@type": "City", "name": "St. Petersburg" },
      { "@type": "City", "name": "Clearwater" },
      { "@type": "City", "name": "Brandon" },
      { "@type": "City", "name": "Wesley Chapel" },
      { "@type": "City", "name": "Riverview" },
      { "@type": "City", "name": "Lutz" },
      { "@type": "City", "name": "Land O Lakes" },
      { "@type": "City", "name": "Odessa" },
      { "@type": "City", "name": "Temple Terrace" },
      { "@type": "City", "name": "New Tampa" },
      { "@type": "City", "name": "Carrollwood" },
      { "@type": "City", "name": "Oldsmar" },
      { "@type": "City", "name": "Palm Harbor" },
      { "@type": "City", "name": "Tarpon Springs" },
      { "@type": "City", "name": "Safety Harbor" },
      { "@type": "City", "name": "Dunedin" },
      { "@type": "City", "name": "Largo" },
      { "@type": "City", "name": "Seminole" },
      { "@type": "City", "name": "New Port Richey" },
      { "@type": "City", "name": "Trinity" },
      { "@type": "City", "name": "Valrico" },
      { "@type": "City", "name": "Plant City" },
      { "@type": "City", "name": "Seffner" },
      { "@type": "City", "name": "Town n Country" },
      { "@type": "City", "name": "Citrus Park" },
      { "@type": "City", "name": "Fish Hawk" },
      { "@type": "City", "name": "Apollo Beach" },
      { "@type": "City", "name": "Sun City Center" },
      { "@type": "AdministrativeArea", "name": "Hillsborough County" },
      { "@type": "AdministrativeArea", "name": "Pinellas County" },
      { "@type": "AdministrativeArea", "name": "Pasco County" }
    ],
    "sameAs": [
      "https://www.facebook.com/share/1E27RD4hjZ/",
      "https://www.instagram.com/happyroofflorida",
      "https://www.tiktok.com/@happyrooffl",
      "https://share.google/eM5h7LtohVsqVd0Nd"
    ],
    "hasCredential": "Florida Roofing Contractor License #CCC1337380"
  },{
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What areas does Happy Roof serve?",
        "acceptedAnswer": { "@type": "Answer", "text": "Happy Roof serves all of Hillsborough, Pinellas, and Pasco counties including Tampa, St. Petersburg, Clearwater, Brandon, Riverview, Wesley Chapel, Lutz, Land O' Lakes, Odessa, Temple Terrace, Oldsmar, Palm Harbor, Tarpon Springs, Safety Harbor, Dunedin, Largo, Seminole, New Port Richey, Trinity, and surrounding communities." }
      },
      {
        "@type": "Question",
        "name": "Is Happy Roof licensed and insured?",
        "acceptedAnswer": { "@type": "Answer", "text": "Yes. Happy Roof LLC holds Florida Roofing Contractor License #CCC1337380 and carries full general liability and workers' compensation insurance. We install premium Owens Corning and GAF roofing products." }
      },
      {
        "@type": "Question",
        "name": "How do I get a free estimate?",
        "acceptedAnswer": { "@type": "Answer", "text": "Call us at (813) 595-7663 or fill out the contact form on our website. We'll schedule a free on-site inspection and provide an itemized, no-obligation estimate — typically within 24–48 hours." }
      },
      {
        "@type": "Question",
        "name": "How long has Happy Roof been in business?",
        "acceptedAnswer": { "@type": "Answer", "text": "Happy Roof was founded in 2025 and is a locally owned roofing company serving Tampa Bay. While we're a newer company, our leadership team brings over 30 years of combined experience in the roofing industry. We hold FL License #CCC1337380 and install premium Owens Corning and GAF roofing products." }
      },
      {
        "@type": "Question",
        "name": "Do you offer emergency roofing services?",
        "acceptedAnswer": { "@type": "Answer", "text": "Yes. We offer emergency tarping and temporary repairs for active leaks and storm damage. Call (813) 595-7663 for urgent assistance." }
      },
      {
        "@type": "Question",
        "name": "What does the roof replacement process look like?",
        "acceptedAnswer": { "@type": "Answer", "text": "Our process includes a free inspection, detailed estimate, material selection, permit pulling, full tear-off, installation, final inspection, and cleanup. Most residential roofs are completed in 1–3 days." }
      },
      {
        "@type": "Question",
        "name": "How long does a roof replacement take?",
        "acceptedAnswer": { "@type": "Answer", "text": "Most residential roof replacements take 1–3 days depending on size, material, and weather. Metal and tile roofs may take 3–5 days. Happy Roof handles all permits and inspections." }
      },
      {
        "@type": "Question",
        "name": "Do I need to be home during the roof replacement?",
        "acceptedAnswer": { "@type": "Answer", "text": "No. As long as we have access to the property and any gates, you do not need to be home. We'll keep you updated throughout the process via phone or text." }
      },
      {
        "@type": "Question",
        "name": "Does Happy Roof pull permits?",
        "acceptedAnswer": { "@type": "Answer", "text": "Yes. Happy Roof pulls all required building permits for every roof replacement and handles scheduling the final inspection with the local building department. This is included in every project at no extra charge." }
      },
      {
        "@type": "Question",
        "name": "Will you remove and dispose of my old roof?",
        "acceptedAnswer": { "@type": "Answer", "text": "Yes. Every roof replacement includes full tear-off, disposal of old materials, and thorough cleanup of your property. We use magnetic nail sweepers to ensure no debris is left behind." }
      },
      {
        "@type": "Question",
        "name": "What roofing materials does Happy Roof install?",
        "acceptedAnswer": { "@type": "Answer", "text": "We install shingles from Owens Corning (Duration, Oakridge, Berkshire) and GAF (Timberline HDZ, UHDZ), standing seam and corrugated metal from Gulfcoast Supply, Verea clay and concrete tile, and flat roof systems including TPO, EPDM, and modified bitumen. We also work with other brands by request." }
      },
      {
        "@type": "Question",
        "name": "What is the best roofing material for Florida?",
        "acceptedAnswer": { "@type": "Answer", "text": "Architectural shingles (like Owens Corning Duration or GAF Timberline HDZ) are the most popular and cost-effective choice. Metal roofing offers superior wind resistance and longevity. Tile is ideal for Mediterranean-style homes. The best choice depends on your budget, aesthetic preference, and HOA requirements." }
      },
      {
        "@type": "Question",
        "name": "What is the difference between 3-tab and architectural shingles?",
        "acceptedAnswer": { "@type": "Answer", "text": "Architectural (dimensional) shingles are thicker, more durable, and offer better wind resistance (up to 130 mph) compared to 3-tab shingles. They also have a more dimensional appearance and longer manufacturer warranties. Happy Roof recommends architectural shingles for Florida homes." }
      },
      {
        "@type": "Question",
        "name": "Do you install metal roofs?",
        "acceptedAnswer": { "@type": "Answer", "text": "Yes. We install standing seam and corrugated metal roofing in a variety of colors and profiles. Metal roofs offer excellent wind resistance, energy efficiency, and can last 40–70 years with proper maintenance." }
      },
      {
        "@type": "Question",
        "name": "What warranty does Happy Roof offer?",
        "acceptedAnswer": { "@type": "Answer", "text": "Happy Roof provides a 15-year workmanship warranty on all shingle, metal, and tile roof installations, and a 10-year workmanship warranty on flat roof systems. This is provided in writing on every project, in addition to manufacturer material warranties." }
      },
      {
        "@type": "Question",
        "name": "What do manufacturer warranties cover?",
        "acceptedAnswer": { "@type": "Answer", "text": "Manufacturer warranties cover defects in the roofing material itself. We offer manufacturer warranties on all Owens Corning and GAF products we install. GAF and other brands also offer their own manufacturer warranties on their products." }
      },
      {
        "@type": "Question",
        "name": "What is NOT covered by the workmanship warranty?",
        "acceptedAnswer": { "@type": "Answer", "text": "Our workmanship warranty does not cover damage caused by storms, hurricanes, falling trees, improper modifications by others, lack of maintenance, or normal wear and tear. It covers defects in our installation work." }
      },
      {
        "@type": "Question",
        "name": "How do I file a warranty claim?",
        "acceptedAnswer": { "@type": "Answer", "text": "Call us at (813) 595-7663 or email info@happyroof.com. We'll schedule an inspection to assess the issue. If it's covered under our workmanship warranty, we'll repair it at no cost to you." }
      },
      {
        "@type": "Question",
        "name": "Does Happy Roof offer financing?",
        "acceptedAnswer": { "@type": "Answer", "text": "Yes. We offer flexible financing options for roof replacements and repairs, including low monthly payments and promotional 0% APR periods. Visit our financing page or call (813) 595-7663 for details." }
      },
      {
        "@type": "Question",
        "name": "What credit score do I need to qualify for financing?",
        "acceptedAnswer": { "@type": "Answer", "text": "Our financing partners offer options for a range of credit profiles. The best way to find out what you qualify for is to apply — the soft credit check will not affect your score. Contact us for more information." }
      },
      {
        "@type": "Question",
        "name": "Can I finance a roof repair, or only a full replacement?",
        "acceptedAnswer": { "@type": "Answer", "text": "Financing is available for both roof replacements and larger repair projects. Minimum amounts may apply depending on the financing partner. Call (813) 595-7663 to discuss your options." }
      },
      {
        "@type": "Question",
        "name": "Does Happy Roof help with insurance claims?",
        "acceptedAnswer": { "@type": "Answer", "text": "Yes. We assist Tampa Bay homeowners with the full insurance claim process for storm damage — from the initial roof inspection and damage documentation to working directly with your adjuster. The initial storm damage inspection is free." }
      },
      {
        "@type": "Question",
        "name": "How do I know if my roof has storm damage?",
        "acceptedAnswer": { "@type": "Answer", "text": "Signs of storm damage include missing or lifted shingles, dents in metal components, cracked tiles, granule loss, leaks after a storm, and dented gutters or downspouts. If you suspect damage, call (813) 595-7663 for a free storm damage inspection." }
      },
      {
        "@type": "Question",
        "name": "Should I file an insurance claim or pay out of pocket?",
        "acceptedAnswer": { "@type": "Answer", "text": "It depends on the extent of damage and your deductible. If storm damage is significant, filing a claim is usually the right move. We'll inspect your roof for free and give you an honest assessment before you decide. We never pressure homeowners to file unnecessary claims." }
      },
      {
        "@type": "Question",
        "name": "Does Happy Roof do emergency tarping after a storm?",
        "acceptedAnswer": { "@type": "Answer", "text": "Yes. We provide emergency tarping to prevent further interior damage while your claim is processed or your replacement is scheduled. Call (813) 595-7663 for urgent storm damage assistance." }
      }
    ]
  },{"@context":"https://schema.org","@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"Home","item":"https://happyroof.com/index.html"},{"@type":"ListItem","position":2,"name":"FAQ","item":"https://happyroof.com/faq.html"}]}]`;
---

<BaseLayout
  title="Roofing FAQ — Common Questions Answered | Happy Roof"
  description="Find answers to common roofing questions — warranties, financing, materials, insurance claims, and the roof replacement process. Happy Roof serves Tampa Bay, FL."
  canonical="https://happyroof.com/faq"
  ogTitle="Roofing FAQ | Happy Roof Tampa Bay"
  ogDescription="Answers to common roofing questions — warranties, financing, materials, insurance claims, and more. Serving Tampa Bay, FL."
  schema={schema}
>

<style is:inline>
/* FAQ */
    .cat-tab{padding:.55rem 1.2rem;border-radius:100px;font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:.85rem;letter-spacing:.08em;text-transform:uppercase;cursor:pointer;transition:background .18s,color .18s;border:1px solid #E0E0E0;background:#FFFFFF;color:#555555}
    .cat-tab:hover{background:#F7F7F7}
    .cat-tab.active{background:#E6A817;color:#1A1A1A;border-color:#E6A817}
    .faq-item{background:#FFFFFF;border:1px solid #E0E0E0;border-radius:12px;margin-bottom:.65rem;overflow:hidden;cursor:pointer;transition:border-color .2s}
    .faq-item:hover{border-color:rgba(230,168,23,.3)}
    .faq-q{display:flex;align-items:center;justify-content:space-between;padding:1rem 1.25rem;gap:.75rem}
    .faq-a{max-height:0;overflow:hidden;transition:max-height .35s ease,padding .35s ease;padding:0 1.25rem}
    .faq-item.open .faq-a{max-height:600px;padding:0 1.25rem 1.1rem}
    .faq-arr{transition:transform .25s ease;flex-shrink:0}
    .faq-item.open .faq-arr{transform:rotate(180deg)}
</style>

<section class="relative overflow-hidden" style="padding:8rem 0 5rem;background:#FFFFFF">
  <div class="hero-photo-bg" style="background-image:url('/Brand%20Assets/Photos/architectural-shingle-roof-tampa-bay.jpg')"></div>
  <div class="hero-photo-overlay"></div>
  <div class="relative z-10 max-w-5xl mx-auto px-5 text-center">
    <p class="sl mb-4" style="color:#888888">Knowledge Base</p>
    <h1 class="font-display font-black tracking-tightest mb-5" style="font-family:'Barlow Condensed',sans-serif;font-size:clamp(3rem,7vw,5.5rem);line-height:.88;letter-spacing:-.01em;color:#1A1A1A">
      FREQUENTLY ASKED<br/><span style="color:#E6A817">QUESTIONS.</span>
    </h1>
    <p style="color:#555555;font-size:1.1rem;line-height:1.75;max-width:560px;margin:0 auto 2.5rem">
      Everything you need to know about roofing in Tampa Bay — from materials and warranties to financing and insurance claims.
    </p>
    <div class="flex flex-wrap gap-3 justify-center">
      <a href="/contact" class="btn-p" style="font-size:1.1rem;padding:.9rem 2rem">Get a Free Estimate</a>
      <a href="tel:8135957663" class="btn-o call-tracking-number" style="font-size:1rem;padding:.85rem 1.8rem">Call (813) 595-7663</a>
    </div>
  </div>
</section>

<!-- ══════ CATEGORY FILTER + FAQ ACCORDIONS ══════ -->
<section style="background:#F7F7F7;padding:4rem 0 5rem">
  <div class="max-w-3xl mx-auto px-5">
    <!-- Category tabs -->
    <div class="flex flex-wrap gap-2 justify-center mb-10">
      <button class="cat-tab active" onclick="filterFaq('all',this)">All</button>
      <button class="cat-tab" onclick="filterFaq('general',this)">General</button>
      <button class="cat-tab" onclick="filterFaq('process',this)">Process</button>
      <button class="cat-tab" onclick="filterFaq('materials',this)">Materials</button>
      <button class="cat-tab" onclick="filterFaq('warranties',this)">Warranties</button>
      <button class="cat-tab" onclick="filterFaq('financing',this)">Financing</button>
      <button class="cat-tab" onclick="filterFaq('insurance',this)">Insurance &amp; Storm</button>
    </div>

    <!-- GENERAL -->
    <div class="mb-8" data-cat="general">
      <h2 style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.1rem;letter-spacing:.12em;text-transform:uppercase;color:#3B9FD9;margin-bottom:1rem">General</h2>
      <div class="faq-item" onclick="toggleFaq(this)">
        <div class="faq-q"><p class="font-medium text-sm" style="color:#1A1A1A">What areas does Happy Roof serve?</p><svg class="faq-arr" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#555" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg></div>
        <div class="faq-a"><p style="color:#555555;font-size:.88rem;line-height:1.7;padding-top:.5rem">Happy Roof serves all of Hillsborough, Pinellas, and Pasco counties — including Tampa, St. Petersburg, Clearwater, Brandon, Riverview, Wesley Chapel, Lutz, Land O' Lakes, Odessa, Temple Terrace, Oldsmar, Palm Harbor, Tarpon Springs, Safety Harbor, Dunedin, Largo, Seminole, New Port Richey, Trinity, and surrounding communities.</p></div>
      </div>
      <div class="faq-item" onclick="toggleFaq(this)">
        <div class="faq-q"><p class="font-medium text-sm" style="color:#1A1A1A">Is Happy Roof licensed and insured?</p><svg class="faq-arr" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#555" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg></div>
        <div class="faq-a"><p style="color:#555555;font-size:.88rem;line-height:1.7;padding-top:.5rem">Yes. Happy Roof LLC holds Florida Roofing Contractor License #CCC1337380 and carries full general liability and workers' compensation insurance. Certificate of insurance is available on request.</p></div>
      </div>
      <div class="faq-item" onclick="toggleFaq(this)">
        <div class="faq-q"><p class="font-medium text-sm" style="color:#1A1A1A">How do I get a free estimate?</p><svg class="faq-arr" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#555" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg></div>
        <div class="faq-a"><p style="color:#555555;font-size:.88rem;line-height:1.7;padding-top:.5rem">Call us at <a href="tel:8135957663" class="call-tracking-number" style="color:#3B9FD9;text-decoration:underline">(813) 595-7663</a> or fill out the contact form on our website. We'll schedule a free on-site inspection and provide an itemized, no-obligation estimate — typically within 24–48 hours.</p></div>
      </div>
      <div class="faq-item" onclick="toggleFaq(this)">
        <div class="faq-q"><p class="font-medium text-sm" style="color:#1A1A1A">How long has Happy Roof been in business?</p><svg class="faq-arr" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#555" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg></div>
        <div class="faq-a"><p style="color:#555555;font-size:.88rem;line-height:1.7;padding-top:.5rem">Happy Roof was founded in 2025 and is a locally owned roofing company proudly serving Tampa Bay. While we're a newer company, our leadership team brings over 30 years of combined experience in the roofing industry. We hold Florida Roofing Contractor License #CCC1337380 and install premium Owens Corning and GAF roofing products.</p></div>
      </div>
      <div class="faq-item" onclick="toggleFaq(this)">
        <div class="faq-q"><p class="font-medium text-sm" style="color:#1A1A1A">Do you offer emergency roofing services?</p><svg class="faq-arr" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#555" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg></div>
        <div class="faq-a"><p style="color:#555555;font-size:.88rem;line-height:1.7;padding-top:.5rem">Yes. We offer emergency tarping and temporary repairs for active leaks and storm damage throughout Tampa Bay. Call <a href="tel:8135957663" class="call-tracking-number" style="color:#3B9FD9;text-decoration:underline">(813) 595-7663</a> for urgent assistance.</p></div>
      </div>
      <div class="faq-item" onclick="toggleFaq(this)">
        <div class="faq-q"><p class="font-medium text-sm" style="color:#1A1A1A">How much does a roof replacement cost in Tampa Bay?</p><svg class="faq-arr" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#555" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg></div>
        <div class="faq-a"><p style="color:#555555;font-size:.88rem;line-height:1.7;padding-top:.5rem">A typical residential roof replacement in Tampa Bay ranges from $8,000 to $25,000+ depending on roof size, material (asphalt shingles, metal, tile), slope complexity, and whether structural repairs are needed. Happy Roof provides free, itemized estimates with no hidden fees.</p></div>
      </div>
    </div>

    <!-- PROCESS -->
    <div class="mb-8" data-cat="process">
      <h2 style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.1rem;letter-spacing:.12em;text-transform:uppercase;color:#3B9FD9;margin-bottom:1rem">Process</h2>
      <div class="faq-item" onclick="toggleFaq(this)">
        <div class="faq-q"><p class="font-medium text-sm" style="color:#1A1A1A">What does the roof replacement process look like?</p><svg class="faq-arr" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#555" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg></div>
        <div class="faq-a"><p style="color:#555555;font-size:.88rem;line-height:1.7;padding-top:.5rem">Our process includes: free inspection, detailed written estimate, material selection, permit pulling, full tear-off of the old roof, installation of new underlayment and roofing material, final building department inspection, and thorough cleanup. Most residential roofs are completed in 1–3 days.</p></div>
      </div>
      <div class="faq-item" onclick="toggleFaq(this)">
        <div class="faq-q"><p class="font-medium text-sm" style="color:#1A1A1A">How long does a roof replacement take?</p><svg class="faq-arr" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#555" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg></div>
        <div class="faq-a"><p style="color:#555555;font-size:.88rem;line-height:1.7;padding-top:.5rem">Most residential shingle roof replacements take 1–3 days depending on size and complexity. Metal roofs typically take 3–5 days. Tile roofs can take 5–7 days. Weather delays are possible during Florida's rainy season, but we plan accordingly and keep you informed.</p></div>
      </div>
      <div class="faq-item" onclick="toggleFaq(this)">
        <div class="faq-q"><p class="font-medium text-sm" style="color:#1A1A1A">Do I need to be home during the roof replacement?</p><svg class="faq-arr" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#555" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg></div>
        <div class="faq-a"><p style="color:#555555;font-size:.88rem;line-height:1.7;padding-top:.5rem">No. As long as we have access to the property and any gates, you do not need to be home. We'll keep you updated throughout the process via phone or text and send photos when the job is complete.</p></div>
      </div>
      <div class="faq-item" onclick="toggleFaq(this)">
        <div class="faq-q"><p class="font-medium text-sm" style="color:#1A1A1A">Does Happy Roof pull permits?</p><svg class="faq-arr" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#555" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg></div>
        <div class="faq-a"><p style="color:#555555;font-size:.88rem;line-height:1.7;padding-top:.5rem">Yes. Happy Roof pulls all required building permits for every roof replacement and handles scheduling the final inspection with the local building department. This is included in every project at no extra charge. A permitted roof protects your home's resale value and insurance coverage.</p></div>
      </div>
      <div class="faq-item" onclick="toggleFaq(this)">
        <div class="faq-q"><p class="font-medium text-sm" style="color:#1A1A1A">Will you remove and dispose of my old roof?</p><svg class="faq-arr" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#555" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg></div>
        <div class="faq-a"><p style="color:#555555;font-size:.88rem;line-height:1.7;padding-top:.5rem">Yes. Every roof replacement includes full tear-off, disposal of old materials, and thorough cleanup of your property. We use magnetic nail sweepers to ensure no nails or debris are left behind in your yard or driveway.</p></div>
      </div>
    </div>

    <!-- MATERIALS -->
    <div class="mb-8" data-cat="materials">
      <h2 style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.1rem;letter-spacing:.12em;text-transform:uppercase;color:#3B9FD9;margin-bottom:1rem">Materials</h2>
      <div class="faq-item" onclick="toggleFaq(this)">
