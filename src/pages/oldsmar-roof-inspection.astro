      <span class="scard px-4 py-3 text-center" style="font-size:.9rem;font-weight:600">Mobbly Bay</span>
      <span class="scard px-4 py-3 text-center" style="font-size:.9rem;font-weight:600">Upper Tampa Bay</span>
      <span class="scard px-4 py-3 text-center" style="font-size:.9rem;font-weight:600">Forest Lakes</span>
      <span class="scard px-4 py-3 text-center" style="font-size:.9rem;font-weight:600">Pine Ridge</span>
      <span class="scard px-4 py-3 text-center" style="font-size:.9rem;font-weight:600">Shore Drive</span>
      <span class="scard px-4 py-3 text-center" style="font-size:.9rem;font-weight:600">Baywatch</span>
      <span class="scard px-4 py-3 text-center" style="font-size:.9rem;font-weight:600">State St Corridor</span>
      <span class="scard px-4 py-3 text-center" style="font-size:.9rem;font-weight:600">Veterans Memorial</span>
      <span class="scard px-4 py-3 text-center" style="font-size:.9rem;font-weight:600">East Lake Woodlands</span>
    </div>
  </div>
</section>

<!-- FAQ -->
<section class="py-20" style="background:#FFFFFF">
  <div class="max-w-3xl mx-auto px-5">
    <div class="text-center mb-12">
      <p class="sl gt mb-3">Common Questions</p>
      <h2 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:clamp(2rem,4vw,3rem);line-height:.95;color:#1A1A1A;letter-spacing:-.01em">OLDSMAR ROOF INSPECTION FAQ</h2>
    </div>
    <div class="faq-item">
      <button class="faq-btn" aria-expanded="false" onclick="this.setAttribute('aria-expanded',this.getAttribute('aria-expanded')==='true'?'false':'true');this.nextElementSibling.classList.toggle('open')">
        Is the roof inspection really free in Oldsmar?
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#1A1A1A" stroke-width="2.5"><path d="M6 9l6 6 6-6"/></svg>
      </button>
      <div class="faq-answer"><div class="faq-answer-inner">Yes. It is completely free with no obligation. Happy Roof is based in Oldsmar, and we believe earning our neighbors' trust starts with honest, no-cost inspections. You are never required to purchase any services.</div></div>
    </div>
    <div class="faq-item">
      <button class="faq-btn" aria-expanded="false" onclick="this.setAttribute('aria-expanded',this.getAttribute('aria-expanded')==='true'?'false':'true');this.nextElementSibling.classList.toggle('open')">
        How long does a roof inspection take?
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#1A1A1A" stroke-width="2.5"><path d="M6 9l6 6 6-6"/></svg>
      </button>
