import BaseLayout from '../layouts/BaseLayout.astro';

const schema = `[{"@context":"https://schema.org","@type":["LocalBusiness","RoofingContractor"],"name":"Happy Roof LLC","url":"https://happyroof.com","telephone":"+1-813-595-7663","email":"info@happyroof.com","description":"Palm Harbor roofing contractor specializing in shingle, metal, and tile roof replacement. Licensed and insured. FL License #CCC1337380.","image":"/Brand%20Assets/Happy%20Roof%20Logo.jpeg","logo":"/Brand%20Assets/Happy%20Roof%20Logo.jpeg","address":{"@type":"PostalAddress","streetAddress":"141 Stevens Ave #12","addressLocality":"Oldsmar","addressRegion":"FL","postalCode":"34677","addressCountry":"US"},"areaServed":{"@type":"City","name":"Palm Harbor","containedInPlace":{"@type":"State","name":"Florida"}},"hasCredential":"Florida Roofing Contractor License #CCC1337380"},{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[
    {"@type":"Question","name":"How much does a roof replacement cost in Palm Harbor?","acceptedAnswer":{"@type":"Answer","text":"Roof replacement in Palm Harbor typically ranges from $8,500 to $25,000+ depending on roof size, pitch, material (shingles, metal, or tile), and any structural repairs needed. Homes in communities like Innisbrook, Lansbrook, and East Lake have varying roof styles that affect pricing. Happy Roof provides free, detailed estimates — call (813) 595-7663."}},
    {"@type":"Question","name":"What roofing material is best for Palm Harbor?","acceptedAnswer":{"@type":"Answer","text":"Palm Harbor's location in upper Pinellas County means roofs face intense UV, tropical rain, and hurricane-force winds. Architectural shingles with 130+ MPH wind ratings are the most popular. Metal roofing is excellent for energy savings and longevity (40-60 years). Tile roofs are common in Innisbrook and other Mediterranean-style communities. We install all three and help you choose."}},
    {"@type":"Question","name":"Does Happy Roof handle permits in Palm Harbor?","acceptedAnswer":{"@type":"Answer","text":"Yes. Palm Harbor is an unincorporated area of Pinellas County, so roofing permits are handled through the Pinellas County building department. Happy Roof manages the entire permitting and inspection process — you never have to visit a county office."}},
    {"@type":"Question","name":"How long does a roof replacement take in Palm Harbor?","acceptedAnswer":{"@type":"Answer","text":"Most Palm Harbor shingle roofs are completed in 1 to 3 days. Metal roofs take 3 to 5 days, and tile roofs 5 to 7 days. We plan around weather and keep you informed throughout the project. Complete cleanup and debris removal is included."}},
    {"@type":"Question","name":"Is Happy Roof licensed to work in Palm Harbor?","acceptedAnswer":{"@type":"Answer","text":"Yes. Happy Roof LLC holds Florida Roofing Contractor License #CCC1337380, authorizing us to perform roofing work throughout Florida, including Palm Harbor and all of Pinellas County. We carry full general liability and workers' compensation insurance."}}
  ]}]`;
