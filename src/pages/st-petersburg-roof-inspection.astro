---
import BaseLayout from '../layouts/BaseLayout.astro';

const schema = `[{
    "@context": "https://schema.org",
    "@type": ["LocalBusiness", "RoofingContractor"],
    "name": "Happy Roof LLC",
    "url": "https://happyroof.com",
    "telephone": "+1-813-595-7663",
    "email": "info@happyroof.com",
    "description": "Free roof inspections in St. Petersburg FL. Comprehensive assessment of all roof types. FL License #CCC1337380.",
    "image": "/Brand%20Assets/Happy%20Roof%20Logo.jpeg",
    "logo": "/Brand%20Assets/Happy%20Roof%20Logo.jpeg",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "141 Stevens Ave #12",
      "addressLocality": "Oldsmar",
      "addressRegion": "FL",
      "postalCode": "34677",
      "addressCountry": "US"
    },
    "areaServed": {
      "@type": "City",
      "name": "St. Petersburg",
      "containedInPlace": { "@type": "State", "name": "Florida" }
    },
    "hasCredential": "Florida Roofing Contractor License #CCC1337380",
    "dateModified": "2026-04-25"
  },{
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Is the roof inspection really free in St. Petersburg?",
        "acceptedAnswer": { "@type": "Answer", "text": "Yes. It is 100% free with no obligation. You are not required to purchase any services. We believe that providing honest inspections builds trust with St. Petersburg homeowners and earns their business when they do need roofing work." }
      },
      {
        "@type": "Question",
        "name": "How long does a roof inspection take in St. Petersburg?",
        "acceptedAnswer": { "@type": "Answer", "text": "Most inspections take 45 to 60 minutes. Larger homes, multi-story properties, or tile roofs may take slightly longer. We are thorough, and we check every component rather than doing a quick visual scan." }
      },
      {
        "@type": "Question",
        "name": "What if you find problems during my inspection?",
        "acceptedAnswer": { "@type": "Answer", "text": "We document everything with photos and walk you through the findings. If repairs or replacement are warranted, we provide a written estimate with clear options. There is no pressure, and the decision is entirely yours." }
      },
      {
        "@type": "Question",
        "name": "When should I get my St. Petersburg roof inspected?",
        "acceptedAnswer": { "@type": "Answer", "text": "Before hurricane season (June), after any major storm, if your roof is over 10 years old, before buying or selling a home, or if you notice warning signs like water stains, missing shingles, or granules in gutters. Many St. Pete homeowners schedule annual inspections for peace of mind." }
      }
    ]
  }]`;
---

<BaseLayout
  title="Free Roof Inspection St. Petersburg | Happy Roof"
  description="Free roof inspection in St. Petersburg FL. Comprehensive 25-point assessment by Happy Roof. No obligation. FL License #CCC1337380. Schedule: (813) 595-7663."
  canonical="https://happyroof.com/st-petersburg-roof-inspection"
  schema={schema}
>

<style is:inline>
.check-dot{width:20px;height:20px;border-radius:50%;display:flex;align-items:center;justify-content:center;background:rgba(230,168,23,.1);flex-shrink:0;margin-top:.15rem}
    .step-num{width:48px;height:48px;border-radius:14px;display:flex;align-items:center;justify-content:center;background:rgba(230,168,23,.1);font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.25rem;color:#E6A817;flex-shrink:0}
</style>

<!-- HERO -->
<section class="pt-32 pb-20 relative overflow-hidden" style="background:#F5F5F5;border-bottom:1px solid #E5E5E5">
  <div class="hero-photo-bg" style="background-image:url('/Brand%20Assets/Photos/architectural-shingle-roof-tampa-bay.jpg')"></div>
  <div class="hero-photo-overlay"></div>
  <div class="relative z-10 max-w-7xl mx-auto px-5 text-center">
    <p class="sl gp mb-4">St. Petersburg Roof Inspection</p>
