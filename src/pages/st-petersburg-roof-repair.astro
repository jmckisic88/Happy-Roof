</section>

<!-- FAQ -->
<section class="py-20" style="background:#FFFFFF">
  <div class="max-w-3xl mx-auto px-5">
    <div class="text-center mb-12">
      <p class="sl gt mb-3">Common Questions</p>
      <h2 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:clamp(2rem,4vw,3rem);line-height:.95;color:#1A1A1A;letter-spacing:-.01em">ST. PETERSBURG ROOF REPAIR FAQ</h2>
    </div>
    <div class="faq-item">
      <button class="faq-btn" aria-expanded="false" onclick="this.setAttribute('aria-expanded',this.getAttribute('aria-expanded')==='true'?'false':'true');this.nextElementSibling.classList.toggle('open')">
        How fast can you respond to a roof emergency in St. Petersburg?
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#1A1A1A" stroke-width="2.5"><path d="M6 9l6 6 6-6"/></svg>
      </button>
      <div class="faq-answer"><div class="faq-answer-inner">We offer same-day emergency tarping for active leaks in St. Petersburg and throughout Pinellas County. Once the immediate damage is contained, we schedule the permanent repair as quickly as possible, typically within a few days.</div></div>
    </div>
    <div class="faq-item">
      <button class="faq-btn" aria-expanded="false" onclick="this.setAttribute('aria-expanded',this.getAttribute('aria-expanded')==='true'?'false':'true');this.nextElementSibling.classList.toggle('open')">
        Should I repair or replace my St. Petersburg roof?
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#1A1A1A" stroke-width="2.5"><path d="M6 9l6 6 6-6"/></svg>
