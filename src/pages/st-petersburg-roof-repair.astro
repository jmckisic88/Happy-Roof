---
import BaseLayout from '../layouts/BaseLayout.astro';

const schema = `[{
    "@context": "https://schema.org",
    "@type": ["LocalBusiness", "RoofingContractor"],
    "name": "Happy Roof LLC",
    "url": "https://happyroof.com",
    "telephone": "+1-813-595-7663",
    "email": "info@happyroof.com",
    "description": "St. Petersburg roof repair contractor. Emergency leak repair, storm damage, shingle and tile repair. FL License #CCC1337380.",
    "image": "/Brand%20Assets/Happy%20Roof%20Logo.jpeg",
    "logo": "/Brand%20Assets/Happy%20Roof%20Logo.jpeg",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "141 Stevens Ave #12",
      "addressLocality": "Oldsmar",
      "addressRegion": "FL",
      "postalCode": "34677",
      "addressCountry": "US"
    },
    "areaServed": {
      "@type": "City",
      "name": "St. Petersburg",
      "containedInPlace": { "@type": "State", "name": "Florida" }
    },
    "hasCredential": "Florida Roofing Contractor License #CCC1337380",
    "dateModified": "2026-04-20"
  },{
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How fast can you respond to a roof emergency in St. Petersburg?",
        "acceptedAnswer": { "@type": "Answer", "text": "We offer same-day emergency tarping for active leaks in St. Petersburg and throughout Pinellas County. Once the immediate damage is contained, we schedule the permanent repair as quickly as possible, typically within a few days." }
      },
      {
        "@type": "Question",
        "name": "Should I repair or replace my St. Petersburg roof?",
        "acceptedAnswer": { "@type": "Answer", "text": "If your roof is under 15 years old and damage is limited to a specific area, repair is usually the better option. If your roof is 20+ years old with widespread issues, replacement is often more cost-effective. We provide honest guidance either way." }
      },
      {
        "@type": "Question",
        "name": "Does insurance cover storm damage repairs in St. Petersburg?",
        "acceptedAnswer": { "@type": "Answer", "text": "Most homeowners insurance policies in Florida cover wind and storm damage to roofs. We document all damage with detailed photos and can work directly with your insurance adjuster to support your claim." }
      },
      {
        "@type": "Question",
        "name": "How much does a roof repair cost in St. Petersburg?",
        "acceptedAnswer": { "@type": "Answer", "text": "Minor repairs like replacing a few shingles or resealing flashing range from $300 to $1,500. More extensive repairs involving multiple areas or tile work can cost $1,500 to $5,000+. We always provide a free inspection and transparent estimate first." }
      }
    ]
  }]`;
---

<BaseLayout
  title="St. Petersburg Roof Repair | Same-Day Response | Happy Roof"
  description="St. Petersburg roof repair: same-day emergency response by Happy Roof. Leak repair, storm damage, missing shingles & tile. FL License #CCC1337380. Call (813) 595-7663."
  canonical="https://happyroof.com/st-petersburg-roof-repair"
  schema={schema}
>

<style is:inline>
.check-dot{width:20px;height:20px;border-radius:50%;display:flex;align-items:center;justify-content:center;background:rgba(230,168,23,.1);flex-shrink:0;margin-top:.15rem}
    .step-num{width:48px;height:48px;border-radius:14px;display:flex;align-items:center;justify-content:center;background:rgba(230,168,23,.1);font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.25rem;color:#E6A817;flex-shrink:0}
</style>

<!-- HERO -->
<section class="pt-32 pb-20 relative overflow-hidden" style="background:#F5F5F5;border-bottom:1px solid #E5E5E5">
  <div class="hero-photo-bg" style="background-image:url('/Brand%20Assets/Photos/commercial-tpo-roof-tampa.jpg')"></div>
  <div class="hero-photo-overlay"></div>
  <div class="relative z-10 max-w-7xl mx-auto px-5 text-center">
    <p class="sl gp mb-4">St. Petersburg Roof Repair</p>
    <h1 class="font-display font-black tracking-tightest mb-5" style="font-family:'Barlow Condensed',sans-serif;font-size:clamp(2.5rem,5.5vw,4.5rem);line-height:.92;letter-spacing:-.01em;color:#1A1A1A">
      ST. PETERSBURG ROOF REPAIR<br/><span class="gt">SAME-DAY RESPONSE</span>
    </h1>
    <p class="max-w-2xl mx-auto" style="color:#555555;font-size:1.05rem;line-height:1.75">
      Roof leaking in St. Petersburg? Happy Roof provides fast emergency repairs for shingle, metal, and tile roofs across Pinellas County. From storm damage in Shore Acres to aging roofs in Kenwood, we respond quickly with honest assessments and quality repairs.
    </p>
    <div class="flex flex-wrap gap-3 justify-center mt-8">
      <a href="/contact" class="btn-t">Get a Free Estimate <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg></a>
      <a href="tel:8135957663" class="btn-o call-tracking-number">Call (813) 595-7663</a>
    </div>
  </div>
</section>

<!-- INFO STRIP -->
<div style="background:#FFFFFF;border-top:2px solid #E6A817;border-bottom:1px solid #E0E0E0;padding:.85rem 0">
  <div class="max-w-7xl mx-auto px-5">
    <div class="flex flex-wrap items-center justify-center gap-x-8 gap-y-2 font-display font-bold text-sm tracking-widest" style="color:#1A1A1A;text-transform:uppercase;font-family:'Barlow Condensed',sans-serif">
      <span>St. Petersburg, FL</span><span style="color:#E6A817">·</span><span>CCC1337380</span><span style="color:#E6A817">·</span><span>HappyRoof.com</span><span style="color:#E6A817">·</span><span style="color:#3B9FD9">(813) 595-7663</span>
    </div>
  </div>
</div>

<!-- WHY SECTION -->
<section class="py-20" style="background:#FFFFFF">
  <div class="max-w-7xl mx-auto px-5">
    <div class="grid lg:grid-cols-2 gap-14 items-start">
      <div>
        <p class="sl gt mb-3">Why Choose Happy Roof for Repairs</p>
        <h2 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:clamp(2rem,4vw,3rem);line-height:.95;color:#1A1A1A;letter-spacing:-.01em;margin-bottom:1.5rem">WHY ST. PETERSBURG HOMEOWNERS TRUST US FOR ROOF REPAIRS</h2>
        <p style="color:#555555;font-size:1rem;line-height:1.75;margin-bottom:1.5rem">St. Petersburg's position on a narrow peninsula between Tampa Bay and Boca Ciega Bay means roofs here face a double dose of moisture and salt air that mainland homes never experience. The city averages over 60 inches of rain annually, most of it falling in intense bursts during summer thunderstorms. Add hurricane-season winds that funnel between the bays, and it is easy to understand why roof damage is one of the most common homeowner concerns in St. Pete.</p>
        <p style="color:#555555;font-size:1rem;line-height:1.75;margin-bottom:1.5rem">Common repairs in St. Petersburg include replacing wind-lifted shingles in neighborhoods like Tyrone and Disston Heights, resealing flashing around the skylights and chimneys found on mid-century homes in Lakewood Estates, and replacing cracked barrel tiles on the Spanish-style homes of Old Northeast and Snell Isle. Salt air corrosion also affects metal flashing and fasteners faster here than in inland areas, making periodic inspection and repair essential for coastal properties.</p>
        <p style="color:#555555;font-size:1rem;line-height:1.75;margin-bottom:1.5rem">Happy Roof provides honest, fast roof repair services throughout St. Petersburg and Pinellas County. If a repair will solve your problem, that is what we recommend - no unnecessary upsells. For active leaks, we offer emergency tarping to prevent further damage. Visit our <a href="/st-petersburg-roofing" style="color:#3B9FD9;text-decoration:none;font-weight:600">St. Petersburg roofing page</a> or our general <a href="/roof-repair" style="color:#3B9FD9;text-decoration:none;font-weight:600">roof repair page</a> for more information.</p>
      </div>
      <div class="space-y-4">
        <div class="scard p-6">
          <div class="check"><div class="check-dot"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#E6A817" stroke-width="3"><path d="M20 6L9 17l-5-5"/></svg></div><div><strong style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.05rem">Emergency Leak Response</strong><p style="color:#555555;font-size:.9rem;line-height:1.6;margin-top:.25rem">Same-day tarping for active leaks in St. Petersburg. We contain the damage immediately, then schedule a permanent repair to restore your roof's integrity.</p></div></div>
        </div>
        <div class="scard p-6">
          <div class="check"><div class="check-dot"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#E6A817" stroke-width="3"><path d="M20 6L9 17l-5-5"/></svg></div><div><strong style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.05rem">Wind & Storm Damage</strong><p style="color:#555555;font-size:.9rem;line-height:1.6;margin-top:.25rem">St. Pete's coastal storms lift shingles, crack tiles, and tear off ridge caps. We assess and repair all storm-related damage and help document it for your insurance claim.</p></div></div>
        </div>
        <div class="scard p-6">
          <div class="check"><div class="check-dot"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#E6A817" stroke-width="3"><path d="M20 6L9 17l-5-5"/></svg></div><div><strong style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.05rem">Salt Air Corrosion Repair</strong><p style="color:#555555;font-size:.9rem;line-height:1.6;margin-top:.25rem">Metal flashing, fasteners, and roof vents corrode faster in St. Pete's salt air. We replace compromised components with marine-grade materials built for coastal conditions.</p></div></div>
        </div>
        <div class="scard p-6">
          <div class="check"><div class="check-dot"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#E6A817" stroke-width="3"><path d="M20 6L9 17l-5-5"/></svg></div><div><strong style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.05rem">Honest Repair-or-Replace Advice</strong><p style="color:#555555;font-size:.9rem;line-height:1.6;margin-top:.25rem">We give you a straight answer. If your St. Pete roof can be repaired effectively, we will tell you. If replacement makes more sense financially, we explain why.</p></div></div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- WHAT'S INCLUDED / COMMON REPAIRS / WHAT WE CHECK -->
<section class="py-20" style="background:#F7F7F7">
  <div class="max-w-7xl mx-auto px-5">
    <div class="text-center mb-14">
