      <span class="scard px-4 py-3 text-center" style="font-size:.9rem;font-weight:600">Clearwater</span>
      <span class="scard px-4 py-3 text-center" style="font-size:.9rem;font-weight:600">Countryside</span>
      <span class="scard px-4 py-3 text-center" style="font-size:.9rem;font-weight:600">East Lake</span>
      <span class="scard px-4 py-3 text-center" style="font-size:.9rem;font-weight:600">Westchase</span>
      <span class="scard px-4 py-3 text-center" style="font-size:.9rem;font-weight:600">Palm Harbor</span>
    </div>
