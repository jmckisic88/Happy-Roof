---
import BaseLayout from '../layouts/BaseLayout.astro';

const schema = `[{
    "@context": "https://schema.org",
    "@type": ["LocalBusiness", "RoofingContractor"],
    "name": "Happy Roof LLC",
    "url": "https://happyroof.com",
    "telephone": "+1-813-595-7663",
    "email": "info@happyroof.com",
    "description": "Safety Harbor roofing contractor specializing in shingle, metal, and tile roof replacement and installation. Licensed and insured. FL License #CCC1337380.",
    "image": "/Brand%20Assets/Happy%20Roof%20Logo.jpeg",
    "logo": "/Brand%20Assets/Happy%20Roof%20Logo.jpeg",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "141 Stevens Ave #12",
      "addressLocality": "Oldsmar",
      "addressRegion": "FL",
      "postalCode": "34677",
      "addressCountry": "US"
    },
    "areaServed": {
      "@type": "City",
      "name": "Safety Harbor",
      "containedInPlace": {
        "@type": "State",
        "name": "Florida"
      }
    },
    "hasCredential": "Florida Roofing Contractor License #CCC1337380"
  },{
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How much does a roof replacement cost in Safety Harbor?",
        "acceptedAnswer": { "@type": "Answer", "text": "Roof replacement costs in Safety Harbor typically range from $8,000 to $25,000+ depending on your roof's size, pitch, material (shingles, metal, or tile), and any structural repairs needed. Homes along Bayshore Boulevard and near the Old Tampa Bay waterfront may have additional considerations due to wind exposure and salt air. Happy Roof provides free, transparent estimates — call (813) 595-7663." }
      },
      {
        "@type": "Question",
        "name": "What roofing materials work best for Safety Harbor's waterfront location?",
        "acceptedAnswer": { "@type": "Answer", "text": "Safety Harbor sits on the western shore of Old Tampa Bay, which means homes face salt air exposure, strong bay winds, and Florida's intense UV radiation. Standing seam metal roofing resists corrosion and lasts 40-60 years. Owens Corning Duration HDZ shingles rated for 130+ MPH winds are popular throughout Safety Harbor's residential neighborhoods. Tile roofs are a great match for the Mediterranean and craftsman-style homes found in the downtown district and along Philippe Park." }
      },
      {
        "@type": "Question",
        "name": "Does Happy Roof handle permits for Safety Harbor roofing projects?",
        "acceptedAnswer": { "@type": "Answer", "text": "Yes. Happy Roof handles all permit applications with the City of Safety Harbor and Pinellas County building departments. We manage the entire permitting and inspection process so you never have to visit a government office or coordinate inspectors yourself. All work meets current Florida Building Code standards." }
      },
      {
        "@type": "Question",
        "name": "How long does a roof replacement take in Safety Harbor?",
        "acceptedAnswer": { "@type": "Answer", "text": "Most Safety Harbor shingle roof replacements are completed in 1 to 3 days. Metal roofs typically take 3 to 5 days, and tile roofs 5 to 7 days. Florida's summer afternoon storms can occasionally cause brief delays, but we plan around weather patterns and keep you informed at every stage of the project." }
      },
      {
        "@type": "Question",
        "name": "Is Happy Roof licensed to work in Safety Harbor?",
        "acceptedAnswer": { "@type": "Answer", "text": "Yes. Happy Roof LLC holds Florida Roofing Contractor License #CCC1337380, which authorizes roofing work throughout the entire state of Florida, including the City of Safety Harbor and all of Pinellas County. We carry full general liability and workers' compensation insurance." }
      }
    ]
  }]`;
---

<BaseLayout
  title="Safety Harbor Roofing Contractor — Licensed & Insured | Happy Roof"
  description="Safety Harbor roofing contractor — Happy Roof provides roof replacement, repair, and installation across Safety Harbor FL. Licensed and insured. FL License #CCC1337380. Free estimates: (813) 595-7663."
  canonical="https://happyroof.com/safety-harbor-roofing"
  ogDescription="Trusted Safety Harbor roofing contractor. Shingle, metal, and tile roof replacement. Licensed and insured. 15-year warranty. Free estimates."
  schema={schema}
>

<style is:inline>
.check-dot{width:20px;height:20px;border-radius:50%;display:flex;align-items:center;justify-content:center;background:rgba(230,168,23,.1);flex-shrink:0;margin-top:.15rem}
    .step-num{width:48px;height:48px;border-radius:14px;display:flex;align-items:center;justify-content:center;background:rgba(230,168,23,.1);font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.25rem;color:#E6A817;flex-shrink:0}
</style>

<!-- HERO -->
<section class="pt-32 pb-20 relative overflow-hidden" style="background:#F5F5F5;border-bottom:1px solid #E5E5E5">
