    ]
  },{
    "@context": "https://schema.org",
    "@type": "Service",
    "serviceType": "Commercial Roofing",
    "provider": { "@type": "RoofingContractor", "name": "Happy Roof LLC", "telephone": "+1-813-595-7663", "url": "https://happyroof.com" },
    "areaServed": { "@type": "State", "name": "Florida" },
    "description": "Complete commercial roofing services in Tampa Bay including TPO, EPDM, modified bitumen, and metal roofing systems. Phased scheduling for minimal business disruption. 10-year flat roof workmanship warranty."
  },{"@context":"https://schema.org","@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"Home","item":"https://happyroof.com/"},{"@type":"ListItem","position":2,"name":"Services","item":"https://happyroof.com/services"},{"@type":"ListItem","position":3,"name":"Commercial Roofing","item":"https://happyroof.com/commercial-roofing"}]}]`;
