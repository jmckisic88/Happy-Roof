---
import BaseLayout from '../layouts/BaseLayout.astro';

const schema = `[{
    "@context": "https://schema.org",
    "@type": ["LocalBusiness", "RoofingContractor"],
    "name": "Happy Roof LLC",
    "url": "https://happyroof.com",
    "telephone": "+1-813-595-7663",
    "email": "info@happyroof.com",
    "description": "Pinellas Park roofing contractor specializing in shingle, metal, and tile roof replacement and installation for residential and commercial properties. Licensed and insured. FL License #CCC1337380.",
    "image": "/Brand%20Assets/Happy%20Roof%20Logo.jpeg",
    "logo": "/Brand%20Assets/Happy%20Roof%20Logo.jpeg",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "141 Stevens Ave #12",
      "addressLocality": "Oldsmar",
      "addressRegion": "FL",
      "postalCode": "34677",
      "addressCountry": "US"
    },
    "areaServed": {
      "@type": "City",
      "name": "Pinellas Park",
      "containedInPlace": {
        "@type": "State",
        "name": "Florida"
      }
    },
    "hasCredential": "Florida Roofing Contractor License #CCC1337380",
    "dateModified": "2026-04-10"
  },{
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How much does a roof replacement cost in Pinellas Park?",
        "acceptedAnswer": { "@type": "Answer", "text": "Roof replacement costs in Pinellas Park typically range from $8,000 to $25,000+ for residential properties depending on size, pitch, material (shingles, metal, or tile), and any structural repairs. Commercial properties along the Park Boulevard corridor and Gateway area vary based on square footage and roof system type. Happy Roof provides free, transparent estimates - call (813) 595-7663." }
      },
      {
        "@type": "Question",
        "name": "What roofing materials work best for Pinellas Park properties?",
        "acceptedAnswer": { "@type": "Answer", "text": "Pinellas Park's central location between St. Petersburg and Clearwater means properties face Florida's full weather spectrum - intense UV, heavy rain, and hurricane winds. Owens Corning Duration HDZ shingles rated for 130+ MPH winds are the most popular residential choice. Standing seam metal is ideal for both homes and commercial buildings along Park Boulevard, offering 40-60 year lifespans and energy savings. TPO and modified bitumen systems serve the city's many flat-roof commercial and industrial properties." }
      },
      {
        "@type": "Question",
        "name": "Does Happy Roof handle permits for Pinellas Park roofing projects?",
        "acceptedAnswer": { "@type": "Answer", "text": "Yes. Happy Roof handles all permit applications with the City of Pinellas Park and Pinellas County building departments. We manage the entire permitting and inspection process so you never have to visit a government office or coordinate inspectors yourself. All work meets current Florida Building Code standards." }
      },
      {
        "@type": "Question",
        "name": "How long does a roof replacement take in Pinellas Park?",
        "acceptedAnswer": { "@type": "Answer", "text": "Most Pinellas Park residential shingle roof replacements are completed in 1 to 3 days. Metal roofs typically take 3 to 5 days. Commercial projects vary based on building size and roof system, but we provide detailed timelines during the estimate phase. Florida's summer storms can cause brief delays, but we plan around weather and keep you informed throughout." }
      },
      {
        "@type": "Question",
        "name": "Does Happy Roof handle commercial roofing in Pinellas Park?",
        "acceptedAnswer": { "@type": "Answer", "text": "Yes. Pinellas Park has a significant commercial and industrial presence, particularly along the Park Boulevard corridor and in the Gateway area. Happy Roof services commercial properties including flat-roof systems, metal roofing, and modified bitumen. We hold Florida Roofing Contractor License #CCC1337380 and carry full general liability and workers' compensation insurance for both residential and commercial projects." }
      }
    ]
  }]`;
---

<BaseLayout
  title="Pinellas Park Roofing Contractor - Licensed & Insured | Happy Roof"
  description="Pinellas Park roofing contractor - Happy Roof provides roof replacement, repair, and installation across Pinellas Park FL. Licensed and insured. FL License #CCC1337380. Free estimates: (813) 595-7663."
  canonical="https://happyroof.com/pinellas-park-roofing"
  ogTitle="Pinellas Park Roofing Contractor | Happy Roof"
  ogDescription="Licensed Pinellas Park roofer for replacements, repairs & storm damage. Free estimates - call (813) 595-7663."
  schema={schema}
>

<style is:inline>
.check-dot{width:20px;height:20px;border-radius:50%;display:flex;align-items:center;justify-content:center;background:rgba(230,168,23,.1);flex-shrink:0;margin-top:.15rem}
    .step-num{width:48px;height:48px;border-radius:14px;display:flex;align-items:center;justify-content:center;background:rgba(230,168,23,.1);font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.25rem;color:#E6A817;flex-shrink:0}
</style>

<!-- HERO -->
<section class="pt-32 pb-20 relative overflow-hidden" style="background:#F5F5F5;border-bottom:1px solid #E5E5E5">
  <div class="hero-photo-bg" style="background-image:url('/Brand%20Assets/Photos/architectural-shingle-roof-tampa-bay.jpg')"></div>
