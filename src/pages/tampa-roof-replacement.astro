---
import BaseLayout from '../layouts/BaseLayout.astro';

const schema = `[{
    "@context": "https://schema.org",
    "@type": ["LocalBusiness", "RoofingContractor"],
    "name": "Happy Roof LLC",
    "url": "https://happyroof.com",
    "telephone": "+1-813-595-7663",
    "email": "info@happyroof.com",
    "description": "Tampa roof replacement contractor specializing in shingle, metal, and tile roofing systems. Licensed and insured. FL License #CCC1337380.",
    "image": "/Brand%20Assets/Happy%20Roof%20Logo.jpeg",
    "logo": "/Brand%20Assets/Happy%20Roof%20Logo.jpeg",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "141 Stevens Ave #12",
      "addressLocality": "Oldsmar",
      "addressRegion": "FL",
      "postalCode": "34677",
      "addressCountry": "US"
    },
    "areaServed": {
      "@type": "City",
      "name": "Tampa",
      "containedInPlace": { "@type": "State", "name": "Florida" }
    },
    "hasCredential": "Florida Roofing Contractor License #CCC1337380",
    "dateModified": "2026-04-10"
  },{
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How much does a roof replacement cost in Tampa?",
        "acceptedAnswer": { "@type": "Answer", "text": "Roof replacement in Tampa typically costs between $8,000 and $25,000 or more, depending on your home's square footage, roof pitch, chosen material (architectural shingles, standing seam metal, or tile), and whether structural repairs are needed. Homes in older neighborhoods like Seminole Heights and Hyde Park sometimes require additional decking work. Call Happy Roof at (813) 595-7663 for a free, no-obligation estimate." }
      },
      {
        "@type": "Question",
        "name": "What roofing materials are best for Tampa homes?",
        "acceptedAnswer": { "@type": "Answer", "text": "Tampa's combination of intense UV, tropical storms, and hurricane-force winds requires durable materials. Owens Corning Duration HDZ architectural shingles are rated for 130+ MPH winds and are the most popular choice. Standing seam metal roofing reflects heat and lasts 40-60 years, ideal for waterfront properties along Bayshore Boulevard. Concrete and clay tile suit the Mediterranean-style homes common in Palma Ceia and Beach Park." }
      },
      {
        "@type": "Question",
        "name": "How long does a full roof replacement take in Tampa?",
        "acceptedAnswer": { "@type": "Answer", "text": "Most shingle roof replacements in Tampa are completed in 1 to 3 days. Metal roof installations typically take 3 to 5 days, and tile roofs may require 5 to 7 days depending on size and complexity. Tampa's afternoon thunderstorms during summer can occasionally cause brief delays, but our crews plan around weather forecasts and keep you informed throughout." }
      },
      {
        "@type": "Question",
        "name": "Does Happy Roof handle permits for Tampa roof replacements?",
        "acceptedAnswer": { "@type": "Answer", "text": "Yes. We handle the entire permitting process with the City of Tampa and Hillsborough County building departments. We pull the permit, schedule and attend all required inspections, and ensure your new roof meets current Florida Building Code requirements. You never have to visit a government office or coordinate inspectors yourself." }
      }
    ]
  }]`;
---

<BaseLayout
  title="Tampa Roof Replacement — Licensed Contractor | Happy Roof"
  description="Tampa roof replacement by Happy Roof — licensed Florida contractor serving South Tampa, Seminole Heights, Carrollwood & more. Shingle, metal, and tile roofs. FL License #CCC1337380. Free estimates: (813) 595-7663."
  canonical="https://happyroof.com/tampa-roof-replacement"
  ogDescription="Full roof replacement in Tampa FL. Shingle, metal, and tile options. Licensed and insured. 15-year workmanship warranty. Free estimates."
  schema={schema}
>

<style is:inline>
.check-dot{width:20px;height:20px;border-radius:50%;display:flex;align-items:center;justify-content:center;background:rgba(230,168,23,.1);flex-shrink:0;margin-top:.15rem}
    .step-num{width:48px;height:48px;border-radius:14px;display:flex;align-items:center;justify-content:center;background:rgba(230,168,23,.1);font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.25rem;color:#E6A817;flex-shrink:0}
</style>

<!-- HERO -->
<section class="pt-32 pb-20 relative overflow-hidden" style="background:#F5F5F5;border-bottom:1px solid #E5E5E5">
  <div class="hero-photo-bg" style="background-image:url('/Brand%20Assets/Photos/architectural-shingle-roof-tampa-bay.jpg')"></div>
  <div class="hero-photo-overlay"></div>
  <div class="relative z-10 max-w-7xl mx-auto px-5 text-center">
    <p class="sl gp mb-4">Tampa Roof Replacement</p>
    <h1 class="font-display font-black tracking-tightest mb-5" style="font-family:'Barlow Condensed',sans-serif;font-size:clamp(2.5rem,5.5vw,4.5rem);line-height:.92;letter-spacing:-.01em;color:#1A1A1A">
      TAMPA ROOF REPLACEMENT<br/><span class="gt">LICENSED CONTRACTOR</span>
    </h1>
    <p class="max-w-2xl mx-auto" style="color:#555555;font-size:1.05rem;line-height:1.75">
      When it is time to replace your roof in Tampa, Happy Roof delivers a complete tear-off and installation backed by a 15-year workmanship warranty. We are a licensed and insured roofing contractor serving every Tampa neighborhood — from the historic bungalows of Seminole Heights to the waterfront estates along Bayshore Boulevard.
    </p>
    <div class="flex flex-wrap gap-3 justify-center mt-8">
      <a href="/contact" class="btn-t">Get a Free Estimate <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg></a>
      <a href="tel:8135957663" class="btn-o call-tracking-number">Call (813) 595-7663</a>
    </div>
  </div>
</section>

<!-- INFO STRIP -->
<div style="background:#FFFFFF;border-top:2px solid #E6A817;border-bottom:1px solid #E0E0E0;padding:.85rem 0">
  <div class="max-w-7xl mx-auto px-5">
    <div class="flex flex-wrap items-center justify-center gap-x-8 gap-y-2 font-display font-bold text-sm tracking-widest" style="color:#1A1A1A;text-transform:uppercase;font-family:'Barlow Condensed',sans-serif">
      <span>Tampa, FL</span><span style="color:#E6A817">·</span><span>CCC1337380</span><span style="color:#E6A817">·</span><span>HappyRoof.com</span><span style="color:#E6A817">·</span><span style="color:#3B9FD9">(813) 595-7663</span>
    </div>
  </div>
</div>

<!-- WHY ROOF REPLACEMENT IN TAMPA -->
<section class="py-20" style="background:#FFFFFF">
  <div class="max-w-7xl mx-auto px-5">
    <div class="grid lg:grid-cols-2 gap-14 items-start">
      <div>
        <p class="sl gt mb-3">Why Replace Your Roof in Tampa</p>
        <h2 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:clamp(2rem,4vw,3rem);line-height:.95;color:#1A1A1A;letter-spacing:-.01em;margin-bottom:1.5rem">WHY TAMPA HOMEOWNERS CHOOSE A FULL ROOF REPLACEMENT</h2>
        <p style="color:#555555;font-size:1rem;line-height:1.75;margin-bottom:1.5rem">
          Tampa sits at the heart of Hillsborough County where summer temperatures regularly push past 92 degrees, afternoon thunderstorms roll in almost daily from June through September, and hurricane season stretches from June 1 to November 30. That combination of relentless UV exposure, wind-driven rain, and the ever-present threat of tropical storms takes a heavy toll on roofing systems. Homes in neighborhoods like Palma Ceia, Hyde Park, and Davis Islands — many built in the 1920s through 1950s — often have roofs that have reached or exceeded their expected lifespan.
        </p>
        <p style="color:#555555;font-size:1rem;line-height:1.75;margin-bottom:1.5rem">
          A full roof replacement is the most effective way to protect your home against Tampa's weather. Unlike patchwork repairs that only address surface issues, a complete tear-off lets our crews inspect and repair the decking, install modern peel-and-stick underlayment, upgrade flashing around chimneys and skylights, and ensure proper attic ventilation — all of which directly affect how long your new roof will last. Homeowners in New Tampa and Carrollwood who have replaced aging shingle roofs with standing seam metal have reported noticeable drops in monthly cooling costs, thanks to the reflective properties of metal panels.
        </p>
        <p style="color:#555555;font-size:1rem;line-height:1.75;margin-bottom:1.5rem">
          Happy Roof holds Florida Roofing Contractor License #CCC1337380, carries full general liability and workers' compensation insurance, and pulls all required permits with the City of Tampa and Hillsborough County. We also coordinate every inspection from start to final sign-off. Learn more about our full range of services on our <a href="/tampa-roofing" style="color:#3B9FD9;text-decoration:none;font-weight:600">Tampa roofing page</a>.
        </p>
      </div>
      <div class="space-y-4">
        <div class="scard p-6">
          <div class="check"><div class="check-dot"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#E6A817" stroke-width="3"><path d="M20 6L9 17l-5-5"/></svg></div><div><strong style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.05rem">Architectural Shingles</strong><p style="color:#555555;font-size:.9rem;line-height:1.6;margin-top:.25rem">Owens Corning Duration HDZ shingles rated for 130+ MPH winds — the most popular choice for Tampa homes. Available in dozens of color options to complement any architectural style.</p></div></div>
        </div>
        <div class="scard p-6">
          <div class="check"><div class="check-dot"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#E6A817" stroke-width="3"><path d="M20 6L9 17l-5-5"/></svg></div><div><strong style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.05rem">Standing Seam Metal</strong><p style="color:#555555;font-size:.9rem;line-height:1.6;margin-top:.25rem">Panels from Gulf Coast Supply that reflect solar heat, resist corrosion in Tampa's humid air, and last 40 to 60 years with minimal maintenance.</p></div></div>
        </div>
        <div class="scard p-6">
          <div class="check"><div class="check-dot"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#E6A817" stroke-width="3"><path d="M20 6L9 17l-5-5"/></svg></div><div><strong style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.05rem">Concrete & Clay Tile</strong><p style="color:#555555;font-size:.9rem;line-height:1.6;margin-top:.25rem">Ideal for the Mediterranean and Spanish Revival homes found throughout South Tampa, Beach Park, and Bayshore. Extremely durable with a 50+ year lifespan.</p></div></div>
        </div>
        <div class="scard p-6">
          <div class="check"><div class="check-dot"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#E6A817" stroke-width="3"><path d="M20 6L9 17l-5-5"/></svg></div><div><strong style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.05rem">15-Year Workmanship Warranty</strong><p style="color:#555555;font-size:.9rem;line-height:1.6;margin-top:.25rem">Every Tampa roof replacement includes our written 15-year workmanship warranty, plus the manufacturer's material warranty for complete protection.</p></div></div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- WHAT'S INCLUDED -->
<section class="py-20" style="background:#F7F7F7">
  <div class="max-w-7xl mx-auto px-5">
    <div class="text-center mb-14">
      <p class="sl gt mb-3">What's Included</p>
      <h2 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:clamp(2rem,4vw,3rem);line-height:.95;color:#1A1A1A;letter-spacing:-.01em">EVERY TAMPA ROOF REPLACEMENT INCLUDES</h2>
    </div>
    <div class="grid md:grid-cols-3 gap-8">
      <div class="scard p-8">
        <div style="width:52px;height:52px;border-radius:14px;display:flex;align-items:center;justify-content:center;background:rgba(230,168,23,.1);margin-bottom:1rem">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#E6A817" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/></svg>
        </div>
        <h3 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.35rem;color:#1A1A1A;margin-bottom:.75rem">Full Tear-Off & Decking Inspection</h3>
        <p style="color:#555555;font-size:.95rem;line-height:1.7">We remove all existing roofing material down to the decking, inspect every square foot for rot or damage, and replace compromised plywood before any new material goes on.</p>
      </div>
      <div class="scard p-8">
        <div style="width:52px;height:52px;border-radius:14px;display:flex;align-items:center;justify-content:center;background:rgba(230,168,23,.1);margin-bottom:1rem">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#E6A817" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </div>
        <h3 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.35rem;color:#1A1A1A;margin-bottom:.75rem">Premium Underlayment & Flashing</h3>
        <p style="color:#555555;font-size:.95rem;line-height:1.7">Peel-and-stick synthetic underlayment across the entire roof deck, plus new aluminum or galvanized flashing at all penetrations, valleys, and edges — critical for Tampa's heavy rain events.</p>
      </div>
      <div class="scard p-8">
        <div style="width:52px;height:52px;border-radius:14px;display:flex;align-items:center;justify-content:center;background:rgba(230,168,23,.1);margin-bottom:1rem">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#E6A817" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        </div>
        <h3 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.35rem;color:#1A1A1A;margin-bottom:.75rem">Permits, Inspections & Cleanup</h3>
        <p style="color:#555555;font-size:.95rem;line-height:1.7">We pull all City of Tampa and Hillsborough County permits, schedule every inspection, and perform a thorough cleanup including magnetic nail sweeps of your yard and driveway.</p>
      </div>
    </div>
  </div>
</section>

<!-- OUR PROCESS -->
<section class="py-20" style="background:#FFFFFF">
  <div class="max-w-7xl mx-auto px-5">
    <div class="text-center mb-14">
      <p class="sl gt mb-3">How It Works</p>
      <h2 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:clamp(2rem,4vw,3rem);line-height:.95;color:#1A1A1A;letter-spacing:-.01em">OUR 4-STEP REPLACEMENT PROCESS</h2>
    </div>
    <div class="grid md:grid-cols-2 gap-6">
      <div class="scard p-8 flex gap-5">
        <div class="step-num">1</div>
        <div>
          <h3 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.2rem;color:#1A1A1A;margin-bottom:.5rem">Free Roof Inspection</h3>
          <p style="color:#555555;font-size:.95rem;line-height:1.7">We inspect your roof from top to bottom — decking, underlayment, flashing, ventilation, and overall condition. You receive a detailed written estimate with material options, timelines, and transparent pricing.</p>
        </div>
      </div>
      <div class="scard p-8 flex gap-5">
        <div class="step-num">2</div>
        <div>
          <h3 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.2rem;color:#1A1A1A;margin-bottom:.5rem">Material Selection & Permits</h3>
          <p style="color:#555555;font-size:.95rem;line-height:1.7">Choose from shingles, metal, or tile with guidance from our team. We pull permits with the City of Tampa or Hillsborough County, order materials, and schedule your installation date.</p>
        </div>
      </div>
      <div class="scard p-8 flex gap-5">
        <div class="step-num">3</div>
        <div>
          <h3 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.2rem;color:#1A1A1A;margin-bottom:.5rem">Professional Installation</h3>
          <p style="color:#555555;font-size:.95rem;line-height:1.7">Our crew performs the full tear-off, inspects decking, installs new underlayment and flashing, and lays your new roofing system to manufacturer specifications. We protect your landscaping and property throughout.</p>
        </div>
      </div>
      <div class="scard p-8 flex gap-5">
        <div class="step-num">4</div>
        <div>
          <h3 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.2rem;color:#1A1A1A;margin-bottom:.5rem">Final Inspection & Warranty</h3>
          <p style="color:#555555;font-size:.95rem;line-height:1.7">We schedule the county inspection to verify code compliance. Once passed, you receive your 15-year workmanship warranty and manufacturer warranty documentation. We follow up at 30 days and 1 year.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- SERVICE AREA -->
<section class="py-20" style="background:#F7F7F7">
  <div class="max-w-7xl mx-auto px-5">
    <div class="text-center mb-10">
      <p class="sl gt mb-3">Tampa Service Area</p>
      <h2 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:clamp(2rem,4vw,3rem);line-height:.95;color:#1A1A1A;letter-spacing:-.01em;margin-bottom:1rem">TAMPA NEIGHBORHOODS WE SERVE</h2>
      <p style="color:#555555;font-size:1rem;line-height:1.75;max-width:700px;margin:0 auto">Happy Roof provides roof replacement services throughout Tampa and all of Hillsborough County.</p>
    </div>
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-3 max-w-4xl mx-auto">
      <span class="scard px-4 py-3 text-center" style="font-size:.9rem;font-weight:600">South Tampa</span>
      <span class="scard px-4 py-3 text-center" style="font-size:.9rem;font-weight:600">Seminole Heights</span>
      <span class="scard px-4 py-3 text-center" style="font-size:.9rem;font-weight:600">Palma Ceia</span>
      <span class="scard px-4 py-3 text-center" style="font-size:.9rem;font-weight:600">Westshore</span>
      <span class="scard px-4 py-3 text-center" style="font-size:.9rem;font-weight:600">Hyde Park</span>
      <span class="scard px-4 py-3 text-center" style="font-size:.9rem;font-weight:600">Davis Islands</span>
      <span class="scard px-4 py-3 text-center" style="font-size:.9rem;font-weight:600">Carrollwood</span>
      <span class="scard px-4 py-3 text-center" style="font-size:.9rem;font-weight:600">New Tampa</span>
      <span class="scard px-4 py-3 text-center" style="font-size:.9rem;font-weight:600">Town 'n' Country</span>
      <span class="scard px-4 py-3 text-center" style="font-size:.9rem;font-weight:600">Ybor City</span>
      <span class="scard px-4 py-3 text-center" style="font-size:.9rem;font-weight:600">Citrus Park</span>
      <span class="scard px-4 py-3 text-center" style="font-size:.9rem;font-weight:600">Beach Park</span>
      <span class="scard px-4 py-3 text-center" style="font-size:.9rem;font-weight:600">Bayshore</span>
      <span class="scard px-4 py-3 text-center" style="font-size:.9rem;font-weight:600">Westchase</span>
      <span class="scard px-4 py-3 text-center" style="font-size:.9rem;font-weight:600">Riverview</span>
    </div>
  </div>
</section>

<!-- FAQ -->
<section class="py-20" style="background:#FFFFFF">
  <div class="max-w-3xl mx-auto px-5">
    <div class="text-center mb-12">
      <p class="sl gt mb-3">Common Questions</p>
      <h2 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:clamp(2rem,4vw,3rem);line-height:.95;color:#1A1A1A;letter-spacing:-.01em">TAMPA ROOF REPLACEMENT FAQ</h2>
    </div>
    <div class="faq-item">
      <button class="faq-btn" aria-expanded="false" onclick="this.setAttribute('aria-expanded',this.getAttribute('aria-expanded')==='true'?'false':'true');this.nextElementSibling.classList.toggle('open')">
        How much does a roof replacement cost in Tampa?
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#1A1A1A" stroke-width="2.5"><path d="M6 9l6 6 6-6"/></svg>
      </button>
      <div class="faq-answer"><div class="faq-answer-inner">Roof replacement in Tampa typically costs between $8,000 and $25,000 or more, depending on your home's square footage, roof pitch, chosen material (architectural shingles, standing seam metal, or tile), and whether structural repairs are needed. Homes in older neighborhoods like Seminole Heights and Hyde Park sometimes require additional decking work. Call Happy Roof at <a href="tel:8135957663" class="call-tracking-number" style="color:#3B9FD9;text-decoration:none;font-weight:600">(813) 595-7663</a> for a free, no-obligation estimate.</div></div>
    </div>
    <div class="faq-item">
      <button class="faq-btn" aria-expanded="false" onclick="this.setAttribute('aria-expanded',this.getAttribute('aria-expanded')==='true'?'false':'true');this.nextElementSibling.classList.toggle('open')">
        What roofing materials are best for Tampa homes?
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#1A1A1A" stroke-width="2.5"><path d="M6 9l6 6 6-6"/></svg>
      </button>
      <div class="faq-answer"><div class="faq-answer-inner">Tampa's combination of intense UV, tropical storms, and hurricane-force winds requires durable materials. Owens Corning Duration HDZ architectural shingles are rated for 130+ MPH winds and are the most popular choice. Standing seam metal reflects heat and lasts 40-60 years — ideal for waterfront properties along Bayshore Boulevard. Concrete and clay tile suit Mediterranean-style homes common in Palma Ceia and Beach Park.</div></div>
    </div>
    <div class="faq-item">
      <button class="faq-btn" aria-expanded="false" onclick="this.setAttribute('aria-expanded',this.getAttribute('aria-expanded')==='true'?'false':'true');this.nextElementSibling.classList.toggle('open')">
        How long does a full roof replacement take in Tampa?
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#1A1A1A" stroke-width="2.5"><path d="M6 9l6 6 6-6"/></svg>
      </button>
      <div class="faq-answer"><div class="faq-answer-inner">Most shingle roof replacements in Tampa are completed in 1 to 3 days. Metal roofs typically take 3 to 5 days, and tile roofs may require 5 to 7 days depending on size and complexity. Tampa's afternoon thunderstorms during summer can occasionally cause brief delays, but our crews plan around weather forecasts and keep you informed throughout.</div></div>
    </div>
    <div class="faq-item">
      <button class="faq-btn" aria-expanded="false" onclick="this.setAttribute('aria-expanded',this.getAttribute('aria-expanded')==='true'?'false':'true');this.nextElementSibling.classList.toggle('open')">
        Does Happy Roof handle permits for Tampa roof replacements?
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#1A1A1A" stroke-width="2.5"><path d="M6 9l6 6 6-6"/></svg>
      </button>
      <div class="faq-answer"><div class="faq-answer-inner">Yes. We handle the entire permitting process with the City of Tampa and Hillsborough County building departments. We pull the permit, schedule and attend all required inspections, and ensure your new roof meets current Florida Building Code requirements. You never have to visit a government office or coordinate inspectors yourself.</div></div>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="cta-grad relative overflow-hidden py-20">
  <div class="relative z-10 max-w-3xl mx-auto px-5 text-center">
    <h2 class="font-display font-black tracking-tightest mb-4" style="font-family:'Barlow Condensed',sans-serif;font-size:clamp(2.5rem,5vw,4.5rem);line-height:.92;letter-spacing:-.01em">
      READY FOR A NEW ROOF<span style="color:#F0C040">?</span>
    </h2>
