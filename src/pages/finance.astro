---

<BaseLayout
  title="Roof Financing Options Tampa Bay | $0 Down | Happy Roof"
  description="Finance your new roof in Tampa Bay with flexible options including 0% interest. Check your rate in 60 seconds — no obligation!"
  canonical="https://happyroof.com/finance"
  ogTitle="Roof Financing Tampa Bay | 0% Interest | Happy Roof"
  ogDescription="Finance your Tampa Bay roof replacement with 0% interest options. Check your rate in 60 seconds through our Enhancify partnership. No obligation."
  activePage="finance"
  schema={schema}
>

<style is:inline>
    .gfin{background:linear-gradient(135deg,#68BA62 0%,#1C418C 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
    .white-section{background:#F5F5F5;color:#1A1A1A}
    .feat-card{background:#FFFFFF;border:1px dashed #E0E0E0;border-radius:16px;padding:1.5rem;transition:border-color .2s,transform .25s cubic-bezier(.34,1.56,.64,1)}
    .feat-card:hover{border-color:rgba(104,186,98,.25);transform:translateY(-4px)}
    .enhancify-wrap{background:#fff;border-radius:20px;box-shadow:0 32px 80px -16px rgba(0,0,0,.4),0 8px 24px -8px rgba(0,0,0,.3);min-height:600px}
</style>

<!-- HERO -->
<section class="white-section pt-32 pb-16 relative overflow-hidden" style="border-bottom:1px solid #E5E5E5">
  <!-- Hero background photo -->
  <div class="hero-photo-bg" style="background-image:url('/Brand%20Assets/Photos/architectural-shingle-roof-tampa-bay.jpg')"></div>
  <div class="hero-photo-overlay"></div>
  <div class="relative z-10 max-w-5xl mx-auto px-5 text-center">
    <!-- Co-brand lockup -->
    <div class="flex items-center justify-center gap-5 mb-8 flex-wrap">
      <img src="/Brand%20Assets/Happy Roof Logo.png" alt="Happy Roof" style="height:52px;width:auto" />
      <div style="width:1px;height:40px;background:#D0D0D0"></div>
      <!-- Enhancify wordmark -->
      <div style="display:flex;flex-direction:column;align-items:flex-start">
        <span style="font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:1.6rem;letter-spacing:-.02em;background:linear-gradient(135deg,#68BA62,#1C418C);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;line-height:1">ENHANCIFY</span>
        <span style="font-size:.6rem;letter-spacing:.18em;text-transform:uppercase;color:#888;margin-top:.1rem">Financing Partner</span>
      </div>
    </div>
    <p class="sl mb-3" style="color:#888">Roofing Financing</p>
    <h1 class="font-display font-black mb-5" style="font-family:'Barlow Condensed',sans-serif;font-size:clamp(2.8rem,7vw,5.2rem);line-height:.9;letter-spacing:-.01em;color:#1A1A1A">
      DON'T LET BUDGET<br/>STAND BETWEEN YOU<br/><span class="gfin">AND A SAFE ROOF.</span>
    </h1>
    <p style="font-size:1.1rem;color:#555555;line-height:1.75;max-width:580px;margin:0 auto 2rem">
      Happy Roof has partnered with Enhancify to offer fast, flexible financing — so you can protect your home today and pay over time. Checking your rate takes 60 seconds and won't affect your credit score.
    </p>
    <div class="flex flex-wrap gap-3 justify-center">
      <a href="#apply" class="btn-fin">Check My Rate — It's Free <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg></a>
      <a href="/contact" class="btn-p" style="background:transparent;border:1.5px solid rgba(0,0,0,.2);color:#1A1A1A;box-shadow:none">Get a Free Estimate First</a>
    </div>
  </div>
</section>

<!-- Trust Signals -->
<section style="background:#F7F7F7;border-top:1px solid #E0E0E0;border-bottom:1px solid #E0E0E0;padding:1.5rem 0">
  <div class="max-w-7xl mx-auto px-5">
    <div style="display:flex;flex-wrap:wrap;align-items:center;justify-content:center;gap:2rem 3rem">
      <div style="display:flex;align-items:center;gap:.5rem"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#E6A817" stroke-width="2"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg><span style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:.85rem;color:#1A1A1A;letter-spacing:.02em">OWENS CORNING INSTALLER</span></div>
      <div style="display:flex;align-items:center;gap:.5rem"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#3B9FD9" stroke-width="2"><path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg><span style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:.85rem;color:#1A1A1A;letter-spacing:.02em">FL LICENSE #CCC1337380</span></div>
      <div style="display:flex;align-items:center;gap:.5rem"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#E6A817" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg><span style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:.85rem;color:#1A1A1A;letter-spacing:.02em">FULLY INSURED & BONDED</span></div>
      <div style="display:flex;align-items:center;gap:.5rem"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#3B9FD9" stroke-width="2"><path d="M12 2v4m0 12v4M4.93 4.93l2.83 2.83m8.48 8.48l2.83 2.83M2 12h4m12 0h4M4.93 19.07l2.83-2.83m8.48-8.48l2.83-2.83"/></svg><span style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:.85rem;color:#1A1A1A;letter-spacing:.02em">15-YEAR WARRANTY</span></div>
    </div>
  </div>
</section>


<!-- WHY FINANCE -->
<section style="background:#FFFFFF;padding:5rem 0">
  <div class="max-w-6xl mx-auto px-5">
    <div class="text-center mb-12">
      <p class="sl gt mb-3">The Smart Way to Roof</p>
      <h2 class="font-display font-black" style="font-family:'Barlow Condensed',sans-serif;font-size:clamp(2.2rem,4vw,3.4rem);line-height:.95;letter-spacing:-.01em">
        WHY HOMEOWNERS CHOOSE TO FINANCE
      </h2>
    </div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
      <div class="feat-card">
        <div style="width:44px;height:44px;border-radius:12px;background:linear-gradient(135deg,rgba(104,186,98,.2),rgba(104,186,98,.08));display:flex;align-items:center;justify-content:center;margin-bottom:1rem">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#68BA62" stroke-width="2"><path d="M13 2 3 14h9l-1 8 10-12h-9l1-8z"/></svg>
        </div>
        <h3 class="font-display font-bold mb-2" style="font-family:'Barlow Condensed',sans-serif;font-size:1.2rem;color:#1A1A1A">Don't Delay Repairs</h3>
        <p style="color:#555555;font-size:.88rem;line-height:1.65">A small leak left untreated becomes a major structural problem. Financing lets you address damage now — before it multiplies in cost.</p>
      </div>
      <div class="feat-card">
        <div style="width:44px;height:44px;border-radius:12px;background:linear-gradient(135deg,rgba(28,65,140,.25),rgba(28,65,140,.1));display:flex;align-items:center;justify-content:center;margin-bottom:1rem">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#5B8CE0" stroke-width="2"><rect x="2" y="5" width="20" height="14" rx="2"/><path d="M2 10h20"/></svg>
        </div>
        <h3 class="font-display font-bold mb-2" style="font-family:'Barlow Condensed',sans-serif;font-size:1.2rem;color:#1A1A1A">Preserve Your Cash</h3>
        <p style="color:#555555;font-size:.88rem;line-height:1.65">A new roof is one of the biggest home investments you'll make. Spreading payments over time lets you keep your savings intact for other needs.</p>
      </div>
      <div class="feat-card">
        <div style="width:44px;height:44px;border-radius:12px;background:linear-gradient(135deg,rgba(230,168,23,.2),rgba(230,168,23,.08));display:flex;align-items:center;justify-content:center;margin-bottom:1rem">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#F0C040" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        </div>
        <h3 class="font-display font-bold mb-2" style="font-family:'Barlow Condensed',sans-serif;font-size:1.2rem;color:#1A1A1A">Upgrade, Don't Compromise</h3>
        <p style="color:#555555;font-size:.88rem;line-height:1.65">Financing lets you choose the best material — premium shingles, metal, or tile — instead of settling for the cheapest option that won't last.</p>
      </div>
      <div class="feat-card">
        <div style="width:44px;height:44px;border-radius:12px;background:linear-gradient(135deg,rgba(59,159,217,.15),rgba(59,159,217,.06));display:flex;align-items:center;justify-content:center;margin-bottom:1rem">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#3B9FD9" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>
        </div>
        <h3 class="font-display font-bold mb-2" style="font-family:'Barlow Condensed',sans-serif;font-size:1.2rem;color:#1A1A1A">Fast Approval</h3>
        <p style="color:#555555;font-size:.88rem;line-height:1.65">Enhancify's application takes 60 seconds. Most decisions come back in minutes — so there's no waiting around when your roof can't wait.</p>
      </div>
      <div class="feat-card">
        <div style="width:44px;height:44px;border-radius:12px;background:linear-gradient(135deg,rgba(104,186,98,.2),rgba(104,186,98,.08));display:flex;align-items:center;justify-content:center;margin-bottom:1rem">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#68BA62" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </div>
        <h3 class="font-display font-bold mb-2" style="font-family:'Barlow Condensed',sans-serif;font-size:1.2rem;color:#1A1A1A">Soft Credit Pull</h3>
        <p style="color:#555555;font-size:.88rem;line-height:1.65">Checking your rate doesn't affect your credit score. You can explore your options risk-free before committing to anything.</p>
      </div>
      <div class="feat-card">
        <div style="width:44px;height:44px;border-radius:12px;background:linear-gradient(135deg,rgba(28,65,140,.25),rgba(28,65,140,.1));display:flex;align-items:center;justify-content:center;margin-bottom:1rem">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#5B8CE0" stroke-width="2"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
        </div>
        <h3 class="font-display font-bold mb-2" style="font-family:'Barlow Condensed',sans-serif;font-size:1.2rem;color:#1A1A1A">Flexible Terms</h3>
        <p style="color:#555555;font-size:.88rem;line-height:1.65">Choose a monthly payment that works for your budget. Enhancify works with multiple lenders to find you competitive rates and terms.</p>
      </div>
    </div>
  </div>
</section>

<!-- HOW IT WORKS -->
<section class="white-section" style="padding:5rem 0;border-top:1px solid #E5E5E5">
  <div class="max-w-4xl mx-auto px-5">
    <div class="text-center mb-12">
      <p class="sl mb-3" style="color:#888">Simple Process</p>
      <h2 class="font-display font-black" style="font-family:'Barlow Condensed',sans-serif;font-size:clamp(2.2rem,4vw,3.2rem);line-height:.95;letter-spacing:-.01em;color:#1A1A1A">HOW IT WORKS</h2>
    </div>
    <div class="grid sm:grid-cols-3 gap-8">
      <div class="text-center">
        <div style="width:60px;height:60px;border-radius:50%;background:linear-gradient(135deg,#68BA62,#1C418C);display:flex;align-items:center;justify-content:center;margin:0 auto 1.25rem;box-shadow:0 8px 24px -4px rgba(28,65,140,.35)">
          <span style="font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:1.4rem;color:#fff">1</span>
        </div>
        <h3 class="font-display font-bold mb-2" style="font-family:'Barlow Condensed',sans-serif;font-size:1.2rem;color:#1A1A1A">Check Your Rate</h3>
        <p style="font-size:.88rem;color:#555555;line-height:1.65">Fill out the form below. It takes about 60 seconds and uses a soft credit pull — no impact to your score.</p>
      </div>
      <div class="text-center">
        <div style="width:60px;height:60px;border-radius:50%;background:linear-gradient(135deg,#68BA62,#1C418C);display:flex;align-items:center;justify-content:center;margin:0 auto 1.25rem;box-shadow:0 8px 24px -4px rgba(28,65,140,.35)">
          <span style="font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:1.4rem;color:#fff">2</span>
        </div>
        <h3 class="font-display font-bold mb-2" style="font-family:'Barlow Condensed',sans-serif;font-size:1.2rem;color:#1A1A1A">Choose Your Offer</h3>
        <p style="font-size:.88rem;color:#555555;line-height:1.65">Review loan options from multiple lenders and pick the monthly payment and term that fits your budget.</p>
      </div>
      <div class="text-center">
        <div style="width:60px;height:60px;border-radius:50%;background:linear-gradient(135deg,#68BA62,#1C418C);display:flex;align-items:center;justify-content:center;margin:0 auto 1.25rem;box-shadow:0 8px 24px -4px rgba(28,65,140,.35)">
          <span style="font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:1.4rem;color:#fff">3</span>
        </div>
        <h3 class="font-display font-bold mb-2" style="font-family:'Barlow Condensed',sans-serif;font-size:1.2rem;color:#1A1A1A">Get Your Roof Done</h3>
        <p style="font-size:.88rem;color:#555555;line-height:1.65">Once approved, Happy Roof schedules your project. Funds go directly to us — you just make your monthly payments.</p>
      </div>
    </div>
  </div>
</section>

<!-- PARTNER CALLOUT -->
<div style="background:#F7F7F7;border-top:1px solid #E0E0E0;border-bottom:1px solid #1A1A1A;padding:2.5rem 0">
  <div class="max-w-5xl mx-auto px-5">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-6">
      <div class="flex items-center gap-5 flex-wrap justify-center sm:justify-start">
        <img src="/Brand%20Assets/Happy Roof Logo_Alt.png" alt="Happy Roof" style="height:40px;width:auto" />
        <div style="width:1px;height:32px;background:#E0E0E0"></div>
        <div>
          <span style="font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:1.3rem;letter-spacing:-.02em;background:linear-gradient(135deg,#68BA62,#1C418C);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text">ENHANCIFY</span>
          <p style="color:#888888;font-size:.7rem;letter-spacing:.1em;text-transform:uppercase;margin-top:.1rem">Official Financing Partner</p>
        </div>
      </div>
      <div class="flex flex-wrap gap-4 text-center sm:text-left">
        <div>
          <p class="font-display font-black" style="font-family:'Barlow Condensed',sans-serif;font-size:1.8rem;line-height:1;background:linear-gradient(135deg,#68BA62,#4A9E44);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text">60s</p>
          <p style="color:#555555;font-size:.75rem;margin-top:.2rem">To apply</p>
        </div>
        <div style="width:1px;background:#222;align-self:stretch"></div>
        <div>
          <p class="font-display font-black" style="font-family:'Barlow Condensed',sans-serif;font-size:1.8rem;line-height:1;background:linear-gradient(135deg,#68BA62,#1C418C);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text">0</p>
          <p style="color:#555555;font-size:.75rem;margin-top:.2rem">Credit score impact</p>
        </div>
        <div style="width:1px;background:#222;align-self:stretch"></div>
        <div>
          <p class="font-display font-black" style="font-family:'Barlow Condensed',sans-serif;font-size:1.8rem;line-height:1;background:linear-gradient(135deg,#5B8CE0,#1C418C);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text">Many</p>
          <p style="color:#555555;font-size:.75rem;margin-top:.2rem">Lender options</p>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- ENHANCIFY WIDGET -->
<section id="apply" style="background:#FFFFFF;padding:5rem 0 3rem">
  <!-- Heading stays in constrained container -->
  <div class="max-w-2xl mx-auto px-5 text-center mb-10">
    <p class="sl mb-3" style="color:#555">Powered by Enhancify</p>
    <h2 class="font-display font-black" style="font-family:'Barlow Condensed',sans-serif;font-size:clamp(2.2rem,4vw,3.2rem);line-height:.95;letter-spacing:-.01em">
      CHECK YOUR RATE<br/><span class="gfin">IN 60 SECONDS.</span>
    </h2>
    <p style="color:#555555;font-size:.95rem;margin-top:.75rem">No obligation. Soft credit check only. Offered through our partner Enhancify.</p>
  </div>
  <!-- Widget loaded in iframe to prevent it from modifying parent page DOM -->
  <div style="max-width:1400px;margin:0 auto;padding:0 1rem">
    <div class="enhancify-wrap">
      <iframe id="enhancify-frame" style="width:100%;border:none;min-height:700px;border-radius:16px" scrolling="no"></iframe>
      <script is:inline>
      (function(){
        var frame = document.getElementById('enhancify-frame');
