<script is:inline>
function toggleFaq(el) {
  const isOpen = el.classList.contains('open');
  document.querySelectorAll('.faq-item').forEach(i => i.classList.remove('open'));
  if (!isOpen) el.classList.add('open');
}

// Guard: re-show nav after any 3rd-party script (Enhancify) might hide it
(function guardNav() {
  function fixNav() {
    var nav = document.querySelector('.nav-wrap');
    var bar = document.getElementById('give-back-bar');
    if (nav) { nav.style.display = 'block'; nav.style.visibility = 'visible'; nav.style.opacity = '1'; }
    if (bar) { bar.style.display = 'flex'; bar.style.visibility = 'visible'; }
  }
  fixNav();
  setTimeout(fixNav, 500);
  setTimeout(fixNav, 1500);
  setTimeout(fixNav, 3000);
  // Also watch for DOM changes that might hide the nav
  var observer = new MutationObserver(fixNav);
  var nav = document.querySelector('.nav-wrap');
  if (nav) observer.observe(nav, { attributes: true, attributeFilter: ['style', 'class'] });
  var bar = document.getElementById('give-back-bar');
  if (bar) observer.observe(bar, { attributes: true, attributeFilter: ['style', 'class'] });
})();
</script>

