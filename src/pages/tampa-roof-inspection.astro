---
import BaseLayout from '../layouts/BaseLayout.astro';

const schema = `[{
    "@context": "https://schema.org",
    "@type": ["LocalBusiness", "RoofingContractor"],
    "name": "Happy Roof LLC",
    "url": "https://happyroof.com",
    "telephone": "+1-813-595-7663",
    "email": "info@happyroof.com",
    "description": "Free roof inspections in Tampa FL. Comprehensive assessment of shingle, metal, and tile roofs. FL License #CCC1337380.",
    "image": "/Brand%20Assets/Happy%20Roof%20Logo.jpeg",
    "logo": "/Brand%20Assets/Happy%20Roof%20Logo.jpeg",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "141 Stevens Ave #12",
      "addressLocality": "Oldsmar",
      "addressRegion": "FL",
      "postalCode": "34677",
      "addressCountry": "US"
    },
    "areaServed": {
      "@type": "City",
      "name": "Tampa",
      "containedInPlace": { "@type": "State", "name": "Florida" }
    },
    "hasCredential": "Florida Roofing Contractor License #CCC1337380",
    "dateModified": "2026-04-10"
  },{
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Is the roof inspection really free?",
        "acceptedAnswer": { "@type": "Answer", "text": "Yes. It is completely free with no obligation. We do not require you to purchase any services after the inspection. We believe that earning your trust with an honest assessment is the best way to build a lasting relationship with Tampa homeowners." }
      },
      {
        "@type": "Question",
        "name": "How long does a roof inspection take?",
        "acceptedAnswer": { "@type": "Answer", "text": "Most roof inspections in Tampa take between 45 and 60 minutes, depending on your roof's size, complexity, and accessibility. Multi-story homes or tile roofs may take slightly longer. We are thorough. We would rather spend extra time and catch everything than rush through." }
      },
      {
        "@type": "Question",
        "name": "What happens if you find damage during the inspection?",
        "acceptedAnswer": { "@type": "Answer", "text": "We document everything with photos and present our findings to you. If repairs or replacement are needed, we provide a written estimate with options. There is absolutely no pressure, and the decision is yours, and we are happy to answer questions or provide the report for a second opinion." }
      },
      {
        "@type": "Question",
        "name": "When should I schedule a roof inspection in Tampa?",
        "acceptedAnswer": { "@type": "Answer", "text": "We recommend scheduling an inspection if your roof is over 10 years old, after any major storm, before buying or selling a home, or if you notice any signs of damage like water stains, missing shingles, or granules in your gutters. Many Tampa homeowners schedule an annual inspection before hurricane season starts in June." }
      }
    ]
  }]`;
---

<BaseLayout
  title="Free Roof Inspection Tampa | Schedule Today | Happy Roof"
  description="Free roof inspection in Tampa FL by Happy Roof. Comprehensive 25-point inspection of shingle, metal & tile roofs. No obligation. FL License #CCC1337380. Schedule today: (813) 595-7663."
  canonical="https://happyroof.com/tampa-roof-inspection"
  schema={schema}
>

<style is:inline>
.check-dot{width:20px;height:20px;border-radius:50%;display:flex;align-items:center;justify-content:center;background:rgba(230,168,23,.1);flex-shrink:0;margin-top:.15rem}
    .step-num{width:48px;height:48px;border-radius:14px;display:flex;align-items:center;justify-content:center;background:rgba(230,168,23,.1);font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.25rem;color:#E6A817;flex-shrink:0}
</style>

<!-- HERO -->
<section class="pt-32 pb-20 relative overflow-hidden" style="background:#F5F5F5;border-bottom:1px solid #E5E5E5">
  <div class="hero-photo-bg" style="background-image:url('/Brand%20Assets/Photos/commercial-tpo-roof-tampa.jpg')"></div>
  <div class="hero-photo-overlay"></div>
  <div class="relative z-10 max-w-7xl mx-auto px-5 text-center">
    <p class="sl gp mb-4">Tampa Roof Inspection</p>
    <h1 class="font-display font-black tracking-tightest mb-5" style="font-family:'Barlow Condensed',sans-serif;font-size:clamp(2.5rem,5.5vw,4.5rem);line-height:.92;letter-spacing:-.01em;color:#1A1A1A">
      FREE ROOF INSPECTION<br/><span class="gt">TAMPA, FLORIDA</span>
    </h1>
    <p class="max-w-2xl mx-auto" style="color:#555555;font-size:1.05rem;line-height:1.75">
      Schedule a free, no-obligation roof inspection with Happy Roof in Tampa. Our licensed inspectors check every component of your roofing system, including decking, underlayment, flashing, ventilation, and surface material, so you know exactly where your roof stands before making any decisions.
    </p>
    <div class="flex flex-wrap gap-3 justify-center mt-8">
      <a href="/contact" class="btn-t">Get a Free Estimate <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg></a>
      <a href="tel:8135957663" class="btn-o call-tracking-number">Call (813) 595-7663</a>
    </div>
  </div>
</section>

<!-- INFO STRIP -->
<div style="background:#FFFFFF;border-top:2px solid #E6A817;border-bottom:1px solid #E0E0E0;padding:.85rem 0">
  <div class="max-w-7xl mx-auto px-5">
    <div class="flex flex-wrap items-center justify-center gap-x-8 gap-y-2 font-display font-bold text-sm tracking-widest" style="color:#1A1A1A;text-transform:uppercase;font-family:'Barlow Condensed',sans-serif">
      <span>Tampa, FL</span><span style="color:#E6A817">·</span><span>CCC1337380</span><span style="color:#E6A817">·</span><span>HappyRoof.com</span><span style="color:#E6A817">·</span><span style="color:#3B9FD9">(813) 595-7663</span>
    </div>
  </div>
</div>

<!-- WHY SECTION -->
<section class="py-20" style="background:#FFFFFF">
  <div class="max-w-7xl mx-auto px-5">
    <div class="grid lg:grid-cols-2 gap-14 items-start">
      <div>
        <p class="sl gt mb-3">Why Get a Free Inspection</p>
        <h2 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:clamp(2rem,4vw,3rem);line-height:.95;color:#1A1A1A;letter-spacing:-.01em;margin-bottom:1.5rem">WHY TAMPA HOMEOWNERS SCHEDULE FREE ROOF INSPECTIONS</h2>
        <p style="color:#555555;font-size:1rem;line-height:1.75;margin-bottom:1.5rem">Most Tampa homeowners do not think about their roof until something goes wrong - a water stain appears on the ceiling, shingles are scattered across the yard after a storm, or an insurance renewal notice demands a roof condition report. By then, minor issues may have already become expensive problems. A proactive roof inspection catches deterioration early, when repairs are still affordable and a full replacement can be planned on your timeline rather than in an emergency.</p>
        <p style="color:#555555;font-size:1rem;line-height:1.75;margin-bottom:1.5rem">Tampa's climate is uniquely harsh on roofing systems. The city averages over 100 days of measurable rainfall per year, temperatures routinely exceed 90 degrees for months on end, and the area sits in one of the highest-risk hurricane corridors in the United States. Roofs in neighborhoods like Channelside and Harbour Island face additional salt air exposure from Tampa Bay. Homes in Seminole Heights and Ybor City, many built before modern building codes, often have aging roofing systems that benefit from regular professional assessment.</p>
        <p style="color:#555555;font-size:1rem;line-height:1.75;margin-bottom:1.5rem">Happy Roof provides comprehensive, genuinely free roof inspections throughout Tampa and Hillsborough County. There is no sales pitch attached - we inspect your roof, document our findings with photos, and give you an honest report. If your roof is in good shape, we tell you. If it needs attention, we explain your options and provide a written estimate. Learn more on our <a href="/tampa-roofing" style="color:#3B9FD9;text-decoration:none;font-weight:600">Tampa roofing page</a>.</p>
      </div>
      <div class="space-y-4">
        <div class="scard p-6">
          <div class="check"><div class="check-dot"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#E6A817" stroke-width="3"><path d="M20 6L9 17l-5-5"/></svg></div><div><strong style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.05rem">Complete 25-Point Inspection</strong><p style="color:#555555;font-size:.9rem;line-height:1.6;margin-top:.25rem">We check every component: shingles or tiles, flashing at all penetrations, ridge caps, drip edge, gutters, soffit and fascia, attic ventilation, and visible decking condition.</p></div></div>
        </div>
        <div class="scard p-6">
          <div class="check"><div class="check-dot"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#E6A817" stroke-width="3"><path d="M20 6L9 17l-5-5"/></svg></div><div><strong style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.05rem">Photo Documentation</strong><p style="color:#555555;font-size:.9rem;line-height:1.6;margin-top:.25rem">Every finding is documented with high-resolution photos so you can see exactly what we see - no guesswork, no vague descriptions.</p></div></div>
        </div>
        <div class="scard p-6">
          <div class="check"><div class="check-dot"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#E6A817" stroke-width="3"><path d="M20 6L9 17l-5-5"/></svg></div><div><strong style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.05rem">Written Report & Estimate</strong><p style="color:#555555;font-size:.9rem;line-height:1.6;margin-top:.25rem">You receive a clear written report with our findings and, if any work is needed, a transparent estimate with material options and pricing.</p></div></div>
        </div>
        <div class="scard p-6">
          <div class="check"><div class="check-dot"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#E6A817" stroke-width="3"><path d="M20 6L9 17l-5-5"/></svg></div><div><strong style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.05rem">No Obligation Whatsoever</strong><p style="color:#555555;font-size:.9rem;line-height:1.6;margin-top:.25rem">Our inspection is completely free with zero pressure. If your roof is fine, we will tell you. We earn your trust by being honest, not by inventing problems.</p></div></div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- WHAT'S INCLUDED / COMMON REPAIRS / WHAT WE CHECK -->
<section class="py-20" style="background:#F7F7F7">
  <div class="max-w-7xl mx-auto px-5">
    <div class="text-center mb-14">
      <p class="sl gt mb-3">What We Check</p>
      <h2 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:clamp(2rem,4vw,3rem);line-height:.95;color:#1A1A1A;letter-spacing:-.01em">WHAT'S INCLUDED IN A TAMPA ROOF INSPECTION</h2>
    </div>
    <div class="grid md:grid-cols-3 gap-8">
      <div class="scard p-8">
        <div style="width:52px;height:52px;border-radius:14px;display:flex;align-items:center;justify-content:center;background:rgba(230,168,23,.1);margin-bottom:1rem">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#E6A817" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        </div>
        <h3 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.35rem;color:#1A1A1A;margin-bottom:.75rem">Surface Material Condition</h3>
        <p style="color:#555555;font-size:.95rem;line-height:1.7">We assess every square foot of your roof's surface - checking for cracked, curling, or missing shingles, broken tiles, rust on metal panels, and signs of granule loss that indicate aging.</p>
      </div>
      <div class="scard p-8">
        <div style="width:52px;height:52px;border-radius:14px;display:flex;align-items:center;justify-content:center;background:rgba(230,168,23,.1);margin-bottom:1rem">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#E6A817" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        </div>
        <h3 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.35rem;color:#1A1A1A;margin-bottom:.75rem">Flashing, Seals & Penetrations</h3>
        <p style="color:#555555;font-size:.95rem;line-height:1.7">Roof leaks in Tampa most often start at penetrations. We inspect flashing around chimneys, skylights, vents, and pipe boots for deterioration, gaps, or improper installation.</p>
      </div>
      <div class="scard p-8">
        <div style="width:52px;height:52px;border-radius:14px;display:flex;align-items:center;justify-content:center;background:rgba(230,168,23,.1);margin-bottom:1rem">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#E6A817" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        </div>
        <h3 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.35rem;color:#1A1A1A;margin-bottom:.75rem">Ventilation & Structural Signs</h3>
        <p style="color:#555555;font-size:.95rem;line-height:1.7">Proper attic ventilation is critical in Tampa's heat. We check ridge vents, soffit vents, and look for signs of inadequate airflow like moisture buildup or decking deterioration visible from the attic.</p>
      </div>
    </div>
  </div>
</section>

<!-- OUR PROCESS -->
<section class="py-20" style="background:#FFFFFF">
  <div class="max-w-7xl mx-auto px-5">
    <div class="text-center mb-14">
      <p class="sl gt mb-3">How It Works</p>
      <h2 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:clamp(2rem,4vw,3rem);line-height:.95;color:#1A1A1A;letter-spacing:-.01em">OUR INSPECTION PROCESS</h2>
    </div>
    <div class="grid md:grid-cols-2 gap-6">
      <div class="scard p-8 flex gap-5">
        <div class="step-num">1</div>
        <div>
          <h3 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.2rem;color:#1A1A1A;margin-bottom:.5rem">Schedule Your Inspection</h3>
          <p style="color:#555555;font-size:.95rem;line-height:1.7">Call us at (813) 595-7663 or request an appointment online. We will schedule a time that works for you, and inspections typically take 45 to 60 minutes.</p>
        </div>
      </div>
      <div class="scard p-8 flex gap-5">
        <div class="step-num">2</div>
        <div>
          <h3 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.2rem;color:#1A1A1A;margin-bottom:.5rem">On-Site Assessment</h3>
          <p style="color:#555555;font-size:.95rem;line-height:1.7">Our licensed inspector examines your entire roofing system from the surface down to the attic space, documenting findings with photos along the way.</p>
        </div>
      </div>
      <div class="scard p-8 flex gap-5">
        <div class="step-num">3</div>
        <div>
          <h3 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.2rem;color:#1A1A1A;margin-bottom:.5rem">Review Findings Together</h3>
          <p style="color:#555555;font-size:.95rem;line-height:1.7">We walk you through our findings in plain language - what is in good condition, what needs attention now, and what to monitor over time.</p>
        </div>
      </div>
      <div class="scard p-8 flex gap-5">
        <div class="step-num">4</div>
        <div>
          <h3 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.2rem;color:#1A1A1A;margin-bottom:.5rem">Receive Your Report</h3>
          <p style="color:#555555;font-size:.95rem;line-height:1.7">You get a written report with photos you can keep for your records, share with your insurance company, or use to plan future maintenance or replacement.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- SERVICE AREA -->
<section class="py-20" style="background:#F7F7F7">
  <div class="max-w-7xl mx-auto px-5">
    <div class="text-center mb-10">
      <p class="sl gt mb-3">Tampa Service Area</p>
      <h2 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:clamp(2rem,4vw,3rem);line-height:.95;color:#1A1A1A;letter-spacing:-.01em;margin-bottom:1rem">TAMPA NEIGHBORHOODS WE SERVE</h2>
      <p style="color:#555555;font-size:1rem;line-height:1.75;max-width:700px;margin:0 auto">Happy Roof provides free roof inspections throughout Tampa and all of Hillsborough County.</p>
    </div>
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-3 max-w-4xl mx-auto">
      <span class="scard px-4 py-3 text-center" style="font-size:.9rem;font-weight:600">South Tampa</span>
      <span class="scard px-4 py-3 text-center" style="font-size:.9rem;font-weight:600">Seminole Heights</span>
      <span class="scard px-4 py-3 text-center" style="font-size:.9rem;font-weight:600">Palma Ceia</span>
      <span class="scard px-4 py-3 text-center" style="font-size:.9rem;font-weight:600">Westshore</span>
      <span class="scard px-4 py-3 text-center" style="font-size:.9rem;font-weight:600">Hyde Park</span>
      <span class="scard px-4 py-3 text-center" style="font-size:.9rem;font-weight:600">Davis Islands</span>
      <span class="scard px-4 py-3 text-center" style="font-size:.9rem;font-weight:600">Carrollwood</span>
      <span class="scard px-4 py-3 text-center" style="font-size:.9rem;font-weight:600">New Tampa</span>
      <span class="scard px-4 py-3 text-center" style="font-size:.9rem;font-weight:600">Town 'n' Country</span>
      <span class="scard px-4 py-3 text-center" style="font-size:.9rem;font-weight:600">Ybor City</span>
      <span class="scard px-4 py-3 text-center" style="font-size:.9rem;font-weight:600">Citrus Park</span>
      <span class="scard px-4 py-3 text-center" style="font-size:.9rem;font-weight:600">Beach Park</span>
      <span class="scard px-4 py-3 text-center" style="font-size:.9rem;font-weight:600">Bayshore</span>
      <span class="scard px-4 py-3 text-center" style="font-size:.9rem;font-weight:600">Westchase</span>
      <span class="scard px-4 py-3 text-center" style="font-size:.9rem;font-weight:600">Riverview</span>
    </div>
  </div>
</section>

<!-- FAQ -->
<section class="py-20" style="background:#FFFFFF">
  <div class="max-w-3xl mx-auto px-5">
    <div class="text-center mb-12">
      <p class="sl gt mb-3">Common Questions</p>
      <h2 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:clamp(2rem,4vw,3rem);line-height:.95;color:#1A1A1A;letter-spacing:-.01em">TAMPA ROOF INSPECTION FAQ</h2>
    </div>
    <div class="faq-item">
      <button class="faq-btn" aria-expanded="false" onclick="this.setAttribute('aria-expanded',this.getAttribute('aria-expanded')==='true'?'false':'true');this.nextElementSibling.classList.toggle('open')">
        Is the roof inspection really free?
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#1A1A1A" stroke-width="2.5"><path d="M6 9l6 6 6-6"/></svg>
      </button>
      <div class="faq-answer"><div class="faq-answer-inner">Yes. It is completely free with no obligation. We do not require you to purchase any services after the inspection. We believe that earning your trust with an honest assessment is the best way to build a lasting relationship with Tampa homeowners.</div></div>
    </div>
    <div class="faq-item">
      <button class="faq-btn" aria-expanded="false" onclick="this.setAttribute('aria-expanded',this.getAttribute('aria-expanded')==='true'?'false':'true');this.nextElementSibling.classList.toggle('open')">
        How long does a roof inspection take?
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#1A1A1A" stroke-width="2.5"><path d="M6 9l6 6 6-6"/></svg>
      </button>
      <div class="faq-answer"><div class="faq-answer-inner">Most roof inspections in Tampa take between 45 and 60 minutes, depending on your roof's size, complexity, and accessibility. Multi-story homes or tile roofs may take slightly longer. We are thorough. We would rather spend extra time and catch everything than rush through.</div></div>
    </div>
    <div class="faq-item">
      <button class="faq-btn" aria-expanded="false" onclick="this.setAttribute('aria-expanded',this.getAttribute('aria-expanded')==='true'?'false':'true');this.nextElementSibling.classList.toggle('open')">
        What happens if you find damage during the inspection?
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#1A1A1A" stroke-width="2.5"><path d="M6 9l6 6 6-6"/></svg>
      </button>
      <div class="faq-answer"><div class="faq-answer-inner">We document everything with photos and present our findings to you. If repairs or replacement are needed, we provide a written estimate with options. There is absolutely no pressure, and the decision is yours, and we are happy to answer questions or provide the report for a second opinion.</div></div>
    </div>
    <div class="faq-item">
      <button class="faq-btn" aria-expanded="false" onclick="this.setAttribute('aria-expanded',this.getAttribute('aria-expanded')==='true'?'false':'true');this.nextElementSibling.classList.toggle('open')">
        When should I schedule a roof inspection in Tampa?
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#1A1A1A" stroke-width="2.5"><path d="M6 9l6 6 6-6"/></svg>
      </button>
      <div class="faq-answer"><div class="faq-answer-inner">We recommend scheduling an inspection if your roof is over 10 years old, after any major storm, before buying or selling a home, or if you notice any signs of damage like water stains, missing shingles, or granules in your gutters. Many Tampa homeowners schedule an annual inspection before hurricane season starts in June.</div></div>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="cta-grad relative overflow-hidden py-20">
  <div class="relative z-10 max-w-3xl mx-auto px-5 text-center">
    <h2 class="font-display font-black tracking-tightest mb-4" style="font-family:'Barlow Condensed',sans-serif;font-size:clamp(2.5rem,5vw,4.5rem);line-height:.92;letter-spacing:-.01em">
      SCHEDULE YOUR FREE INSPECTION<span style="color:#F0C040">.</span>
    </h2>
    <p style="color:rgba(255,248,240,.85);font-size:1rem;line-height:1.75;margin-bottom:2rem">Call us or request a free estimate online. We respond within 24 hours.</p>
    <div class="flex flex-wrap gap-3 justify-center">
      <a href="/contact" class="btn-t" style="font-size:1.15rem;padding:1rem 2.5rem">Get My Free Estimate <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg></a>
      <a href="tel:8135957663" class="btn-o call-tracking-number" style="font-size:1.05rem;padding:1rem 2.5rem">Call Now, No Obligation</a>
    </div>
  </div>
</section>

<!-- Google Map + Local Keywords -->
<section style="background:#F7F7F7;padding:3rem 0;border-top:1px solid #E0E0E0">
  <div class="max-w-5xl mx-auto px-5">
    <div class="rounded-2xl overflow-hidden" style="background:#F7F7F7;border:1px solid #E0E0E0">
      <iframe
        src="https://www.google.com/maps/embed?pb=!1m14!1m12!1m3!1d50000!2d-82.4572!3d27.9506!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!5e0!3m2!1sen!2sus"
        width="100%" height="300" style="border:0;display:block"
        allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"
