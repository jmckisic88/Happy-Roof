---
import BaseLayout from '../layouts/BaseLayout.astro';

const schema = `[{
    "@context": "https://schema.org",
    "@type": ["LocalBusiness", "RoofingContractor"],
    "name": "Happy Roof LLC",
    "url": "https://happyroof.com",
    "telephone": "+1-813-595-7663",
    "email": "info@happyroof.com",
    "description": "Oldsmar roof repair contractor based at 141 Stevens Ave. Emergency leak repair, storm damage, and general roofing repairs. FL License #CCC1337380.",
    "image": "/Brand%20Assets/Happy%20Roof%20Logo.jpeg",
    "logo": "/Brand%20Assets/Happy%20Roof%20Logo.jpeg",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "141 Stevens Ave #12",
      "addressLocality": "Oldsmar",
      "addressRegion": "FL",
      "postalCode": "34677",
      "addressCountry": "US"
    },
    "areaServed": {
      "@type": "City",
      "name": "Oldsmar",
      "containedInPlace": { "@type": "State", "name": "Florida" }
    },
    "hasCredential": "Florida Roofing Contractor License #CCC1337380",
    "dateModified": "2026-04-10"
  },{
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How fast can Happy Roof respond to an Oldsmar roof emergency?",
        "acceptedAnswer": { "@type": "Answer", "text": "As an Oldsmar-based company, our response times are among the fastest in the area. For active leaks, we provide same-day emergency tarping in most cases. Our office at 141 Stevens Ave is minutes from anywhere in Oldsmar." }
      },
      {
        "@type": "Question",
        "name": "Should I repair or replace my Oldsmar roof?",
        "acceptedAnswer": { "@type": "Answer", "text": "If damage is limited to a small area and your roof is under 15 years old, repair is usually the right call. If your roof is 20+ years old with widespread issues, a full replacement may be more cost-effective. We give honest recommendations based on what we see, not what generates the biggest invoice." }
      },
      {
        "@type": "Question",
        "name": "Does insurance cover roof repairs in Oldsmar?",
        "acceptedAnswer": { "@type": "Answer", "text": "Storm and wind damage repairs are generally covered by Florida homeowners insurance. We document all damage with detailed photos and measurements, and we can coordinate with your insurance adjuster." }
      },
      {
        "@type": "Question",
        "name": "How much does a roof repair cost in Oldsmar?",
        "acceptedAnswer": { "@type": "Answer", "text": "Minor repairs range from $300 to $1,500. Larger repairs involving multiple areas, tile, or decking work may cost $1,500 to $5,000+. We provide free inspections and written estimates before starting any work." }
      }
    ]
  }]`;
---

<BaseLayout
  title="Oldsmar Roof Repair | Fast Response | Happy Roof"
