---
import BaseLayout from '../layouts/BaseLayout.astro';

const schema = `[{
    "@context": "https://schema.org",
    "@type": ["LocalBusiness", "RoofingContractor"],
    "name": "Happy Roof LLC","url": "https://happyroof.com","telephone": "+1-813-595-7663","email": "info@happyroof.com",
    "description": "Professional roof maintenance services in Tampa Bay. Preventive care, seasonal programs, gutter cleaning. FL License #CCC1337380.",
    "image": "/Brand%20Assets/Happy%20Roof%20Logo.jpeg","logo": "/Brand%20Assets/Happy%20Roof%20Logo.jpeg",
    "address": {"@type": "PostalAddress","streetAddress": "141 Stevens Ave #12","addressLocality": "Oldsmar","addressRegion": "FL","postalCode": "34677","addressCountry": "US"},
    "hasCredential": "Florida Roofing Contractor License #CCC1337380"
  },{
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {"@type": "Question","name": "How often should I have my roof maintained in Florida?","acceptedAnswer": {"@type": "Answer","text": "We recommend professional roof maintenance at least twice a year in Tampa Bay — once before hurricane season (May-June) and once after (November-December). Florida's intense UV, heat, and storm exposure accelerate wear faster than moderate climates. Regular maintenance catches small issues before they become expensive repairs."}},
      {"@type": "Question","name": "What does roof maintenance include?","acceptedAnswer": {"@type": "Answer","text": "Our maintenance service includes a full roof inspection, debris removal, gutter cleaning, flashing and sealant reapplication where needed, minor repair of cracked or loose materials, ventilation check, and a condition report with photos. We address small problems on the spot so they don't grow into major issues."}},
      {"@type": "Question","name": "Can maintenance really extend my roof's lifespan?","acceptedAnswer": {"@type": "Answer","text": "Yes. Industry data consistently shows that regular professional maintenance can add 5-10 years to a roof's lifespan. By addressing minor wear, keeping drainage clear, and maintaining sealants and flashing, you prevent the cascading damage that leads to premature replacement. The cost of maintenance is a fraction of what a new roof costs."}},
      {"@type": "Question","name": "Do you offer a maintenance plan or program?","acceptedAnswer": {"@type": "Answer","text": "Yes. Happy Roof offers seasonal maintenance programs that include scheduled inspections and maintenance visits throughout the year. Contact us at (813) 595-7663 to learn about our current maintenance program options and pricing for your property."}},
      {"@type": "Question","name": "Will roof maintenance affect my insurance?","acceptedAnswer": {"@type": "Answer","text": "Positively. Maintaining your roof and keeping documentation of professional maintenance can help with insurance renewals and claims. Many Florida insurers look favorably on well-maintained roofs, and having a documented maintenance history demonstrates responsible property care."}},
      {"@type": "Question","name": "What happens if you find damage during a maintenance visit?","acceptedAnswer": {"@type": "Answer","text": "If we discover damage beyond routine maintenance during a visit, we'll document it with photos and provide you with a separate repair estimate. Minor issues like a few loose shingles or dried sealant are typically handled during the maintenance visit at no extra charge. For larger issues, we give you a clear, honest assessment and let you decide how to proceed."}}
    ]
  },{
    "@context": "https://schema.org","@type": "Service","serviceType": "Roof Maintenance",
    "provider": {"@type": "RoofingContractor","name": "Happy Roof LLC","telephone": "+1-813-595-7663","url": "https://happyroof.com"},
    "areaServed": {"@type": "State","name": "Florida"},
    "description": "Professional roof maintenance services in Tampa Bay including inspections, cleaning, gutter maintenance, sealant repair, and seasonal programs. Licensed contractor FL #CCC1337380."
  }]`;
---

<BaseLayout
  title="Roof Maintenance Services Tampa Bay | Happy Roof"
  description="Professional roof maintenance services in Tampa Bay by Happy Roof. Preventive care, seasonal programs, gutter cleaning, and more. Extend your roof's life. FL #CCC1337380."
  canonical="https://happyroof.com/roof-maintenance"
  ogDescription="Preventive roof maintenance in Tampa Bay. Extend your roof's lifespan with professional seasonal care. FL #CCC1337380."
  schema={schema}
>

<style is:inline>
.check-dot{width:20px;height:20px;border-radius:50%;display:flex;align-items:center;justify-content:center;background:rgba(230,168,23,.1);flex-shrink:0;margin-top:.15rem}
    .step-num{width:48px;height:48px;border-radius:14px;display:flex;align-items:center;justify-content:center;background:rgba(230,168,23,.1);font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.25rem;color:#E6A817;flex-shrink:0}
</style>

<!-- PAGE HERO -->
<section class="pt-32 pb-20 relative overflow-hidden" style="background:#F5F5F5;border-bottom:1px solid #E5E5E5">
  <div class="hero-photo-bg" style="background-image:url('/Brand%20Assets/Photos/architectural-shingle-roof-tampa-bay.jpg')"></div>
  <div class="hero-photo-overlay"></div>
  <div class="relative z-10 max-w-7xl mx-auto px-5 text-center">
    <p class="sl gp mb-4">Roof Maintenance</p>
    <h1 class="font-display font-black tracking-tightest mb-5" style="font-family:'Barlow Condensed',sans-serif;font-size:clamp(3rem,6vw,5rem);line-height:.92;letter-spacing:-.01em;color:#1A1A1A">
      ROOF MAINTENANCE<br/><span class="gt">TAMPA BAY.</span>
    </h1>
    <p class="max-w-2xl mx-auto" style="color:#555555;font-size:1.05rem;line-height:1.75">
      The smartest investment you can make in your roof isn't a replacement — it's maintenance. Happy Roof's preventive maintenance services keep your roofing system performing at its best, extend its lifespan by years, and help you avoid costly emergency repairs.
    </p>
    <div class="flex flex-wrap gap-3 justify-center mt-8">
      <a href="/contact" class="btn-t">Schedule Maintenance <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg></a>
      <a href="tel:8135957663" class="btn-o call-tracking-number">Call (813) 595-7663</a>
    </div>
  </div>
</section>

<!-- INFO STRIP -->
<div style="background:#FFFFFF;border-top:2px solid #E6A817;border-bottom:1px solid #E0E0E0;padding:.85rem 0">
  <div class="max-w-7xl mx-auto px-5">
    <div class="flex flex-wrap items-center justify-center gap-x-8 gap-y-2 font-display font-bold text-sm tracking-widest" style="color:#1A1A1A;text-transform:uppercase;font-family:'Barlow Condensed',sans-serif">
      <span>Tampa Bay, FL</span><span style="color:#E6A817">·</span><span>CCC1337380</span><span style="color:#E6A817">·</span><span>HappyRoof.com</span><span style="color:#E6A817">·</span><span style="color:#3B9FD9">(813) 595-7663</span>
    </div>
  </div>
</div>

<!-- WHY MAINTENANCE MATTERS -->
<section class="py-20" style="background:#FFFFFF">
  <div class="max-w-7xl mx-auto px-5">
    <div class="grid lg:grid-cols-2 gap-14 items-start">
      <div>
        <p class="sl gt mb-3">Why Maintenance Matters</p>
        <h2 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:clamp(2rem,4vw,3rem);line-height:.95;color:#1A1A1A;letter-spacing:-.01em;margin-bottom:1.5rem">PREVENTIVE ROOF MAINTENANCE SAVES MONEY</h2>
        <p style="color:#555555;font-size:1rem;line-height:1.75;margin-bottom:1.5rem">
          Florida's climate is uniquely harsh on roofing systems. Between intense UV radiation that degrades materials, summer thunderstorms that test drainage and waterproofing, and hurricanes that stress every component of your roof, the wear accumulates faster here than almost anywhere else in the country.
        </p>
        <p style="color:#555555;font-size:1rem;line-height:1.75;margin-bottom:1.5rem">
          Without regular maintenance, small issues — a lifted shingle, clogged gutter, dried sealant around a vent — silently escalate. By the time you notice a water stain on your ceiling or mold in your attic, the damage has been building for months or years. The repair bill at that point is often 10 to 50 times what preventive maintenance would have cost.
        </p>
        <p style="color:#555555;font-size:1rem;line-height:1.75;margin-bottom:1.5rem">
          Happy Roof's maintenance services are designed specifically for Tampa Bay's conditions. We inspect, clean, repair, and document your roof's condition on a regular schedule — so problems get caught early, your roof performs as designed, and your investment is protected for the long haul.
        </p>
      </div>
      <div class="space-y-4">
        <div class="scard p-6">
          <div class="check"><div class="check-dot"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#E6A817" stroke-width="3"><path d="M20 6L9 17l-5-5"/></svg></div><div><strong style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.05rem">Add 5-10 Years of Roof Life</strong><p style="color:#555555;font-size:.9rem;line-height:1.6;margin-top:.25rem">Regular professional maintenance prevents the cascading damage that leads to premature replacement. A well-maintained roof consistently outlasts a neglected one by 5 to 10 years.</p></div></div>
        </div>
        <div class="scard p-6">
          <div class="check"><div class="check-dot"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#E6A817" stroke-width="3"><path d="M20 6L9 17l-5-5"/></svg></div><div><strong style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.05rem">Avoid Emergency Repairs</strong><p style="color:#555555;font-size:.9rem;line-height:1.6;margin-top:.25rem">Emergency roof repairs are stressful and expensive. Maintenance catches the warning signs — cracked caulk, loose flashing, debris buildup — before they become urgent problems.</p></div></div>
        </div>
        <div class="scard p-6">
          <div class="check"><div class="check-dot"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#E6A817" stroke-width="3"><path d="M20 6L9 17l-5-5"/></svg></div><div><strong style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.05rem">Protect Warranty Coverage</strong><p style="color:#555555;font-size:.9rem;line-height:1.6;margin-top:.25rem">Many manufacturer warranties require or recommend regular maintenance. Documented professional care helps keep your warranty valid and supports claims if issues arise.</p></div></div>
        </div>
        <div class="scard p-6">
          <div class="check"><div class="check-dot"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#E6A817" stroke-width="3"><path d="M20 6L9 17l-5-5"/></svg></div><div><strong style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.05rem">Lower Energy Bills</strong><p style="color:#555555;font-size:.9rem;line-height:1.6;margin-top:.25rem">A well-ventilated, properly sealed roof keeps your attic cooler and reduces the load on your AC system. In Florida's heat, this translates to meaningful savings on your monthly energy bill.</p></div></div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- WHAT'S INCLUDED -->
<section class="py-20" style="background:#F5F5F5;border-top:1px solid #E5E5E5;border-bottom:1px solid #E5E5E5">
  <div class="max-w-7xl mx-auto px-5">
    <div class="text-center mb-14">
      <p class="sl gp mb-3">What's Included</p>
      <h2 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:clamp(2rem,4vw,3rem);line-height:.95;color:#1A1A1A;letter-spacing:-.01em">OUR MAINTENANCE SERVICES</h2>
    </div>
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      <div class="scard p-6">
        <div class="step-num mb-4">01</div>
        <h3 style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.15rem;margin-bottom:.5rem">Full Roof Inspection</h3>
        <p style="color:#555555;font-size:.9rem;line-height:1.7">Every maintenance visit begins with a comprehensive inspection of your entire roofing system — materials, flashing, vents, soffit, fascia, gutters, and attic ventilation. We document everything with photos so you have a clear record of your roof's condition over time.</p>
      </div>
      <div class="scard p-6">
        <div class="step-num mb-4">02</div>
        <h3 style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.15rem;margin-bottom:.5rem">Debris Removal</h3>
        <p style="color:#555555;font-size:.9rem;line-height:1.7">Leaves, branches, pine needles, and other organic material trap moisture against your roof and accelerate deterioration. We clear all debris from the roof surface, valleys, and around penetrations to maintain proper drainage and prevent decay.</p>
      </div>
      <div class="scard p-6">
        <div class="step-num mb-4">03</div>
        <h3 style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.15rem;margin-bottom:.5rem">Gutter Cleaning</h3>
        <p style="color:#555555;font-size:.9rem;line-height:1.7">Clogged gutters cause water to back up under your roofline, leading to fascia rot, foundation problems, and landscape erosion. We clean all gutters and downspouts and verify proper water flow away from your foundation.</p>
      </div>
      <div class="scard p-6">
        <div class="step-num mb-4">04</div>
        <h3 style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.15rem;margin-bottom:.5rem">Sealant &amp; Flashing Repair</h3>
        <p style="color:#555555;font-size:.9rem;line-height:1.7">Florida's heat and UV exposure cause sealants to dry, crack, and fail faster than in cooler climates. We inspect and reapply sealant around vents, pipes, skylights, and flashing joints as needed — preventing the most common sources of roof leaks.</p>
      </div>
      <div class="scard p-6">
        <div class="step-num mb-4">05</div>
        <h3 style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.15rem;margin-bottom:.5rem">Minor Repairs</h3>
        <p style="color:#555555;font-size:.9rem;line-height:1.7">Loose shingles, cracked tiles, popped nails, and small gaps are addressed during the maintenance visit at no extra charge. These small fixes prevent water from reaching the deck and causing expensive structural damage down the road.</p>
      </div>
      <div class="scard p-6">
        <div class="step-num mb-4">06</div>
        <h3 style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.15rem;margin-bottom:.5rem">Condition Report</h3>
        <p style="color:#555555;font-size:.9rem;line-height:1.7">After every visit, you receive a written report with photos documenting your roof's current condition, work performed, and any recommendations for future attention. This documentation is valuable for insurance, warranty claims, and property records.</p>
      </div>
    </div>
  </div>
</section>

<!-- SEASONAL MAINTENANCE -->
<section class="py-20" style="background:#FFFFFF">
  <div class="max-w-7xl mx-auto px-5">
    <div class="text-center mb-14">
      <p class="sl gt mb-3">Seasonal Care</p>
      <h2 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:clamp(2rem,4vw,3rem);line-height:.95;color:#1A1A1A;letter-spacing:-.01em">SEASONAL ROOF MAINTENANCE FOR FLORIDA</h2>
    </div>
    <div class="max-w-3xl mx-auto space-y-8">
      <div class="flex gap-5 items-start">
        <div class="step-num" style="background:rgba(59,159,217,.1);color:#3B9FD9">SPR</div>
        <div>
          <h3 style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.15rem;margin-bottom:.35rem">Spring (March - May)</h3>
          <p style="color:#555555;font-size:.95rem;line-height:1.75">Assess any damage from winter cold snaps and prepare for the rainy season ahead. Clear debris, check drainage, inspect sealants, and address any wear from the dry season's UV exposure. This is your window to fix issues before Florida's afternoon thunderstorms begin.</p>
        </div>
      </div>
      <div class="flex gap-5 items-start">
        <div class="step-num" style="background:rgba(230,168,23,.1);color:#E6A817">PRE</div>
        <div>
          <h3 style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.15rem;margin-bottom:.35rem">Pre-Hurricane Season (May - June)</h3>
          <p style="color:#555555;font-size:.95rem;line-height:1.75">The most critical maintenance window for Florida homeowners. We perform a thorough storm-readiness check: securing loose materials, reinforcing vulnerable areas, clearing gutters, and ensuring your roof is in the best possible condition to withstand high winds and heavy rain.</p>
        </div>
      </div>
      <div class="flex gap-5 items-start">
        <div class="step-num" style="background:rgba(230,168,23,.1);color:#E6A817">PST</div>
        <div>
          <h3 style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.15rem;margin-bottom:.35rem">Post-Hurricane Season (December - January)</h3>
          <p style="color:#555555;font-size:.95rem;line-height:1.75">After hurricane season ends, we assess your roof for any storm damage that may have gone unnoticed, clean accumulated debris, and perform repairs before winter. This visit documents your roof's condition heading into the cooler months and sets a baseline for spring.</p>
        </div>
      </div>
      <div class="flex gap-5 items-start">
        <div class="step-num" style="background:rgba(59,159,217,.1);color:#3B9FD9">ANN</div>
        <div>
          <h3 style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.15rem;margin-bottom:.35rem">Annual Deep Maintenance</h3>
          <p style="color:#555555;font-size:.95rem;line-height:1.75">Once a year, we recommend a more thorough maintenance session that includes attic inspection, ventilation assessment, and a detailed evaluation of all roof components. This deeper look catches issues that surface-level maintenance may miss and provides a comprehensive health report for your roof.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- EXTENDING ROOF LIFE -->
<section class="py-20" style="background:#F5F5F5;border-top:1px solid #E5E5E5;border-bottom:1px solid #E5E5E5">
  <div class="max-w-7xl mx-auto px-5">
    <div class="grid lg:grid-cols-2 gap-14 items-start">
      <div>
        <p class="sl gp mb-3">Roof Longevity</p>
        <h2 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:clamp(2rem,4vw,3rem);line-height:.95;color:#1A1A1A;letter-spacing:-.01em;margin-bottom:1.5rem">TIPS FOR EXTENDING YOUR ROOF'S LIFE IN FLORIDA</h2>
        <p style="color:#555555;font-size:1rem;line-height:1.75;margin-bottom:1.5rem">
          Beyond professional maintenance, there are steps every homeowner can take to protect their roof investment. These habits, combined with regular professional care, help maximize your roof's performance and lifespan in Tampa Bay's demanding climate.
        </p>
        <p style="color:#555555;font-size:1rem;line-height:1.75;margin-bottom:1.5rem">
          <strong>Keep trees trimmed.</strong> Overhanging branches drop debris, trap moisture, and can cause physical damage during storms. Maintain at least 6-10 feet of clearance between tree branches and your roof.
        </p>
        <p style="color:#555555;font-size:1rem;line-height:1.75;margin-bottom:1.5rem">
          <strong>Ensure proper attic ventilation.</strong> Florida's heat builds up in poorly ventilated attics, cooking shingles from below and dramatically shortening their lifespan. Proper ridge and soffit ventilation keeps temperatures manageable and prevents moisture buildup.
        </p>
      </div>
      <div class="space-y-4">
        <div class="scard p-6">
          <div class="check"><div class="check-dot"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#E6A817" stroke-width="3"><path d="M20 6L9 17l-5-5"/></svg></div><div><strong style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.05rem">Check After Every Storm</strong><p style="color:#555555;font-size:.9rem;line-height:1.6;margin-top:.25rem">After any significant weather event, do a visual check from the ground. Look for missing material, debris on the roof, or damaged gutters. Call a professional if anything looks off.</p></div></div>
        </div>
        <div class="scard p-6">
          <div class="check"><div class="check-dot"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#E6A817" stroke-width="3"><path d="M20 6L9 17l-5-5"/></svg></div><div><strong style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.05rem">Don't Ignore Gutters</strong><p style="color:#555555;font-size:.9rem;line-height:1.6;margin-top:.25rem">Clogged gutters are one of the leading causes of preventable roof damage. When water can't drain properly, it backs up under shingles and rots fascia boards. Clean them regularly or include it in your maintenance plan.</p></div></div>
        </div>
        <div class="scard p-6">
          <div class="check"><div class="check-dot"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#E6A817" stroke-width="3"><path d="M20 6L9 17l-5-5"/></svg></div><div><strong style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.05rem">Address Issues Immediately</strong><p style="color:#555555;font-size:.9rem;line-height:1.6;margin-top:.25rem">A $200 repair today prevents a $5,000 problem next year. When you notice anything unusual — a water stain, a loose shingle visible from the ground, a musty smell in the attic — act quickly.</p></div></div>
        </div>
        <div class="scard p-6">
          <div class="check"><div class="check-dot"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#E6A817" stroke-width="3"><path d="M20 6L9 17l-5-5"/></svg></div><div><strong style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.05rem">Keep Records</strong><p style="color:#555555;font-size:.9rem;line-height:1.6;margin-top:.25rem">Maintain a file of all roof-related work, inspections, and maintenance reports. This documentation is valuable for insurance claims, warranty support, and future home sales.</p></div></div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- FAQ -->
<section class="py-20" style="background:#FFFFFF">
  <div class="max-w-3xl mx-auto px-5">
    <div class="text-center mb-14">
      <p class="sl gp mb-3">FAQ</p>
      <h2 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:clamp(2rem,4vw,3rem);line-height:.95;color:#1A1A1A;letter-spacing:-.01em">FREQUENTLY ASKED QUESTIONS</h2>
    </div>
    <div>
      <div class="faq-item">
        <button class="faq-btn" aria-expanded="false" onclick="this.setAttribute('aria-expanded',this.getAttribute('aria-expanded')==='true'?'false':'true');this.nextElementSibling.classList.toggle('open')">How often should I have my roof maintained in Florida?<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#1A1A1A" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg></button>
        <div class="faq-answer"><div class="faq-answer-inner">We recommend professional roof maintenance at least twice a year in Tampa Bay — once before hurricane season (May-June) and once after (November-December). Florida's intense UV, heat, and storm exposure accelerate wear faster than moderate climates. Regular maintenance catches small issues before they become expensive repairs and keeps your roof performing at its peak.</div></div>
      </div>
      <div class="faq-item">
        <button class="faq-btn" aria-expanded="false" onclick="this.setAttribute('aria-expanded',this.getAttribute('aria-expanded')==='true'?'false':'true');this.nextElementSibling.classList.toggle('open')">What does roof maintenance include?<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#1A1A1A" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg></button>
        <div class="faq-answer"><div class="faq-answer-inner">Our maintenance service includes a full roof inspection, debris removal, gutter cleaning, flashing and sealant reapplication where needed, minor repair of cracked or loose materials, ventilation check, and a condition report with photos. We address small problems on the spot so they don't grow into major issues.</div></div>
      </div>
      <div class="faq-item">
        <button class="faq-btn" aria-expanded="false" onclick="this.setAttribute('aria-expanded',this.getAttribute('aria-expanded')==='true'?'false':'true');this.nextElementSibling.classList.toggle('open')">Can maintenance really extend my roof's lifespan?<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#1A1A1A" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg></button>
        <div class="faq-answer"><div class="faq-answer-inner">Yes. Industry data consistently shows that regular professional maintenance can add 5-10 years to a roof's lifespan. By addressing minor wear, keeping drainage clear, and maintaining sealants and flashing, you prevent the cascading damage that leads to premature replacement. The cost of annual maintenance is a fraction of what a new roof costs.</div></div>
      </div>
      <div class="faq-item">
        <button class="faq-btn" aria-expanded="false" onclick="this.setAttribute('aria-expanded',this.getAttribute('aria-expanded')==='true'?'false':'true');this.nextElementSibling.classList.toggle('open')">Do you offer a maintenance plan or program?<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#1A1A1A" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg></button>
