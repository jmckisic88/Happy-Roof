<!-- FOOTER -->

<script is:inline>
function filterBlog(cat, btn) {
  document.querySelectorAll('.blog-filter').forEach(t => t.classList.remove('active'));
  btn.classList.add('active');
  const cards = document.querySelectorAll('.blog-card');
  let visible = 0;
  cards.forEach(card => {
    if (cat === 'all' || card.dataset.category === cat) {
      card.style.display = '';
      visible++;
    } else {
      card.style.display = 'none';
    }
  });
  const msg = document.getElementById('no-posts-msg');
  if (msg) msg.style.display = visible === 0 ? '' : 'none';
}
</script>

</BaseLayout>