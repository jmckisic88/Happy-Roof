---
import BaseLayout from '../../layouts/BaseLayout.astro';

const schema = `{
  "@context": "https://schema.org",
  "@type": "Blog",
  "name": "Happy Roof Blog",
  "description": "Roofing tips, guides, and expert advice for Tampa Bay homeowners.",
  "url": "https://happyroof.com/blog",
  "publisher": {
    "@type": "Organization",
    "name": "Happy Roof LLC",
    "url": "https://happyroof.com"
  },
  "dateModified": "2026-04-20"
}`;
---

<BaseLayout
  title="Roofing Blog | Tips, Guides & News | Happy Roof"
  description="Roofing tips, guides, and expert advice for Tampa Bay homeowners. Materials, costs, insurance claims, and choosing the right contractor."
  canonical="https://happyroof.com/blog"
  ogTitle="Roofing Blog | Tampa Bay Tips & Guides | Happy Roof"
  ogDescription="Roofing knowledge with zero fluff. Tips, guides, and expert advice for Tampa Bay homeowners."
  schema={schema}
>

<style is:inline>
.blog-card{background:#FFFFFF;border:1px dashed #E0E0E0;border-radius:20px;overflow:hidden;transition:border-color .25s,transform .2s cubic-bezier(.34,1.56,.64,1);display:flex;flex-direction:column}
    .blog-card:hover{border-color:rgba(230,168,23,.3);transform:translateY(-3px)}
    .blog-filter{padding:.45rem 1rem;border-radius:100px;font-weight:700;font-size:.8rem;letter-spacing:.08em;text-transform:uppercase;cursor:pointer;transition:background .18s,color .18s;border:1px solid #E0E0E0;background:#FFFFFF;color:#555555;font-family:'Barlow Condensed',sans-serif}
    .blog-filter:hover{background:#F7F7F7}
    .blog-filter.active{background:#E6A817;color:#1A1A1A;border-color:#E6A817}
</style>

<!-- PAGE HERO -->
<section class="pt-32 pb-20 relative overflow-hidden" style="background:#F5F5F5;border-bottom:1px solid #E5E5E5">
  <div class="hero-photo-bg" style="background-image:url('/Brand%20Assets/Photos/4055F5E2-0A81-4BAC-A34D-586DC69AFF69_1_105_c.jpeg')"></div>
  <div class="hero-photo-overlay"></div>
  <div class="relative z-10 max-w-7xl mx-auto px-5 text-center">
    <p class="sl gp mb-4">Happy Roof Blog</p>
    <h1 class="font-display font-black tracking-tightest mb-5" style="font-family:'Barlow Condensed',sans-serif;font-size:clamp(3rem,6vw,5rem);line-height:.92;letter-spacing:-.01em;color:#1A1A1A">
      ROOFING KNOWLEDGE.<br/><span class="gt">ZERO FLUFF.</span>
    </h1>
    <p class="max-w-2xl mx-auto" style="color:#555555;font-size:1.05rem;line-height:1.75">
      Straight-talk roofing guides, material comparisons, cost breakdowns, and expert tips written specifically for Tampa Bay homeowners. No jargon, no sales pitches, just the information you need to make smart decisions about your roof.
    </p>
  </div>
</section>

<!-- CATEGORY FILTER -->
<div style="background:#FFFFFF;border-top:2px solid #E6A817;border-bottom:1px solid #E0E0E0;padding:.85rem 0">
  <div class="max-w-7xl mx-auto px-5">
    <div class="flex flex-wrap items-center justify-center gap-2" style="font-family:'Barlow Condensed',sans-serif">
      <button class="blog-filter active" onclick="filterBlog('all',this)">All</button>
      <button class="blog-filter" onclick="filterBlog('Materials',this)">Materials</button>
      <button class="blog-filter" onclick="filterBlog('Insurance',this)">Insurance</button>
      <button class="blog-filter" onclick="filterBlog('Education',this)">Education</button>
      <button class="blog-filter" onclick="filterBlog('Process',this)">Process</button>
      <button class="blog-filter" onclick="filterBlog('Maintenance',this)">Maintenance</button>
      <button class="blog-filter" onclick="filterBlog('Emergency',this)">Emergency</button>
      <button class="blog-filter" onclick="filterBlog('Codes',this)">Codes</button>
      <button class="blog-filter" onclick="filterBlog('Commercial',this)">Commercial</button>
      <button class="blog-filter" onclick="filterBlog('Hiring',this)">Hiring</button>
    </div>
  </div>
</div>

<!-- BLOG GRID -->
<section class="py-20" style="background:#F7F7F7">
  <div class="max-w-5xl mx-auto px-5">
    <div id="blog-grid" class="grid md:grid-cols-2 gap-8">

      <!-- Post: Choosing Right Roof Type -->
      <a href="/blog/choosing-right-roof-type-florida" class="blog-card" data-publish="2026-04-20" data-category="Materials" style="text-decoration:none;color:inherit">
        <div style="padding:2rem 2rem 0">
          <div style="margin-bottom:1rem">
            <span class="blog-tag" style="background:rgba(59,159,217,.1);color:#3B9FD9">Materials</span>
            <span style="color:#888888;font-size:.8rem;margin-left:.75rem">April 20, 2026</span>
          </div>
