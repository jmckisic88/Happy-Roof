        <div class="step-num">2</div>
        <div>
          <h3 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.2rem;color:#1A1A1A;margin-bottom:.5rem">Material Selection & Permits</h3>
          <p style="color:#555555;font-size:.95rem;line-height:1.7">Choose your material with our guidance. We handle all permits and schedule your installation date.</p>
        </div>
