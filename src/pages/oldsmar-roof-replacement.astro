---
import BaseLayout from '../layouts/BaseLayout.astro';

const schema = `[{
    "@context": "https://schema.org",
    "@type": ["LocalBusiness", "RoofingContractor"],
    "name": "Happy Roof LLC",
    "url": "https://happyroof.com",
    "telephone": "+1-813-595-7663",
    "email": "info@happyroof.com",
    "description": "Oldsmar roof replacement contractor headquartered at 141 Stevens Ave. Shingle, metal, and tile roofing. FL License #CCC1337380.",
    "image": "/Brand%20Assets/Happy%20Roof%20Logo.jpeg",
    "logo": "/Brand%20Assets/Happy%20Roof%20Logo.jpeg",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "141 Stevens Ave #12",
      "addressLocality": "Oldsmar",
      "addressRegion": "FL",
      "postalCode": "34677",
      "addressCountry": "US"
    },
    "areaServed": {
      "@type": "City",
      "name": "Oldsmar",
      "containedInPlace": { "@type": "State", "name": "Florida" }
    },
    "hasCredential": "Florida Roofing Contractor License #CCC1337380",
    "dateModified": "2026-04-20"
  },{
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How much does a roof replacement cost in Oldsmar?",
        "acceptedAnswer": { "@type": "Answer", "text": "Oldsmar roof replacements typically range from $8,000 to $24,000 depending on roof size, material choice, pitch, and structural condition. Waterfront properties may require corrosion-resistant materials at slightly higher cost. Call us at (813) 595-7663 for a free in-person estimate." }
      },
      {
        "@type": "Question",
        "name": "What roofing material works best in Oldsmar?",
        "acceptedAnswer": { "@type": "Answer", "text": "For most Oldsmar homes, Owens Corning Duration HDZ architectural shingles offer the best balance of durability, wind resistance, and value. Waterfront properties near Old Tampa Bay benefit from standing seam metal's corrosion resistance. Tile is ideal for homes with the structural support and aesthetic preference for it." }
      },
      {
        "@type": "Question",
        "name": "How long does a roof replacement take in Oldsmar?",
        "acceptedAnswer": { "@type": "Answer", "text": "Shingle roofs: 1-3 days. Metal roofs: 3-5 days. Tile: 5-7 days. As your local Oldsmar contractor, we can often schedule Oldsmar jobs quickly since we are just around the corner." }
      },
      {
        "@type": "Question",
        "name": "Is Happy Roof actually based in Oldsmar?",
        "acceptedAnswer": { "@type": "Answer", "text": "Yes. Our office is at 141 Stevens Ave #12, Oldsmar, FL 34677. We are a genuinely local business, not a company with a virtual address. When you work with Happy Roof, you are working with your Oldsmar neighbors." }
      }
    ]
  }]`;
