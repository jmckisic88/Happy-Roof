<BaseLayout
  title="Residential Roofing Tampa Bay - Shingle, Metal, Tile | Happy Roof"
  description="Residential roofing in Tampa Bay - shingles, metal, and tile. Licensed &amp; insured. FL #CCC1337380. Free estimates available."
  canonical="https://happyroof.com/residential-roofing"
  ogTitle="Residential Roofing Tampa Bay | Happy Roof"
  ogDescription="Expert residential roofing in Tampa Bay. Shingles, metal, tile. Licensed and insured. 15-year warranty option."
  schema={schema}
>

<style is:inline>
.check-dot{width:20px;height:20px;border-radius:50%;display:flex;align-items:center;justify-content:center;background:rgba(230,168,23,.1);flex-shrink:0;margin-top:.15rem}
    .step-num{width:48px;height:48px;border-radius:14px;display:flex;align-items:center;justify-content:center;background:rgba(230,168,23,.1);font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.25rem;color:#E6A817;flex-shrink:0}
</style>

<section class="relative overflow-hidden" style="padding:8rem 0 5rem;background:#FFFFFF">
