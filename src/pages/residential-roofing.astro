---
import BaseLayout from '../layouts/BaseLayout.astro';

const schema = `[{
    "@context": "https://schema.org",
    "@type": ["LocalBusiness", "RoofingContractor"],
    "name": "Happy Roof LLC",
    "url": "https://happyroof.com",
    "telephone": "+1-813-595-7663",
    "email": "info@happyroof.com",
    "description": "Tampa Bay residential roofing contractor specializing in shingle, metal, and tile roof replacement and installation. Licensed and insured. FL License #CCC1337380.",
    "image": "/Brand%20Assets/Happy%20Roof%20Logo.jpeg",
    "logo": "/Brand%20Assets/Happy%20Roof%20Logo.jpeg",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "141 Stevens Ave #12","addressLocality": "Oldsmar",
      "addressRegion": "FL","postalCode": "34677","addressCountry": "US"
    },
    "hasCredential": "Florida Roofing Contractor License #CCC1337380",
    "dateModified": "2026-04-10"
  },{
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How much does a residential roof replacement cost in Tampa Bay?",
        "acceptedAnswer": { "@type": "Answer", "text": "A typical residential roof replacement in Tampa Bay ranges from $8,000 to $25,000+ depending on roof size, pitch, material choice (asphalt shingles, metal, or tile), and whether structural repairs are needed. Happy Roof provides free, detailed estimates with no hidden fees. Call (813) 595-7663 for a personalized quote." }
      },
      {
        "@type": "Question",
        "name": "What is the best roofing material for Florida homes?",
        "acceptedAnswer": { "@type": "Answer", "text": "The best roofing material depends on your budget, aesthetic preference, and long-term goals. Architectural shingles (like Owens Corning Duration HDZ or GAF Timberline HDZ) offer the best value with 130+ MPH wind ratings. Standing seam metal roofs last 40-60 years and reflect heat, reducing energy bills. Concrete and clay tile provide a classic Florida look with 50+ year lifespans. Happy Roof installs all three and can help you choose." }
      },
      {
        "@type": "Question",
        "name": "How long does a residential roof replacement take?",
        "acceptedAnswer": { "@type": "Answer", "text": "Most residential shingle roof replacements in Tampa Bay take 1 to 3 days. Metal roofs typically take 3 to 5 days, and tile roofs may take 5 to 7 days depending on complexity. Happy Roof handles all permits, inspections, and cleanup so you don't have to coordinate anything." }
      },
      {
        "@type": "Question",
        "name": "Does Happy Roof offer a warranty on residential roofing?",
        "acceptedAnswer": { "@type": "Answer", "text": "Yes. Happy Roof provides a 15-year workmanship warranty on all residential shingle, metal, and tile roof installations - in writing, every time. This is in addition to manufacturer material warranties from Owens Corning (up to lifetime). We stand behind every roof we install." }
      },
      {
        "@type": "Question",
        "name": "Is Happy Roof licensed and insured for residential work in Florida?",
        "acceptedAnswer": { "@type": "Answer", "text": "Yes. Happy Roof LLC holds Florida Roofing Contractor License #CCC1337380 and carries full general liability and workers' compensation insurance. Certificates of insurance are available on request." }
      }
    ]
  },{
    "@context": "https://schema.org",
    "@type": "Service",
    "serviceType": "Residential Roofing",
    "provider": { "@type": "RoofingContractor", "name": "Happy Roof LLC", "telephone": "+1-813-595-7663", "url": "https://happyroof.com" },
    "areaServed": { "@type": "State", "name": "Florida" },
    "description": "Complete residential roofing services in Tampa Bay including shingle, metal, and tile roof replacement and installation. Licensed and insured. 15-year workmanship warranty."
  },{"@context":"https://schema.org","@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"Home","item":"https://happyroof.com/"},{"@type":"ListItem","position":2,"name":"Services","item":"https://happyroof.com/services"},{"@type":"ListItem","position":3,"name":"Residential Roofing","item":"https://happyroof.com/residential-roofing"}]}]`;
