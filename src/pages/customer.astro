---
import BaseLayout from '../layouts/BaseLayout.astro';

const schema = `{
  "@context": "https://schema.org",
  "@type": ["LocalBusiness", "RoofingContractor"],
  "name": "Happy Roof LLC",
  "url": "https://happyroof.com",
  "telephone": "+1-813-595-7663",
  "email": "info@happyroof.com",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "141 Stevens Ave #12",
    "addressLocality": "Oldsmar",
    "addressRegion": "FL",
    "postalCode": "34677",
    "addressCountry": "US"
  },
  "hasCredential": "Florida Roofing Contractor License #CCC1337380",
  "dateModified": "2026-04-15"
}`;
---

<BaseLayout
  title="Customer Guide | Your Roofing Project | Happy Roof"
  description="Your complete guide to working with Happy Roof. Learn about our team, process, warranties, materials, financing, and what to expect during your roofing project."
  canonical="https://happyroof.com/customer"
  hideBanner={true}
  hideNavLinks={true}
  hideExitPopup={true}
  schema={schema}
>

<style is:inline>
  /* ── Customer binder styles ── */
  .binder-section { padding: 5rem 0; border-bottom: 1px solid #E0E0E0 }
  .binder-section:last-of-type { border-bottom: none }
  .binder-label { font-family: 'Barlow Condensed', sans-serif; font-weight: 700; font-size: .78rem; letter-spacing: .15em; text-transform: uppercase; color: #E6A817; margin-bottom: .5rem }
  .binder-h2 { font-family: 'Barlow Condensed', sans-serif; font-weight: 900; font-size: clamp(2rem, 4vw, 3rem); line-height: .92; letter-spacing: -.01em; color: #1A1A1A; text-transform: uppercase; margin-bottom: 1.5rem }
  .binder-card { background: #FFFFFF; border: 1px solid #E0E0E0; border-radius: 16px; padding: 1.75rem; transition: border-color .2s }
  .binder-card:hover { border-color: rgba(230,168,23,.3) }
  .binder-stat { text-align: center; padding: 1.5rem }
  .binder-stat-num { font-family: 'Barlow Condensed', sans-serif; font-weight: 900; font-size: 2.2rem; line-height: 1; color: #E6A817 }
  .binder-stat-label { font-size: .78rem; color: #888; letter-spacing: .1em; text-transform: uppercase; font-weight: 600; margin-top: .4rem }
  .binder-value { display: flex; align-items: flex-start; gap: 1rem; margin-bottom: 1.5rem }
  .binder-value-icon { width: 40px; height: 40px; border-radius: 10px; display: flex; align-items: center; justify-content: center; flex-shrink: 0 }
  .binder-check { display: flex; align-items: flex-start; gap: .75rem; padding: .75rem 0; border-bottom: 1px solid #F0F0F0 }
  .binder-check:last-child { border-bottom: none }
  .binder-check svg { flex-shrink: 0; margin-top: 2px }
  .binder-toc a { display: flex; align-items: center; gap: .75rem; padding: .85rem 1.25rem; border-radius: 10px; text-decoration: none; color: #1A1A1A; font-weight: 600; font-size: .92rem; transition: background .15s }
  .binder-toc a:hover { background: rgba(230,168,23,.06) }
  .binder-toc-num { font-family: 'Barlow Condensed', sans-serif; font-weight: 800; font-size: .85rem; color: #E6A817; width: 28px; text-align: center }
  .warranty-table { width: 100%; border-collapse: collapse; border-radius: 12px; overflow: hidden }
  .warranty-table th { background: #1A1A1A; color: #F7F7F7; font-family: 'Barlow Condensed', sans-serif; font-weight: 700; font-size: .82rem; letter-spacing: .08em; text-transform: uppercase; padding: .85rem 1.25rem; text-align: left }
  .warranty-table td { padding: .85rem 1.25rem; font-size: .9rem; border-bottom: 1px solid #E0E0E0 }
  .warranty-table tr:last-child td { border-bottom: none }
  .warranty-happy { color: #E6A817; font-family: 'Barlow Condensed', sans-serif; font-weight: 800 }
  .warranty-avg { color: #888 }
  .tier-row { display: grid; grid-template-columns: 60px 1fr 1fr auto; align-items: center; padding: .85rem 1.25rem; border-bottom: 1px solid #E0E0E0; font-size: .88rem }
  .tier-row:last-child { border-bottom: none }

  /* Force hide mobile CTA on customer page */
  #mobile-cta-bar { display: none !important }
  body { padding-bottom: 0 !important }

  /* Print styles */
  @media print {
    nav, footer, .nav-wrap, #mobile-menu, .no-print, .btn-p, .btn-t, .btn-o { display: none !important }
    .binder-section { page-break-inside: avoid; padding: 2rem 0 }
    body { font-size: 11pt }
    section:first-of-type { padding-top: 1rem !important }
  }

  /* Mobile */
  @media (max-width: 767px) {
    .tier-row { grid-template-columns: 40px 1fr 1fr auto; font-size: .78rem; padding: .65rem .75rem }
    .binder-stat-num { font-size: 1.8rem }
  }
</style>

<!-- ══════ COVER / HERO ══════ -->
<section class="relative overflow-hidden" style="background:#F5F5F5;padding:6rem 0 4rem">
  <div class="hero-photo-bg" style="background-image:url('/Brand%20Assets/Photos/4055F5E2-0A81-4BAC-A34D-586DC69AFF69_1_105_c.jpeg')"></div>
  <div class="hero-photo-overlay"></div>
  <div class="relative z-10 max-w-4xl mx-auto px-5 text-center">
    <img src="/Brand%20Assets/Happy Roof Logo.png" alt="Happy Roof" style="height:56px;width:auto;margin:0 auto 1.5rem" />
    <p style="color:#888;font-size:.88rem;letter-spacing:.08em;font-weight:600;margin-bottom:2rem">Tampa Bay's Trusted Roofing Contractor</p>
    <h1 class="font-display font-black tracking-tightest" style="font-family:'Barlow Condensed',sans-serif;font-size:clamp(2.8rem,6vw,4.5rem);line-height:.88;letter-spacing:-.01em;color:#1A1A1A">
      YOUR ROOF PROTECTS<br/>EVERYTHING.<br/><span style="color:#E6A817">WE PROTECT YOUR ROOF.</span>
    </h1>
    <div style="display:flex;flex-wrap:wrap;justify-content:center;gap:1rem;margin-top:2rem;font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:.82rem;letter-spacing:.06em;color:#555">
      <span>FL License #CCC1337380</span>
      <span style="color:#E0E0E0">|</span>
      <span>Owens Corning Installer</span>
      <span style="color:#E0E0E0">|</span>
      <span>Fully Insured & Bonded</span>
    </div>
    <div style="display:flex;flex-wrap:wrap;justify-content:center;gap:.75rem;margin-top:2rem">
      <a href="tel:8135957663" class="btn-p call-tracking-number" style="font-size:1rem;padding:.75rem 1.5rem">(813) 595-7663</a>
    </div>
  </div>
</section>

<!-- ══════ TABLE OF CONTENTS ══════ -->
<section style="background:#FFFFFF;padding:3rem 0;border-bottom:1px solid #E0E0E0">
  <div class="max-w-3xl mx-auto px-5">
    <p class="binder-label" style="text-align:center">In This Guide</p>
    <div class="binder-toc" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:.25rem">
      <a href="#company"><span class="binder-toc-num">01</span> Company Story</a>
      <a href="#why"><span class="binder-toc-num">02</span> Why Happy Roof</a>
      <a href="#warranty"><span class="binder-toc-num">03</span> Our Warranty</a>
      <a href="#services"><span class="binder-toc-num">04</span> Products & Services</a>
      <a href="#materials"><span class="binder-toc-num">05</span> Materials We Trust</a>
      <a href="#process"><span class="binder-toc-num">06</span> How It Works</a>
      <a href="#checklist"><span class="binder-toc-num">07</span> Homeowner Checklist</a>
      <a href="#financing"><span class="binder-toc-num">08</span> Financing Options</a>
      <a href="#reviews"><span class="binder-toc-num">09</span> Customer Reviews</a>
      <a href="#heroes"><span class="binder-toc-num">10</span> Heroes Discount</a>
      <a href="#referrals"><span class="binder-toc-num">11</span> Referral Program</a>
      <a href="#credentials"><span class="binder-toc-num">12</span> Credentials & Insurance</a>
    </div>
  </div>
</section>

<!-- ══════ SECTION 1: COMPANY STORY ══════ -->
<section id="company" class="binder-section" style="background:#F7F7F7">
  <div class="max-w-4xl mx-auto px-5">
    <p class="binder-label">Section 1</p>
    <h2 class="binder-h2">A MESSAGE FROM OUR OWNER</h2>
    <div class="binder-card" style="padding:2.5rem">
      <p style="color:#555;font-size:.95rem;line-height:1.8;margin-bottom:1rem">Hello Future Happy Roof Client,</p>
      <p style="color:#555;font-size:.95rem;line-height:1.8;margin-bottom:1rem">First and foremost, thank you for giving us the opportunity to earn your business. We know that choosing a roofing contractor is not a small decision. Your roof protects everything you care about, and you deserve a company that takes that seriously.</p>
      <p style="color:#555;font-size:.95rem;line-height:1.8;margin-bottom:1rem">Happy Roof was built on a simple observation: most homeowners dread dealing with roofers. Confusing quotes, missed appointments, work that didn't hold up. We knew it didn't have to be that way. So we built the company we wished existed: one rooted in honesty, reliability, and craftsmanship that we'd be proud to put our name on.</p>
      <p style="color:#555;font-size:.95rem;line-height:1.8;margin-bottom:1rem">When you hire Happy Roof, you're not just getting a new roof. You're getting a team that shows up on time, communicates clearly, cleans up completely, and stands behind every nail with a warranty that means something. We treat your home the way we'd treat our own.</p>
      <p style="color:#555;font-size:.95rem;line-height:1.8;margin-bottom:1rem">There are plenty of contractors out there. What sets us apart isn't just what we do, it's why we do it. We genuinely care about the homeowners and businesses we serve here in Tampa Bay, and it shows in every job we complete.</p>
      <p style="color:#555;font-size:.95rem;line-height:1.8;margin-bottom:2rem">Thank you for taking the time to review this guide. Our team will walk you through everything, but please don't hesitate to reach out to me directly with any questions.</p>
      <p style="font-weight:700;color:#1A1A1A;font-size:.95rem;margin-bottom:1.5rem">We look forward to serving you,</p>
      <div>
        <p style="font-weight:800;color:#1A1A1A;font-size:1rem">Josh McKisic</p>
        <p style="color:#888;font-size:.85rem">Owner, Happy Roof</p>
        <p style="color:#888;font-size:.85rem;margin-top:.25rem">(813) 595-7663 &nbsp;|&nbsp; happyroof.com</p>
      </div>
    </div>
  </div>
</section>

<!-- ══════ ABOUT / STATS ══════ -->
<section style="background:#FFFFFF;padding:4rem 0;border-bottom:1px solid #E0E0E0">
  <div class="max-w-4xl mx-auto px-5">
    <p class="binder-label">About Happy Roof</p>
    <p style="color:#555;font-size:.95rem;line-height:1.8;margin-bottom:1rem">Founded in July 2025, Happy Roof is Tampa Bay's trusted local roofing contractor, serving homeowners and businesses across Hillsborough, Pinellas, and Pasco counties. We provide residential roofing, commercial roofing, roof repairs, inspections, storm damage and insurance support, and new construction roofing.</p>
    <p style="color:#555;font-size:.95rem;line-height:1.8;margin-bottom:1rem">We are a certified Owens Corning Preferred Installer and proudly partner with leading manufacturers including Verea Clay and GulfCoast Supply. Every system we install is built to handle Florida's climate: the heat, the humidity, and the storms.</p>
    <p style="color:#555;font-size:.95rem;line-height:1.8;margin-bottom:2rem">Our philosophy is simple: give every homeowner an honest assessment, a fair price, and a crew they can count on. No upselling. No surprises. Just quality work backed by real warranties and a workmanship guarantee of up to 15 years.</p>

    <!-- Stats bar -->
    <div style="display:grid;grid-template-columns:repeat(4,1fr);background:#1A1A1A;border-radius:16px;overflow:hidden">
      <div class="binder-stat"><p class="binder-stat-num">30+</p><p class="binder-stat-label">Years Team Experience</p></div>
      <div class="binder-stat"><p class="binder-stat-num">5.0&#9733;</p><p class="binder-stat-label">Google Rating</p></div>
      <div class="binder-stat"><p class="binder-stat-num" style="font-size:1.6rem">Up to 15yr</p><p class="binder-stat-label">Workmanship Warranty</p></div>
      <div class="binder-stat"><p class="binder-stat-num">48hr</p><p class="binder-stat-label">Emergency Response</p></div>
    </div>

    <!-- Service areas -->
    <p style="color:#888;font-size:.78rem;line-height:1.7;margin-top:1.5rem;text-align:center">
      <strong style="color:#555">Serving:</strong> Tampa &middot; St. Petersburg &middot; Clearwater &middot; Brandon &middot; Wesley Chapel &middot; Riverview &middot; Lutz &middot; Land O Lakes &middot; Odessa &middot; Carrollwood &middot; New Tampa &middot; Temple Terrace &middot; South Tampa &middot; Sun City Center &middot; Apollo Beach &middot; Oldsmar &middot; Palm Harbor &middot; Tarpon Springs &middot; Safety Harbor &middot; Dunedin &middot; Largo &middot; Seminole &middot; New Port Richey &middot; Trinity &middot; and more.
    </p>
  </div>
</section>

<!-- ══════ MEET THE TEAM ══════ -->
<section style="background:#F7F7F7;padding:4rem 0;border-bottom:1px solid #E0E0E0">
  <div class="max-w-4xl mx-auto px-5 text-center">
    <p class="binder-label">Our Team</p>
    <h2 class="binder-h2">MEET THE PEOPLE<br/><span style="color:#E6A817">BEHIND YOUR ROOF.</span></h2>
    <div style="margin-bottom:2.5rem">
      <img src="/Brand%20Assets/Photos/team-photo.jpeg" alt="The Happy Roof team in front of the company truck" style="width:100%;max-width:600px;border-radius:16px;margin:0 auto;display:block;box-shadow:0 16px 48px -8px rgba(0,0,0,.15)" />
    </div>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:1.5rem">
      <div>
        <div style="width:72px;height:72px;border-radius:50%;background:#E6A817;display:flex;align-items:center;justify-content:center;margin:0 auto 1rem">
          <span style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.5rem;color:#1A1A1A">J</span>
        </div>
        <p style="font-weight:700;font-size:.95rem;color:#1A1A1A">Josh McKisic</p>
        <p style="color:#888;font-size:.78rem">Owner</p>
      </div>
      <div>
        <div style="width:72px;height:72px;border-radius:50%;background:#1A1A1A;display:flex;align-items:center;justify-content:center;margin:0 auto 1rem">
          <span style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.5rem;color:#E6A817">M</span>
        </div>
        <p style="font-weight:700;font-size:.95rem;color:#1A1A1A">Martin Montoya</p>
        <p style="color:#888;font-size:.78rem">Operations Manager</p>
      </div>
      <div>
        <div style="width:72px;height:72px;border-radius:50%;background:rgba(230,168,23,.15);display:flex;align-items:center;justify-content:center;margin:0 auto 1rem">
          <span style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.5rem;color:#E6A817">U</span>
        </div>
        <p style="font-weight:700;font-size:.95rem;color:#1A1A1A">Ulissa Montoya</p>
        <p style="color:#888;font-size:.78rem">Office Manager</p>
      </div>
    </div>
  </div>
</section>

<!-- ══════ SECTION 2: WHY HAPPY ROOF ══════ -->
<section id="why" class="binder-section" style="background:#FFFFFF">
  <div class="max-w-4xl mx-auto px-5">
    <p class="binder-label">Section 2</p>
    <h2 class="binder-h2">WHY HAPPY ROOF</h2>
    <p style="color:#555;font-size:.95rem;line-height:1.8;margin-bottom:2rem">We make roofing stress-free. Here's what that means in practice:</p>
    <div style="display:grid;gap:1.5rem">
      <div class="binder-value">
        <div class="binder-value-icon" style="background:rgba(230,168,23,.1)"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#E6A817" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg></div>
        <div><p style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.1rem;color:#1A1A1A;margin-bottom:.25rem">Honesty First</p><p style="color:#555;font-size:.9rem;line-height:1.7">We tell you what your roof actually needs, not what makes us the most money. If it only needs a repair, we say repair. No upselling, ever.</p></div>
      </div>
      <div class="binder-value">
        <div class="binder-value-icon" style="background:rgba(59,159,217,.1)"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#3B9FD9" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg></div>
        <div><p style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.1rem;color:#1A1A1A;margin-bottom:.25rem">We Show Up</p><p style="color:#555;font-size:.9rem;line-height:1.7">When we schedule a visit, we are there. If something changes, you hear from us, not a no-show. Reliability isn't extra, it's the baseline.</p></div>
      </div>
      <div class="binder-value">
        <div class="binder-value-icon" style="background:rgba(230,168,23,.1)"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#E6A817" stroke-width="2"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg></div>
        <div><p style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.1rem;color:#1A1A1A;margin-bottom:.25rem">Quality Materials</p><p style="color:#555;font-size:.9rem;line-height:1.7">We only install products we'd put on our own homes. Every material we use comes with a manufacturer warranty backed by the industry's top brands.</p></div>
      </div>
      <div class="binder-value">
        <div class="binder-value-icon" style="background:rgba(59,159,217,.1)"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#3B9FD9" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg></div>
        <div><p style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.1rem;color:#1A1A1A;margin-bottom:.25rem">Local Team, Local Knowledge</p><p style="color:#555;font-size:.9rem;line-height:1.7">Our crews live and work in Tampa Bay. We know the building codes, permit requirements, HOA rules, and what Florida weather actually does to a roof.</p></div>
      </div>
      <div class="binder-value">
        <div class="binder-value-icon" style="background:rgba(230,168,23,.1)"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#E6A817" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/><path d="m9 15 2 2 4-4"/></svg></div>
        <div><p style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.1rem;color:#1A1A1A;margin-bottom:.25rem">We Clean Up Completely</p><p style="color:#555;font-size:.9rem;line-height:1.7">Every nail. Every scrap. We use magnet rollers and fully clear your yard before we leave. You shouldn't have to worry about what we leave behind.</p></div>
      </div>
      <div class="binder-value">
        <div class="binder-value-icon" style="background:rgba(59,159,217,.1)"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#3B9FD9" stroke-width="2"><path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg></div>
        <div><p style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.1rem;color:#1A1A1A;margin-bottom:.25rem">We Stand Behind Our Work</p><p style="color:#555;font-size:.9rem;line-height:1.7">Happy Roof backs its workmanship in writing with up to 15 years on shingle, metal, and tile installations, and up to 10 years on flat roofs. If something goes wrong due to our installation, we make it right.</p></div>
      </div>
    </div>
  </div>
</section>

<!-- ══════ SECTION 3: WARRANTY ══════ -->
<section id="warranty" class="binder-section" style="background:#F7F7F7">
  <div class="max-w-4xl mx-auto px-5">
    <p class="binder-label">Section 3</p>
    <h2 class="binder-h2">OUR WARRANTY</h2>
    <p style="color:#555;font-size:.95rem;line-height:1.8;margin-bottom:2rem">Most roofers in Tampa Bay offer 1&ndash;5 years of workmanship coverage. We offer up to 15. In writing, on every job.</p>

    <div class="binder-card" style="padding:0;overflow:hidden;margin-bottom:2rem">
      <table class="warranty-table">
        <thead><tr><th>Roof Type</th><th>Happy Roof</th><th>Industry Average</th></tr></thead>
        <tbody>
          <tr><td>Asphalt Shingles</td><td class="warranty-happy">Up to 15 Years</td><td class="warranty-avg">1&ndash;5 Years</td></tr>
          <tr><td>Metal Roofing</td><td class="warranty-happy">Up to 15 Years</td><td class="warranty-avg">1&ndash;5 Years</td></tr>
          <tr><td>Tile Roofing</td><td class="warranty-happy">Up to 15 Years</td><td class="warranty-avg">1&ndash;5 Years</td></tr>
          <tr><td>Flat Roof (TPO/EPDM)</td><td class="warranty-happy">Up to 10 Years</td><td class="warranty-avg">1&ndash;2 Years</td></tr>
        </tbody>
      </table>
    </div>
    <p style="color:#888;font-size:.82rem;font-style:italic;text-align:center;margin-bottom:2rem">All Happy Roof workmanship warranties are provided in writing at project completion.</p>

    <div style="display:grid;md:grid-cols-2;gap:1.5rem">
      <div class="binder-card">
        <h3 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.15rem;color:#1A1A1A;margin-bottom:1rem">What's Covered</h3>
        <ul style="color:#555;font-size:.88rem;line-height:1.8;list-style:none;padding:0">
          <li style="padding-left:1.25rem;position:relative"><span style="position:absolute;left:0;color:#E6A817">&#10003;</span> Leaks caused by installation defects or workmanship errors</li>
          <li style="padding-left:1.25rem;position:relative"><span style="position:absolute;left:0;color:#E6A817">&#10003;</span> Improperly installed flashing, underlayment, or drip edge</li>
          <li style="padding-left:1.25rem;position:relative"><span style="position:absolute;left:0;color:#E6A817">&#10003;</span> Nail pops or fastener failures from our installation</li>
          <li style="padding-left:1.25rem;position:relative"><span style="position:absolute;left:0;color:#E6A817">&#10003;</span> Vent boot, pipe collar, or penetration seal failures</li>
