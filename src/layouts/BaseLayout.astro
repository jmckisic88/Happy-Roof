---
import GiveBackBanner from '../components/GiveBackBanner.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import MobileCTA from '../components/MobileCTA.astro';
import ExitPopup from '../components/ExitPopup.astro';
import Analytics from '../components/Analytics.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonical: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  activePage?: string;
  schema?: string;
  extraHead?: string;
  hideExitPopup?: boolean;
  hideBanner?: boolean;
  hideNavLinks?: boolean;
}

const {
  title,
  description,
  canonical,
  ogTitle,
  ogDescription,
  ogImage = 'https://www.happyroof.com/Brand%20Assets/og-share-image.png',
  activePage = '',
  schema,
  hideExitPopup = false,
  hideBanner = false,
  hideNavLinks = false,
} = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <!-- Google Tag Manager -->
  <script is:inline>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
  new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
  j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
  'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
  })(window,document,'script','dataLayer','GTM-W9L6VHPB');</script>
  <!-- End Google Tag Manager -->

  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;600;700;800;900&family=Nunito:wght@400;500;600;700&display=swap" rel="stylesheet" />

  <!-- SEO -->
  <meta name="description" content={description} />
  <meta name="robots" content="index, follow" />
  <link rel="canonical" href={canonical} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonical} />
  <meta property="og:title" content={ogTitle || title} />
  <meta property="og:description" content={ogDescription || description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:site_name" content="Happy Roof Tampa Bay" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:image" content={ogImage} />
  <meta name="twitter:title" content={ogTitle || title} />
  <meta name="twitter:description" content={ogDescription || description} />

  {schema && <script type="application/ld+json" set:html={schema} />}

  <slot name="head" />

  <link rel="alternate" hreflang="en" href={canonical} />
  <meta name="geo.region" content="US-FL" />
  <meta name="geo.placename" content="Tampa Bay, Florida" />
</head>
<body>
  <!-- Google Tag Manager (noscript) -->
  <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-W9L6VHPB" height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>

  {!hideBanner && <GiveBackBanner />}
  <Nav activePage={activePage} hideBanner={hideBanner} hideNavLinks={hideNavLinks} />

  <slot />

  <Footer />
  {!hideNavLinks && <MobileCTA />}

  {!hideNavLinks && <script is:inline src="/chat.js"></script>}

  <!-- Promo code validation -->
  <script is:inline>
  (function(){
    var promoCodes = null;
    var inputs = document.querySelectorAll('.promo-input');
    if (!inputs.length) return;

    fetch('/promo-codes.json').then(function(r){ return r.json(); }).then(function(data){
      promoCodes = data;
      // Auto-fill promo code from URL param (e.g. ?promo=HERO26)
      var urlPromo = new URLSearchParams(window.location.search).get('promo');
      if (urlPromo) {
        inputs.forEach(function(input){
          input.value = urlPromo.toUpperCase();
          input.dispatchEvent(new Event('input'));
        });
      }
    });

    inputs.forEach(function(input){
      var wrap = input.closest('.mb-4, .fgroup');
      var status = wrap.querySelector('.promo-status');
      var msg = wrap.querySelector('.promo-msg');
      var debounce;

      input.addEventListener('input', function(){
        clearTimeout(debounce);
        var code = input.value.trim().toUpperCase();

        if (!code) {
          status.style.display = 'none';
          msg.style.display = 'none';
          input.style.borderColor = '';
          return;
        }

        debounce = setTimeout(function(){
          if (!promoCodes) return;
          var promo = promoCodes[code];
          if (promo && promo.active) {
            status.textContent = '\u2713';
            status.style.color = '#16a34a';
            status.style.display = 'block';
            msg.textContent = promo.description;
            msg.style.color = '#16a34a';
            msg.style.display = 'block';
            input.style.borderColor = '#16a34a';
          } else {
            status.textContent = '\u2717';
            status.style.color = '#dc2626';
            status.style.display = 'block';
            msg.textContent = 'Invalid promo code';
            msg.style.color = '#dc2626';
            msg.style.display = 'block';
            input.style.borderColor = '#dc2626';
          }
        }, 300);
      });
    });
  })();
  </script>

  <!-- Reliable anchor scroll accounting for fixed header -->
  <script is:inline>
  (function(){
    if (!window.location.hash) return;
    function scrollToHash() {
      var el = document.querySelector(window.location.hash);
      if (!el) return;
      var top = el.getBoundingClientRect().top + window.scrollY - 90;
      window.scrollTo({ top: top, behavior: 'smooth' });
    }
    if (document.readyState === 'complete') { setTimeout(scrollToHash, 100); }
    else { window.addEventListener('load', function(){ setTimeout(scrollToHash, 100); }); }
  })();
  </script>

  {!hideExitPopup && <ExitPopup />}
  <Analytics />
</body>
</html>
